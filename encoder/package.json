{
  "name": "@jeswr/kernel-encoder",
  "version": "0.1.0",
  "description": "Kernel of Truth encoder v0: deterministic, training-free explication->vector encoder (construction B: exact Hadamard TPR within clauses, unitary HRR across clauses), decoder, and synthetic explication generator.",
  "license": "MIT",
  "private": false,
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test dist/test/*.test.js",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jeswr/kernel-of-truth.git",
    "directory": "encoder"
  },
  "keywords": [
    "vsa",
    "hrr",
    "tensor-product-representation",
    "hyperdimensional-computing",
    "nsm",
    "semantic-primes",
    "deterministic"
  ],
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  }
}
