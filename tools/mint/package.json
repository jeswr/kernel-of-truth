{
  "name": "@jeswr/kot-mint",
  "version": "0.1.0",
  "description": "Kernel of Truth minting pass: UTF-8 NFC + RFC 8785 JCS canonical identity payloads -> sha2-256 multihash urn:kot: URNs per docs/design-hash-input.md",
  "license": "MIT",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test dist/test/*.test.js",
    "mint": "npm run build && node dist/src/cli.js --data ../../data --out ../../dist/canonical"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^5.5.0"
  }
}
