.beads/.~*
# roborev snapshots
/.roborev/

# Node
node_modules/
dist/
dist-corpus/
*.tsbuildinfo
# Phase-X checkpoints (reports are committed; checkpoints are not)
poc/results/*-checkpoint.json
poc/results/*.log
# Python
__pycache__/
# P2 RT-14: unhashed account<->pseudonym sidecar — maintainer-held, never committed
registry/identity-map.json
