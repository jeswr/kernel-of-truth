# re-fetch with data/physics-qudt/tools/fetch-source.mjs)
data/physics-qudt/source/
# Pillar C lit-KB: fetched PDFs/HTML/models — hashes ARE committed in kb/manifest.json (N-C §4.4)
kb/cache/
# CLUTRR cache: generator clone + CC-BY-NC release data are gitignored; the
# sha256-pinned re-fetch record (manifest.json + fetch.sh) IS committed.
data/clutrr-cache/clutrr/
data/clutrr-cache/clutrr-emnlp-release.zip
data/clutrr-cache/release/
scratchpad/
