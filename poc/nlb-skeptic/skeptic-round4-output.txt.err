import json
for p in ['registry/experiments/l3a-parse.json','registry/experiments/a5-nl.json']:
 r=json.load(open(p));
 def walk(x,path=''):
  if isinstance(x,dict):
   for k,v in x.items(): walk(v,path+'/'+k)
  elif isinstance(x,list):
   for i,v in enumerate(x): walk(v,path+f'/{i}')
  elif x in ('ASM-0625','ASM-0626'): print(p,path,x)
 walk(r)
