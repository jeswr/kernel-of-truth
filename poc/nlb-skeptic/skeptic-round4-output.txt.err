   361	def _pins_ok(body):
   362	    """G7: observed harness pins on one arm body equal the frozen manifest
   363	    (fail-closed on a missing pins block or any missing/drifted key)."""
   364	    po = body.get("pins_observed")
   365	    if not isinstance(po, dict) or po.get("_recipe") != CORPUS_RECIPE:
   366	        return False
   367	    for key, want in EXPECTED_HARNESS_PINS.items():
   368	        v = po.get(key)
   369	        if not isinstance(v, dict) or v.get("observed") != want:
   370	            return False
   371	    return True
