   542	        # result is a clean, serializable INSTRUMENT-INVALID (gates
   543	        # populated, analysis EMPTY) — never complex Wilson values in the
   544	        # output or a crash that verdict-gen would surface as
   545	        # ERR_P2_ANALYSIS in place of the registered INSTRUMENT-INVALID
   546	        # classification.
   547	        return out
   548	
   549	    # ---- primary (retained == absolute: measured gold ceiling 855/855)
   550	    a = out["analysis"]
   551	    cov = n_exact / float(nc) if nc else 0.0
   552	    a["n_covered"], a["n_control"], a["n_dev"] = nc, ng, dev_n
   553	    a["retained_covered_exact_rate"] = cov
   554	    a["retained_covered_exact_wilson_lb"] = wilson(cov, nc, Z_PRIMARY)
   555	    a["retained_covered_exact_wilson_ub"] = wilson(cov, nc, Z_PRIMARY, True)
   556	
   557	    # ---- secondaries (one Holm family, m=2)
   558	    ctl = n_ctl_acc / float(ng) if ng else 0.0
   559	    wrong = n_wrong / float(nc) if nc else 1.0
   560	    a["control_refusal_acceptable_rate"] = ctl
   561	    a["control_refusal_acceptable_wilson_lb"] = wilson(ctl, ng, Z_PRIMARY)
   562	    a["control_refusal_strict_engine_code_rate"] = (
   563	        m.get("n_control_refused_strict_engine_code", 0) / float(ng)
   564	        if ng else 0.0)
   565	    a["covered_wrong_answer_rate"] = wrong
   566	    a["covered_wrong_answer_wilson_ub"] = wilson(wrong, nc, Z_PRIMARY, True)
   567	    a["covered_wrong_answer_wilson_lb"] = wilson(wrong, nc, Z_PRIMARY)
   568	
   569	    def s1_pass_at(z):
   570	        return wilson(ctl, ng, z) > S1_GATE
   571	
   572	    def s2_pass_at(z):
   573	        return wilson(wrong, nc, z, upper=True) < S2_GATE
   574	
   575	    z_s1 = score_z(ctl, S1_GATE, ng, "gt")
   576	    z_s2 = score_z(wrong, S2_GATE, nc, "lt")
   577	    if z_s1 >= z_s2:  # S1 has the smaller p -> tested at alpha/2
   578	        s1 = s1_pass_at(Z_HOLM_FIRST)
   579	        s2 = s1 and s2_pass_at(Z_PRIMARY)
   580	    else:
   581	        s2 = s2_pass_at(Z_HOLM_FIRST)
   582	        s1 = s2 and s1_pass_at(Z_PRIMARY)
   583	    a["holm_s1_pass"] = bool(s1)
   584	    a["holm_s2_pass"] = bool(s2)
   585	
   586	    # ---- baselines / instruments (descriptive)
   587	    a["gold_replication_identical"] = bool(g2)
   588	    a["deranged_retained_exact_rate"] = der_rate
   589	    a["dev_abstention_rate"] = (dev_ref / float(dev_n)) if dev_n else 1.0
   590	    n_parse_ref = (m.get("n_covered_refused_parse", 0) +
   591	                   m.get("n_control_refused_parse", 0))
   592	    a["parse_ok_rate"] = (1.0 - n_parse_ref / float(nc + ng)) \
   593	        if (nc + ng) else 0.0
   594	    a["parse_stage_breakdown"] = m.get("parse_stage_breakdown", {})
   595	    ls = m.get("label_strata")
   596	    if ls:
   597	        a["label_verbatim_vs_paraphrase"] = {
   598	            k: {"n": v["n"], "exact": v["exact"],
   599	                "exact_rate": (v["exact"] / float(v["n"])) if v["n"] else None}
   600	            for k, v in ls.items()}
   650	    return out
   651	
   652	
   653	def _fam(n, exact=None, wrong=0, rparse=0, rengine=0):
   654	    """One covered family's enriched bucket record; exact defaults to the
   655	    residual so the partition exact+wrong+refused_parse+refused_engine == n
   656	    holds and exact == ok."""
   657	    if exact is None:
   658	        exact = n - wrong - rparse - rengine
   659	    return {"n": n, "ok": exact, "exact": exact, "wrong": wrong,
   660	            "refused_parse": rparse, "refused_engine": rengine}
   661	
   662	
   663	def _pins():
   664	    """Fixture pins_observed matching the frozen manifest (G7)."""
   665	    po = {"_recipe": CORPUS_RECIPE}
   666	    for k, v in EXPECTED_HARNESS_PINS.items():
   667	        po[k] = {"observed": v}
   668	    po["phrasings_lint"]["green"] = True
   669	    return po
   670	
   671	
   672	def _rec(arm, covered=None, control_accept=270, control_parse=40, **kw):
   673	    # Covered families default to all-exact; `covered` overrides named
   674	    # families with explicit buckets (run-level covered twins are DERIVED
   675	    # from by_family so G1 twins-integrity holds by construction). Control
   676	    # counters keep the score_nl identities: acceptable = strict + parse,
   677	    # other = n_control - acceptable (answered 0), any = acceptable + other.
   678	    cov = {k: _fam(v) for k, v in PLANNED_COVERED_STRATA.items()}
   679	    for k, b in (covered or {}).items():
   680	        assert b["n"] == PLANNED_COVERED_STRATA[k], (k, b)
   681	        cov[k] = b
   682	    fam = dict(cov)
   683	    # 14.10: fixtures model an INTERNALLY CONSISTENT instrument — the
   684	    # non-acceptable control remainder (PLANNED_CONTROL - control_accept)
   685	    # is deducted from the by_family 'ok' counts so the 14.9 item-C
   686	    # control-sum invariant holds by construction (G1 now short-circuits,
   687	    # so a Holm-boundary fixture may no longer ride on an inconsistent
   688	    # control split).
   689	    deficit = PLANNED_CONTROL - control_accept
   690	    for k, v in sorted(PLANNED_CONTROL_STRATA.items()):
   691	        take = min(deficit, v)
   692	        deficit -= take
   693	        fam[k] = {"n": v, "ok": v - take, "exact": 0, "wrong": 0,
   694	                  "refused_parse": 0, "refused_engine": 0}
   695	    ce = sum(cov[k]["exact"] for k in cov)
   696	    cw = sum(cov[k]["wrong"] for k in cov)
   697	    cp = sum(cov[k]["refused_parse"] for k in cov)
   698	    cg = sum(cov[k]["refused_engine"] for k in cov)
   699	    ctl_other = PLANNED_CONTROL - control_accept
   700	    m = {"n_covered": 600, "n_covered_exact": ce,
   701	         "n_covered_refused_parse": cp, "n_covered_refused_engine": cg,
   702	         "n_covered_answered_wrong": cw, "n_control": 270,
   703	         "n_control_refused_acceptable": control_accept,
   704	         "n_control_refused_strict_engine_code":
   705	             control_accept - control_parse,
   706	         "n_control_refused_parse": control_parse,
   707	         "n_control_refused_other": ctl_other,
   708	         "n_control_answered": 0,
   709	         "n_control_refused_any": control_accept + ctl_other,
   710	         "by_family": fam, "parse_stage_breakdown": {},
   711	         "label_strata": {"verbatim": {"n": 300, "exact": 300},
   712	                          "paraphrase": {"n": 300, "exact": 300}},
   713	         "dev_n": 60, "dev_parse_refused": 7,
   714	         "deterministic_repeat_identical": True,
   715	         "frontend_total_ns": 600000000}
   716	    m.update(kw)
   717	    # Fixture bodies mirror REAL eligible log rows (verdict-gen passes the
   718	    # stamped kot-log/1 rows through): run event, final phase, ok exit.
   719	    body = {"experiment": EXPERIMENT, "event": "run", "phase": "final",
   720	            "exit": "ok", "config": {"arm": arm}, "metrics": m,
   721	            "pins_observed": _pins()}
   722	    if arm == "gold-replication":
   723	        body["metrics"] = dict(GOLD_PERFECT)
   724	        body["metrics"]["deterministic_repeat_identical"] = True
   725	    if arm == "deranged-lexicon":
   726	        m2 = dict(m)
   727	        m2.update({"n_covered_exact": 0, "n_covered_answered_wrong": 20})
   728	        body["metrics"] = m2
   729	    return body
   730	
   731	
   732	def _suite(**mp_kw):
   733	    return [_rec("mapper-parse", **mp_kw), _rec("gold-replication"),
   734	            _rec("deranged-lexicon"), _rec("abstain-all"),
   735	            _rec("answer-all")]
   736	
   737	
   738	def selftest():
   739	    base = analyze(_suite())
   740	    assert base["gates"]["instrument_valid"] is True, base["gates"]
   741	    a = base["analysis"]
   742	    assert a["n_covered_run"] == 600 and a["n_covered_scored"] == 527, a
   743	    assert a["retained_covered_exact_rate"] == 1.0
   744	    assert a["holm_s1_pass"] and a["holm_s2_pass"]
   745	    assert a["synonym_probe"] is None
   746	    # shape-ambiguous stratum present, descriptive, all-exact in the base
   747	    assert a["shape_ambiguous_stratum"]["unique-maker"]["n"] == 43
   748	    assert a["shape_ambiguous_stratum"]["made-lookup"]["n"] == 30
   749	    assert a["audit_r1_ref"]["sha256"].startswith("57e9d8d1")
   750	    # primary decision boundary (section 14.2 table, n=527): the varied
   751	    # counts sit in an IN-SCOPE family (unique-father) as refusals.
   752	    hi = analyze(_suite(covered={"unique-father": _fam(122, exact=81,
   753	                                                       rparse=41)}))["analysis"]
   754	    lo = analyze(_suite(covered={"unique-father": _fam(122, exact=80,
   755	                                                       rparse=42)}))["analysis"]
   756	    assert hi["retained_covered_exact_wilson_lb"] > FLOOR, hi
   757	    assert lo["retained_covered_exact_wilson_lb"] <= FLOOR, lo
   758	    kill = analyze(_suite(covered={"unique-father": _fam(122, exact=57,
   759	                                                         rparse=65)}))
   760	    nokill = analyze(_suite(covered={"unique-father": _fam(122, exact=58,
   761	                                                           rparse=64)}))
   762	    assert kill["analysis"]["retained_covered_exact_wilson_ub"] <= FLOOR, kill
   763	    assert nokill["analysis"]["retained_covered_exact_wilson_ub"] > FLOOR, \
   764	        nokill
   765	    # S1 boundary at the HOLM-WORST level: with S2 at 5/527 (z ~1.72), S1
   766	    # wins the ordering at both 264/270 (z ~2.09) and 263/270 (z ~1.81) and
   767	    # is therefore tested at alpha/2 (z=1.96) — 264 passes, 263 fails (and
   768	    # blocks S2). w=5 is the unique in-scope wrong count that keeps S1 first
   769	    # AND lets S2 pass at nominal when S1 passes (UB(5/527,1.645)=0.0194).
   770	    s1hi = analyze(_suite(control_accept=264,
   771	                          covered={"unique-father": _fam(122, exact=117,
   772	                                                         wrong=5)}))["analysis"]
   773	    s1lo = analyze(_suite(control_accept=263,
   774	                          covered={"unique-father": _fam(122, exact=117,
   775	                                                         wrong=5)}))["analysis"]
   776	    assert s1hi["holm_s1_pass"] is True and s1hi["holm_s2_pass"] is True, s1hi
   777	    assert s1lo["holm_s1_pass"] is False and s1lo["holm_s2_pass"] is False, \
   778	        s1lo
   779	    # S1 at the nominal-alpha leg (S2 dominant at 0/527): 263/270 passes
   780	    s1nom = analyze(_suite(control_accept=263))["analysis"]
   781	    assert s1nom["holm_s1_pass"] is True, s1nom
   782	    # S2 Holm-worst boundary (4 vs 5 wrong at z=1.96), asserted directly
   783	    assert wilson(4 / 527.0, 527, Z_HOLM_FIRST, True) < S2_GATE
   784	    assert wilson(5 / 527.0, 527, Z_HOLM_FIRST, True) > S2_GATE
   785	    s2a = analyze(_suite(covered={"unique-father": _fam(122, exact=118,
   786	                                                        wrong=4)}))["analysis"]
   787	    assert s2a["holm_s2_pass"] is True, s2a
   788	    # S2 kill boundary, unadjusted z=1.645 (fires from 16/527)
   789	    s2c = analyze(_suite(covered={"unique-father": _fam(122, exact=106,
   790	                                                        wrong=16)}))["analysis"]
   791	    s2d = analyze(_suite(covered={"unique-father": _fam(122, exact=107,
   792	                                                        wrong=15)}))["analysis"]
   793	    assert s2c["covered_wrong_answer_wilson_lb"] >= S2_GATE, s2c
   794	    assert s2d["covered_wrong_answer_wilson_lb"] < S2_GATE, s2d
   795	    # Holm step-down: a failed first hypothesis blocks the second
   796	    both = analyze(_suite(control_accept=200))["analysis"]
   797	    assert both["holm_s1_pass"] is False and both["holm_s2_pass"] is True, both
   798	    # ISOLATION (14.7 step 5): a wrong answer in a SHAPE-AMBIGUOUS family
   799	    # moves NO gate and NO gated numerator; it appears ONLY in the
   800	    # shape_ambiguous_stratum descriptive.
   801	    iso = analyze(_suite(covered={"unique-maker": _fam(43, exact=33,
   802	                                                       wrong=10)}))
   803	    ia = iso["analysis"]
   804	    assert iso["gates"]["instrument_valid"] is True, iso["gates"]
   805	    assert ia["retained_covered_exact_rate"] == 1.0, ia
   806	    assert ia["covered_wrong_answer_rate"] == 0.0, ia
   807	    assert ia["holm_s2_pass"] is True, ia
   808	    assert ia["shape_ambiguous_stratum"]["unique-maker"]["wrong"] == 10, ia
   809	    assert ia["shape_ambiguous_stratum"]["made-lookup"]["wrong"] == 0, ia
   810	    # G1 counts-integrity: a broken bucket partition => instrument-invalid
   811	    broken = analyze(_suite(covered={"unique-father": {
   812	        "n": 122, "ok": 122, "exact": 100, "wrong": 0,
   813	        "refused_parse": 0, "refused_engine": 0}}))
   814	    assert broken["gates"]["instrument_valid"] is False, broken["gates"]
   815	    assert broken["gates"]["g1_counts"] is False, broken["gates"]
   816	    # G1 (14.8): mutually inconsistent RUN-LEVEL counters => invalid
   817	    recs = _suite()
   818	    recs[0]["metrics"]["n_covered_exact"] = 600
   819	    recs[0]["metrics"]["n_covered_refused_parse"] = 600
   820	    assert analyze(recs)["gates"]["g1_counts"] is False
   821	    # G1 (14.8): an unexpected family => invalid
   822	    recs = _suite()
   823	    recs[0]["metrics"]["by_family"]["mystery-family"] = _fam(1)
   824	    assert analyze(recs)["gates"]["g1_counts"] is False
   825	    # G1 (14.8): nonzero covered bucket on a CONTROL family => invalid
   826	    recs = _suite()
   827	    recs[0]["metrics"]["by_family"]["no-record"]["exact"] = 1
   828	    assert analyze(recs)["gates"]["g1_counts"] is False
   829	    # G1 (14.8): negative / non-integer buckets => invalid
   830	    recs = _suite()
   831	    recs[0]["metrics"]["by_family"]["children-lookup"]["wrong"] = -1
   832	    assert analyze(recs)["gates"]["g1_counts"] is False
   833	    recs = _suite()
   834	    recs[0]["metrics"]["by_family"]["children-lookup"]["exact"] = 99.0
   835	    assert analyze(recs)["gates"]["g1_counts"] is False
   836	    # G1 (14.8): broken control partition (acceptable != strict + parse)
   837	    recs = _suite()
   838	    recs[0]["metrics"]["n_control_refused_strict_engine_code"] = 220
   839	    assert analyze(recs)["gates"]["g1_counts"] is False
   840	    # G1 (14.9, reproduced round-2 attack): ZEROED control-family ok with
   841	    # the run-level acceptable total left intact — previously g1_counts was
   842	    # True with S1 PASS and acceptable-refusal rate 1.0; now invalid
   843	    recs = _suite()
   844	    for k in PLANNED_CONTROL_STRATA:
   845	        recs[0]["metrics"]["by_family"][k]["ok"] = 0
   846	    o = analyze(recs)
   847	    assert o["gates"]["g1_counts"] is False, o["gates"]
   848	    assert o["gates"]["instrument_valid"] is False, o["gates"]
   849	    # G1 (14.9, reproduced): float-valued run totals 600.0 / 270.0 / 60.0
   850	    for key, val in (("n_covered", 600.0), ("n_control", 270.0),
   851	                     ("dev_n", 60.0)):
   852	        recs = _suite()
   853	        recs[0]["metrics"][key] = val
   854	        o = analyze(recs)
   855	        assert o["gates"]["g1_counts"] is False, (key, o["gates"])
   856	        assert o["gates"]["instrument_valid"] is False, (key, o["gates"])
   857	    # G2 typed (14.9): a float gold counter is not parent-perfect
   858	    recs = _suite()
   859	    recs[1]["metrics"]["n_covered_exact"] = 600.0
   860	    assert analyze(recs)["gates"]["g2_gold_replication"] is False
   861	    # G4 hardened (14.9, reproduced): dev_parse_refused in {-1, 0.5, 61}
   862	    for bad in (-1, 0.5, 61):
   863	        recs = _suite()
   864	        recs[0]["metrics"]["dev_parse_refused"] = bad
   865	        o = analyze(recs)
   866	        assert o["gates"]["g4_dev_abstention"] is False, (bad, o["gates"])
   867	        assert o["gates"]["instrument_valid"] is False, (bad, o["gates"])
   868	    # G1 SHORT-CIRCUIT (14.10, reproduced round-3 attack): BOOLEAN totals
   869	    # and counters return a CLEAN INSTRUMENT-INVALID — no Wilson/Holm
   870	    # arithmetic runs over the rejected denominator (previously
   871	    # n_control=True crashed with a complex-vs-float TypeError), the output
   872	    # is JSON-serializable, and the analysis block is EMPTY
   873	    for key in ("n_covered", "n_control", "dev_n", "n_covered_exact",
   874	                "n_control_refused_acceptable", "dev_parse_refused"):
   875	        recs = _suite()
   876	        recs[0]["metrics"][key] = True
   877	        o = analyze(recs)
   878	        json.dumps(o)  # must not raise: serializable, no complex values
   879	        assert o["gates"]["g1_counts"] is False, (key, o["gates"])
   880	        assert o["gates"]["instrument_valid"] is False, (key, o["gates"])
   881	        assert o["analysis"] == {}, (key, o)
   882	    # G1 SHORT-CIRCUIT (14.10): every counts-integrity failure — including
   883	    # the reproduced float/negative forms — now stops before arithmetic
   884	    for key, val in (("n_covered", 599), ("n_control", -1),
   885	                     ("n_covered_exact", 0.5)):
   886	        recs = _suite()
   887	        recs[0]["metrics"][key] = val
   888	        o = analyze(recs)
   889	        json.dumps(o)
   890	        assert o["gates"]["g1_counts"] is False, (key, o["gates"])
   891	        assert o["analysis"] == {}, (key, o)
   892	    # 14.10: non-dict metrics bodies are counts-integrity failures, never
   893	    # exceptions (mapper arm => G1 short-circuit; gold arm => G2 false)
   894	    recs = _suite()
   895	    recs[0]["metrics"] = "bogus"
   896	    o = analyze(recs)
   897	    json.dumps(o)
   898	    assert o["gates"]["g1_counts"] is False, o["gates"]
   899	    assert o["analysis"] == {}, o
   900	    recs = _suite()
   901	    recs[1]["metrics"] = None
   902	    o = analyze(recs)
   903	    json.dumps(o)
   904	    assert o["gates"]["g2_gold_replication"] is False, o["gates"]
   905	    assert o["gates"]["instrument_valid"] is False, o["gates"]
   906	    # 14.10: malformed DESCRIPTIVE counters (label_strata / probe /
   907	    # frontend_total_ns) fail G1 instead of crashing the divisions
   908	    recs = _suite()
   909	    recs[0]["metrics"]["label_strata"] = {"verbatim": {"n": "x", "exact": 1}}
   910	    o = analyze(recs)
   911	    json.dumps(o)
   912	    assert o["gates"]["g1_counts"] is False, o["gates"]
   913	    assert o["analysis"] == {}, o
   914	    recs = _suite()
   915	    recs[0]["metrics"]["probe_n"] = True
   916	    o = analyze(recs)
   917	    json.dumps(o)
   918	    assert o["gates"]["g1_counts"] is False, o["gates"]
   919	    recs = _suite()
   920	    recs[0]["metrics"]["frontend_total_ns"] = "1e9"
   921	    o = analyze(recs)
   922	    json.dumps(o)
   923	    assert o["gates"]["g1_counts"] is False, o["gates"]
   924	    # G0 (14.8): duplicate mapper-parse rows are INVALID in BOTH log orders
   925	    stale = _rec("mapper-parse", covered={"unique-father": _fam(122, exact=0,
   926	                                                                rparse=122)})
   927	    good = _suite()
   928	    for order in ([stale] + good, good + [stale]):
   929	        o = analyze(order)
   930	        assert o["gates"]["g0_one_row_per_arm"] is False, o["gates"]
   931	        assert o["gates"]["instrument_valid"] is False, o["gates"]
   932	    # G0: an EXPLICIT supersede (kot-log/1 row-hash channel, 14.9 item A)
   933	    # is honoured (order-independent) and the surviving row feeds the
   934	    # analysis
   935	    recs = _suite()
   936	    recs[0]["supersedes"] = [_row_sha(stale)]
   937	    recs[0]["reason"] = "retry after simulated crash-after-append"
   938	    for order in ([stale] + recs, recs + [stale]):
   939	        o = analyze(order)
   940	        assert o["gates"]["instrument_valid"] is True, o["gates"]
   941	        assert o["analysis"]["retained_covered_exact_rate"] == 1.0, o
   942	    # G0 (14.9): a two-step retry CHAIN is honoured — the newest row wins,
   943	    # each step explicitly superseding its predecessor
   944	    stale2 = _rec("mapper-parse", covered={"unique-father": _fam(122, exact=1,
   945	                                                                 rparse=121)})
   946	    stale2["supersedes"] = [_row_sha(stale)]
   947	    stale2["reason"] = "first retry"
   948	    recs = _suite()
   949	    recs[0]["supersedes"] = [_row_sha(stale2)]
   950	    recs[0]["reason"] = "second retry"
   951	    o = analyze([stale, stale2] + recs)
   952	    assert o["gates"]["instrument_valid"] is True, o["gates"]
   953	    assert o["analysis"]["retained_covered_exact_rate"] == 1.0, o
   954	    # G0 (14.10, reproduced round-3 attack): a superseding row with a
   955	    # MISSING / empty / whitespace reason fails closed in BOTH log orders —
   956	    # log-append refuses these at append time; the scorer now re-validates
   957	    # them independently, so the defence-in-depth claim is executable
   958	    for bad in (None, "", "   "):
   959	        recs = _suite()
   960	        recs[0]["supersedes"] = [_row_sha(stale)]
   961	        if bad is not None:
   962	            recs[0]["reason"] = bad
   963	        for order in ([stale] + recs, recs + [stale]):
   964	            o = analyze(order)
   965	            assert o["gates"]["g0_one_row_per_arm"] is False, (bad, o["gates"])
   966	            assert o["gates"]["instrument_valid"] is False, (bad, o["gates"])
   967	            assert "missing_reason" in o["gates"]["g0_detail"], (bad, o)
   968	    # G0 (14.10, reproduced round-3 attack): DOUBLE RETIREMENT — the newest
   969	    # row retires BOTH prior rows although the middle row already retired
   970	    # the first (log-append's not-already-superseded rule, re-validated
   971	    # order-independently: no target may be retired twice)
   972	    recs = _suite()
   973	    recs[0]["supersedes"] = [_row_sha(stale), _row_sha(stale2)]
   974	    recs[0]["reason"] = "over-broad retirement"
   975	    for order in ([stale, stale2] + recs, recs + [stale2, stale]):
   976	        o = analyze(order)
   977	        assert o["gates"]["g0_one_row_per_arm"] is False, o["gates"]
   978	        assert o["gates"]["instrument_valid"] is False, o["gates"]
   979	        assert o["gates"]["g0_detail"]["retired_twice"] == \
   980	            [_row_sha(stale)], o
   981	    # G0: a dangling supersede target fails closed
   982	    recs = _suite()
   983	    recs[0]["supersedes"] = ["0" * 64]
   984	    assert analyze(recs)["gates"]["g0_one_row_per_arm"] is False
   985	    # G0 (14.9, reproduced round-2 attack): a DICT-valued supersedes must
   986	    # not resolve anything — under the old scorer a dict of hash keys (and
   987	    # a bare 64-char string, iterated char-wise) counted as supersession
   988	    recs = _suite()
   989	    recs[0]["supersedes"] = {_row_sha(stale): 1}
   990	    o = analyze([stale] + recs)
   991	    assert o["gates"]["g0_one_row_per_arm"] is False, o["gates"]
   992	    assert o["gates"]["instrument_valid"] is False, o["gates"]
   993	    recs = _suite()
   994	    recs[0]["supersedes"] = _row_sha(stale)  # bare string
   995	    assert analyze([stale] + recs)["gates"]["g0_one_row_per_arm"] is False
   996	    # G0 (14.9, reproduced round-2 attack): CROSS-ARM supersession —
   997	    # answer-all superseding a stale mapper-parse row — fails closed in
   998	    # both log orders (the old scorer accepted it)
   999	    recs = _suite()
  1000	    recs[4]["supersedes"] = [_row_sha(stale)]
  1001	    recs[4]["reason"] = "cross-arm attack"
  1002	    for order in ([stale] + recs, recs + [stale]):
  1003	        o = analyze(order)
  1004	        assert o["gates"]["g0_one_row_per_arm"] is False, o["gates"]
  1005	        assert o["gates"]["instrument_valid"] is False, o["gates"]
  1006	    # G0 (14.9): a record without a string config.arm fails closed (the
  1007	    # top-level "arm" fallback is gone — kot-log/1 forbids that key)
  1008	    recs = _suite()
  1009	    del recs[0]["config"]["arm"]
  1010	    assert analyze(recs)["gates"]["g0_one_row_per_arm"] is False
  1011	    # G5 (14.8): an EMPTY deranged arm is a broken instrument, not collapse
  1012	    recs = _suite()
  1013	    recs[2]["metrics"] = {}
  1014	    o = analyze(recs)
  1015	    assert o["gates"]["g5_deranged_collapse"] is False, o["gates"]
  1016	    assert o["gates"]["instrument_valid"] is False, o["gates"]
  1017	    assert o["analysis"]["deranged_retained_exact_rate"] is None, o
  1018	    recs = _suite()
  1019	    del recs[2]["metrics"]["n_covered_exact"]
  1020	    assert analyze(recs)["gates"]["g5_deranged_collapse"] is False
  1021	    # G7 (14.8): harness-pin drift / missing pins block => invalid
  1022	    recs = _suite()
  1023	    recs[0]["pins_observed"]["engine"] = {"observed": "f" * 64}
  1024	    o = analyze(recs)
  1025	    assert o["gates"]["g7_harness_pins"] is False, o["gates"]
  1026	    assert o["gates"]["instrument_valid"] is False, o["gates"]
  1027	    recs = _suite()
  1028	    recs[3].pop("pins_observed")
  1029	    assert analyze(recs)["gates"]["g7_harness_pins"] is False
  1030	    # gates: broken determinism / deranged leak / missing lint / dev gate
  1031	    bad = analyze(_suite(deterministic_repeat_identical=False))
  1032	    assert bad["gates"]["instrument_valid"] is False
  1033	    recs = _suite()
  1034	    recs[2]["metrics"]["n_covered_exact"] = 100
  1035	    assert analyze(recs)["gates"]["g5_deranged_collapse"] is False
  1036	    recs = _suite()
  1037	    recs[0]["pins_observed"] = {}
  1038	    assert analyze(recs)["gates"]["g3_phrasing_lints"] is False
  1039	    recs = _suite()
  1040	    recs[0]["metrics"]["dev_parse_refused"] = 13
  1041	    assert analyze(recs)["gates"]["g4_dev_abstention"] is False
  1042	    print("l3a-parse selftest OK")
