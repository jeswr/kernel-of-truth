   238	
   239	def wilson(p, n, z, upper=False):
   240	    if n <= 0:
   241	        return 1.0 if upper else 0.0
   242	    z2 = z * z
   243	    centre = p + z2 / (2 * n)
   244	    spread = z * ((p * (1 - p) / n + z2 / (4 * n * n)) ** 0.5)
   245	    return (centre + spread if upper else centre - spread) / (1 + z2 / n)
   246	
   247	
   248	def score_z(p_hat, p0, n, direction):
   249	    """One-sided score-test statistic used ONLY to order the two Holm
   250	    hypotheses (larger z == smaller p). direction 'gt': H1 p > p0;
   251	    'lt': H1 p < p0."""
   252	    se = (p0 * (1 - p0) / n) ** 0.5 if n > 0 else 1.0
   253	    z = (p_hat - p0) / se if se > 0 else 0.0
   254	    return z if direction == "gt" else -z
   255	
   256	
   257	def _count(v):
   258	    """A well-formed counter: non-negative int (bool excluded)."""
   259	    return isinstance(v, int) and not isinstance(v, bool) and v >= 0
   260	
   261	
   262	_SHA256_RE = re.compile(r"^[0-9a-f]{64}$")
   263	
   264	
   265	def _canonical(r):
   266	    """Byte-identical twin of tools/registry/kot_common.canonical_dumps —
   267	    the exact serialization the single log writer (log-append) emits.
   268	    Re-implemented here so the pinned sha stays the complete analysis
   269	    artifact (self-contained by design, no shared import)."""
   270	    return json.dumps(r, sort_keys=True, ensure_ascii=False,
   271	                      separators=(",", ":"), allow_nan=False)
   272	
   273	
   274	def _row_sha(r):
   275	    """kot-log/1 row identity for G0 (14.9 item A, ASM-0624): sha256 over
   276	    the row's exact log line bytes (canonical JSON + trailing newline) —
   277	    the SAME identity prev_sha256 and reuse.row_hashes use, so a runner
   278	    computes a supersede target directly from the results-log line."""
   279	    return hashlib.sha256((_canonical(r) + "\n").encode("utf-8")).hexdigest()
   280	
   281	
   282	def _one_row_per_arm(records):
   283	    """G0 (fail-closed; design doc 14.8 item 3 as re-based by 14.9 item A
   284	    and completed by 14.10 item A, ASM-0621/ASM-0624/ASM-0625):
   285	    duplicate/retry rows are never resolved by log order; the ONLY lawful
   286	    resolution is the kot-log/1 run-row `supersedes` channel, re-verified
   287	    here independently of log-append — INCLUDING the append-time rules that
   288	    are order-independently checkable at read time: a superseding row must
   289	    state a non-blank string `reason`, and no target may be retired twice
   290	    (the order-free form of not-already-superseded).
   291	    Returns (by_arm, ok, detail)."""
   292	    eligible = [r for r in records if r.get("experiment") == EXPERIMENT]
   293	    shas = [_row_sha(r) for r in eligible]
   294	    detail = {"duplicate_arms": [], "dangling_supersedes": [],
   295	              "malformed_supersedes": [], "cross_arm_supersedes": [],
   296	              "self_supersedes": [], "malformed_arm": [],
   297	              "duplicate_row_bytes": [], "arms_fully_superseded": [],
   298	              "missing_reason": [], "retired_twice": []}
   299	    if len(set(shas)) != len(shas):
   300	        detail["duplicate_row_bytes"] = sorted(
   301	            s for s in set(shas) if shas.count(s) > 1)
   302	    arms = []
   303	    for i, r in enumerate(eligible):
   304	        arm = (r.get("config") or {}).get("arm")
   305	        if not isinstance(arm, str) or not arm:
   306	            detail["malformed_arm"].append(i)
   307	            arm = None
   308	        arms.append(arm)
   309	    by_sha = {s: i for i, s in enumerate(shas)}
   310	    superseded = set()
   311	    for i, r in enumerate(eligible):
   312	        sup = r.get("supersedes")
   313	        if sup is None:
   314	            continue
   315	        if not (isinstance(sup, list) and sup and
   316	                all(isinstance(t, str) and _SHA256_RE.match(t) for t in sup)
   317	                and len(set(sup)) == len(sup)):
   318	            # dict/string/empty/duplicate/non-hex forms all die here — a
   319	            # malformed field never resolves anything.
   320	            detail["malformed_supersedes"].append(i)
   321	            continue
   322	        # 14.10 item A (ASM-0625): re-validate log-append's mandatory
   323	        # non-blank reason — an unreasoned retirement never resolves.
   324	        reason = r.get("reason")
   325	        if not isinstance(reason, str) or not reason.strip():
   326	            detail["missing_reason"].append(i)
   327	        for t in sup:
   328	            if t == shas[i]:
   329	                detail["self_supersedes"].append(t)
   330	            elif t not in by_sha:
   331	                detail["dangling_supersedes"].append(t)
   332	            elif arms[by_sha[t]] != arms[i]:
   333	                detail["cross_arm_supersedes"].append(t)
   334	            # 14.10 item A (ASM-0625): re-validate log-append's
   335	            # not-already-superseded rule in its order-free form — in a
   336	            # lawful chain every retired row is retired EXACTLY ONCE, by
   337	            # its direct successor; a target named by two superseding rows
   338	            # is a double retirement and never resolves.
   339	            if t in superseded:
   340	                detail["retired_twice"].append(t)
   341	            superseded.add(t)
   342	    detail["retired_twice"] = sorted(set(detail["retired_twice"]))
   343	    by_arm, dup = {}, []
   344	    for i, r in enumerate(eligible):
   345	        if shas[i] in superseded or arms[i] is None:
   346	            continue
   347	        if arms[i] in by_arm:
   348	            dup.append(arms[i])
   349	        by_arm[arms[i]] = r
   350	    # An arm with rows but zero survivors is a supersede cycle / dead chain
   351	    # (unconstructible through log-append, which forbids forward targets;
   352	    # checked anyway — fail closed on any input).
   353	    detail["arms_fully_superseded"] = sorted(
   354	        set(a for a in arms if a) - set(by_arm))
   355	    detail["duplicate_arms"] = sorted(set(dup))
   356	    detail["dangling_supersedes"] = sorted(set(detail["dangling_supersedes"]))
   357	    ok = not any(detail.values())
   358	    return by_arm, ok, {k: v for k, v in detail.items() if v}
   359	
