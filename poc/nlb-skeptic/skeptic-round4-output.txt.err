   435	        exact_in = sum(buck(k, "exact") for k in IN_SCOPE_FAMILIES)
   436	        wrong_in = sum(buck(k, "wrong") for k in IN_SCOPE_FAMILIES)
   437	        scored_ok = (n_scored == N_SCORED)
   438	        # (ii) per covered family the bucket partition holds and exact == ok
   439	        partition_ok = all(
   440	            sum(buck(k, b) for b in BUCKET_KEYS) == buck(k, "n") and
   441	            buck(k, "exact") == buck(k, "ok")
   442	            for k in PLANNED_COVERED_STRATA)
   443	        # (iii) covered-family bucket sums equal the run-level twins
   444	        twins_ok = (
   445	            sum(buck(k, "exact") for k in PLANNED_COVERED_STRATA) == n_exact
   446	            and sum(buck(k, "wrong") for k in PLANNED_COVERED_STRATA)
   447	            == n_wrong and
   448	            sum(buck(k, "refused_parse") for k in PLANNED_COVERED_STRATA)
   449	            == n_rparse and
   450	            sum(buck(k, "refused_engine") for k in PLANNED_COVERED_STRATA)
   451	            == n_rengine)
   452	        # (iv) control families hold zero covered buckets; ok <= n
   453	        control_zero_ok = all(
   454	            all(buck(k, b) == 0 for b in BUCKET_KEYS) and
   455	            buck(k, "ok") <= buck(k, "n")
   456	            for k in PLANNED_CONTROL_STRATA)
   457	        # (iv-b) 14.9 item C: the control-family acceptable ('ok') sums must
   458	        # equal the run-level acceptable total — a zeroed/dropped control-
   459	        # family classification can no longer coexist with an intact
   460	        # run-level n_control_refused_acceptable (reproduced round-2 attack)
   461	        control_sum_ok = (sum(buck(k, "ok") for k in PLANNED_CONTROL_STRATA)
   462	                          == n_ctl_acc)
   463	    else:
   464	        strata_ok = scored_ok = partition_ok = twins_ok = False
   465	        control_zero_ok = control_sum_ok = False
   466	        n_scored = exact_in = wrong_in = 0
   467	    # (v) run-level covered outcome partition over 600
   468	    run_counts = (n_exact, n_wrong, n_rparse, n_rengine)
   469	    run_partition_ok = (all(_count(x) for x in run_counts) and
   470	                        sum(run_counts) == nc)
   471	    # (vi) run-level control outcome partition over 270 (mapper arm: the
   472	    # acceptable set is strict-engine-code + ERR_PARSE — FK-NLB-6; the
   473	    # ABSTAIN branch exists only on the abstain-all arm, never here)
   474	    ctl_counts = (n_ctl_acc, n_ctl_ans, n_ctl_other, n_ctl_any,
   475	                  n_ctl_strict, n_ctl_parse)
   476	    ctl_partition_ok = (all(_count(x) for x in ctl_counts) and
   477	                        n_ctl_ans + n_ctl_acc + n_ctl_other == ng and
   478	                        n_ctl_any == n_ctl_acc + n_ctl_other and
   479	                        n_ctl_acc == n_ctl_strict + n_ctl_parse)
   480	    # (vii) 14.9 item C: run-level totals and dev counters must be strict
   481	    # non-negative INTEGERS (600.0/270.0/60.0 are not lawful counts — the
   482	    # == comparisons above would accept them) and dev_parse_refused must be
   483	    # a count within [0, dev_n]
   484	    totals_int_ok = (_count(nc) and _count(ng) and _count(dev_n) and
   485	                     _count(dev_ref) and dev_ref <= dev_n)
   486	    # (viii) 14.10 item B (ASM-0625): every REMAINING counter the analysis
   487	    # divides — the descriptive label_strata, synonym-probe and
   488	    # frontend_total_ns counters — must be well-formed whenever present, so
   489	    # once G1 is green NO malformed metric of any kind reaches arithmetic.
   490	    ls = m.get("label_strata")
   491	    ls_ok = ls is None or (isinstance(ls, dict) and all(
   492	        isinstance(v, dict) and _count(v.get("n")) and _count(v.get("exact"))
   493	        and v["exact"] <= v["n"] for v in ls.values()))
   494	    if m.get("probe_n"):
   495	        probe_ok = (_count(m.get("probe_n")) and
   496	                    _count(m.get("probe_parse_ok")) and
   497	                    _count(m.get("probe_exact")) and
   498	                    m["probe_parse_ok"] <= m["probe_n"] and
   499	                    m["probe_exact"] <= m["probe_n"])
   500	    else:
   501	        probe_ok = True
   502	    descr_ok = ls_ok and probe_ok and _count(m.get("frontend_total_ns", 0))
   503	    g1 = (all(a in by_arm for a in ARMS) and nc == PLANNED_COVERED and
   504	          ng == PLANNED_CONTROL and dev_n == PLANNED_DEV and fam_keys_ok and
   505	          buckets_wellformed and strata_ok and scored_ok and partition_ok and
   506	          twins_ok and control_zero_ok and control_sum_ok and
   507	          run_partition_ok and ctl_partition_ok and totals_int_ok and
   508	          descr_ok)
   509	    gm = gold.get("metrics") if gold else {}
   510	    if not isinstance(gm, dict):
   511	        gm = {}
   512	    # G2 typed (14.9 item C): a float 600.0 must not satisfy parent-perfect
   513	    g2 = all(_count(gm.get(k)) and gm.get(k) == v
   514	             for k, v in GOLD_PERFECT.items())
   515	    po_mp = mp.get("pins_observed")
   516	    if not isinstance(po_mp, dict):
   517	        po_mp = {}
   518	    lint = po_mp.get("phrasings_lint")
   519	    if not isinstance(lint, dict):
   520	        lint = {}
   521	    g3 = bool(lint.get("green"))
   522	    if EXPECTED_PHRASINGS_SHA256 is not None:
   523	        pf = po_mp.get("phrasings_file")
   524	        if not isinstance(pf, dict):
   525	            pf = {}
   526	        g3 = g3 and pf.get("observed") == EXPECTED_PHRASINGS_SHA256
   527	    # G4 hardened (14.9 item C): the division runs only over well-formed
   528	    # in-range integer counters — dev_parse_refused in {-1, 0.5, 61} or a
   529	    # float dev_n fails closed here (and in G1's totals_int_ok).
   530	    g4 = (_count(dev_n) and dev_n > 0 and _count(dev_ref) and
   531	          dev_ref <= dev_n and (dev_ref / float(dev_n)) <= DEV_MAX_ABSTENTION)
   532	    # G5 (14.8 hardening): the deranged arm must EXIST, cover the full
   533	    # planned covered set, and report an explicit integer exact count —
   534	    # a missing arm or missing metric is a broken instrument, NEVER
   535	    # "perfect collapse".
   235	ARMS = ("mapper-parse", "gold-replication", "deranged-lexicon",
   236	        "abstain-all", "answer-all")
