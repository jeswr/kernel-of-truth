   454	    run_partition_ok = (all(_count(x) for x in run_counts) and
   455	                        sum(run_counts) == nc)
   456	    # (v) run-level control outcome partition over 106 (mapper arm: the
   457	    # acceptable set is strict-engine-code + ERR_PARSE — FK-NLB-6; the
   458	    # ABSTAIN branch exists only on the abstain-all arm, never here)
   459	    ctl_counts = (n_ctl_acc, n_ctl_ans, n_ctl_other, n_ctl_any,
   460	                  n_ctl_strict, n_ctl_parse)
   461	    ctl_partition_ok = (all(_count(x) for x in ctl_counts) and
   462	                        n_ctl_ans + n_ctl_acc + n_ctl_other == ng and
   463	                        n_ctl_any == n_ctl_acc + n_ctl_other and
   464	                        n_ctl_acc == n_ctl_strict + n_ctl_parse)
   465	    # (vi) 14.9 item C: run-level totals and dev counters must be strict
   466	    # non-negative INTEGERS (855.0/106.0/60.0 are not lawful counts — the
   467	    # == comparisons above would accept them) and dev_parse_refused must be
   468	    # a count within [0, dev_n]
   469	    totals_int_ok = (_count(nc) and _count(ng) and _count(dev_n) and
   470	                     _count(dev_ref) and dev_ref <= dev_n)
   471	    # (vii) 14.10 item B (ASM-0625): every REMAINING counter the analysis
   472	    # divides — the descriptive label_strata, synonym-probe and
   473	    # frontend_total_ns counters — must be well-formed whenever present, so
   474	    # once G1 is green NO malformed metric of any kind reaches arithmetic.
   475	    ls = m.get("label_strata")
   476	    ls_ok = ls is None or (isinstance(ls, dict) and all(
   477	        isinstance(v, dict) and _count(v.get("n")) and _count(v.get("exact"))
   478	        and v["exact"] <= v["n"] for v in ls.values()))
   479	    if m.get("probe_n"):
   480	        probe_ok = (_count(m.get("probe_n")) and
   481	                    _count(m.get("probe_parse_ok")) and
   482	                    _count(m.get("probe_exact")) and
   483	                    m["probe_parse_ok"] <= m["probe_n"] and
   484	                    m["probe_exact"] <= m["probe_n"])
   485	    else:
   486	        probe_ok = True
   487	    descr_ok = ls_ok and probe_ok and _count(m.get("frontend_total_ns", 0))
   488	    g1 = (all(a in by_arm for a in ARMS) and nc == PLANNED_COVERED and
   489	          ng == PLANNED_CONTROL and dev_n == PLANNED_DEV and fam_keys_ok and
   490	          buckets_wellformed and strata_ok and partition_ok and twins_ok and
   491	          control_zero_ok and control_sum_ok and run_partition_ok and
   492	          ctl_partition_ok and totals_int_ok and descr_ok)
   493	    gm = gold.get("metrics") if gold else {}
   494	    if not isinstance(gm, dict):
   495	        gm = {}
   496	    # G2 typed (14.9 item C): a float 855.0 must not satisfy parent-perfect
   497	    g2 = all(_count(gm.get(k)) and gm.get(k) == v
   498	             for k, v in GOLD_PERFECT.items())
   499	    po_mp = mp.get("pins_observed")
   500	    if not isinstance(po_mp, dict):
   501	        po_mp = {}
   502	    lint = po_mp.get("phrasings_lint")
   503	    if not isinstance(lint, dict):
   504	        lint = {}
   505	    g3 = bool(lint.get("green"))
   506	    if EXPECTED_PHRASINGS_SHA256 is not None:
   507	        pf = po_mp.get("phrasings_file")
   508	        if not isinstance(pf, dict):
   509	            pf = {}
   510	        g3 = g3 and pf.get("observed") == EXPECTED_PHRASINGS_SHA256
   511	    # G4 hardened (14.9 item C): the division runs only over well-formed
   512	    # in-range integer counters — dev_parse_refused in {-1, 0.5, 61} or a
   513	    # float dev_n fails closed here (and in G1's totals_int_ok).
   514	    g4 = (_count(dev_n) and dev_n > 0 and _count(dev_ref) and
   515	          dev_ref <= dev_n and (dev_ref / float(dev_n)) <= DEV_MAX_ABSTENTION)
