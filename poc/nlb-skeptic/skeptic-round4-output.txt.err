   374	def analyze(records):
   375	    out = {"gates": {"instrument_valid": False}, "analysis": {}}
   376	    by_arm, g0, g0_detail = _one_row_per_arm(records)
   377	    out["gates"]["g0_one_row_per_arm"] = bool(g0)
   378	    if not g0:
   379	        out["gates"]["g0_detail"] = g0_detail
   380	        return out
   381	    mp = by_arm.get("mapper-parse")
   382	    gold = by_arm.get("gold-replication")
   383	    der = by_arm.get("deranged-lexicon")
   384	    if mp is None:
   385	        return out
   386	    # 14.10 item B (ASM-0625): a non-dict metrics body is a counts-integrity
   387	    # failure, never an exception — every read below stays total.
   388	    m = mp.get("metrics")
   389	    if not isinstance(m, dict):
   390	        m = {}
   391	    nc, ng = m.get("n_covered", 0), m.get("n_control", 0)
