   857	    o = analyze(recs)
   858	    json.dumps(o)
   859	    assert o["gates"]["g1_counts"] is False, o["gates"]
   860	    assert o["analysis"] == {}, o
   861	    recs = _suite()
   862	    recs[0]["metrics"]["probe_n"] = True
   863	    o = analyze(recs)
   864	    json.dumps(o)
   865	    assert o["gates"]["g1_counts"] is False, o["gates"]
   866	    recs = _suite()
   867	    recs[0]["metrics"]["frontend_total_ns"] = "1e9"
   868	    o = analyze(recs)
   869	    json.dumps(o)
   870	    assert o["gates"]["g1_counts"] is False, o["gates"]
   871	    # G0 (14.8): duplicate mapper-parse rows are INVALID in BOTH log orders
   872	    stale = _rec("mapper-parse", covered={"contained-in": _fam(201, exact=0,
   873	                                                               rparse=201)})
   874	    good = _suite()
   875	    for order in ([stale] + good, good + [stale]):
   876	        o = analyze(order)
   877	        assert o["gates"]["g0_one_row_per_arm"] is False, o["gates"]
   878	        assert o["gates"]["instrument_valid"] is False, o["gates"]
   879	    # G0: an EXPLICIT supersede (kot-log/1 row-hash channel, 14.9 item A)
   880	    # is honoured (order-independent) and the surviving row feeds the
   881	    # analysis
   882	    recs = _suite()
   883	    recs[0]["supersedes"] = [_row_sha(stale)]
   884	    recs[0]["reason"] = "retry after simulated crash-after-append"
   885	    for order in ([stale] + recs, recs + [stale]):
   886	        o = analyze(order)
   887	        assert o["gates"]["instrument_valid"] is True, o["gates"]
   888	        assert o["analysis"]["retained_covered_exact_rate"] == 1.0, o
   889	    # G0 (14.9): a two-step retry CHAIN is honoured — the newest row wins,
   890	    # each step explicitly superseding its predecessor
   891	    stale2 = _rec("mapper-parse", covered={"contained-in": _fam(201, exact=1,
   892	                                                                rparse=200)})
   893	    stale2["supersedes"] = [_row_sha(stale)]
   894	    stale2["reason"] = "first retry"
   895	    recs = _suite()
   896	    recs[0]["supersedes"] = [_row_sha(stale2)]
   897	    recs[0]["reason"] = "second retry"
   898	    o = analyze([stale, stale2] + recs)
   899	    assert o["gates"]["instrument_valid"] is True, o["gates"]
   900	    assert o["analysis"]["retained_covered_exact_rate"] == 1.0, o
   901	    # G0 (14.10, reproduced round-3 attack): a superseding row with a
   902	    # MISSING / empty / whitespace reason fails closed in BOTH log orders —
   903	    # log-append refuses these at append time; the scorer now re-validates
   904	    # them independently, so the defence-in-depth claim is executable
   905	    for bad in (None, "", "   "):
   906	        recs = _suite()
   907	        recs[0]["supersedes"] = [_row_sha(stale)]
   908	        if bad is not None:
   909	            recs[0]["reason"] = bad
   910	        for order in ([stale] + recs, recs + [stale]):
   911	            o = analyze(order)
   912	            assert o["gates"]["g0_one_row_per_arm"] is False, (bad, o["gates"])
   913	            assert o["gates"]["instrument_valid"] is False, (bad, o["gates"])
   914	            assert "missing_reason" in o["gates"]["g0_detail"], (bad, o)
   915	    # G0 (14.10, reproduced round-3 attack): DOUBLE RETIREMENT — the newest
   916	    # row retires BOTH prior rows although the middle row already retired
   917	    # the first (log-append's not-already-superseded rule, re-validated
