   635	
   636	
   637	def _rec(arm, covered=None, control_accept=106, control_parse=24, **kw):
   638	    # Covered families default to all-exact; `covered` overrides named
   639	    # families with explicit buckets (run-level covered twins are DERIVED
   640	    # from by_family so G1 twins-integrity holds by construction). Control
   641	    # counters keep the score_nl identities: acceptable = strict + parse,
   642	    # other = n_control - acceptable (answered 0), any = acceptable + other.
   643	    cov = {k: _fam(v) for k, v in PLANNED_COVERED_STRATA.items()}
   644	    for k, b in (covered or {}).items():
   645	        assert b["n"] == PLANNED_COVERED_STRATA[k], (k, b)
   646	        cov[k] = b
   647	    fam = dict(cov)
   648	    # 14.10: fixtures model an INTERNALLY CONSISTENT instrument — the
   649	    # non-acceptable control remainder (PLANNED_CONTROL - control_accept)
   650	    # is deducted from the by_family 'ok' counts so the 14.9 item-C
   651	    # control-sum invariant holds by construction (G1 now short-circuits,
   652	    # so a Holm-boundary fixture may no longer ride on an inconsistent
   653	    # control split).
   654	    deficit = PLANNED_CONTROL - control_accept
   655	    for k, v in sorted(PLANNED_CONTROL_STRATA.items()):
   656	        take = min(deficit, v)
   657	        deficit -= take
   658	        fam[k] = {"n": v, "ok": v - take, "exact": 0, "wrong": 0,
   659	                  "refused_parse": 0, "refused_engine": 0}
   660	    ce = sum(cov[k]["exact"] for k in cov)
   661	    cw = sum(cov[k]["wrong"] for k in cov)
   662	    cp = sum(cov[k]["refused_parse"] for k in cov)
   663	    cg = sum(cov[k]["refused_engine"] for k in cov)
   664	    ctl_other = PLANNED_CONTROL - control_accept
   665	    m = {"n_covered": 855, "n_covered_exact": ce,
   666	         "n_covered_refused_parse": cp, "n_covered_refused_engine": cg,
   667	         "n_covered_answered_wrong": cw, "n_control": 106,
   668	         "n_control_refused_acceptable": control_accept,
   669	         "n_control_refused_strict_engine_code":
   670	             control_accept - control_parse,
   671	         "n_control_refused_parse": control_parse,
   672	         "n_control_refused_other": ctl_other,
   673	         "n_control_answered": 0,
   674	         "n_control_refused_any": control_accept + ctl_other,
   675	         "by_family": fam, "parse_stage_breakdown": {},
   676	         "label_strata": {"verbatim": {"n": 455, "exact": 455},
   677	                          "paraphrase": {"n": 400, "exact": 400}},
   678	         "dev_n": 60, "dev_parse_refused": 4,
   679	         "deterministic_repeat_identical": True,
   680	         "frontend_total_ns": 960000000}
   681	    m.update(kw)
   682	    # Fixture bodies mirror REAL eligible log rows (verdict-gen passes the
   683	    # stamped kot-log/1 rows through): run event, final phase, ok exit.
   684	    body = {"experiment": EXPERIMENT, "event": "run", "phase": "final",
   685	            "exit": "ok", "config": {"arm": arm}, "metrics": m,
   686	            "pins_observed": _pins()}
   687	    if arm == "gold-replication":
   688	        body["metrics"] = dict(GOLD_PERFECT)
   689	        body["metrics"]["deterministic_repeat_identical"] = True
   690	    if arm == "deranged-lexicon":
   691	        m2 = dict(m)
   692	        m2.update({"n_covered_exact": 0, "n_covered_answered_wrong": 38})
   693	        body["metrics"] = m2
   694	    return body
   695	
   696	
   697	def _suite(**mp_kw):
   698	    return [_rec("mapper-parse", **mp_kw), _rec("gold-replication"),
   699	            _rec("deranged-lexicon"), _rec("abstain-all"),
   700	            _rec("answer-all")]
   701	
   702	
   703	def selftest():
   704	    base = analyze(_suite())
   705	    assert base["gates"]["instrument_valid"] is True, base["gates"]
   706	    a = base["analysis"]
   707	    assert a["retained_covered_exact_rate"] == 1.0
   708	    assert abs(a["retained_covered_exact_wilson_lb"] - 0.996845) < 1e-4
   709	    assert a["holm_s1_pass"] and a["holm_s2_pass"]
   710	    assert a["synonym_probe"] is None
   711	    # primary decision boundary (recomputed table): the varied counts sit in
   712	    # the contained-in family so by_family twins integrity holds.
   713	    hi = analyze(_suite(covered={"contained-in": _fam(201, exact=130,
   714	                                                      rparse=71)}))["analysis"]
   715	    lo = analyze(_suite(covered={"contained-in": _fam(201, exact=129,
   716	                                                      rparse=72)}))["analysis"]
   717	    assert hi["retained_covered_exact_rate"] == 784 / 855.0, hi
   718	    assert hi["retained_covered_exact_wilson_lb"] > FLOOR, hi
   719	    assert lo["retained_covered_exact_wilson_lb"] <= FLOOR, lo
   720	    kill = analyze(_suite(covered={"contained-in": _fam(201, exact=101,
   721	                                                        rparse=100)}))["analysis"]
   722	    nokill = analyze(_suite(covered={"contained-in": _fam(201, exact=102,
   723	                                                          rparse=99)}))["analysis"]
   724	    assert kill["retained_covered_exact_wilson_ub"] <= FLOOR, kill
   725	    assert nokill["retained_covered_exact_wilson_ub"] > FLOOR, nokill
   726	    # S1 boundary at the HOLM-WORST level: with S2 at 10/855 (z ~1.73), S1
   727	    # wins the ordering at both 102/106 (z ~2.14) and 101/106 (z ~1.81) and
   728	    # is tested at alpha/2 (z=1.96): 102 passes, 101 fails (and blocks S2).
   729	    s1hi = analyze(_suite(control_accept=102,
   730	                          covered={"contained-in": _fam(201, exact=191,
   731	                                                        wrong=10)}))["analysis"]
   732	    s1lo = analyze(_suite(control_accept=101,
   733	                          covered={"contained-in": _fam(201, exact=191,
   734	                                                        wrong=10)}))["analysis"]
   735	    assert s1hi["holm_s1_pass"] is True and s1hi["holm_s2_pass"] is True, s1hi
   736	    assert s1lo["holm_s1_pass"] is False and s1lo["holm_s2_pass"] is False, \
   737	        s1lo
   738	    # S1 at the nominal-alpha leg (S2 dominant at 0/855): 101/106 passes
   739	    s1nom = analyze(_suite(control_accept=101))["analysis"]
   740	    assert s1nom["holm_s1_pass"] is True, s1nom
   741	    # S2 Holm-worst boundary (9 vs 10 wrong at z=1.96), asserted directly
   742	    assert wilson(9 / 855.0, 855, Z_HOLM_FIRST, True) < S2_GATE
   743	    assert wilson(10 / 855.0, 855, Z_HOLM_FIRST, True) > S2_GATE
   744	    # S2 kill boundary, unadjusted z=1.645 (corrected: fires from 24/855)
   745	    s2c = analyze(_suite(covered={"contained-in": _fam(201, exact=177,
   746	                                                       wrong=24)}))["analysis"]
   747	    s2d = analyze(_suite(covered={"contained-in": _fam(201, exact=178,
   748	                                                       wrong=23)}))["analysis"]
   749	    assert s2c["covered_wrong_answer_wilson_lb"] >= S2_GATE, s2c
   750	    assert s2d["covered_wrong_answer_wilson_lb"] < S2_GATE, s2d
   751	    # Holm step-down: a failed first hypothesis blocks the second
   752	    both = analyze(_suite(control_accept=80))["analysis"]
   753	    assert both["holm_s1_pass"] is False and both["holm_s2_pass"] is True, both
   754	    # G1 (14.8): the REPRODUCED finding-6 conflict — exact and refused_parse
   755	    # both claiming the full 855 — must be instrument-invalid.
   756	    recs = _suite()
   757	    recs[0]["metrics"]["n_covered_exact"] = 855
   758	    recs[0]["metrics"]["n_covered_refused_parse"] = 855
   759	    o = analyze(recs)
   760	    assert o["gates"]["g1_counts"] is False, o["gates"]
   761	    assert o["gates"]["instrument_valid"] is False, o["gates"]
   762	    # G1 (14.8): a broken per-family bucket partition => invalid
   763	    broken = analyze(_suite(covered={"contained-in": {
   764	        "n": 201, "ok": 201, "exact": 150, "wrong": 0,
   765	        "refused_parse": 0, "refused_engine": 0}}))
   766	    assert broken["gates"]["g1_counts"] is False, broken["gates"]
   767	    # G1 (14.8): an unexpected family => invalid
   768	    recs = _suite()
   769	    recs[0]["metrics"]["by_family"]["mystery-family"] = _fam(1)
   770	    assert analyze(recs)["gates"]["g1_counts"] is False
   771	    # G1 (14.8): nonzero covered bucket on a CONTROL family => invalid
   772	    recs = _suite()
   773	    recs[0]["metrics"]["by_family"]["unknown-entity"]["exact"] = 1
   774	    assert analyze(recs)["gates"]["g1_counts"] is False
   775	    # G1 (14.8): negative / non-integer buckets => invalid
   776	    recs = _suite()
   777	    recs[0]["metrics"]["by_family"]["callees-of"]["wrong"] = -1
   778	    assert analyze(recs)["gates"]["g1_counts"] is False
   779	    recs = _suite()
   780	    recs[0]["metrics"]["by_family"]["callees-of"]["exact"] = 72.0
   781	    assert analyze(recs)["gates"]["g1_counts"] is False
   782	    # G1 (14.8): broken control partition (acceptable != strict + parse)
   783	    recs = _suite()
   784	    recs[0]["metrics"]["n_control_refused_strict_engine_code"] = 70
   785	    assert analyze(recs)["gates"]["g1_counts"] is False
   786	    # G1 (14.9, reproduced round-2 attack): ZEROED control-family ok with
   787	    # the run-level acceptable total left intact — previously g1_counts was
   788	    # True with S1 PASS and acceptable-refusal rate 1.0; now invalid
   789	    recs = _suite()
   790	    for k in PLANNED_CONTROL_STRATA:
   791	        recs[0]["metrics"]["by_family"][k]["ok"] = 0
   792	    o = analyze(recs)
   793	    assert o["gates"]["g1_counts"] is False, o["gates"]
   794	    assert o["gates"]["instrument_valid"] is False, o["gates"]
   795	    # G1 (14.9, reproduced): float-valued run totals 855.0 / 106.0 / 60.0
   796	    for key, val in (("n_covered", 855.0), ("n_control", 106.0),
   797	                     ("dev_n", 60.0)):
   798	        recs = _suite()
   799	        recs[0]["metrics"][key] = val
   800	        o = analyze(recs)
   801	        assert o["gates"]["g1_counts"] is False, (key, o["gates"])
   802	        assert o["gates"]["instrument_valid"] is False, (key, o["gates"])
   803	    # G2 typed (14.9): a float gold counter is not parent-perfect
   804	    recs = _suite()
   805	    recs[1]["metrics"]["n_covered_exact"] = 855.0
   806	    assert analyze(recs)["gates"]["g2_gold_replication"] is False
   807	    # G4 hardened (14.9, reproduced): dev_parse_refused in {-1, 0.5, 61}
   808	    for bad in (-1, 0.5, 61):
   809	        recs = _suite()
   810	        recs[0]["metrics"]["dev_parse_refused"] = bad
   811	        o = analyze(recs)
   812	        assert o["gates"]["g4_dev_abstention"] is False, (bad, o["gates"])
   813	        assert o["gates"]["instrument_valid"] is False, (bad, o["gates"])
   814	    # G1 SHORT-CIRCUIT (14.10, reproduced round-3 attack): BOOLEAN totals
   815	    # and counters return a CLEAN INSTRUMENT-INVALID — no Wilson/Holm
   816	    # arithmetic runs over the rejected denominator (previously
   817	    # n_covered=True reached the output with complex Wilson values and
   818	    # n_control=True crashed with a complex-vs-float TypeError), the output
   819	    # is JSON-serializable, and the analysis block is EMPTY
   820	    for key in ("n_covered", "n_control", "dev_n", "n_covered_exact",
   821	                "n_control_refused_acceptable", "dev_parse_refused"):
   822	        recs = _suite()
   823	        recs[0]["metrics"][key] = True
   824	        o = analyze(recs)
   825	        json.dumps(o)  # must not raise: serializable, no complex values
   826	        assert o["gates"]["g1_counts"] is False, (key, o["gates"])
   827	        assert o["gates"]["instrument_valid"] is False, (key, o["gates"])
   828	        assert o["analysis"] == {}, (key, o)
   829	    # G1 SHORT-CIRCUIT (14.10): every counts-integrity failure — including
   830	    # the reproduced float/negative forms — now stops before arithmetic
   831	    for key, val in (("n_covered", 854), ("n_control", -1),
   832	                     ("n_covered_exact", 0.5)):
   833	        recs = _suite()
   834	        recs[0]["metrics"][key] = val
   835	        o = analyze(recs)
   836	        json.dumps(o)
   837	        assert o["gates"]["g1_counts"] is False, (key, o["gates"])
   838	        assert o["analysis"] == {}, (key, o)
   839	    # 14.10: non-dict metrics bodies are counts-integrity failures, never
   840	    # exceptions (mapper arm => G1 short-circuit; gold arm => G2 false)
   841	    recs = _suite()
   842	    recs[0]["metrics"] = "bogus"
   843	    o = analyze(recs)
   844	    json.dumps(o)
   845	    assert o["gates"]["g1_counts"] is False, o["gates"]
   846	    assert o["analysis"] == {}, o
   847	    recs = _suite()
   848	    recs[1]["metrics"] = None
   849	    o = analyze(recs)
   850	    json.dumps(o)
   851	    assert o["gates"]["g2_gold_replication"] is False, o["gates"]
   852	    assert o["gates"]["instrument_valid"] is False, o["gates"]
   853	    # 14.10: malformed DESCRIPTIVE counters (label_strata / probe /
   854	    # frontend_total_ns) fail G1 instead of crashing the divisions
   855	    recs = _suite()
