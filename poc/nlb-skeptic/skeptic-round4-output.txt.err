/bin/bash -lc "nl -ba registry/schema/kot-log-1.json | sed -n '1,110p'
nl -ba tools/registry/log-append.py | sed -n '80,170p'
nl -ba tools/registry/kot_common.py | sed -n '270,325p'
python3 analysis/l3a_parse.py --selftest
python3 analysis/a5_nl.py --selftest
python3 tools/registry/prereg-freeze.py --experiment l3a-parse --agent-id skeptic-4 --dry-run
python3 tools/registry/prereg-freeze.py --experiment a5-nl --agent-id skeptic-4 --dry-run" in /home/ec2-user/css/kernel/kernel-of-truth
