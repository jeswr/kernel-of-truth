   421	                        list(PLANNED_COVERED_STRATA.items()) +
   422	                        list(PLANNED_CONTROL_STRATA.items()))
   423	        # (i) per covered family the bucket partition holds and exact == ok
   424	        partition_ok = all(
   425	            sum(buck(k, b) for b in BUCKET_KEYS) == buck(k, "n") and
   426	            buck(k, "exact") == buck(k, "ok")
   427	            for k in PLANNED_COVERED_STRATA)
   428	        # (ii) covered-family bucket sums equal the run-level twins
   429	        twins_ok = (
   430	            sum(buck(k, "exact") for k in PLANNED_COVERED_STRATA) == n_exact
   431	            and sum(buck(k, "wrong") for k in PLANNED_COVERED_STRATA)
   432	            == n_wrong and
   433	            sum(buck(k, "refused_parse") for k in PLANNED_COVERED_STRATA)
   434	            == n_rparse and
