   393	    n_wrong = m.get("n_covered_answered_wrong", 0)
   394	    n_rparse = m.get("n_covered_refused_parse", 0)
   395	    n_rengine = m.get("n_covered_refused_engine", 0)
   396	    n_ctl_acc = m.get("n_control_refused_acceptable", 0)
   397	    n_ctl_ans = m.get("n_control_answered", 0)
   398	    n_ctl_other = m.get("n_control_refused_other", 0)
   399	    n_ctl_any = m.get("n_control_refused_any", 0)
   400	    n_ctl_strict = m.get("n_control_refused_strict_engine_code", 0)
   401	    n_ctl_parse = m.get("n_control_refused_parse", 0)
   402	    dev_n = m.get("dev_n", 0)
   403	    dev_ref = m.get("dev_parse_refused", 0)
   404	    fam = m.get("by_family", {})
