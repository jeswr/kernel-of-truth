/bin/bash -lc "python3 tools/registry/prereg-freeze.py --experiment l3a-parse --agent-id auditor-4 --dry-run
python3 tools/registry/prereg-freeze.py --experiment a5-nl --agent-id auditor-4 --dry-run
python3 - <<'PY'
import copy, hashlib, importlib.util, json, subprocess, sys
from pathlib import Path
ROOT=Path.cwd()
spec=importlib.util.spec_from_file_location('kc', ROOT/'tools/registry/kot_common.py'); kc=importlib.util.module_from_spec(spec); spec.loader.exec_module(kc)
schema=json.load(open(ROOT/'registry/schema/kot-log-1.json'))

def load(name,path):
 s=importlib.util.spec_from_file_location(name, ROOT/path); m=importlib.util.module_from_spec(s); s.loader.exec_module(m); return m
mods=[load('l3','analysis/l3a_parse.py'),load('a5','analysis/a5_nl.py')]

def stamp_chain(rows):
 out=[]; prev=kc.GENESIS
 for i,body in enumerate(rows):
  r=copy.deepcopy(body); r.update(schema_version='kot-log/1',seq=i,prev_sha256=prev,ts=f'2026-07-10T00:00:{i:02d}Z',runner='auditor-4',prereg_hash='a'*64)
  raw=(kc.canonical_dumps(r)+'\\n').encode(); prev=hashlib.sha256(raw).hexdigest(); out.append(r)
 return out

def valid_chain(rows):
 prev=kc.GENESIS
 for i,r in enumerate(rows):
  assert r['seq']==i and r['prev_sha256']==prev
  prev=hashlib.sha256((kc.canonical_dumps(r)+'\\n').encode()).hexdigest()
 return True

def schema_errors(rows): return [kc.validate_schema(r,schema) for r in rows]

def g0_chain(m, kind, reason='ok'):
 stale=m._rec('mapper-parse', covered={next(iter(m.PLANNED_COVERED_STRATA)): m._fam(next(iter(m.PLANNED_COVERED_STRATA.values())), exact=0, rparse=next(iter(m.PLANNED_COVERED_STRATA.values())))})
 # Stamp stale alone first; its hash is stable as seq 0 / genesis.
 stale_s=stamp_chain([stale])[0]; hs=m._row_sha(stale_s)
 if kind=='retry' or kind=='reason':
  newest=m._suite()[0]; newest['supersedes']=[hs]
  if reason is not None: newest['reason']=reason
  chain=stamp_chain([stale,newest]+m._suite()[1:])
