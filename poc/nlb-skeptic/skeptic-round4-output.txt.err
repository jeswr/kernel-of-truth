   409	    # ---- G1 counts integrity (14.8 extensions; any failure =>
   410	    # instrument-invalid). Well-formedness first, so nothing below can
   411	    # arithmetic over a malformed bucket. a5-nl is NOT re-scoped: the gated
   412	    # numerators are the RUN-LEVEL totals; the by_family buckets are
   413	    # consumed as integrity invariants only.
   414	    fam_keys_ok = isinstance(fam, dict) and set(fam) == EXPECTED_FAMILIES
   415	    buckets_wellformed = fam_keys_ok and all(
   416	        isinstance(fam[k], dict) and
   417	        all(_count(fam[k].get(b)) for b in ("n", "ok") + BUCKET_KEYS)
   418	        for k in EXPECTED_FAMILIES)
