   203	
   204	def wilson(p, n, z, upper=False):
   205	    if n <= 0:
   206	        return 1.0 if upper else 0.0
   207	    z2 = z * z
   208	    centre = p + z2 / (2 * n)
   209	    spread = z * ((p * (1 - p) / n + z2 / (4 * n * n)) ** 0.5)
   210	    return (centre + spread if upper else centre - spread) / (1 + z2 / n)
   211	
   212	
   213	def score_z(p_hat, p0, n, direction):
   214	    """One-sided score-test statistic used ONLY to order the two Holm
   215	    hypotheses (larger z == smaller p). direction 'gt': H1 p > p0;
   216	    'lt': H1 p < p0."""
   217	    se = (p0 * (1 - p0) / n) ** 0.5 if n > 0 else 1.0
   218	    z = (p_hat - p0) / se if se > 0 else 0.0
   219	    return z if direction == "gt" else -z
   220	
   221	
   222	def _count(v):
   223	    """A well-formed counter: non-negative int (bool excluded)."""
   224	    return isinstance(v, int) and not isinstance(v, bool) and v >= 0
   225	
   226	
   227	_SHA256_RE = re.compile(r"^[0-9a-f]{64}$")
   228	
   229	
   230	def _canonical(r):
   231	    """Byte-identical twin of tools/registry/kot_common.canonical_dumps —
   232	    the exact serialization the single log writer (log-append) emits.
   233	    Re-implemented here so the pinned sha stays the complete analysis
   234	    artifact (self-contained by design, no shared import)."""
   235	    return json.dumps(r, sort_keys=True, ensure_ascii=False,
   236	                      separators=(",", ":"), allow_nan=False)
   237	
   238	
   239	def _row_sha(r):
   240	    """kot-log/1 row identity for G0 (14.9 item A, ASM-0624): sha256 over
   241	    the row's exact log line bytes (canonical JSON + trailing newline) —
   242	    the SAME identity prev_sha256 and reuse.row_hashes use, so a runner
   243	    computes a supersede target directly from the results-log line."""
   244	    return hashlib.sha256((_canonical(r) + "\n").encode("utf-8")).hexdigest()
   245	
   246	
   247	def _one_row_per_arm(records):
   248	    """G0 (fail-closed; design doc 14.8 item 3 as re-based by 14.9 item A,
   249	    ASM-0621/ASM-0624): duplicate/retry rows are never resolved by log
   250	    order; the ONLY lawful resolution is the kot-log/1 run-row `supersedes`
   251	    channel, re-verified here independently of log-append.
   252	    Returns (by_arm, ok, detail)."""
   253	    eligible = [r for r in records if r.get("experiment") == EXPERIMENT]
   254	    shas = [_row_sha(r) for r in eligible]
   255	    detail = {"duplicate_arms": [], "dangling_supersedes": [],
   256	              "malformed_supersedes": [], "cross_arm_supersedes": [],
   257	              "self_supersedes": [], "malformed_arm": [],
   258	              "duplicate_row_bytes": [], "arms_fully_superseded": []}
   259	    if len(set(shas)) != len(shas):
   260	        detail["duplicate_row_bytes"] = sorted(
   261	            s for s in set(shas) if shas.count(s) > 1)
   262	    arms = []
   263	    for i, r in enumerate(eligible):
   264	        arm = (r.get("config") or {}).get("arm")
   265	        if not isinstance(arm, str) or not arm:
   266	            detail["malformed_arm"].append(i)
   267	            arm = None
   268	        arms.append(arm)
   269	    by_sha = {s: i for i, s in enumerate(shas)}
   270	    superseded = set()
   271	    for i, r in enumerate(eligible):
   272	        sup = r.get("supersedes")
   273	        if sup is None:
   274	            continue
   275	        if not (isinstance(sup, list) and sup and
   276	                all(isinstance(t, str) and _SHA256_RE.match(t) for t in sup)
   277	                and len(set(sup)) == len(sup)):
   278	            # dict/string/empty/duplicate/non-hex forms all die here — a
   279	            # malformed field never resolves anything.
   280	            detail["malformed_supersedes"].append(i)
   281	            continue
   282	        for t in sup:
   283	            if t == shas[i]:
   284	                detail["self_supersedes"].append(t)
   285	            elif t not in by_sha:
   286	                detail["dangling_supersedes"].append(t)
   287	            elif arms[by_sha[t]] != arms[i]:
   288	                detail["cross_arm_supersedes"].append(t)
   289	            superseded.add(t)
   290	    by_arm, dup = {}, []
   291	    for i, r in enumerate(eligible):
   292	        if shas[i] in superseded or arms[i] is None:
   293	            continue
   294	        if arms[i] in by_arm:
   295	            dup.append(arms[i])
   296	        by_arm[arms[i]] = r
   297	    # An arm with rows but zero survivors is a supersede cycle / dead chain
   298	    # (unconstructible through log-append, which forbids forward targets;
   299	    # checked anyway — fail closed on any input).
   300	    detail["arms_fully_superseded"] = sorted(
   301	        set(a for a in arms if a) - set(by_arm))
   302	    detail["duplicate_arms"] = sorted(set(dup))
   303	    detail["dangling_supersedes"] = sorted(set(detail["dangling_supersedes"]))
   304	    ok = not any(detail.values())
   305	    return by_arm, ok, {k: v for k, v in detail.items() if v}
   306	
   307	
   308	def _pins_ok(body):
   309	    """G7: observed harness pins on one arm body equal the frozen manifest
   310	    (fail-closed on a missing pins block or any missing/drifted key)."""
   311	    po = body.get("pins_observed")
   312	    if not isinstance(po, dict) or po.get("_recipe") != CORPUS_RECIPE:
   313	        return False
   314	    for key, want in EXPECTED_HARNESS_PINS.items():
   315	        v = po.get(key)
   316	        if not isinstance(v, dict) or v.get("observed") != want:
   317	            return False
   318	    return True
   319	
   320	
   321	def analyze(records):
   322	    out = {"gates": {"instrument_valid": False}, "analysis": {}}
   323	    by_arm, g0, g0_detail = _one_row_per_arm(records)
   324	    out["gates"]["g0_one_row_per_arm"] = bool(g0)
   325	    if not g0:
   326	        out["gates"]["g0_detail"] = g0_detail
   327	        return out
   328	    mp = by_arm.get("mapper-parse")
   329	    gold = by_arm.get("gold-replication")
   330	    der = by_arm.get("deranged-lexicon")
   331	    if mp is None:
