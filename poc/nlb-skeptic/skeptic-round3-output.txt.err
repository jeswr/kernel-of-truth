   261	    try:
   262	        if args.record == "-":
   263	            body = json.load(sys.stdin)
   264	        else:
   265	            with open(args.record, "r", encoding="utf-8") as f:
   266	                body = json.load(f)
   267	        rec = append_record(root, args.experiment, args.agent_id, body, ts=args.ts)
   268	        print(kc.canonical_dumps(rec))
   269	    except kc.KotError as e:
   270	        fail(e.code, str(e).split(": ", 1)[1])
   271	    except (FileNotFoundError, json.JSONDecodeError) as e:
   272	        fail("ERR_P2_IO", str(e))
