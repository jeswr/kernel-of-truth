   345	def run(root, exp_id, agent_id, computed_at):
   346	    kc.require_pseudonym(agent_id, "--agent-id")
   347	
   348	    # Step 1 — frozen record integrity.
   349	    rec_path = os.path.join(root, "registry", "experiments", "%s.json" % exp_id)
   350	    index_path = os.path.join(root, "registry", "frozen-index.json")
   351	    with open(rec_path, "r", encoding="utf-8") as f:
   352	        record = json.load(f)
   353	    with open(index_path, "r", encoding="utf-8") as f:
   354	        index = json.load(f)
   355	    if exp_id not in index:
   356	        raise kc.KotError("ERR_P2_NOT_FROZEN", "%s absent from frozen-index.json" % exp_id)
   357	    frozen_sha = index[exp_id]
   358	    if kc.frozen_hash(record) != frozen_sha or record.get("frozen_sha256") != frozen_sha:
   359	        raise kc.KotError("ERR_P2_FROZEN_DRIFT",
   360	                          "%s: frozen record bytes drifted from frozen-index — no verdict is producible" % exp_id)
   361	
   362	    # Step 2 — amendment overlay (fail closed, never silently skipped). The
   363	    # chain-verified log is read first: it is the RT-5 cutoff witness. The
   364	    # overlay never touches the frozen file; `record` stays the frozen anchor
   365	    # (prereg_hash eligibility is checked against frozen_sha), `effective` is
   366	    # what readout runs against.
   367	    log_path = os.path.join(root, "results-log", "%s.jsonl" % exp_id)
   368	    records, raw_lines = kc.read_log(log_path)
   369	    effective, amendments_applied, amended_sha = apply_amendment_overlay(root, exp_id, record, records)
   370	
   371	    # Step 3 — eligibility.
   372	    eligible, excluded = select_eligible(records, frozen_sha, effective["design"])
   373	    tail_sha = kc.log_tail_sha256(raw_lines)
   374	    runner_ids = {r["runner"] for r in eligible}
   375	
   376	    # Step 3b — D9 reused-row eligibility (resource-optimization-plan.md §3
   377	    # revision-1). Reused producer rows enter the analysis ONLY when ALL hold:
   378	    #   - the frozen (effective) record is kot-reg/2 with a reused_from block
   379	    #     (an in-log reuse witness without a frozen declaration is refused);
   380	    #   - the ruling is maintainer-ratified (kc.check_record_reuse enforces);
   381	    #   - every RC-1..RC-8 machine check re-verifies at consumption time,
   382	    #     including RC-2 identity with placeholders now FILLED (no
   383	    #     indeterminate pins may license consumption);
   384	    #   - an in-chain RC-6 witness (event:"reuse") restates the exact verified
   385	    #     row set {seqs, row_hashes} for each block.
   386	    # Reused rows NEVER substitute for fresh evidence: the completeness gate
   387	    # below still requires >=1 fresh eligible run row.
   388	    reuse_witnesses = [r for r in records if r.get("event") == "reuse"]
   389	    reused_rows, reused_summary = [], []
   390	    if reuse_witnesses and not (effective.get("reused_from") or []):

