   238	
   239	_SHA256_RE = re.compile(r"^[0-9a-f]{64}$")
   240	
   241	
   242	def _canonical(r):
   243	    """Byte-identical twin of tools/registry/kot_common.canonical_dumps —
   244	    the exact serialization the single log writer (log-append) emits.
   245	    Re-implemented here so the pinned sha stays the complete analysis
   246	    artifact (self-contained by design, no shared import)."""
   247	    return json.dumps(r, sort_keys=True, ensure_ascii=False,
   248	                      separators=(",", ":"), allow_nan=False)
   249	
   250	
   251	def _row_sha(r):
   252	    """kot-log/1 row identity for G0 (14.9 item A, ASM-0624): sha256 over
   253	    the row's exact log line bytes (canonical JSON + trailing newline) —
   254	    the SAME identity prev_sha256 and reuse.row_hashes use, so a runner
   255	    computes a supersede target directly from the results-log line."""
   256	    return hashlib.sha256((_canonical(r) + "\n").encode("utf-8")).hexdigest()
   257	
   258	
   259	def _one_row_per_arm(records):
   260	    """G0 (fail-closed; design doc 14.8 item 3 as re-based by 14.9 item A,
   261	    ASM-0621/ASM-0624): duplicate/retry rows are never resolved by log
   262	    order; the ONLY lawful resolution is the kot-log/1 run-row `supersedes`
   263	    channel, re-verified here independently of log-append.
   264	    Returns (by_arm, ok, detail)."""
   265	    eligible = [r for r in records if r.get("experiment") == EXPERIMENT]
   266	    shas = [_row_sha(r) for r in eligible]
   267	    detail = {"duplicate_arms": [], "dangling_supersedes": [],
   268	              "malformed_supersedes": [], "cross_arm_supersedes": [],
   269	              "self_supersedes": [], "malformed_arm": [],
   270	              "duplicate_row_bytes": [], "arms_fully_superseded": []}
   271	    if len(set(shas)) != len(shas):
   272	        detail["duplicate_row_bytes"] = sorted(
   273	            s for s in set(shas) if shas.count(s) > 1)
   274	    arms = []
   275	    for i, r in enumerate(eligible):
   276	        arm = (r.get("config") or {}).get("arm")
   277	        if not isinstance(arm, str) or not arm:
   278	            detail["malformed_arm"].append(i)
   279	            arm = None
   280	        arms.append(arm)
   281	    by_sha = {s: i for i, s in enumerate(shas)}
   282	    superseded = set()
   283	    for i, r in enumerate(eligible):
   284	        sup = r.get("supersedes")
   285	        if sup is None:
   286	            continue
   287	        if not (isinstance(sup, list) and sup and
   288	                all(isinstance(t, str) and _SHA256_RE.match(t) for t in sup)
   289	                and len(set(sup)) == len(sup)):
   290	            # dict/string/empty/duplicate/non-hex forms all die here — a
   291	            # malformed field never resolves anything.
   292	            detail["malformed_supersedes"].append(i)
   293	            continue
   294	        for t in sup:
   295	            if t == shas[i]:
   296	                detail["self_supersedes"].append(t)
   297	            elif t not in by_sha:
   298	                detail["dangling_supersedes"].append(t)
   299	            elif arms[by_sha[t]] != arms[i]:
   300	                detail["cross_arm_supersedes"].append(t)
   301	            superseded.add(t)
   302	    by_arm, dup = {}, []
   303	    for i, r in enumerate(eligible):
   304	        if shas[i] in superseded or arms[i] is None:
   305	            continue
   306	        if arms[i] in by_arm:
   307	            dup.append(arms[i])
   308	        by_arm[arms[i]] = r
   309	    # An arm with rows but zero survivors is a supersede cycle / dead chain
   310	    # (unconstructible through log-append, which forbids forward targets;
   311	    # checked anyway — fail closed on any input).
   312	    detail["arms_fully_superseded"] = sorted(
   313	        set(a for a in arms if a) - set(by_arm))
   314	    detail["duplicate_arms"] = sorted(set(dup))
   315	    detail["dangling_supersedes"] = sorted(set(detail["dangling_supersedes"]))
   316	    ok = not any(detail.values())
   317	    return by_arm, ok, {k: v for k, v in detail.items() if v}
