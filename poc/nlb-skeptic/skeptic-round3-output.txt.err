   829	    assert o["gates"]["g5_deranged_collapse"] is False, o["gates"]
   830	    assert o["gates"]["instrument_valid"] is False, o["gates"]
   831	    assert o["analysis"]["deranged_retained_exact_rate"] is None, o
   832	    recs = _suite()
   833	    del recs[2]["metrics"]["n_covered_exact"]
   834	    assert analyze(recs)["gates"]["g5_deranged_collapse"] is False
