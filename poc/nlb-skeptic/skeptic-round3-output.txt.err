   659	    assert kill["analysis"]["retained_covered_exact_wilson_ub"] <= FLOOR, kill
   660	    assert nokill["analysis"]["retained_covered_exact_wilson_ub"] > FLOOR, \
   661	        nokill
   662	    # S1 boundary at the HOLM-WORST level: with S2 at 5/527 (z ~1.72), S1
   663	    # wins the ordering at both 264/270 (z ~2.09) and 263/270 (z ~1.81) and
   664	    # is therefore tested at alpha/2 (z=1.96) — 264 passes, 263 fails (and
   665	    # blocks S2). w=5 is the unique in-scope wrong count that keeps S1 first
