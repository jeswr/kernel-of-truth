   598	def selftest():
   599	    base = analyze(_suite())
   600	    assert base["gates"]["instrument_valid"] is True, base["gates"]
   601	    a = base["analysis"]
   602	    assert a["retained_covered_exact_rate"] == 1.0
   603	    assert abs(a["retained_covered_exact_wilson_lb"] - 0.996845) < 1e-4
   604	    assert a["holm_s1_pass"] and a["holm_s2_pass"]
