    86	def append_record(root, experiment, agent_id, body, ts=None):
    87	    """Core append path (importable by verdict-gen for the unblind line).
    88	
    89	    Returns the stamped record. Raises kc.KotError on any refusal.
    90	    """
    91	    kc.require_pseudonym(agent_id, "--agent-id")
