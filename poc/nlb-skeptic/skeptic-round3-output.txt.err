registry/experiments/a5-nl.json:5:  "title": "A5-nl — NL-boundary leg, code vertical: deterministic mapper-a1-hybrid front-end parse of blind held-out NL phrasings of the frozen a5 eval vs the measured gold-parse ceiling, engine re-verified behaviourally parent-perfect in-run by gate G2 + byte-identical kot_code desugaring (HA5 NL analog of HL3a clause 2)",
registry/experiments/a5-nl.json:53:        "name": "n_covered_exact",
registry/experiments/a5-nl.json:59:        "name": "n_covered_refused",
