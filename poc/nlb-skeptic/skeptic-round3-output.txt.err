   105	def scan_open_extrapolations(record, root):
   106	    """PAUSE-and-reassess scan (assumption-register.md §6 item 2): every
   107	    ASM-id cited anywhere in the record's canonical bytes or in its pinned
   108	    prereg doc whose CURRENT register entry is an open EXTRAPOLATION.
   109	    Returns the sorted list of such ids. Non-fatal by design — the guiding
   110	    principle is 'stop false conclusions, not experiments'."""
   111	    register = load_assumption_register(root)
