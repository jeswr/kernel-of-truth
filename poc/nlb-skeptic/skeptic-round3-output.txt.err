467:    # declared schema property; event/exit/prereg_hash complete the
471:        "config": {"vertical": vertical, "arm": arm,
477:    h = _prereg_hash(root, exp_id)
479:        body["prereg_hash"] = h
480:    if supersedes:
481:        body["supersedes"] = list(supersedes)
482:        body["reason"] = reason
511:        bodies[arm] = one_arm_body(root, vertical, arm, phrasing_by_qid,
570:    ap.add_argument("--phase", default="mock")
573:    ap.add_argument("--supersedes", action="append", default=None,
578:                         "requires --reason")
579:    ap.add_argument("--reason", default=None,
580:                    help="mandatory with --supersedes: why the replaced "
584:    if args.supersedes and not (args.reason or "").strip():
585:        ap.error("--supersedes requires a non-empty --reason")
590:    body = one_arm_body(root, args.vertical, args.arm,
592:                        args.phrasings, supersedes=args.supersedes,
593:                        reason=args.reason)

