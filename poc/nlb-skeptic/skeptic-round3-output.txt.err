   541	def _rec(arm, covered=None, control_accept=106, control_parse=24, **kw):
   542	    # Covered families default to all-exact; `covered` overrides named
   543	    # families with explicit buckets (run-level covered twins are DERIVED
   544	    # from by_family so G1 twins-integrity holds by construction). Control
   545	    # counters keep the score_nl identities: acceptable = strict + parse,
   546	    # other = n_control - acceptable (answered 0), any = acceptable + other.
   547	    cov = {k: _fam(v) for k, v in PLANNED_COVERED_STRATA.items()}
   548	    for k, b in (covered or {}).items():
   549	        assert b["n"] == PLANNED_COVERED_STRATA[k], (k, b)
   550	        cov[k] = b
   551	    fam = dict(cov)
   552	    for k, v in PLANNED_CONTROL_STRATA.items():
   553	        fam[k] = {"n": v, "ok": v, "exact": 0, "wrong": 0,
   554	                  "refused_parse": 0, "refused_engine": 0}
   555	    ce = sum(cov[k]["exact"] for k in cov)
   556	    cw = sum(cov[k]["wrong"] for k in cov)
   557	    cp = sum(cov[k]["refused_parse"] for k in cov)
   558	    cg = sum(cov[k]["refused_engine"] for k in cov)
   559	    ctl_other = PLANNED_CONTROL - control_accept
   560	    m = {"n_covered": 855, "n_covered_exact": ce,
   561	         "n_covered_refused_parse": cp, "n_covered_refused_engine": cg,
   562	         "n_covered_answered_wrong": cw, "n_control": 106,
   563	         "n_control_refused_acceptable": control_accept,
   564	         "n_control_refused_strict_engine_code":
   565	             control_accept - control_parse,
   566	         "n_control_refused_parse": control_parse,
   567	         "n_control_refused_other": ctl_other,
   568	         "n_control_answered": 0,
   569	         "n_control_refused_any": control_accept + ctl_other,
   570	         "by_family": fam, "parse_stage_breakdown": {},
   571	         "label_strata": {"verbatim": {"n": 455, "exact": 455},
   572	                          "paraphrase": {"n": 400, "exact": 400}},
   573	         "dev_n": 60, "dev_parse_refused": 4,
   574	         "deterministic_repeat_identical": True,
   575	         "frontend_total_ns": 960000000}
   576	    m.update(kw)
   577	    # Fixture bodies mirror REAL eligible log rows (verdict-gen passes the
   578	    # stamped kot-log/1 rows through): run event, final phase, ok exit.
   579	    body = {"experiment": EXPERIMENT, "event": "run", "phase": "final",
   580	            "exit": "ok", "config": {"arm": arm}, "metrics": m,
   581	            "pins_observed": _pins()}
   582	    if arm == "gold-replication":
   583	        body["metrics"] = dict(GOLD_PERFECT)
   584	        body["metrics"]["deterministic_repeat_identical"] = True
   585	    if arm == "deranged-lexicon":
   586	        m2 = dict(m)
   587	        m2.update({"n_covered_exact": 0, "n_covered_answered_wrong": 38})
   588	        body["metrics"] = m2
   589	    return body
