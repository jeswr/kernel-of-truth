   320	def _pins_ok(body):
   321	    """G7: observed harness pins on one arm body equal the frozen manifest
   322	    (fail-closed on a missing pins block or any missing/drifted key)."""
   323	    po = body.get("pins_observed")
   324	    if not isinstance(po, dict) or po.get("_recipe") != CORPUS_RECIPE:
   325	        return False
   326	    for key, want in EXPECTED_HARNESS_PINS.items():
   327	        v = po.get(key)
   328	        if not isinstance(v, dict) or v.get("observed") != want:
   329	            return False
   330	    return True
   331	
   332	
   333	def analyze(records):
   334	    out = {"gates": {"instrument_valid": False}, "analysis": {}}
   335	    by_arm, g0, g0_detail = _one_row_per_arm(records)
   336	    out["gates"]["g0_one_row_per_arm"] = bool(g0)
   337	    if not g0:
   338	        out["gates"]["g0_detail"] = g0_detail
   339	        return out
   340	    mp = by_arm.get("mapper-parse")
   341	    gold = by_arm.get("gold-replication")
   342	    der = by_arm.get("deranged-lexicon")
   343	    if mp is None:
   344	        return out
   345	    m = mp["metrics"]
   346	    nc, ng = m.get("n_covered", 0), m.get("n_control", 0)
   347	    n_exact = m.get("n_covered_exact", 0)
   348	    n_wrong = m.get("n_covered_answered_wrong", 0)
   349	    n_rparse = m.get("n_covered_refused_parse", 0)
   350	    n_rengine = m.get("n_covered_refused_engine", 0)
   351	    n_ctl_acc = m.get("n_control_refused_acceptable", 0)
   352	    n_ctl_ans = m.get("n_control_answered", 0)
   353	    n_ctl_other = m.get("n_control_refused_other", 0)
   354	    n_ctl_any = m.get("n_control_refused_any", 0)
   355	    n_ctl_strict = m.get("n_control_refused_strict_engine_code", 0)
   356	    n_ctl_parse = m.get("n_control_refused_parse", 0)
   357	    dev_n = m.get("dev_n", 0)
   358	    dev_ref = m.get("dev_parse_refused", 0)
   359	    fam = m.get("by_family", {})
   360	
   361	    def buck(k, key):
   362	        return fam.get(k, {}).get(key, 0)
   363	
   364	    # ---- G1 counts integrity (14.7 + 14.8 extensions; any failure =>
   365	    # instrument-invalid). Well-formedness first, so nothing below can
   366	    # arithmetic over a malformed bucket.
   367	    fam_keys_ok = isinstance(fam, dict) and set(fam) == EXPECTED_FAMILIES
   368	    buckets_wellformed = fam_keys_ok and all(
   369	        isinstance(fam[k], dict) and
   370	        all(_count(fam[k].get(b)) for b in ("n", "ok") + BUCKET_KEYS)
   371	        for k in EXPECTED_FAMILIES)
   372	    if buckets_wellformed:
   373	        strata_ok = all(fam[k]["n"] == v for k, v in
   374	                        list(PLANNED_COVERED_STRATA.items()) +
   375	                        list(PLANNED_CONTROL_STRATA.items()))
   376	        # (i) in-scope n_scored == 527 (gated numerators are bucket sums over
   377	        # the 7 in-scope families only — FK-NLB-10, ASM-0420; the two dropped
   378	        # families' outcomes never enter a gate)
   379	        n_scored = sum(buck(k, "n") for k in IN_SCOPE_FAMILIES)
   380	        exact_in = sum(buck(k, "exact") for k in IN_SCOPE_FAMILIES)
   381	        wrong_in = sum(buck(k, "wrong") for k in IN_SCOPE_FAMILIES)
   382	        scored_ok = (n_scored == N_SCORED)
   383	        # (ii) per covered family the bucket partition holds and exact == ok
   384	        partition_ok = all(
   385	            sum(buck(k, b) for b in BUCKET_KEYS) == buck(k, "n") and
   386	            buck(k, "exact") == buck(k, "ok")
   387	            for k in PLANNED_COVERED_STRATA)
   388	        # (iii) covered-family bucket sums equal the run-level twins
   389	        twins_ok = (
   390	            sum(buck(k, "exact") for k in PLANNED_COVERED_STRATA) == n_exact
   391	            and sum(buck(k, "wrong") for k in PLANNED_COVERED_STRATA)
   392	            == n_wrong and
   393	            sum(buck(k, "refused_parse") for k in PLANNED_COVERED_STRATA)
   394	            == n_rparse and
   395	            sum(buck(k, "refused_engine") for k in PLANNED_COVERED_STRATA)
   396	            == n_rengine)
   397	        # (iv) control families hold zero covered buckets; ok <= n
   398	        control_zero_ok = all(
   399	            all(buck(k, b) == 0 for b in BUCKET_KEYS) and
   400	            buck(k, "ok") <= buck(k, "n")
   401	            for k in PLANNED_CONTROL_STRATA)
   402	        # (iv-b) 14.9 item C: the control-family acceptable ('ok') sums must
   403	        # equal the run-level acceptable total — a zeroed/dropped control-
   404	        # family classification can no longer coexist with an intact
   405	        # run-level n_control_refused_acceptable (reproduced round-2 attack)
   406	        control_sum_ok = (sum(buck(k, "ok") for k in PLANNED_CONTROL_STRATA)
   407	                          == n_ctl_acc)
   408	    else:
   409	        strata_ok = scored_ok = partition_ok = twins_ok = False
   410	        control_zero_ok = control_sum_ok = False
   411	        n_scored = exact_in = wrong_in = 0
   412	    # (v) run-level covered outcome partition over 600
   413	    run_counts = (n_exact, n_wrong, n_rparse, n_rengine)
   414	    run_partition_ok = (all(_count(x) for x in run_counts) and
   415	                        sum(run_counts) == nc)
   416	    # (vi) run-level control outcome partition over 270 (mapper arm: the
   417	    # acceptable set is strict-engine-code + ERR_PARSE — FK-NLB-6; the
   418	    # ABSTAIN branch exists only on the abstain-all arm, never here)
   419	    ctl_counts = (n_ctl_acc, n_ctl_ans, n_ctl_other, n_ctl_any,
   420	                  n_ctl_strict, n_ctl_parse)
   421	    ctl_partition_ok = (all(_count(x) for x in ctl_counts) and
   422	                        n_ctl_ans + n_ctl_acc + n_ctl_other == ng and
   423	                        n_ctl_any == n_ctl_acc + n_ctl_other and
   424	                        n_ctl_acc == n_ctl_strict + n_ctl_parse)
   425	    # (vii) 14.9 item C: run-level totals and dev counters must be strict
   426	    # non-negative INTEGERS (600.0/270.0/60.0 are not lawful counts — the
   427	    # == comparisons above would accept them) and dev_parse_refused must be
   428	    # a count within [0, dev_n]
   429	    totals_int_ok = (_count(nc) and _count(ng) and _count(dev_n) and
   430	                     _count(dev_ref) and dev_ref <= dev_n)
   431	    g1 = (all(a in by_arm for a in ARMS) and nc == PLANNED_COVERED and
   432	          ng == PLANNED_CONTROL and dev_n == PLANNED_DEV and fam_keys_ok and
   433	          buckets_wellformed and strata_ok and scored_ok and partition_ok and
   434	          twins_ok and control_zero_ok and control_sum_ok and
   435	          run_partition_ok and ctl_partition_ok and totals_int_ok)
   436	    gm = gold["metrics"] if gold else {}
   437	    # G2 typed (14.9 item C): a float 600.0 must not satisfy parent-perfect
   438	    g2 = all(_count(gm.get(k)) and gm.get(k) == v
   439	             for k, v in GOLD_PERFECT.items())
   440	    lint = (mp.get("pins_observed", {}) or {}).get("phrasings_lint", {})
   441	    g3 = bool(lint.get("green"))
   442	    if EXPECTED_PHRASINGS_SHA256 is not None:
   443	        pf = (mp.get("pins_observed", {}) or {}).get("phrasings_file", {})
   444	        g3 = g3 and pf.get("observed") == EXPECTED_PHRASINGS_SHA256
   445	    # G4 hardened (14.9 item C): the division runs only over well-formed
   446	    # in-range integer counters — dev_parse_refused in {-1, 0.5, 61} or a
   447	    # float dev_n fails closed here (and in G1's totals_int_ok).
   448	    g4 = (_count(dev_n) and dev_n > 0 and _count(dev_ref) and
   449	          dev_ref <= dev_n and (dev_ref / float(dev_n)) <= DEV_MAX_ABSTENTION)
   450	    # G5 (14.8 hardening): the deranged arm must EXIST, cover the full
   451	    # planned covered set, and report an explicit integer exact count —
   452	    # a missing arm or missing metric is a broken instrument, NEVER
   453	    # "perfect collapse".
   454	    dm = der["metrics"] if der else {}
   455	    if der is not None and dm.get("n_covered") == PLANNED_COVERED and \
   456	            _count(dm.get("n_covered")) and _count(dm.get("n_covered_exact")):
   457	        der_rate = dm["n_covered_exact"] / float(dm["n_covered"])
   458	        g5 = der_rate < DERANGED_MAX
   459	    else:
   460	        der_rate = None
   461	        g5 = False
   462	    g6 = m.get("deterministic_repeat_identical") is True
   463	    g7 = all(a in by_arm and _pins_ok(by_arm[a]) for a in ARMS)
   464	    out["gates"].update({"g1_counts": g1, "g2_gold_replication": g2,
   465	                         "g3_phrasing_lints": g3, "g4_dev_abstention": g4,
   466	                         "g5_deranged_collapse": g5, "g6_determinism": g6,
   467	                         "g7_harness_pins": g7})
   468	    out["gates"]["instrument_valid"] = all((g0, g1, g2, g3, g4, g5, g6, g7))
   469	
   470	    # ---- primary (retained == absolute over the 527 in-scope slice;
   471	    # measured gold ceiling 600/600)
   472	    a = out["analysis"]
   473	    cov = exact_in / float(N_SCORED) if N_SCORED else 0.0
   474	    a["n_covered_run"] = nc          # 600 executed (replaces n_covered)
   475	    a["n_covered_scored"] = N_SCORED  # 527 gated (FK-NLB-10)
   476	    a["n_control"], a["n_dev"] = ng, dev_n
   477	    a["retained_covered_exact_rate"] = cov
   478	    a["retained_covered_exact_wilson_lb"] = wilson(cov, N_SCORED, Z_PRIMARY)
   479	    a["retained_covered_exact_wilson_ub"] = wilson(cov, N_SCORED, Z_PRIMARY,
   480	                                                   True)
   481	
   482	    # ---- secondaries (one Holm family, m=2): S1 run-level over 270,
   483	    # S2 over the 527 in-scope slice
   484	    ctl = n_ctl_acc / float(ng) if ng else 0.0
   485	    wrong = wrong_in / float(N_SCORED) if N_SCORED else 1.0
   486	    a["control_refusal_acceptable_rate"] = ctl
   487	    a["control_refusal_acceptable_wilson_lb"] = wilson(ctl, ng, Z_PRIMARY)
   488	    a["control_refusal_strict_engine_code_rate"] = (
   489	        m.get("n_control_refused_strict_engine_code", 0) / float(ng)
   490	        if ng else 0.0)
   491	    a["covered_wrong_answer_rate"] = wrong
   492	    a["covered_wrong_answer_wilson_ub"] = wilson(wrong, N_SCORED, Z_PRIMARY,
   493	                                                 True)
   494	    a["covered_wrong_answer_wilson_lb"] = wilson(wrong, N_SCORED, Z_PRIMARY)
   495	
   496	    def s1_pass_at(z):
   497	        return wilson(ctl, ng, z) > S1_GATE
   498	
   499	    def s2_pass_at(z):
   500	        return wilson(wrong, N_SCORED, z, upper=True) < S2_GATE
   130	    "unlicensed-unique": 15}
   131	EXPECTED_FAMILIES = frozenset(PLANNED_COVERED_STRATA) | \
