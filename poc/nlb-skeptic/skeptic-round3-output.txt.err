    93	        if k in body:
    94	            raise kc.KotError("ERR_P2_STAMPED_FIELD", "%r is tooling-stamped and may not be supplied" % k)
    95	
    96	    index_path = os.path.join(root, "registry", "frozen-index.json")
    97	    if not os.path.isfile(index_path):
    98	        raise kc.KotError("ERR_P2_NOT_FROZEN", "registry/frozen-index.json does not exist")
    99	    with open(index_path, "r", encoding="utf-8") as f:
   100	        index = json.load(f)
   101	    if experiment not in index:
   102	        raise kc.KotError("ERR_P2_NOT_FROZEN", "%s is not FROZEN (absent from frozen-index.json); "
   103	                          "nothing run pre-freeze can feed a verdict (G-1)" % experiment)
   104	    if body.get("prereg_hash") != index[experiment]:
   105	        raise kc.KotError("ERR_P2_PREREG_HASH", "record prereg_hash %r != frozen_sha256 %s (G-1)"
   106	                          % (body.get("prereg_hash"), index[experiment]))
   107	
   108	    log_path = os.path.join(root, "results-log", "%s.jsonl" % experiment)
   109	    records, raw_lines = kc.read_log(log_path)  # raises ERR_P2_CHAIN on tamper
   110	
   111	    record = dict(body)
   112	    record["schema_version"] = "kot-log/1"
   113	    record["experiment"] = experiment
   114	    record["seq"] = len(records)
   115	    record["prev_sha256"] = kc.sha256_hex(raw_lines[-1]) if raw_lines else kc.GENESIS
   116	    record["ts"] = ts or datetime.datetime.utcnow().strftime("%Y-%m-%dT%H:%M:%SZ")
   117	    record["runner"] = agent_id
   118	
   119	    schema_path = os.path.join(root, "registry", "schema", "kot-log-1.json")
   120	    with open(schema_path, "r", encoding="utf-8") as f:
   121	        schema = json.load(f)
   122	    errs = kc.validate_schema(record, schema)
   123	    if errs:
   124	        raise kc.KotError("ERR_P2_SCHEMA", "; ".join(errs[:10]))
   125	
   126	    event = record["event"]
   127	    if "supersedes" in record and event != "run":
   128	        raise kc.KotError("ERR_P2_SUPERSEDE_RUN",
   129	                          "supersedes is lawful only on event:\"run\" rows (retry supersession)")
   130	    if event == "run":
   131	        missing = [k for k in RUN_REQUIRED if k not in record]
   132	        if missing:
   133	            raise kc.KotError("ERR_P2_SCHEMA", "run record missing: %s" % ", ".join(missing))
   134	        forbidden = kc.find_forbidden_metric_keys(record["metrics"])
   135	        if forbidden:
   136	            raise kc.KotError(
   137	                "ERR_P2_DERIVED_STAT",
   138	                "raw run metrics may not contain derived statistics (P2 §2.4): %s" % ", ".join(forbidden),
   139	            )
   140	        # config_sha256 is derivable; stamp it if absent, verify it if present.
   141	        want = kc.canonical_sha256(record["config"])
   142	        if record.setdefault("config_sha256", want) != want:
   143	            raise kc.KotError("ERR_P2_SCHEMA", "config_sha256 does not match canonical hash of config")
   144	        sup = record.get("supersedes")
   145	        if sup is not None:
   146	            # Retry-supersession channel (14.9 item A, ASM-0624): schema
   147	            # already guarantees a non-empty list of 64-hex strings; the
   148	            # semantic checks here are fail-closed. Targets must ALREADY be
   149	            # chain lines, so forward/self/cyclic references cannot be
   150	            # appended (a self-reference would need a SHA-256 fixed point).
   151	            if len(set(sup)) != len(sup):
