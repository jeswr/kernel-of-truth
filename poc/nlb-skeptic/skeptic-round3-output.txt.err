   216	def wilson(p, n, z, upper=False):
   217	    if n <= 0:
   218	        return 1.0 if upper else 0.0
   219	    z2 = z * z
   220	    centre = p + z2 / (2 * n)
   221	    spread = z * ((p * (1 - p) / n + z2 / (4 * n * n)) ** 0.5)
   222	    return (centre + spread if upper else centre - spread) / (1 + z2 / n)
   223	
   224	
   225	def score_z(p_hat, p0, n, direction):
   226	    """One-sided score-test statistic used ONLY to order the two Holm
   227	    hypotheses (larger z == smaller p). direction 'gt': H1 p > p0;
   228	    'lt': H1 p < p0."""
   229	    se = (p0 * (1 - p0) / n) ** 0.5 if n > 0 else 1.0
   230	    z = (p_hat - p0) / se if se > 0 else 0.0
   231	    return z if direction == "gt" else -z
