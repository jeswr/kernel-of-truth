   251	def main():
   252	    ap = argparse.ArgumentParser(description="Append one record to the hash-chained results log (fail-closed).")
   253	    ap.add_argument("--experiment", required=True)
   254	    ap.add_argument("--agent-id", required=True, help="pseudonymous identity, e.g. runner-1")
   255	    ap.add_argument("--record", required=True, help="path to partial record JSON, or - for stdin")
   256	    ap.add_argument("--root", default=None)
   257	    ap.add_argument("--ts", default=None, help="UTC timestamp override (tests/determinism)")
   258	    args = ap.parse_args()
   259	
