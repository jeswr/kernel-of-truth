   113	    prereg_path = os.path.join(root, record.get("prereg_doc", {}).get("path", ""))
   114	    if os.path.isfile(prereg_path):
   115	        try:
   116	            with open(prereg_path, "r", encoding="utf-8") as f:
   117	                cited |= set(ASM_CITE_RE.findall(f.read()))
   118	        except (OSError, UnicodeDecodeError):
   119	            pass  # the P-6 pin check already guarantees the doc's bytes
   120	    return sorted(a for a in cited
   121	                  if register.get(a, {}).get("tag") == "EXTRAPOLATION"
   122	                  and register.get(a, {}).get("status") == "open")
