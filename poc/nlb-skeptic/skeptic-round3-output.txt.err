   578	def _rec(arm, covered=None, control_accept=270, control_parse=40, **kw):
   579	    # Covered families default to all-exact; `covered` overrides named
   580	    # families with explicit buckets (run-level covered twins are DERIVED
   581	    # from by_family so G1 twins-integrity holds by construction). Control
   582	    # counters keep the score_nl identities: acceptable = strict + parse,
   583	    # other = n_control - acceptable (answered 0), any = acceptable + other.
   584	    cov = {k: _fam(v) for k, v in PLANNED_COVERED_STRATA.items()}
   585	    for k, b in (covered or {}).items():
   586	        assert b["n"] == PLANNED_COVERED_STRATA[k], (k, b)
   587	        cov[k] = b
   588	    fam = dict(cov)
   589	    for k, v in PLANNED_CONTROL_STRATA.items():
   590	        fam[k] = {"n": v, "ok": v, "exact": 0, "wrong": 0,
   591	                  "refused_parse": 0, "refused_engine": 0}
   592	    ce = sum(cov[k]["exact"] for k in cov)
   593	    cw = sum(cov[k]["wrong"] for k in cov)
   594	    cp = sum(cov[k]["refused_parse"] for k in cov)
   595	    cg = sum(cov[k]["refused_engine"] for k in cov)
   596	    ctl_other = PLANNED_CONTROL - control_accept
   597	    m = {"n_covered": 600, "n_covered_exact": ce,
   598	         "n_covered_refused_parse": cp, "n_covered_refused_engine": cg,
   599	         "n_covered_answered_wrong": cw, "n_control": 270,
   600	         "n_control_refused_acceptable": control_accept,
   601	         "n_control_refused_strict_engine_code":
   602	             control_accept - control_parse,
   603	         "n_control_refused_parse": control_parse,
   604	         "n_control_refused_other": ctl_other,
   605	         "n_control_answered": 0,
   606	         "n_control_refused_any": control_accept + ctl_other,
   607	         "by_family": fam, "parse_stage_breakdown": {},
   608	         "label_strata": {"verbatim": {"n": 300, "exact": 300},
   609	                          "paraphrase": {"n": 300, "exact": 300}},
   610	         "dev_n": 60, "dev_parse_refused": 7,
   611	         "deterministic_repeat_identical": True,
   612	         "frontend_total_ns": 600000000}
   613	    m.update(kw)
   614	    # Fixture bodies mirror REAL eligible log rows (verdict-gen passes the
   615	    # stamped kot-log/1 rows through): run event, final phase, ok exit.
   616	    body = {"experiment": EXPERIMENT, "event": "run", "phase": "final",
   617	            "exit": "ok", "config": {"arm": arm}, "metrics": m,
   618	            "pins_observed": _pins()}
   619	    if arm == "gold-replication":
   620	        body["metrics"] = dict(GOLD_PERFECT)
