    69	import datetime
    70	import json
    71	import os
    72	import sys
    73	
    74	sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
    75	import kot_common as kc
    76	
    77	STAMPED = ("seq", "prev_sha256", "ts", "runner", "schema_version")
    78	RUN_REQUIRED = ("phase", "config", "metrics", "exit")
