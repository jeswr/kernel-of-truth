   542	    # S2 Holm-worst boundary (9 vs 10 wrong at z=1.96), asserted directly
   543	    assert wilson(9 / 855.0, 855, Z_HOLM_FIRST, True) < S2_GATE
   544	    assert wilson(10 / 855.0, 855, Z_HOLM_FIRST, True) > S2_GATE
   545	    # S2 kill boundary, unadjusted z=1.645 (corrected: fires from 24/855)
   546	    s2c = analyze(_suite(covered={"contained-in": _fam(201, exact=177,
   547	                                                       wrong=24)}))["analysis"]
   548	    s2d = analyze(_suite(covered={"contained-in": _fam(201, exact=178,
   549	                                                       wrong=23)}))["analysis"]
   550	    assert s2c["covered_wrong_answer_wilson_lb"] >= S2_GATE, s2c
   551	    assert s2d["covered_wrong_answer_wilson_lb"] < S2_GATE, s2d
   552	    # Holm step-down: a failed first hypothesis blocks the second
   553	    both = analyze(_suite(control_accept=80))["analysis"]
