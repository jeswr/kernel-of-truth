   271	def select_eligible(records, frozen_sha, design):
   272	    """P2 §3.1 step 3. Returns (eligible, excluded=[{seq, reason}])."""
   273	    superseded = {r.get("target_seq") for r in records if r.get("event") == "supersede"}
   274	    iv_levels = {iv["name"]: iv["levels"] for iv in design.get("independent_vars", [])}
   275	    seeds = design.get("seeds", [])
   276	    eligible, excluded = [], []
   277	
   278	    def exclude(rec, reason):
   279	        excluded.append({"seq": rec["seq"], "reason": reason})
   280	
   281	    for rec in records:
   282	        if rec.get("event") != "run":
   283	            continue
   284	        if rec.get("phase") != "final":
   285	            exclude(rec, "phase!=final (%r)" % rec.get("phase"))
   286	            continue
   287	        if rec.get("exit") != "ok":
   288	            exclude(rec, "exit!=ok (%r)" % rec.get("exit"))
   289	            continue
   290	        if rec["seq"] in superseded:
   291	            exclude(rec, "superseded")
   292	            continue
   293	        if rec.get("prereg_hash") != frozen_sha:
   294	            exclude(rec, "prereg_hash mismatch")
   295	            continue
   296	        cfg = rec.get("config", {})
   297	        if seeds and "seed" in cfg and cfg["seed"] not in seeds:
   298	            exclude(rec, "seed %r not registered" % cfg["seed"])
   299	            continue
   300	        bad_level = None
   301	        for name, levels in iv_levels.items():
   302	            if name in cfg and cfg[name] not in levels:
   303	                bad_level = "config.%s=%r not in declared levels" % (name, cfg[name])
   304	                break
   305	        if bad_level:
   306	            exclude(rec, bad_level)
   307	            continue
   308	        eligible.append(rec)
   309	    return eligible, excluded
