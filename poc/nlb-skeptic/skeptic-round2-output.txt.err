   221	def _one_row_per_arm(records):
   222	    """G0 (fail-closed; design doc 14.8, ASM-0621): duplicate/retry rows are
   223	    never resolved by log order. Returns (by_arm, ok, detail)."""
   224	    eligible = [r for r in records
   225	                if r.get("experiment") in (None, EXPERIMENT)]
   226	    shas = [_body_sha(r) for r in eligible]
   227	    sha_set = set(shas)
   228	    superseded, dangling = set(), []
   229	    for r in eligible:
   230	        for s in (r.get("supersedes") or []):
   231	            if s not in sha_set:
   232	                dangling.append(s)
   233	            superseded.add(s)
   234	    by_arm, dup = {}, []
   235	    for r, s in zip(eligible, shas):
   236	        if s in superseded:
   237	            continue
   238	        arm = r.get("config", {}).get("arm") or r.get("arm")
   239	        if arm in by_arm:
   240	            dup.append(arm)
   241	        by_arm[arm] = r
