 succeeded in 0ms:
     1	#!/usr/bin/env python3
     2	"""nlb_lint — mechanical lints on the NLB phrasing corpora (instrument gate
     3	G3, design doc docs/design-nl-boundary-l3a-parse-a5-nl.md sections 5.4 / 6.3).
     4	
     5	    python3 tools/experiments/nlb/nlb_lint.py --vertical l3a \
     6	        --arms-profile deterministic-r0 [--receipt]
     7	
     8	ARMS PROFILE (FK-NLB-11 / ASM-0423, fail-closed — design doc section 14.8):
     9	the EVAL-NO-ANSWER forced-substring exemption is lawful ONLY for records
    10	whose every arm is deterministic and surface-blind (the l3a-parse / a5-nl
    11	R0 arms). The DEFAULT profile is `model`: under it a NONEMPTY
    12	waived_forced_substring list is itself a blocking finding (green=False),
    13	because a model-based arm can read the answer off the question surface.
    14	A record with no model arm must EXPLICITLY attest that by passing
    15	`--arms-profile deterministic-r0` (the pinned invocation for l3a-parse /
    16	a5-nl); under that profile waived qids stay exempt-and-disclosed. Reusing
    17	this lint for any successor with a model arm therefore fails closed instead
    18	of relying on prose.
    19	
    20	Checks (each a named finding; ALL must pass for green):
    21	
    22	  DEV corpus (always):
    23	    DEV-COUNT        exactly 60 items, unique qids
    24	    DEV-FRESH        every dev-entity URN absent from the world store AND
    25	                     from every eval query (disjoint-from-scored, ASM-0145);
    26	                     every dev phrasing references only dev entities (no
    27	                     scored-eval entity surface occurs in any dev phrasing)
    28	    DEV-FORM         UTF-8, single line, <= 200 chars, no urn: substring,
    29	                     no grammar keyword leakage
    30	
    31	  EVAL corpus (when eval.jsonl exists — the Opus input build):
    32	    EVAL-COUNT       exactly one phrasing per included eval qid (600+270 l3a;
    33	                     855+106 a5), no extras
    34	    EVAL-FORM        UTF-8, single line, <= 200 chars
    35	    EVAL-NO-URN      no 'urn:' substring
    36	    EVAL-NO-GRAMMAR  no closed-grammar keyword leakage: 'op', 'direction',
    37	                     'unique(', 'lookup(', 'instance(', JSON braces, or the
    38	                     scaffold token 'inverse'
    39	    EVAL-NO-ANSWER   no covered phrasing contains its own expected answer's
    40	                     surface form (value slug/string) AFTER masking all
    41	                     occurrences of the item's entity surfaces (longest-first,
    42	                     the mask_template discipline). An answer surface that
    43	                     leaks ONLY as a forced substring of the mandatory
    44	                     verbatim entity identifier (ASM-0142) is EXEMPT and its
    45	                     qid is DISCLOSED in the receipt field
    46	                     waived_forced_substring — never silent (FK-NLB-11 /
    47	                     ASM-0423, design doc section 14.4). Only answer surfaces
    48	                     that SURVIVE the entity mask are flagged.
    49	    EVAL-NO-MOCK     no phrasing byte-identical to a mock template
    50	                     instantiation (poc/nlb-mock quarantine, section 10.6)
    51	    EVAL-DIVERSITY   per covered family: >= min(6, n) distinct masked
    52	                     templates AND no single masked template > 50% of the
    53	                     family (FK-NLB-8 syntactic-diversity quota)
    54	    EVAL-SCAFFOLD    per covered family: <= 50% of phrasings match the
    55	                     canonical scaffold 'wh… the <label> of <entity>'
    56	                     (FK-NLB-8)
    57	
    58	  PROBE corpus (when probe.jsonl exists):
    59	    PROBE-COUNT      exactly 60 items; every qid is a covered eval qid
    60	    PROBE-NO-LABEL   no probe phrasing contains its item's relation/concept
    61	                     label (verbatim, spaced or raw) — the no-label
    62	                     constraint that defines the synonym probe
    63	    PROBE-FORM       same form lints as EVAL
    64	
    65	Raw findings only; the receipt (lint-receipt.json) is embedded in the run
    66	bodies by nlb_instrument and gated by the pinned analysis scripts (G3).
    67	"""
    68	
    69	import argparse
    70	import hashlib
    71	import json
    72	import os
    73	import re
    74	import sys
    75	
    76	_HERE = os.path.dirname(os.path.abspath(__file__))
    77	_ROOT = os.path.dirname(os.path.dirname(os.path.dirname(_HERE)))
    78	sys.path.insert(0, os.path.join(_ROOT, "tools", "axiom"))
    79	sys.path.insert(0, _HERE)
    80	
    81	import kot_axiom  # noqa: E402
    82	import kot_code  # noqa: E402
    83	import nlb_frontend  # noqa: E402
    84	import gen_mock_phrasings  # noqa: E402
    85	
    86	_ENT_PREFIX = "urn:kotw:v0:"
    87	GRAMMAR_TOKENS = ("{", "}", '"op"', "direction", "unique(", "lookup(",
    88	                  "instance(", " inverse ")
    89	
    90	
    91	def load_jsonl(path):
    92	    with open(path, "r", encoding="utf-8") as f:
    93	        return [json.loads(l) for l in f if l.strip()]
    94	
    95	
    96	def form_lint(findings, key, items):
    97	    for r in items:
    98	        t = r["text"]
    99	        if "\n" in t or "\r" in t:
   100	            findings.append("%s: %s multi-line" % (key, r["qid"]))
   101	        if len(t) > 200:
   102	            findings.append("%s: %s > 200 chars" % (key, r["qid"]))
   103	        if "urn:" in t.lower():
   104	            findings.append("%s: %s contains urn:" % (key, r["qid"]))
   105	        low = " %s " % t.lower()
   106	        for tok in GRAMMAR_TOKENS:
   107	            if tok in low:
   108	                findings.append("%s: %s grammar-token %r" % (key, r["qid"], tok))
   109	
   110	
   111	def surfaces(urn):
   112	    slug = urn[len(_ENT_PREFIX):].lower()
   113	    return {slug, slug.replace("-", " ")}
   114	
   115	
   116	def mask_template(text, ent_surfaces):
   117	    low = re.sub(r"\s+", " ", text.lower().strip())
   118	    for s in sorted(ent_surfaces, key=len, reverse=True):
   119	        low = low.replace(s, "@")
   120	    return low
   121	
   122	
   123	def _has_surface(hay, s):
   124	    """Word-boundary presence of surface s in already-lowercased hay (the
   125	    EVAL-NO-ANSWER predicate; underscores/alphanumerics are word chars,
   126	    hyphens and '@' are boundaries)."""
   127	    return bool(re.search(r"(?<![a-z0-9_])%s(?![a-z0-9_])" % re.escape(s), hay))
   128	
   129	
   130	def run(root, vertical):
   131	    findings = []
   132	    waived = []  # EVAL-NO-ANSWER forced-substring exemptions (FK-NLB-11)
   133	    base = os.path.join(root, "data", "nlb-phrasings-%s" % vertical)
   134	    ev = load_jsonl(os.path.join(
   135	        root, "data", "l3a-eval" if vertical == "l3a" else "a5-eval",
   136	        "queries.jsonl"))
   137	    included = [r for r in ev if r["family"] != "malformed"]
   138	    if vertical == "l3a":
   139	        axioms, world = kot_axiom.load_corpora(root)
   140	        engine = kot_axiom.Engine(axioms, world)
   141	    else:
   142	        engine = kot_code.build_code_oracle(root).engine
   143	    world_ents = set(engine.entities)
   144	    eval_ents = set()
   145	    for r in ev:
   146	        q = r.get("query") or {}
   147	        for k in ("subject", "entity", "of"):
   148	            if isinstance(q.get(k), str):
   149	                eval_ents.add(q[k])
   150	    urn2label = nlb_frontend._load_labels(root)
   151	
   152	    # ---------------- DEV
   153	    dev = load_jsonl(os.path.join(base, "dev.jsonl"))
   154	    dev_ents = [r["urn"] for r in
   155	                load_jsonl(os.path.join(base, "dev-entities.jsonl"))]
   156	    if len(dev) != 60 or len({r["qid"] for r in dev}) != 60:
   157	        findings.append("DEV-COUNT: expected 60 unique dev items")
   158	    for u in dev_ents:
   159	        if u in world_ents or u in eval_ents:
   160	            findings.append("DEV-FRESH: %s collides with a scored store/eval "
   161	                            "identity" % u)
   162	    scored_surf = set()
   163	    for u in world_ents | eval_ents:
   164	        if u.startswith(_ENT_PREFIX):
   165	            scored_surf |= surfaces(u)
   166	    for r in dev:
   167	        low = " %s " % re.sub(r"\s+", " ", r["text"].lower())
   168	        for s in scored_surf:
   169	            if re.search(r"(?<![a-z0-9_])%s(?![a-z0-9_])" % re.escape(s), low):
   170	                findings.append("DEV-FRESH: %s mentions scored surface %r"
   171	                                % (r["qid"], s))
   172	    form_lint(findings, "DEV-FORM", dev)
   173	
   174	    # ---------------- EVAL (input build; absent pre-build)
   175	    eval_path = os.path.join(base, "eval.jsonl")
   176	    checked = {"dev": True, "eval": False, "probe": False}
   177	    if os.path.isfile(eval_path):
   178	        checked["eval"] = True
   179	        items = load_jsonl(eval_path)
   180	        want = {r["qid"] for r in included}
   181	        got = [r["qid"] for r in items]
   182	        if sorted(got) != sorted(want) or len(got) != len(set(got)):
   183	            findings.append("EVAL-COUNT: phrasing qids != included eval qids")
   184	        form_lint(findings, "EVAL-FORM", items)
   185	        by_qid = {r["qid"]: r for r in included}
   186	        mock_texts = {p["text"] for p in
   187	                      gen_mock_phrasings.generate(root, vertical)}
   188	        fam_templates = {}
   189	        for r in items:
   190	            rec = by_qid.get(r["qid"])
   191	            if rec is None:
   192	                continue
   193	            if r["text"] in mock_texts:
   194	                findings.append("EVAL-NO-MOCK: %s equals a mock template"
   195	                                % r["qid"])
   196	            if rec["class"] == "covered":
   197	                q = rec.get("query") or {}
   198	                ent_urns = [q.get(k) for k in ("subject", "entity", "of")
   199	                            if isinstance(q.get(k), str)]
   200	                ent_surf = set()
   201	                for u in ent_urns:
   202	                    ent_surf |= surfaces(u)
   203	                low_raw = re.sub(r"\s+", " ", r["text"].lower().strip())
   204	                masked = mask_template(r["text"], ent_surf)
   205	                # EVAL-NO-ANSWER masked forced-substring rule (FK-NLB-11 /
   206	                # ASM-0423): flag an answer surface only if it SURVIVES masking
   207	                # of the entity identifier; a leak removed entirely by the mask
   208	                # is a forced substring of the mandatory verbatim identifier
   209	                # (ASM-0142) -> EXEMPT and disclosed in waived_forced_substring.
   210	                val = rec["expected"].get("value")
   211	                vals = val if isinstance(val, list) else [val]
   212	                ans_surf = set()
   213	                for v in vals:
   214	                    if isinstance(v, str) and v.startswith(_ENT_PREFIX):
   215	                        ans_surf |= surfaces(v)
   216	                leaked_masked = any(_has_surface(masked, s) for s in ans_surf)
   217	                leaked_raw = any(_has_surface(low_raw, s) for s in ans_surf)
   218	                if leaked_masked:
   219	                    findings.append("EVAL-NO-ANSWER: %s leaks expected value"
   220	                                    % r["qid"])
   221	                elif leaked_raw:
   222	                    waived.append(r["qid"])
   223	                fam_templates.setdefault(rec["family"], []).append(
   224	                    (masked, q, r["text"]))
   225	        for fam, rows in fam_templates.items():
   226	            n = len(rows)
   227	            tpls = [t for t, _q, _x in rows]
   228	            distinct = len(set(tpls))
   229	            if distinct < min(6, n):
   230	                findings.append("EVAL-DIVERSITY: family %s has %d distinct "
   231	                                "templates over %d items" % (fam, distinct, n))
   232	            most = max(tpls.count(t) for t in set(tpls))
   233	            if n >= 2 and most > 0.5 * n:
   234	                findings.append("EVAL-DIVERSITY: family %s dominant template "
   235	                                "%d/%d > 50%%" % (fam, most, n))
   236	            scaffold = 0
   237	            for tpl, q, _x in rows:
   238	                lab = urn2label.get(q.get("rel") or q.get("concept"), "")
   239	                lab = (lab or "").replace("-", " ")
   240	                if lab and re.search(
   241	                        r"^(?:who|what|which|list|how many|where)\b.*\bthe %s"
   242	                        r"(?: of)? @" % re.escape(lab.split(" of")[0]), tpl):
   243	                    scaffold += 1
   244	            if n >= 2 and scaffold > 0.5 * n:
   245	                findings.append("EVAL-SCAFFOLD: family %s canonical scaffold "
   246	                                "%d/%d > 50%%" % (fam, scaffold, n))
   247	
   248	    # ---------------- PROBE (descriptive synonym probe; optional)
   249	    probe_path = os.path.join(base, "probe.jsonl")
   250	    if os.path.isfile(probe_path):
   251	        checked["probe"] = True
   252	        probe = load_jsonl(probe_path)
   253	        covered_qids = {r["qid"] for r in included if r["class"] == "covered"}
   254	        if len(probe) != 60:
   255	            findings.append("PROBE-COUNT: expected 60, got %d" % len(probe))
   256	        by_qid = {r["qid"]: r for r in included}
   257	        for r in probe:
   258	            if r["qid"] not in covered_qids:
   259	                findings.append("PROBE-COUNT: %s is not a covered eval qid"
   260	                                % r["qid"])
   261	                continue
   262	            q = by_qid[r["qid"]].get("query") or {}
   263	            lab = urn2label.get(q.get("rel") or q.get("concept"))
   264	            if lab:
   265	                low = r["text"].lower()
   266	                if lab in low or lab.replace("-", " ") in low:
   267	                    findings.append("PROBE-NO-LABEL: %s contains label %r"
   268	                                    % (r["qid"], lab))
   269	        form_lint(findings, "PROBE-FORM", probe)
   270	
   271	    return findings, checked, sorted(waived)
   272	
   273	
   274	def file_sha256(path):
   275	    h = hashlib.sha256()
   276	    with open(path, "rb") as f:
   277	        h.update(f.read())
   278	    return h.hexdigest()
   279	
   280	
   281	def main():
   282	    ap = argparse.ArgumentParser()
   283	    ap.add_argument("--vertical", required=True, choices=("l3a", "a5"))
   284	    ap.add_argument("--root", default=_ROOT)
   285	    ap.add_argument("--receipt", action="store_true")
   286	    ap.add_argument("--arms-profile", choices=("model", "deterministic-r0"),
   287	                    default="model",
   288	                    help="FK-NLB-11/ASM-0423 fail-closed guard (design doc "
   289	                         "14.8): under the DEFAULT 'model' profile a "
   290	                         "nonempty waived_forced_substring list BLOCKS "
   291	                         "green (a model arm can read the answer off the "
   292	                         "question); pass 'deterministic-r0' only for a "
