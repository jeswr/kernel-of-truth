   358	                         "g5_deranged_collapse": g5, "g6_determinism": g6,
   359	                         "g7_harness_pins": g7})
   360	    out["gates"]["instrument_valid"] = all((g0, g1, g2, g3, g4, g5, g6, g7))
   361	
   362	    # ---- primary (retained == absolute: measured gold ceiling 855/855)
   363	    a = out["analysis"]
   364	    cov = n_exact / float(nc) if nc else 0.0
   365	    a["n_covered"], a["n_control"], a["n_dev"] = nc, ng, dev_n
   366	    a["retained_covered_exact_rate"] = cov
   367	    a["retained_covered_exact_wilson_lb"] = wilson(cov, nc, Z_PRIMARY)
   368	    a["retained_covered_exact_wilson_ub"] = wilson(cov, nc, Z_PRIMARY, True)
   369	
   370	    # ---- secondaries (one Holm family, m=2)
