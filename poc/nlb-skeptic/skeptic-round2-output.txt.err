+{"analysis_plan_ref":{"anchor":"1.6","path":"docs/research-plan/08-stats-and-extrapolation.md","sha256":"823b321d9b27d5648bfd6f8d9bf55d3b446712e91f9b6d444ac4cc9de98d5c86"},"budget":{"gpu_hours_cap":0,"usd_cap":10,"wall_clock_cap_hours":12},"coverage_requirement":{"rung_field":"coverage_rung","source":"m0b"},"depends_on":["g9","m0b"],"design":{"arms_mandatory_baselines":["deranged-explication probe (the judge-level content-scramble control, house shuffled-kernel idiom: own paraphrase deranged out via seed-pinned Sattolo cycle => correct substitutability answer 'no' by construction; measures false-endorsement propensity = the channel that would fabricate a proxy-PASS from NSM-style familiarity)","deepnsm-8b-published-point-estimate (the frozen g9 comparator verbatim: published point 0.24, margin +0.10 => threshold 0.34; published CIs unavailable; SEVERITY-COMPARABILITY of a proxy judge to the published evaluation protocol is uncalibrated — named binding weakening, the margin comparison is form-preserving only)","kernel-as-text null and host-model arms: NOT APPLICABLE by design — no host model, no GPU cell; this record measures a reviewer's endorsement of authored explications, not model lift"],"dependent_vars":[{"better":"higher","definition":"A_g9p = n_composite_pass_proxy / n_labelled: share of labelled sheets with mechanical legality (MEASURED 50/50 at g9.author) AND substitutable=yes AND cross_translatable=yes; cannot-say counts against composite pass; no-label sheets leave the denominator (capped by gate). Estimand is GPT-5.x-family endorsement under blind rendering, NOT blinded human review (envelope clause 1)","name":"composite_rate_proxy","unit":"fraction"},{"better":"lower","definition":"share of labelled probe items with substitutable=yes where 'no' is correct by construction; point >= 0.30 invalidates the judge instrument (style-endorsement channel, crude form)","name":"probe_false_endorse_rate","unit":"fraction"},{"better":"n/a","definition":"per-leg diagnostic: substitutability endorsement rate alone (reported-only)","name":"sub_yes_rate","unit":"fraction"},{"better":"n/a","definition":"per-leg diagnostic: cross-translatability endorsement rate alone; REPORTED-ONLY and flagged as the weakest leg (judged property, no content control; probe xt rate reported alongside as the content-insensitivity disclosure)","name":"xt_yes_rate","unit":"fraction"},{"better":"n/a","definition":"raw per-field self-agreement over the 10 duplicate sheets; < 0.80 invalidates; pass direction validates nothing","name":"retest_agreement","unit":"fraction"}],"independent_vars":[{"levels":["review-adjudication-instrument"],"name":"arm"},{"levels":["judge-r1p (GPT-5.6-Sol, sole proxy reviewer; LLM stand-in for the g9.review blinded-human role; CROSS-VENDOR mandatory — the 50 explications are Fable-authored, so a Claude-family judge would grade its own family's authoring)"],"name":"judge_role"},{"levels":["the 50 BLINDED review sheets (byte-identical to the human g9.review materials; sheet order seed-pinned g9lp/1|judge-r1p|20260710)","deranged-explication probe (50; instrument control, seed-pinned Sattolo pairing of word/examples with another sheet's paraphrase; never in labels or the composite rate)","retest duplicates (10; stability floor; never in labels)"],"name":"item_set"}],"n_planned":{"adjudication":"judge-r1p (gpt-5.6-sol via npx-pinned codex-cli 0.144.1, reasoning effort low; invocation form byte-derived from the truthstyle-2x2 judges-invocation spec section 4.1) labels all 50 sheets in seed-pinned order, then the 50 probe items (g9lp/1|probe-order|20260710), then the 10 retest duplicates; per-item stateless hardened calls (empty out-of-repo workdir, user config ignored, memories + web search disabled, read-only sandbox, server-side output schema {substitutable, cross_translatable} each yes/no/cannot-say, zero-tool tripwire, first-valid-answer-final, <= 3 content attempts then no-label); preflight on 2 pinned calibration sheets must pass first-attempt before any real item; blinding grep audit per call (kernel/nsm/deepnsm/baartman/explication) — any hit aborts to the designer","assumptions":[{"claim":"stand-in rationale: the frozen g9 record requires g9.review to be a blinded HUMAN review (GATE-H, ~4h); that human is unavailable at run time and the maintainer requested blind-LLM stand-ins for the outstanding human annotation passes (2026-07-10) so experiments run now and are human-verified later; this record is the SEPARATE, clearly-labelled stand-in on the f2b-transfer-llmproxy model — a fresh id, never a correction of g9; registered as ASM-0550 and ASM-0520","tag":"STIPULATED"},{"claim":"judge choice: cross-vendor is mandatory because the judged artifacts are Fable-authored (design-vs-judge separation); gpt-5.6-sol effort low under npx-pinned codex-cli 0.144.1 is the established pinned blind-judge mechanism (availability + invocation semantics MEASURED at the truthstyle-2x2 staging, 2026-07-10); registered as ASM-0520 and ASM-0551","tag":"STIPULATED"},{"claim":"metric operationalisation: substitutability and cross-translatability are rendered as per-sheet blind yes/no/cannot-say judgments from the sheet bytes only; if the human g9.review operationalises the published metric definitions differently (e.g. translation-based cross-translatability), the proxy legs are form-analogous only; composite = MEASURED mechanical legality AND both judged legs; registered as ASM-0521","tag":"STIPULATED"},{"claim":"severity-comparability: the proxy judge's strictness is uncalibrated to the published DeepNSM evaluation protocol, so clearing (or missing) the +0.10 margin vs the published 0.24 point is form-preserving only and cannot bear on HS-A; direction unproven; registered as ASM-0522, load_bearing false, resolved by the human g9.review on identical sheets","tag":"EXTRAPOLATION"},{"claim":"tradition-familiarity direction: NSM-style text is plausibly in the judge family's training data and plausibly inflates endorsement; direction and size unproven; registered as ASM-0552, load_bearing false, resolved by the human-vs-proxy delta on identical sheets","tag":"EXTRAPOLATION"},{"claim":"coverage disclosure (mandatory): kernel-expressibility coverage 0.3542 at rung molecules-v0, MEASURED by m0b on one incomplete kernel-v0 instance — NOT general coverage; the 50 sheets are DeepNSM test-split words, a favourable authoring surface, and no coverage-general authoring claim exists here","tag":"MEASURED"},{"claim":"nothing here amends g9: its frozen record, blinded_review_done gate, GATE-H human review path and single review stage stand exactly as frozen; this record neither sets g9's review gate nor appends to its log; proxy outputs are quarantined from any future human reviewer (ASM-0553)","tag":"BINDING-NOTE"}],"detectable_alternative":"at expected composite rate 0.60 (the frozen g9 declaration), n=50 fully labelled: Wilson LB ~0.484 >= 0.34 (clears); FAIL-analog reachable from true rates <~0.22 (UB at 0.20, n=50 ~0.307 < 0.34); both branches remain live at the n_labelled floor 45","instrument_gates":"adjudication_valid: preflight_pass AND n_labelled >= 45 AND n_nolabel <= 5 AND retest raw per-field agreement >= 0.80. probe_valid: n_probe_labelled >= 45 AND probe substitutability false-endorsement point-rate < 0.30. Failures are INSTRUMENT-INVALID, never FAIL/PASS","n_sheets":50,"probe":50,"retest":10,"stage_discipline":"freeze BEFORE any judge call; stage judge-invocation spec + prompt template + output schema + probe manifest + calibration items -> ops amendment pins them (artifact_hashes placeholders) -> preflight -> 50 real sheets -> 50 probes -> 10 retests -> assemble data/g9-review-llmproxy -> corpus-pin ops amendment -> log-append the single final-phase record -> verdict-gen -> cross-vendor audit (family overlap with the judge DISCLOSED; the audit is mechanical recomputation from pinned bytes and does not validate judge quality) -> Fable interpretive assessment"},"scale_rungs":["none (blinded-review adjudication only; no host model; no GPU)"],"seeds":[0]},"efficiency_relevant":false,"endpoints":[{"id":"primary","metric":"/analysis/wilson_lb_proxy","role":"primary","test":"one-sided alpha=0.05 (z=1.645, the pinned analysis/g9.py closed form): Wilson 95% LB of the composite proxy rate over labelled sheets vs margin_threshold = 0.24 + 0.10 = 0.34 (the frozen g9 bar verbatim). PASS-analog iff LB >= 0.34; FAIL-analog iff UB < 0.34; else INCONCLUSIVE — and the extrapolation envelope caps ANY PASS at 'weak feasibility proxy'","wilson_gate":{"expected_rate":0.6,"n_planned":50,"threshold":0.34}},{"id":"sec-adjudication-gate","metric":"/gates/adjudication_valid","role":"secondary","test":"INSTRUMENT gate (never a hypothesis test): preflight_pass AND n_labelled >= 45 AND n_nolabel <= 5 AND retest raw per-field agreement >= 0.80; failure => INSTRUMENT-INVALID"},{"id":"sec-probe-gate","metric":"/gates/probe_valid","role":"secondary","test":"INSTRUMENT gate, point rule: deranged-explication probe substitutability false-endorsement rate >= 0.30 OR n_probe_labelled < 45 => INSTRUMENT-INVALID; the probe is the judge-level content-scramble control on the substitutability leg only"},{"id":"sec-leg-diagnostics","metric":"/analysis/xt_yes_rate","role":"secondary","test":"REPORTED-ONLY: per-leg endorsement rates (substitutability alone; cross-translatability alone) + probe cross-translatability rate — the latter documents the xt leg's content-insensitivity by construction; carries no verdict weight"},{"id":"sec-retest-diagnostic","metric":"/analysis/retest_agreement","role":"secondary","test":"REPORTED-ONLY + consumed by the adjudication gate in its FAIL direction: raw self-agreement over 10 duplicates; high agreement validates nothing (single judge)"}],"extrapolation_envelope_verbatim":"Binding on ANY verdict of this record and on every citation of its numbers. STAND-IN, NOT THE ADJUDICATING REVIEW: the g9.review blinded-reviewer role is filled by a pinned LLM (GPT-5.6-Sol via npx-pinned codex-cli 0.144.1, reasoning effort low) because the blinded HUMAN reviewer the frozen g9 record requires (GATE-H, ~4h) is unavailable at run time; g9 (frozen_sha256 cf56c5cea66c7207cbd693914eebcf0d0244c8d5ef249f5065300eff8ab00aa8) remains FROZEN, unconsumed, and is the ONLY experiment on this line whose readout adjudicates HS-A. The composite score here IS one LLM's blind endorsement of substitutability and cross-translatability — NOT a blinded human review and NOT the published DeepNSM evaluation protocol. Binding weakenings: (1) SINGLE LLM REVIEWER — the estimand is 'GPT-5.x-family endorsement of the authored explications under blind sheet rendering', which family-level bias can inflate or deflate independent of real explication quality; there is no second reviewer; the retest floor is stability only and validates nothing in its pass direction. (2) TRADITION FAMILIARITY — the judge is kernel-instance-naive by context control but NOT NSM-tradition-naive (ASM-0552): it may endorse a familiar reductive-paraphrase STYLE rather than judge substitutability from language competence — a channel that inflates the composite rate; the deranged-explication probe bounds only its crudest form, and ONLY on the substitutability leg. (3) CROSS-TRANSLATABILITY IS THE WEAKEST LEG — it is operationalised as a judged text-intrinsic property (ASM-0521), has NO content-scramble control by construction, and is form-analogous at best to the published metric definition; its endorsement rate is disclosed per-leg so no reader can attribute composite strength to it silently. (4) SEVERITY-COMPARABILITY UNCALIBRATED (ASM-0522) — the +0.10 margin vs the published 0.24 point presumes protocol-comparable judge severity; a proxy judge's severity is unknown relative to the published evaluation, so clearing or missing the margin is form-preserving only: NEITHER outcome bears on HS-A, the why-now argument, or authoring-cost estimates in any plan document. (5) LICENSE OF A PASS — a PASS means exactly: 'a kernel-instance-naive cross-vendor LLM, under blind sheet rendering with a working escape, endorses the 50 Fable-authored explications at the frozen composite bar'. It is a WEAK FEASIBILITY PROXY (ASM-0550). It does NOT discharge g9's blinded_review_done gate, does NOT adjudicate HS-A, does NOT substitute for the GATE-H human review, does NOT license any authoring-cost claim in any prospectus or plan document, and does NOT extend to human reviewers, other authoring runs, other word sets, or any coverage-general claim (kernel-expressibility coverage 0.3542 at rung molecules-v0, MEASURED by m0b on one incomplete kernel-v0 instance, restated mandatorily). (6) ASYMMETRIC READING — the named channels plausibly push endorsement UP, so FAIL-analog is the more informative outcome: it warrants pausing authoring-cost claims and escalating to the maintainer, while remaining formally scoped to this proxy id; a PASS licenses only continued investment (human reviewer recruitment, authoring-pipeline continuation) and never upgrades any claim. (7) Sheet bytes and the withheld-reference blinding are byte-identical to the human g9.review materials; per-sheet proxy labels are pinned so the eventual human review yields a free human-vs-proxy bias measurement (ASM-0553); nothing else carries over.","frozen_at":"2026-07-10T18:43:21Z","frozen_by":"runner-1","frozen_sha256":"bc15a9e21e038d09b98c1c7f2425f9b9a4d36b1437a68289b371fd88ff175bf6","hypotheses":["H-G9P-ENDORSE (the only load-bearing hypothesis, scoped to the proxy): a kernel-instance-naive cross-vendor LLM reviewer, shown ONLY the blinded sheet bytes (word, def, examples, ambig examples, proposed paraphrase; reference explications and authoring notes withheld exactly as for the human), endorses the authored explications at the frozen g9 bar: one-sided 95% Wilson LB of the composite proxy rate >= 0.34 over the 50 sheets. A PASS is a WEAK FEASIBILITY SIGNAL only; a FAIL is the g9-kill analog at this proxy id (early warning, escalate)","H-G9P-STYLE (instrument alternative, controlled): high endorsement could be NSM-style/tradition familiarity rather than content judgment; the deranged-explication probe (own-paraphrase deranged out via seed-pinned Sattolo cycle; correct substitutability answer 'no' by construction) bounds the crude form on the substitutability leg ONLY — false-endorsement >= 0.30 invalidates the instrument, never reads as a hypothesis outcome; the cross-translatability leg has NO content-scramble control by construction (text-intrinsic property; disclosed weakening)","H-G9P-STABLE (instrument floor, FAIL-direction only): 10 seed-pinned duplicate sheets re-asked; raw per-field self-agreement < 0.80 invalidates; its pass direction validates nothing (single judge)"],"id":"g9-llmproxy","kill_criterion_verbatim":"g9-llmproxy kill (PROXY-ONLY, zero GPU, the g9.review role filled by the pinned GPT-5.6-Sol stand-in): FAIL-analog fires iff the one-sided 95% Wilson UPPER bound of the composite proxy rate < 0.34 over the labelled sheets (composite = MEASURED mechanical legality AND substitutable=yes AND cross_translatable=yes; cannot-say counts against pass; no-label leaves the denominator, capped by gate). This mirrors the frozen g9 kill ('not decisively better than DeepNSM-8B') in FORM ONLY; it can neither fire nor discharge g9's own kill, whose reviewer is a blinded HUMAN (GATE-H), and it cannot weaken or strengthen the why-now argument or revert any authoring-cost estimate — a proxy FAIL-analog warrants pausing authoring-cost claims and escalating to the maintainer, formally scoped to this proxy id. Degeneracy discipline (INSTRUMENT-INVALID, never FAIL/PASS): preflight failure; n_labelled < 45 of 50; n_nolabel > 5; retest raw agreement < 0.80; probe false-endorsement >= 0.30 or probe coverage < 45/50 (a judge endorsing substitutability of deranged paraphrases at >= 0.30 is answering from style/familiarity, and its endorsement of the real sheets cannot be read as content endorsement — exactly the channel that would fabricate a proxy-PASS).","pins":{"analysis_script":{"output_fields":["/gates/adjudication_valid","/gates/probe_valid","/analysis/n_sheets","/analysis/n_labelled","/analysis/n_nolabel","/analysis/n_composite_pass_proxy","/analysis/composite_rate_proxy","/analysis/wilson_lb_proxy","/analysis/wilson_ub_proxy","/analysis/margin_threshold","/analysis/clears_margin_proxy","/analysis/below_margin_proxy","/analysis/sub_yes_rate","/analysis/xt_yes_rate","/analysis/probe_false_endorse_rate","/analysis/probe_xt_yes_rate","/analysis/retest_agreement"],"path":"analysis/g9_llmproxy.py","sha256":"fc889af1786f1c110c6f8095457416e6a267963a514555cce04af00f369467bf"},"artifact_hashes":{"analysis/g9.py (Wilson closed-form + margin source, read-only reference)":"6a105f935e33c24c1d78ccd775b4732e15ee9253d33cf2f79bbda01cca5ecabc","data/authored-explication-set/review/sheets.json":"55082b1588c1c4f55b15fd07c6fbbc1b941d8fcb948de94e69b3f0e1d05b8c7c","data/authored-explication-set/validation/mechanical-summary.json":"a8c8ef69f8e4f4317910ab8221c6566ff931f18f2ec10a63d7b9ae177f7bf0fe","poc/g9-llmproxy/build-deranged-probe.py":"b6db890b5a39d91aa2cbf2e4126560a4c9add51c957555fb309ccc2fbd5dfa3a","poc/g9-llmproxy/calibration-sheets.jsonl":"0dd9ec51c0f16367652f42f6ac575b91f33b28757153f7c8d376bc8ea9d53e16","poc/g9-llmproxy/deranged-probe-manifest.json":"bd1d90d2293f6c1e58f981a09d82320e1a6a98b4450a5c19c32862bcb5577269","poc/g9-llmproxy/deranged-probe.jsonl":"c53ee4a84153456bdd421779b8cb57267f7bbe539cf4bac112640ca0775fa2a0","poc/g9-llmproxy/judge-invocation.md":"d9c256027e842303622786ef442490ed5bc9609ba1fd5949ee42630aaa9dfbfd","poc/g9-llmproxy/output-schema.json":"f0d18c1b85cd05f6d404906ba9ce7bf0834b3a9836d44f4bd8601c03164a7543","poc/g9-llmproxy/prompt-template.txt":"c855cc3c27a1bba5b375aad6fbb060fb2ae9df6e9b1a3d759795aaad0e961916"},"corpus_hashes":{"_recipe":"kot-corpus-hash/1: digest = sha256 over the UTF-8 concatenation of one line per regular file under data/<corpus>/ (recursive; symlinks and directories excluded), each line '<sha256-of-file-bytes-hex>  <relpath>\\n' with exactly two spaces, relpath POSIX-style ('/'-separated) relative to data/<corpus>/, lines sorted by the UTF-8 byte order of relpath; reference implementation tools/registry/corpus-pin.py","authored-explication-set":"6a51f44a079c777ffc9df412cc5eb2b41053806f383b329cda77f24c8ca1591c","g9-review-llmproxy":"PINNED-AT-INPUTS:judge-r1p responses + probe responses + labels-proxy + summary, pinned by ops amendment after the judge run and before the final-phase record","kernel-v0":"8209cadabcfc2eaa11631c5c1100c04a48f33673516780b1f36cbf957217c809"},"encoder_hash":"40e8c8ba4c3d081c5051ea62d946d2ee9ee9f3205853b5c377a4c1e647e2d10c","model_revisions":{"_note":"no host models: zero GPU cells in this record","judge-r1p":"gpt-5.6-sol via npx-pinned codex-cli 0.144.1, reasoning effort low (catalog + invocation semantics MEASURED at the truthstyle-2x2 staging 2026-07-10; re-verify version banner at preflight)"}},"prereg_doc":{"anchors":["S1","S2","S3","S4","S5","S6"],"path":"poc/g9-llmproxy/design.md","sha256":"f46ffb4d766e914b0920b925ee939231c3cff627deb9bfc0b320935cf12483ea"},"runner_constraints":{"authorization":"maintainer-requested stand-in (2026-07-10): blind-LLM proxies for the outstanding human annotation passes, human-verified later, per the f2b-transfer-llmproxy precedent (ASM-0550); usd_cap 10 sits inside every auto-authorization envelope; budget.maintainer_signoff reserved for Tier-5 records and deliberately absent","concurrency_cap":1,"foreground_gates":true,"harness":"poc/g9-llmproxy/judge-invocation.md (mechanical; staged + pinned pre-run; any undecided situation is a BOUNDARY STOP back to the designer, never runner improvisation)","infra":"sequential per-item codex exec calls, concurrency 1","provider":"openai-codex-cli (npx-pinned 0.144.1)","tier":0,"tier_cap_usd":10},"schema_version":"kot-reg/2","status":"FROZEN","title":"g9-llmproxy — STAND-IN blinded review: a pinned cross-vendor LLM (GPT-5.6-Sol) fills the g9.review blinded-reviewer role over the SAME 50 blinded sheets (substitutability + cross-translatability, composite with the MEASURED mechanical legality leg) because the GATE-H blinded HUMAN review is unavailable at run time; deranged-explication probe as the content-scramble control on the substitutability leg, retest stability floor, zero GPU; the human-reviewed g9 remains FROZEN, unconsumed, and solely adjudicating for HS-A","verdict_rules":[{"verdict":"INSTRUMENT-INVALID","when":{"a":{"a":{"metric":"/gates/adjudication_valid"},"b":{"metric":"/gates/probe_valid"},"op":"and"},"op":"not"}},{"verdict":"FAIL","when":{"metric":"/analysis/below_margin_proxy"}},{"verdict":"PASS","when":{"metric":"/analysis/clears_margin_proxy"}},{"verdict":"INCONCLUSIVE","when":{"const":true}}]}
