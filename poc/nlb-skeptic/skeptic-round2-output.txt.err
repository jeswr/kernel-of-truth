   200	def score_z(p_hat, p0, n, direction):
   201	    """One-sided score-test statistic used ONLY to order the two Holm
   202	    hypotheses (larger z == smaller p). direction 'gt': H1 p > p0;
   203	    'lt': H1 p < p0."""
