   566	    assert kill["analysis"]["retained_covered_exact_wilson_ub"] <= FLOOR, kill
   567	    assert nokill["analysis"]["retained_covered_exact_wilson_ub"] > FLOOR, \
   568	        nokill
   569	    # S1 boundary at the HOLM-WORST level: with S2 at 5/527 (z ~1.72), S1
   570	    # wins the ordering at both 264/270 (z ~2.09) and 263/270 (z ~1.81) and
   571	    # is therefore tested at alpha/2 (z=1.96) — 264 passes, 263 fails (and
   572	    # blocks S2). w=5 is the unique in-scope wrong count that keeps S1 first
   573	    # AND lets S2 pass at nominal when S1 passes (UB(5/527,1.645)=0.0194).
   574	    s1hi = analyze(_suite(control_accept=264,
   575	                          covered={"unique-father": _fam(122, exact=117,
   576	                                                         wrong=5)}))["analysis"]
   577	    s1lo = analyze(_suite(control_accept=263,
   578	                          covered={"unique-father": _fam(122, exact=117,
   579	                                                         wrong=5)}))["analysis"]
   580	    assert s1hi["holm_s1_pass"] is True and s1hi["holm_s2_pass"] is True, s1hi
   581	    assert s1lo["holm_s1_pass"] is False and s1lo["holm_s2_pass"] is False, \
   582	        s1lo
   583	    # S1 at the nominal-alpha leg (S2 dominant at 0/527): 263/270 passes
   584	    s1nom = analyze(_suite(control_accept=263))["analysis"]
   585	    assert s1nom["holm_s1_pass"] is True, s1nom
   586	    # S2 Holm-worst boundary (4 vs 5 wrong at z=1.96), asserted directly
   587	    assert wilson(4 / 527.0, 527, Z_HOLM_FIRST, True) < S2_GATE
   588	    assert wilson(5 / 527.0, 527, Z_HOLM_FIRST, True) > S2_GATE
   589	    s2a = analyze(_suite(covered={"unique-father": _fam(122, exact=118,
   590	                                                        wrong=4)}))["analysis"]
   591	    assert s2a["holm_s2_pass"] is True, s2a
   592	    # S2 kill boundary, unadjusted z=1.645 (fires from 16/527)
   593	    s2c = analyze(_suite(covered={"unique-father": _fam(122, exact=106,
   594	                                                        wrong=16)}))["analysis"]
   595	    s2d = analyze(_suite(covered={"unique-father": _fam(122, exact=107,
   596	                                                        wrong=15)}))["analysis"]
   597	    assert s2c["covered_wrong_answer_wilson_lb"] >= S2_GATE, s2c
   598	    assert s2d["covered_wrong_answer_wilson_lb"] < S2_GATE, s2d
