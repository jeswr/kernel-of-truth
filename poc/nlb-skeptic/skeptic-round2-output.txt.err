   450	def _rec(arm, covered=None, control_accept=106, control_parse=24, **kw):
   451	    # Covered families default to all-exact; `covered` overrides named
   452	    # families with explicit buckets (run-level covered twins are DERIVED
   453	    # from by_family so G1 twins-integrity holds by construction). Control
   454	    # counters keep the score_nl identities: acceptable = strict + parse,
   455	    # other = n_control - acceptable (answered 0), any = acceptable + other.
   456	    cov = {k: _fam(v) for k, v in PLANNED_COVERED_STRATA.items()}
   457	    for k, b in (covered or {}).items():
   458	        assert b["n"] == PLANNED_COVERED_STRATA[k], (k, b)
   459	        cov[k] = b
   460	    fam = dict(cov)
   461	    for k, v in PLANNED_CONTROL_STRATA.items():
   462	        fam[k] = {"n": v, "ok": v, "exact": 0, "wrong": 0,
   463	                  "refused_parse": 0, "refused_engine": 0}
   464	    ce = sum(cov[k]["exact"] for k in cov)
   465	    cw = sum(cov[k]["wrong"] for k in cov)
   466	    cp = sum(cov[k]["refused_parse"] for k in cov)
   467	    cg = sum(cov[k]["refused_engine"] for k in cov)
   468	    ctl_other = PLANNED_CONTROL - control_accept
   469	    m = {"n_covered": 855, "n_covered_exact": ce,
   470	         "n_covered_refused_parse": cp, "n_covered_refused_engine": cg,
   471	         "n_covered_answered_wrong": cw, "n_control": 106,
   472	         "n_control_refused_acceptable": control_accept,
   473	         "n_control_refused_strict_engine_code":
   474	             control_accept - control_parse,
   475	         "n_control_refused_parse": control_parse,
   476	         "n_control_refused_other": ctl_other,
   477	         "n_control_answered": 0,
   478	         "n_control_refused_any": control_accept + ctl_other,
   479	         "by_family": fam, "parse_stage_breakdown": {},
   480	         "label_strata": {"verbatim": {"n": 455, "exact": 455},
   481	                          "paraphrase": {"n": 400, "exact": 400}},
   482	         "dev_n": 60, "dev_parse_refused": 4,
   483	         "deterministic_repeat_identical": True,
   484	         "frontend_total_ns": 960000000}
   485	    m.update(kw)
   486	    body = {"experiment": EXPERIMENT, "config": {"arm": arm}, "metrics": m,
   487	            "pins_observed": _pins()}
   488	    if arm == "gold-replication":
   489	        body["metrics"] = dict(GOLD_PERFECT)
   490	        body["metrics"]["deterministic_repeat_identical"] = True
   491	    if arm == "deranged-lexicon":
   492	        m2 = dict(m)
   493	        m2.update({"n_covered_exact": 0, "n_covered_answered_wrong": 38})
   494	        body["metrics"] = m2
   495	    return body
