   312	def confirmed_audit(root, exp_id, runner_ids):
   313	    """Return the path of a CONFIRMED audit by a non-runner identity, or None."""
   314	    for path in sorted(glob.glob(os.path.join(root, "registry", "audits", exp_id, "*.json"))):
   315	        with open(path, "r", encoding="utf-8") as f:
   316	            audit = json.load(f)
   317	        if audit.get("outcome") != "CONFIRMED":
