   298	    if args.arms_profile == "model" and waived:
   299	        findings.append(
   300	            "EVAL-NO-ANSWER: %d waived_forced_substring qid(s) are direct "
   301	            "answer leaks under a model-based arm (FK-NLB-11/ASM-0423: the "
   302	            "forced-substring exemption is lawful ONLY for deterministic "
   303	            "surface-blind arms) — exclude or re-phrase them, or attest "
   304	            "--arms-profile deterministic-r0" % len(waived))
   305	    green = not findings
   306	    out = {"schema": "nlb-lint-receipt/1", "vertical": args.vertical,
   307	           "green": green, "checked": checked, "findings": findings,
   308	           "waived_forced_substring": waived}
   309	    print(json.dumps(out, indent=1, sort_keys=True))
   310	    if args.receipt:
   311	        base = os.path.join(args.root, "data",
   312	                            "nlb-phrasings-%s" % args.vertical)
   313	        pins = {}
   314	        for name in ("dev.jsonl", "dev-entities.jsonl", "eval.jsonl",
   315	                     "probe.jsonl"):
   316	            p = os.path.join(base, name)
   317	            if os.path.isfile(p):
   318	                pins[name] = file_sha256(p)
   319	        out["pins"] = pins
   320	        rp = os.path.join(base, "lint-receipt.json")
   321	        with open(rp, "w", encoding="utf-8") as f:
   322	            json.dump(out, f, indent=1, sort_keys=True)
   323	            f.write("\n")
   324	        print("receipt -> %s" % rp, file=sys.stderr)
   325	    sys.exit(0 if green else 1)
