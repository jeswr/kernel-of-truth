   639	    assert analyze(recs)["gates"]["g1_counts"] is False
   640	    # G1 (14.8): broken control partition (acceptable != strict + parse)
   641	    recs = _suite()
   642	    recs[0]["metrics"]["n_control_refused_strict_engine_code"] = 220
   643	    assert analyze(recs)["gates"]["g1_counts"] is False
   644	    # G0 (14.8): duplicate mapper-parse rows are INVALID in BOTH log orders
   645	    stale = _rec("mapper-parse", covered={"unique-father": _fam(122, exact=0,
   646	                                                                rparse=122)})
   647	    good = _suite()
   648	    for order in ([stale] + good, good + [stale]):
   649	        o = analyze(order)
