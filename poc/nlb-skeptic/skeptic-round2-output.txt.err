import importlib.util, json, copy, math
mods=[]
for name,path in [('l3','analysis/l3a_parse.py'),('a5','analysis/a5_nl.py')]:
 s=importlib.util.spec_from_file_location(name,path); m=importlib.util.module_from_spec(s); s.loader.exec_module(m); mods.append((name,m))
for name,m in mods:
 base=m._suite()
 stale=m._rec('mapper-parse')
 # mutate stale to be distinct and bad while maintaining internal integrity
 fam = 'unique-father' if name=='l3' else 'contained-in'
 n=m.PLANNED_COVERED_STRATA[fam]
 stale=m._rec('mapper-parse', covered={fam:m._fam(n, exact=0, rparse=n)})
 print('\\n',name)
 for order in ([stale]+base,base+[stale]):
  o=m.analyze(order); print('dup',o['gates']['g0_one_row_per_arm'],o['gates']['instrument_valid'])
 new=m._suite(); new[0]['supersedes']=[m._body_sha(stale)]
 for order in ([stale]+new,new+[stale]):
  o=m.analyze(order); print('supersede-list',o['gates']['g0_one_row_per_arm'],o['gates']['instrument_valid'],o['analysis'].get('retained_covered_exact_rate'))
 # malformed dict accepted
 new=m._suite(); new[0]['supersedes']={m._body_sha(stale):'not-a-list'}
 o=m.analyze([stale]+new); print('supersede-dict',o['gates']['g0_one_row_per_arm'],o['gates']['instrument_valid'])
 # unrelated answer-all row can supersede stale mapper
 new=m._suite(); new[4]['supersedes']=[m._body_sha(stale)]
 o=m.analyze([stale]+new); print('cross-arm-supersede',o['gates']['g0_one_row_per_arm'],o['gates']['instrument_valid'])
 # two surviving rows
 o=m.analyze(base+[copy.deepcopy(base[0])]); print('identical-duplicate-survives',o['gates']['g0_one_row_per_arm'],o['gates']['instrument_valid'])
 # G5 variants
 for label,dm in [('empty',{}),('missing-exact',{'n_covered':m.PLANNED_COVERED}),('float-exact',{'n_covered':m.PLANNED_COVERED,'n_covered_exact':0.0}),('minimal-two-fields',{'n_covered':m.PLANNED_COVERED,'n_covered_exact':0})]:
  rs=m._suite(); rs[2]['metrics']=dm; o=m.analyze(rs); print('g5-'+label,o['gates']['g5_deranged_collapse'],o['gates']['instrument_valid'])
 rs=m._suite(); rs[2]['config']['arm']='wrong-name'; o=m.analyze(rs); print('g5-wrong-name',o['gates'].get('g5_deranged_collapse'),o['gates']['instrument_valid'])
 # G7 every arm missing/drift/malformed
 for i in range(5):
  rs=m._suite(); rs[i].pop('pins_observed'); o=m.analyze(rs); print('g7-missing-arm'+str(i),o['gates']['g7_harness_pins'],o['gates']['instrument_valid'])
 rs=m._suite(); rs[0]['pins_observed']['engine']['observed']=rs[0]['pins_observed']['engine']['observed'][:8]; print('g7-truncated',m.analyze(rs)['gates']['g7_harness_pins'])
 rs=m._suite(); rs[0]['pins_observed']['engine']='bad'; print('g7-malformed',m.analyze(rs)['gates']['g7_harness_pins'])
 # counts reproduced and variants
 rs=m._suite(); rs[0]['metrics']['n_covered_refused_parse']=m.PLANNED_COVERED; o=m.analyze(rs); print('counts-duplicate-full',o['gates']['g1_counts'],o['gates']['instrument_valid'])
 rs=m._suite(); rs[0]['metrics']['by_family']['unexpected']=m._fam(1); print('counts-unexpected-family',m.analyze(rs)['gates']['g1_counts'])
 rs=m._suite(); first=next(iter(m.PLANNED_COVERED_STRATA)); rs[0]['metrics']['by_family'][first]['wrong']=-1; print('counts-negative',m.analyze(rs)['gates']['g1_counts'])
 rs=m._suite(); rs[0]['metrics']['n_control_answered']=m.PLANNED_CONTROL; print('counts-control-double',m.analyze(rs)['gates']['g1_counts'])
 for v in (-1,0.5):
  rs=m._suite(); rs[0]['metrics']['dev_parse_refused']=v; o=m.analyze(rs); print('dev-malformed',repr(v),o['gates']['g4_dev_abstention'],o['gates']['instrument_valid'],o['analysis'].get('dev_abstention_rate'))

# Wilson complement all k and boundary exactness
m=mods[0][1]
for n,k in [(527,4),(855,9)]:
