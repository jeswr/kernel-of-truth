   504	def selftest():
   505	    base = analyze(_suite())
   506	    assert base["gates"]["instrument_valid"] is True, base["gates"]
   507	    a = base["analysis"]
   508	    assert a["retained_covered_exact_rate"] == 1.0
   509	    assert abs(a["retained_covered_exact_wilson_lb"] - 0.996845) < 1e-4
   510	    assert a["holm_s1_pass"] and a["holm_s2_pass"]
   511	    assert a["synonym_probe"] is None
   512	    # primary decision boundary (recomputed table): the varied counts sit in
   513	    # the contained-in family so by_family twins integrity holds.
   514	    hi = analyze(_suite(covered={"contained-in": _fam(201, exact=130,
   515	                                                      rparse=71)}))["analysis"]
   516	    lo = analyze(_suite(covered={"contained-in": _fam(201, exact=129,
   517	                                                      rparse=72)}))["analysis"]
   518	    assert hi["retained_covered_exact_rate"] == 784 / 855.0, hi
   519	    assert hi["retained_covered_exact_wilson_lb"] > FLOOR, hi
   520	    assert lo["retained_covered_exact_wilson_lb"] <= FLOOR, lo
   521	    kill = analyze(_suite(covered={"contained-in": _fam(201, exact=101,
   522	                                                        rparse=100)}))["analysis"]
   523	    nokill = analyze(_suite(covered={"contained-in": _fam(201, exact=102,
   524	                                                          rparse=99)}))["analysis"]
   525	    assert kill["retained_covered_exact_wilson_ub"] <= FLOOR, kill
   526	    assert nokill["retained_covered_exact_wilson_ub"] > FLOOR, nokill
   527	    # S1 boundary at the HOLM-WORST level: with S2 at 10/855 (z ~1.73), S1
   528	    # wins the ordering at both 102/106 (z ~2.14) and 101/106 (z ~1.81) and
   529	    # is tested at alpha/2 (z=1.96): 102 passes, 101 fails (and blocks S2).
   530	    s1hi = analyze(_suite(control_accept=102,
   531	                          covered={"contained-in": _fam(201, exact=191,
   532	                                                        wrong=10)}))["analysis"]
   533	    s1lo = analyze(_suite(control_accept=101,
   534	                          covered={"contained-in": _fam(201, exact=191,
   535	                                                        wrong=10)}))["analysis"]
   536	    assert s1hi["holm_s1_pass"] is True and s1hi["holm_s2_pass"] is True, s1hi
   537	    assert s1lo["holm_s1_pass"] is False and s1lo["holm_s2_pass"] is False, \
   538	        s1lo
   539	    # S1 at the nominal-alpha leg (S2 dominant at 0/855): 101/106 passes
   540	    s1nom = analyze(_suite(control_accept=101))["analysis"]
