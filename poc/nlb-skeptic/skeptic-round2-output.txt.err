   627	    recs[0]["metrics"]["by_family"]["mystery-family"] = _fam(1)
   628	    assert analyze(recs)["gates"]["g1_counts"] is False
   629	    # G1 (14.8): nonzero covered bucket on a CONTROL family => invalid
   630	    recs = _suite()
   631	    recs[0]["metrics"]["by_family"]["no-record"]["exact"] = 1
   632	    assert analyze(recs)["gates"]["g1_counts"] is False
   633	    # G1 (14.8): negative / non-integer buckets => invalid
   634	    recs = _suite()
   635	    recs[0]["metrics"]["by_family"]["children-lookup"]["wrong"] = -1
   636	    assert analyze(recs)["gates"]["g1_counts"] is False
