   614	    # G1 counts-integrity: a broken bucket partition => instrument-invalid
   615	    broken = analyze(_suite(covered={"unique-father": {
   616	        "n": 122, "ok": 122, "exact": 100, "wrong": 0,
   617	        "refused_parse": 0, "refused_engine": 0}}))
   618	    assert broken["gates"]["instrument_valid"] is False, broken["gates"]
   619	    assert broken["gates"]["g1_counts"] is False, broken["gates"]
   620	    # G1 (14.8): mutually inconsistent RUN-LEVEL counters => invalid
   621	    recs = _suite()
   622	    recs[0]["metrics"]["n_covered_exact"] = 600
   623	    recs[0]["metrics"]["n_covered_refused_parse"] = 600
   624	    assert analyze(recs)["gates"]["g1_counts"] is False
   625	    # G1 (14.8): an unexpected family => invalid
