   651	        assert o["gates"]["instrument_valid"] is False, o["gates"]
   652	    # G0: an EXPLICIT supersede is honoured (order-independent) and the
   653	    # surviving row feeds the analysis
   654	    recs = _suite()
   655	    recs[0]["supersedes"] = [_body_sha(stale)]
   656	    for order in ([stale] + recs, recs + [stale]):
