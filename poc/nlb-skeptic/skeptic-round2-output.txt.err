   559	    recs[0]["metrics"]["n_covered_refused_parse"] = 855
   560	    o = analyze(recs)
   561	    assert o["gates"]["g1_counts"] is False, o["gates"]
   562	    assert o["gates"]["instrument_valid"] is False, o["gates"]
   563	    # G1 (14.8): a broken per-family bucket partition => invalid
   564	    broken = analyze(_suite(covered={"contained-in": {
   565	        "n": 201, "ok": 201, "exact": 150, "wrong": 0,
   566	        "refused_parse": 0, "refused_engine": 0}}))
   567	    assert broken["gates"]["g1_counts"] is False, broken["gates"]
   568	    # G1 (14.8): an unexpected family => invalid
   569	    recs = _suite()
   570	    recs[0]["metrics"]["by_family"]["mystery-family"] = _fam(1)
   571	    assert analyze(recs)["gates"]["g1_counts"] is False
   572	    # G1 (14.8): nonzero covered bucket on a CONTROL family => invalid
   573	    recs = _suite()
   574	    recs[0]["metrics"]["by_family"]["unknown-entity"]["exact"] = 1
   575	    assert analyze(recs)["gates"]["g1_counts"] is False
   576	    # G1 (14.8): negative / non-integer buckets => invalid
   577	    recs = _suite()
