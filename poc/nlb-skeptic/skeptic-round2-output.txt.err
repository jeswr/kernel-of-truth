   579	    assert analyze(recs)["gates"]["g1_counts"] is False
   580	    recs = _suite()
   581	    recs[0]["metrics"]["by_family"]["callees-of"]["exact"] = 72.0
   582	    assert analyze(recs)["gates"]["g1_counts"] is False
   583	    # G1 (14.8): broken control partition (acceptable != strict + parse)
   584	    recs = _suite()
   585	    recs[0]["metrics"]["n_control_refused_strict_engine_code"] = 70
   586	    assert analyze(recs)["gates"]["g1_counts"] is False
   587	    # G0 (14.8): duplicate mapper-parse rows are INVALID in BOTH log orders
   588	    stale = _rec("mapper-parse", covered={"contained-in": _fam(201, exact=0,
   589	                                                               rparse=201)})
   590	    good = _suite()
   591	    for order in ([stale] + good, good + [stale]):
   592	        o = analyze(order)
   593	        assert o["gates"]["g0_one_row_per_arm"] is False, o["gates"]
   594	        assert o["gates"]["instrument_valid"] is False, o["gates"]
   595	    # G0: an EXPLICIT supersede is honoured (order-independent) and the
   596	    # surviving row feeds the analysis
   597	    recs = _suite()
   598	    recs[0]["supersedes"] = [_body_sha(stale)]
   599	    for order in ([stale] + recs, recs + [stale]):
   600	        o = analyze(order)
   601	        assert o["gates"]["instrument_valid"] is True, o["gates"]
   602	        assert o["analysis"]["retained_covered_exact_rate"] == 1.0, o
   603	    # G0: a dangling supersede target fails closed
   604	    recs = _suite()
   605	    recs[0]["supersedes"] = ["0" * 64]
   606	    assert analyze(recs)["gates"]["g0_one_row_per_arm"] is False
   607	    # G5 (14.8): an EMPTY deranged arm is a broken instrument, not collapse
   608	    recs = _suite()
   609	    recs[2]["metrics"] = {}
   610	    o = analyze(recs)
   611	    assert o["gates"]["g5_deranged_collapse"] is False, o["gates"]
   612	    assert o["gates"]["instrument_valid"] is False, o["gates"]
   613	    assert o["analysis"]["deranged_retained_exact_rate"] is None, o
