-  "endpoints": [
-    {"id": "primary", "role": "primary", "metric": "/analysis/wilson_lb_proxy", "test": "one-sided alpha=0.05 (z=1.645, the pinned analysis/g9.py closed form): Wilson 95% LB of the composite proxy rate over labelled sheets vs margin_threshold = 0.24 + 0.10 = 0.34 (the frozen g9 bar verbatim). PASS-analog iff LB >= 0.34; FAIL-analog iff UB < 0.34; else INCONCLUSIVE — and the extrapolation envelope caps ANY PASS at 'weak feasibility proxy'", "wilson_gate": {"expected_rate": 0.6, "n_planned": 50, "threshold": 0.34}},
-    {"id": "sec-adjudication-gate", "role": "secondary", "metric": "/gates/adjudication_valid", "test": "INSTRUMENT gate (never a hypothesis test): preflight_pass AND n_labelled >= 45 AND n_nolabel <= 5 AND retest raw per-field agreement >= 0.80; failure => INSTRUMENT-INVALID"},
