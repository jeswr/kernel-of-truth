 a=m.wilson(1-p,n,1.96,False); b=1-m.wilson(p,n,1.96,True)
 diffs=[]; mismatches=[]
 for j in range(n+1):
  q=j/n; x=m.wilson(1-q,n,1.96); y=1-m.wilson(q,n,1.96,True)
  diffs.append(abs(x-y))
  if (m.wilson(q,n,1.96,True)<.02) "'!= (m.wilson(1-q,n,1.96)>.98): mismatches.append(j)
 print('"'wilson',n,k,'equal',a==b,'hex',a.hex(),b.hex(),'delta',a-b,'max_delta',max(diffs),'decision_mismatches',mismatches[:10],len(mismatches))
