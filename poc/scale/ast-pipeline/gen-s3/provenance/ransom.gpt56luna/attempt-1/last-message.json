{"id":"urn:kernel-v1:ransom","label":"ransom (act of freeing)","synset":"urn:lexical-wn31:n-00097671","pattern":"InstanceSchema; captivity-release polarity across a time boundary","gloss":"An act by which a person held against their will or undergoing an imposed penalty is released from that condition, so that the confinement or penal treatment ceases.","explication":{"schema":"kot-ast/1","frame":"InstanceSchema","referents":[{"index":1,"refKind":"SomethingRef"},{"index":2,"refKind":"SomeoneRef"},{"index":3,"refKind":"SomethingRef"},{"index":4,"refKind":"TimeRef"}],"clauses":[{"type":"pred","pred":"HAPPEN","roles":{"undergoer":{"kind":"ref","index":1},"time":{"kind":"sp","det":"SOME","head":{"kind":"primeHead","prime":"WHEN~TIME"},"bind":4}}},{"type":"op","op":"BEFORE","args":[{"kind":"ref","index":4},{"type":"pred","pred":"BE-SOMEWHERE","roles":{"undergoer":{"kind":"sp","det":"SOME","head":{"kind":"primeHead","prime":"SOMEONE"},"bind":2},"locus":{"kind":"sp","det":"SOME","head":{"kind":"primeHead","prime":"SOMETHING~THING"},"bind":3},"manner":{"kind":"prime","prime":"INSIDE"}}}]},{"type":"op","op":"BEFORE","args":[{"kind":"ref","index":4},{"type":"op","op":"NOT","args":[{"type":"op","op":"CAN","args":[{"type":"pred","pred":"MOVE","roles":{"undergoer":{"kind":"ref","index":2}}}]}]}]},{"type":"op","op":"AFTER","args":[{"kind":"ref","index":4},{"type":"op","op":"CAN","args":[{"type":"pred","pred":"MOVE","roles":{"undergoer":{"kind":"ref","index":2}}}]}]}]},"references":[],"status":"draft","notes":"AST adequacy: lossy — it renders release from captivity as a before-and-after change from being inside a place and unable to move to being able to move, but cannot encode the alternative of imposed punishment or its penal authority."}