  352| class TestTzinfoInputTypes(object):
  353|     def assert_equal_same_tz(self, dt1, dt2):
  354|         assert dt1 == dt2
  355|         assert dt1.tzinfo is dt2.tzinfo
  356| 
  357|     def test_tzinfo_dict_could_return_none(self):
  358|         dstr = "2017-02-03 12:40 BRST"
  359|         result = parse(dstr, tzinfos={"BRST": None})
  360|         expected = datetime(2017, 2, 3, 12, 40)
  361|         self.assert_equal_same_tz(result, expected)
  362| 
  363|     def test_tzinfos_callable_could_return_none(self):
  364|         dstr = "2017-02-03 12:40 BRST"
  365|         result = parse(dstr, tzinfos=lambda *args: None)
  366|         expected = datetime(2017, 2, 3, 12, 40)
  367|         self.assert_equal_same_tz(result, expected)
  368| 
  369|     def test_invalid_tzinfo_input(self):
  370|         dstr = "2014 January 19 09:00 UTC"
  371|         # Pass an absurd tzinfos object
  372|         tzinfos = {"UTC": ValueError}
  373|         with pytest.raises(TypeError):
  374|             parse(dstr, tzinfos=tzinfos)
  375| 
  376|     def test_valid_tzinfo_tzinfo_input(self):
  377|         dstr = "2014 January 19 09:00 UTC"
  378|         tzinfos = {"UTC": tz.UTC}
  379|         expected = datetime(2014, 1, 19, 9, tzinfo=tz.UTC)
  380|         res = parse(dstr, tzinfos=tzinfos)
  381|         self.assert_equal_same_tz(res, expected)
  382| 
  383|     def test_valid_tzinfo_unicode_input(self):
  384|         dstr = "2014 January 19 09:00 UTC"
  385|         tzinfos = {u"UTC": u"UTC+0"}
  386|         expected = datetime(2014, 1, 19, 9, tzinfo=tz.tzstr("UTC+0"))
  387|         res = parse(dstr, tzinfos=tzinfos)
  388|         self.assert_equal_same_tz(res, expected)
  389| 
  390|     def test_valid_tzinfo_callable_input(self):
  391|         dstr = "2014 January 19 09:00 UTC"
  392| 
  393|         def tzinfos(*args, **kwargs):
  394|             return u"UTC+0"
  395| 
  396|         expected = datetime(2014, 1, 19, 9, tzinfo=tz.tzstr("UTC+0"))
  397|         res = parse(dstr, tzinfos=tzinfos)
  398|         self.assert_equal_same_tz(res, expected)
  399| 
  400|     def test_valid_tzinfo_int_input(self):
  401|         dstr = "2014 January 19 09:00 UTC"
  402|         tzinfos = {u"UTC": -28800}
  403|         expected = datetime(2014, 1, 19, 9, tzinfo=tz.tzoffset(u"UTC", -28800))
  404|         res = parse(dstr, tzinfos=tzinfos)
  405|         self.assert_equal_same_tz(res, expected)
  406| 
  407| 
  408| class ParserTest(unittest.TestCase):
  409| 
  410|     @classmethod
  411|     def setup_class(cls):
  412|         cls.tzinfos = {"BRST": -10800}
  413|         cls.brsttz = tzoffset("BRST", -10800)
  414|         cls.default = datetime(2003, 9, 25)
  415| 
  416|         # Parser should be able to handle bytestring and unicode
  417|         cls.uni_str = '2014-05-01 08:00:00'
  418|         cls.str_str = cls.uni_str.encode()
  419| 
  420|     def testParserParseStr(self):
  421|         from dateutil.parser import parser
  422| 
  423|         assert parser().parse(self.str_str) == parser().parse(self.uni_str)
  424| 
  425|     def testParseUnicodeWords(self):
  426| 
  427|         class rus_parserinfo(parserinfo):
  428|             MONTHS = [("янв", "Январь"),
  429|                       ("фев", "Февраль"),
  430|                       ("мар", "Март"),
  431|                       ("апр", "Апрель"),
  432|                       ("май", "Май"),
  433|                       ("июн", "Июнь"),
  434|                       ("июл", "Июль"),
  435|                       ("авг", "Август"),
  436|                       ("сен", "Сентябрь"),
  437|                       ("окт", "Октябрь"),
  438|                       ("ноя", "Ноябрь"),
  439|                       ("дек", "Декабрь")]
  440| 
  441|         expected = datetime(2015, 9, 10, 10, 20)
  442|         res = parse('10 Сентябрь 2015 10:20', parserinfo=rus_parserinfo())
  443|         assert res  == expected
  444| 
  445|     def testParseWithNulls(self):
  446|         # This relies on the from __future__ import unicode_literals, because
  447|         # explicitly specifying a unicode literal is a syntax error in Py 3.2
  448|         # May want to switch to u'...' if we ever drop Python 3.2 support.
  449|         pstring = '\x00\x00August 29, 1924'
  450| 
  451|         assert parse(pstring) == datetime(1924, 8, 29)
  452| 
  453|     def testDateCommandFormat(self):
  454|         self.assertEqual(parse("Thu Sep 25 10:36:28 BRST 2003",
  455|                                tzinfos=self.tzinfos),
  456|                          datetime(2003, 9, 25, 10, 36, 28,
  457|                                   tzinfo=self.brsttz))
