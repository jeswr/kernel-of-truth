    1| # -*- coding: utf-8 -*-
    2| from __future__ import unicode_literals
    3| 
    4| from datetime import datetime, timedelta, date, time
    5| import itertools as it
    6| 
    7| from dateutil import tz
    8| from dateutil.tz import UTC
    9| from dateutil.parser import isoparser, isoparse
   10| 
   11| import pytest
   12| import six
   13| 
   14| 
   15| def _generate_tzoffsets(limited):
   16|     def _mkoffset(hmtuple, fmt):
   17|         h, m = hmtuple
   18|         m_td = (-1 if h < 0 else 1) * m
   19| 
   20|         tzo = tz.tzoffset(None, timedelta(hours=h, minutes=m_td))
   21|         return tzo, fmt.format(h, m)
   22| 
   23|     out = []
   24|     if not limited:
   25|         # The subset that's just hours
   26|         hm_out_h = [(h, 0) for h in (-23, -5, 0, 5, 23)]
   27|         out.extend([_mkoffset(hm, '{:+03d}') for hm in hm_out_h])
   28| 
   29|         # Ones that have hours and minutes
   30|         hm_out = [] + hm_out_h
   31|         hm_out += [(-12, 15), (11, 30), (10, 2), (5, 15), (-5, 30)]
   32|     else:
   33|         hm_out = [(-5, -0)]
   34| 
   35|     fmts = ['{:+03d}:{:02d}', '{:+03d}{:02d}']
   36|     out += [_mkoffset(hm, fmt) for hm in hm_out for fmt in fmts]
   37| 
   38|     # Also add in UTC and naive
   39|     out.append((UTC, 'Z'))
   40|     out.append((None, ''))
   41| 
   42|     return out
   43| 
   44| FULL_TZOFFSETS = _generate_tzoffsets(False)
   45| FULL_TZOFFSETS_AWARE = [x for x in FULL_TZOFFSETS if x[1]]
   46| TZOFFSETS = _generate_tzoffsets(True)
   47| 
