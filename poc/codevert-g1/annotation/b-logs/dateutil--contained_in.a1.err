   72| def _isoparse_date_and_time(dt, date_fmt, time_fmt, tzoffset,
   73|                             microsecond_precision=None):
   74|     tzi, offset_str = tzoffset
   75|     fmt = date_fmt + 'T' + time_fmt
   76|     dt = dt.replace(tzinfo=tzi)
   77|     dtstr = dt.strftime(fmt)
   78| 
   79|     if microsecond_precision is not None:
   80|         if not fmt.endswith('%f'):  # pragma: nocover
   81|             raise ValueError('Time format has no microseconds!')
   82| 
   83|         if microsecond_precision != 6:
   84|             dtstr = dtstr[: -(6 - microsecond_precision)]
   85|         elif microsecond_precision > 6:  # pragma: nocover
   86|             raise ValueError("Precision must be 1-6")
   87| 
   88|     dtstr += offset_str
   89| 
   90|     assert isoparse(dtstr) == dt
