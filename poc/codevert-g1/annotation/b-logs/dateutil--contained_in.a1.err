  496|     def testPertain(self):
  497|         self.assertEqual(parse("Sep 03", default=self.default),
  498|                          datetime(2003, 9, 3))
  499|         self.assertEqual(parse("Sep of 03", default=self.default),
  500|                          datetime(2003, 9, 25))
