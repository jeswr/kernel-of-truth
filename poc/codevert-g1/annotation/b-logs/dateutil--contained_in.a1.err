  251|     ('2012-04-9', ValueError),                  # YYYY-MM-D not valid
  252|     ('201204', ValueError),                     # YYYYMM not valid
  253|     ('20120411T03:30+', ValueError),            # Time zone too short
  254|     ('20120411T03:30+1234567', ValueError),     # Time zone too long
  255|     ('20120411T03:30-25:40', ValueError),       # Time zone invalid
  256|     ('2012-1a', ValueError),                    # Invalid month
