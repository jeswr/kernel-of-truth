  225| class TracebackInfo:
  226|     """The TracebackInfo class provides a basic representation of a stack
  227|     trace, be it from an exception being handled or just part of
  228|     normal execution. It is basically a wrapper around a list of
  229|     :class:`Callpoint` objects representing frames.
  230| 
  231|     Args:
  232|         frames (list): A list of frame objects in the stack.
  233| 
  234|     .. note ::
  235| 
  236|       ``TracebackInfo`` can represent both exception tracebacks and
  237|       non-exception tracebacks (aka stack traces). As a result, there
  238|       is no ``TracebackInfo.from_current()``, as that would be
  239|       ambiguous. Instead, call :meth:`TracebackInfo.from_frame`
  240|       without the *frame* argument for a stack trace, or
  241|       :meth:`TracebackInfo.from_traceback` without the *tb* argument
  242|       for an exception traceback.
  243|     """
  244|     callpoint_type = Callpoint
  245| 
  246|     def __init__(self, frames):
  247|         self.frames = frames
  248| 
  249|     @classmethod
  250|     def from_frame(cls, frame=None, level=1, limit=None):
  251|         """Create a new TracebackInfo *frame* by recurring up in the stack a
  252|         max of *limit* times. If *frame* is unset, get the frame from
  253|         :func:`sys._getframe` using *level*.
  254| 
  255|         Args:
  256|             frame (types.FrameType): frame object from
  257|                 :func:`sys._getframe` or elsewhere. Defaults to result
  258|                 of :func:`sys.get_frame`.
  259|             level (int): If *frame* is unset, the desired frame is
  260|                 this many levels up the stack from the invocation of
  261|                 this method. Default ``1`` (i.e., caller of this method).
  262|             limit (int): max number of parent frames to extract
  263|                 (defaults to :data:`sys.tracebacklimit`)
  264| 
  265|         """
  266|         ret = []
  267|         if frame is None:
  268|             frame = sys._getframe(level)
  269|         if limit is None:
  270|             limit = getattr(sys, 'tracebacklimit', 1000)
  271|         n = 0
  272|         while frame is not None and n < limit:
  273|             item = cls.callpoint_type.from_frame(frame)
  274|             ret.append(item)
  275|             frame = frame.f_back
  276|             n += 1
  277|         ret.reverse()
  278|         return cls(ret)
  279| 
  280|     @classmethod
  281|     def from_traceback(cls, tb=None, limit=None):
  282|         """Create a new TracebackInfo from the traceback *tb* by recurring
  283|         up in the stack a max of *limit* times. If *tb* is unset, get
  284|         the traceback from the currently handled exception. If no
  285|         exception is being handled, raise a :exc:`ValueError`.
  286| 
  287|         Args:
  288| 
  289|             frame (types.TracebackType): traceback object from
  290|                 :func:`sys.exc_info` or elsewhere. If absent or set to
  291|                 ``None``, defaults to ``sys.exc_info()[2]``, and
  292|                 raises a :exc:`ValueError` if no exception is
  293|                 currently being handled.
  294|             limit (int): max number of parent frames to extract
  295|                 (defaults to :data:`sys.tracebacklimit`)
  296| 
  297|         """
  298|         ret = []
  299|         if tb is None:
  300|             tb = sys.exc_info()[2]
  301|             if tb is None:
  302|                 raise ValueError('no tb set and no exception being handled')
  303|         if limit is None:
  304|             limit = getattr(sys, 'tracebacklimit', 1000)
  305|         n = 0
  306|         while tb is not None and n < limit:
  307|             item = cls.callpoint_type.from_tb(tb)
  308|             ret.append(item)
  309|             tb = tb.tb_next
  310|             n += 1
  311|         return cls(ret)
  312| 
  313|     @classmethod
  314|     def from_dict(cls, d):
  315|         "Complements :meth:`TracebackInfo.to_dict`."
  316|         # TODO: check this.
  317|         return cls(d['frames'])
  318| 
  319|     def to_dict(self):
  320|         """Returns a dict with a list of :class:`Callpoint` frames converted
  321|         to dicts.
  322|         """
  323|         return {'frames': [f.to_dict() for f in self.frames]}
  324| 
  325|     def __len__(self):
  326|         return len(self.frames)
  327| 
  328|     def __iter__(self):
  329|         return iter(self.frames)
  330| 
  331|     def __repr__(self):
  332|         cn = self.__class__.__name__
  333| 
  334|         if self.frames:
  335|             frame_part = f' last={self.frames[-1]!r}'
  336|         else:
  337|             frame_part = ''
  338| 
  339|         return f'<{cn} frames={len(self.frames)}{frame_part}>'
  340| 
  341|     def __str__(self):
  342|         return self.get_formatted()
  343| 
  344|     def get_formatted(self):
  345|         """Returns a string as formatted in the traditional Python
  346|         built-in style observable when an exception is not caught. In
  347|         other words, mimics :func:`traceback.format_tb` and
  348|         :func:`traceback.format_stack`.
  349|         """
  350|         ret = 'Traceback (most recent call last):\n'
  351|         ret += ''.join([f.tb_frame_str() for f in self.frames])
  352|         return ret
