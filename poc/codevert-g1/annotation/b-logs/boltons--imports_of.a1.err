  355| class ExceptionInfo:
  356|     """An ExceptionInfo object ties together three main fields suitable
  357|     for representing an instance of an exception: The exception type
  358|     name, a string representation of the exception itself (the
  359|     exception message), and information about the traceback (stored as
  360|     a :class:`TracebackInfo` object).
  361| 
  362|     These fields line up with :func:`sys.exc_info`, but unlike the
  363|     values returned by that function, ExceptionInfo does not hold any
  364|     references to the real exception or traceback. This property makes
  365|     it suitable for serialization or long-term retention, without
  366|     worrying about formatting pitfalls, circular references, or leaking memory.
  367| 
  368|     Args:
  369| 
  370|         exc_type (str): The exception type name.
  371|         exc_msg (str): String representation of the exception value.
  372|         tb_info (TracebackInfo): Information about the stack trace of the
  373|             exception.
  374| 
  375|     Like the :class:`TracebackInfo`, ExceptionInfo is most commonly
  376|     instantiated from one of its classmethods: :meth:`from_exc_info`
  377|     or :meth:`from_current`.
  378|     """
  379| 
  380|     #: Override this in inherited types to control the TracebackInfo type used
  381|     tb_info_type = TracebackInfo
  382| 
  383|     def __init__(self, exc_type, exc_msg, tb_info):
  384|         # TODO: additional fields for SyntaxErrors
  385|         self.exc_type = exc_type
  386|         self.exc_msg = exc_msg
  387|         self.tb_info = tb_info
  388| 
  389|     @classmethod
  390|     def from_exc_info(cls, exc_type, exc_value, traceback):
  391|         """Create an :class:`ExceptionInfo` object from the exception's type,
  392|         value, and traceback, as returned by :func:`sys.exc_info`. See
  393|         also :meth:`from_current`.
  394|         """
  395|         type_str = exc_type.__name__
  396|         type_mod = exc_type.__module__
  397|         if type_mod not in ("__main__", "__builtin__", "exceptions", "builtins"):
  398|             type_str = f'{type_mod}.{type_str}'
  399|         val_str = _some_str(exc_value)
  400|         tb_info = cls.tb_info_type.from_traceback(traceback)
  401|         return cls(type_str, val_str, tb_info)
  402| 
  403|     @classmethod
  404|     def from_current(cls):
  405|         """Create an :class:`ExceptionInfo` object from the current exception
  406|         being handled, by way of :func:`sys.exc_info`. Will raise an
  407|         exception if no exception is currently being handled.
  408|         """
  409|         return cls.from_exc_info(*sys.exc_info())
  410| 
  411|     def to_dict(self):
  412|         """Get a :class:`dict` representation of the ExceptionInfo, suitable
  413|         for JSON serialization.
  414|         """
  415|         return {'exc_type': self.exc_type,
  416|                 'exc_msg': self.exc_msg,
  417|                 'exc_tb': self.tb_info.to_dict()}
  418| 
  419|     def __repr__(self):
  420|         cn = self.__class__.__name__
  421|         try:
  422|             len_frames = len(self.tb_info.frames)
  423|             last_frame = f', last={self.tb_info.frames[-1]!r}'
  424|         except Exception:
  425|             len_frames = 0
  426|             last_frame = ''
  427|         args = (cn, self.exc_type, self.exc_msg, len_frames, last_frame)
  428|         return '<%s [%s: %s] (%s frames%s)>' % args
  429| 
  430|     def get_formatted(self):
  431|         """Returns a string formatted in the traditional Python
  432|         built-in style observable when an exception is not caught. In
  433|         other words, mimics :func:`traceback.format_exception`.
  434|         """
  435|         # TODO: add SyntaxError formatting
  436|         tb_str = self.tb_info.get_formatted()
  437|         return ''.join([tb_str, f'{self.exc_type}: {self.exc_msg}'])
  438| 
  439|     def get_formatted_exception_only(self):
  440|         return f'{self.exc_type}: {self.exc_msg}'
  441| 
  442| 
  443| class ContextualCallpoint(Callpoint):
  444|     """The ContextualCallpoint is a :class:`Callpoint` subtype with the
  445|     exact same API and storing two additional values:
  446| 
  447|       1. :func:`repr` outputs for local variables from the Callpoint's scope
  448|       2. A number of lines before and after the Callpoint's line of code
  449| 
  450|     The ContextualCallpoint is used by the :class:`ContextualTracebackInfo`.
  451|     """
  452|     def __init__(self, *a, **kw):
  453|         self.local_reprs = kw.pop('local_reprs', {})
  454|         self.pre_lines = kw.pop('pre_lines', [])
  455|         self.post_lines = kw.pop('post_lines', [])
  456|         super().__init__(*a, **kw)
  457| 
  458|     @classmethod
  459|     def from_frame(cls, frame):
  460|         "Identical to :meth:`Callpoint.from_frame`"
  461|         ret = super().from_frame(frame)
  462|         ret._populate_local_reprs(frame.f_locals)
  463|         ret._populate_context_lines()
  464|         return ret
  465| 
  466|     @classmethod
  467|     def from_tb(cls, tb):
  468|         "Identical to :meth:`Callpoint.from_tb`"
  469|         ret = super().from_tb(tb)
  470|         ret._populate_local_reprs(tb.tb_frame.f_locals)
  471|         ret._populate_context_lines()
  472|         return ret
  473| 
  474|     def _populate_context_lines(self, pivot=8):
  475|         DL, lineno = _DeferredLine, self.lineno
  476|         try:
  477|             module_globals = self.line.module_globals
  478|         except AttributeError:
  479|             module_globals = None
  480|         start_line = max(0, lineno - pivot)
  481|         pre_lines = [DL(self.module_path, ln, module_globals)
  482|                      for ln in range(start_line, lineno)]
  483|         self.pre_lines[:] = pre_lines
  484|         post_lines = [DL(self.module_path, ln, module_globals)
  485|                       for ln in range(lineno + 1, lineno + 1 + pivot)]
  486|         self.post_lines[:] = post_lines
  487|         return
  488| 
  489|     def _populate_local_reprs(self, f_locals):
  490|         local_reprs = self.local_reprs
  491|         for k, v in f_locals.items():
  492|             try:
  493|                 local_reprs[k] = repr(v)
  494|             except Exception:
  495|                 surrogate = '<unprintable %s object>' % type(v).__name__
  496|                 local_reprs[k] = surrogate
  497|         return
  498| 
  499|     def to_dict(self):
  500|         """
  501|         Same principle as :meth:`Callpoint.to_dict`, but with the added
  502|         contextual values. With ``ContextualCallpoint.to_dict()``,
  503|         each frame will now be represented like::
  504| 
  505|           {'func_name': 'print_example',
  506|            'lineno': 0,
  507|            'module_name': 'example_module',
  508|            'module_path': '/home/example/example_module.pyc',
  509|            'lasti': 0,
  510|            'line': 'print "example"',
  511|            'locals': {'variable': '"value"'},
  512|            'pre_lines': ['variable = "value"'],
  513|            'post_lines': []}
  514| 
  515|         The locals dictionary and line lists are copies and can be mutated
  516|         freely.
  517|         """
  518|         ret = super().to_dict()
  519|         ret['locals'] = dict(self.local_reprs)
  520| 
  521|         # get the line numbers and textual lines
  522|         # without assuming DeferredLines
  523|         start_line = self.lineno - len(self.pre_lines)
  524|         pre_lines = [{'lineno': start_line + i, 'line': str(l)}
  525|                      for i, l in enumerate(self.pre_lines)]
  526|         # trim off leading empty lines
  527|         for i, item in enumerate(pre_lines):
  528|             if item['line']:
  529|                 break
  530|         if i:
  531|             pre_lines = pre_lines[i:]
  532|         ret['pre_lines'] = pre_lines
  533| 
  534|         # now post_lines
  535|         post_lines = [{'lineno': self.lineno + i, 'line': str(l)}
  536|                       for i, l in enumerate(self.post_lines)]
  537|         _last = 0
  538|         for i, item in enumerate(post_lines):
  539|             if item['line']:
  540|                 _last = i
  541|         post_lines = post_lines[:_last + 1]
  542|         ret['post_lines'] = post_lines
  543|         return ret
  544| 
  545| 
  546| class ContextualTracebackInfo(TracebackInfo):
  547|     """The ContextualTracebackInfo type is a :class:`TracebackInfo`
  548|     subtype that is used by :class:`ContextualExceptionInfo` and uses
  549|     the :class:`ContextualCallpoint` as its frame-representing
  550|     primitive.
  551|     """
  552|     callpoint_type = ContextualCallpoint
  553| 
  554| 
  555| class ContextualExceptionInfo(ExceptionInfo):
  556|     """The ContextualTracebackInfo type is a :class:`TracebackInfo`
  557|     subtype that uses the :class:`ContextualCallpoint` as its
  558|     frame-representing primitive.
  559| 
  560|     It carries with it most of the exception information required to
  561|     recreate the widely recognizable "500" page for debugging Django
  562|     applications.
  563|     """
  564|     tb_info_type = ContextualTracebackInfo
  565| 
  566| 
  567| # TODO: clean up & reimplement -- specifically for syntax errors
  568| def format_exception_only(etype, value):
  569|     """Format the exception part of a traceback.
  570| 
  571|     The arguments are the exception type and value such as given by
  572|     sys.last_type and sys.last_value. The return value is a list of
  573|     strings, each ending in a newline.
  574| 
  575|     Normally, the list contains a single string; however, for
  576|     SyntaxError exceptions, it contains several lines that (when
  577|     printed) display detailed information about where the syntax
  578|     error occurred.
  579| 
  580|     The message indicating which exception occurred is always the last
  581|     string in the list.
  582| 
  583|     """
  584|     # Gracefully handle (the way Python 2.4 and earlier did) the case of
  585|     # being called with (None, None).
  586|     if etype is None:
  587|         return [_format_final_exc_line(etype, value)]
  588| 
  589|     stype = etype.__name__
  590|     smod = etype.__module__
  591|     if smod not in ("__main__", "builtins", "exceptions"):
  592|         stype = smod + '.' + stype
  593| 
  594|     if not issubclass(etype, SyntaxError):
  595|         return [_format_final_exc_line(stype, value)]
  596| 
  597|     # It was a syntax error; show exactly where the problem was found.
  598|     lines = []
  599|     filename = value.filename or "<string>"
  600|     lineno = str(value.lineno) or '?'
  601|     lines.append(f'  File "{filename}", line {lineno}\n')
  602|     badline = value.text
  603|     offset = value.offset
  604|     if badline is not None:
  605|         lines.append('    %s\n' % badline.strip())
  606|         if offset is not None:
  607|             caretspace = badline.rstrip('\n')[:offset].lstrip()
  608|             # non-space whitespace (likes tabs) must be kept for alignment
  609|             caretspace = ((c.isspace() and c or ' ') for c in caretspace)
  610|             # only three spaces to account for offset1 == pos 0
  611|             lines.append('   %s^\n' % ''.join(caretspace))
  612|     msg = value.msg or "<no detail available>"
  613|     lines.append(f"{stype}: {msg}\n")
  614|     return lines
  615| 
  616| 
  617| # TODO: use asciify, improved if necessary
  618| def _some_str(value):
  619|     try:
  620|         return str(value)
  621|     except Exception:
  622|         pass
  623|     return '<unprintable %s object>' % type(value).__name__
  624| 
  625| 
  626| def _format_final_exc_line(etype, value):
  627|     valuestr = _some_str(value)
  628|     if value is None or not valuestr:
  629|         line = "%s\n" % etype
  630|     else:
  631|         line = f"{etype}: {valuestr}\n"
  632|     return line
  633| 
  634| 
  635| def print_exception(etype, value, tb, limit=None, file=None):
  636|     """Print exception up to 'limit' stack trace entries from 'tb' to 'file'.
  637| 
  638|     This differs from print_tb() in the following ways: (1) if
  639|     traceback is not None, it prints a header "Traceback (most recent
  640|     call last):"; (2) it prints the exception type and value after the
  641|     stack trace; (3) if type is SyntaxError and value has the
  642|     appropriate format, it prints the line where the syntax error
  643|     occurred with a caret on the next line indicating the approximate
  644|     position of the error.
  645|     """
  646| 
  647|     if file is None:
  648|         file = sys.stderr
  649|     if tb:
  650|         tbi = TracebackInfo.from_traceback(tb, limit)
  651|         print(str(tbi), end='', file=file)
  652| 
  653|     for line in format_exception_only(etype, value):
  654|         print(line, end='', file=file)
  655| 
  656| 
  657| def fix_print_exception():
  658|     """
  659|     Sets the default exception hook :func:`sys.excepthook` to the
  660|     :func:`tbutils.print_exception` that uses all the ``tbutils``
  661|     facilities to provide a consistent output behavior.
  662|     """
  663|     sys.excepthook = print_exception
  664| 
  665| 
  666| _frame_re = re.compile(r'^File "(?P<filepath>.+)", line (?P<lineno>\d+)'
  667|                        r', in (?P<funcname>.+)$')
  668| _se_frame_re = re.compile(r'^File "(?P<filepath>.+)", line (?P<lineno>\d+)')
  669| _underline_re = re.compile(r'^[~^ ]*$')
  670| 
  671| # TODO: ParsedException generator over large bodies of text
  672| 
  673| class ParsedException:
  674|     """Stores a parsed traceback and exception as would be typically
  675|     output by :func:`sys.excepthook` or
  676|     :func:`traceback.print_exception`.
  677| 
  678|     .. note:
  679| 
  680|        Does not currently store SyntaxError details such as column.
  681| 
  682|     """
  683|     def __init__(self, exc_type_name, exc_msg, frames=None):
  684|         self.exc_type = exc_type_name
  685|         self.exc_msg = exc_msg
  686|         self.frames = list(frames or [])
  687| 
  688|     @property
  689|     def source_file(self):
  690|         """
  691|         The file path of module containing the function that raised the
  692|         exception, or None if not available.
  693|         """
  694|         try:
  695|             return self.frames[-1]['filepath']
  696|         except IndexError:
  697|             return None
  698| 
  699|     def to_dict(self):
  700|         "Get a copy as a JSON-serializable :class:`dict`."
  701|         return {'exc_type': self.exc_type,
  702|                 'exc_msg': self.exc_msg,
  703|                 'frames': list(self.frames)}
  704| 
  705|     def __repr__(self):
  706|         cn = self.__class__.__name__
  707|         return ('%s(%r, %r, frames=%r)'
  708|                 % (cn, self.exc_type, self.exc_msg, self.frames))
  709| 
  710|     def to_string(self):
  711|         """Formats the exception and its traceback into the standard format,
  712|         as returned by the traceback module.
  713| 
  714|         ``ParsedException.from_string(text).to_string()`` should yield
  715|         ``text``.
  716| 
  717|         .. note::
  718| 
  719|            Note that this method does not output "anchors" (e.g.,
  720|            ``~~~~~^^``), as were added in Python 3.13. See the built-in
  721|            ``traceback`` module if these are necessary.
  722|         """
  723|         lines = ['Traceback (most recent call last):']
  724| 
  725|         for frame in self.frames:
  726|             lines.append('  File "{}", line {}, in {}'.format(frame['filepath'],
  727|                                                            frame['lineno'],
  728|                                                            frame['funcname']))
  729|             source_line = frame.get('source_line')
  730|             if source_line:
  731|                 lines.append(f'    {source_line}')
  732|         if self.exc_msg:
  733|             lines.append(f'{self.exc_type}: {self.exc_msg}')
  734|         else:
  735|             lines.append(f'{self.exc_type}')
  736|         return '\n'.join(lines)
  737| 
  738|     @classmethod
  739|     def from_string(cls, tb_str):
  740|         """Parse a traceback and exception from the text *tb_str*. This text
  741|         is expected to have been decoded, otherwise it will be
  742|         interpreted as UTF-8.
  743| 
  744|         This method does not search a larger body of text for
  745|         tracebacks. If the first line of the text passed does not
  746|         match one of the known patterns, a :exc:`ValueError` will be
  747|         raised. This method will ignore trailing text after the end of
  748|         the first traceback.
  749| 
  750|         Args:
  751|             tb_str (str): The traceback text (:class:`unicode` or UTF-8 bytes)
  752|         """
  753|         if not isinstance(tb_str, str):
  754|             tb_str = tb_str.decode('utf-8')
  755|         tb_lines = tb_str.lstrip().splitlines()
  756| 
  757|         # First off, handle some ignored exceptions. These can be the
  758|         # result of exceptions raised by __del__ during garbage
  759|         # collection
  760|         while tb_lines:
  761|             cl = tb_lines[-1]
  762|             if cl.startswith('Exception ') and cl.endswith('ignored'):
  763|                 tb_lines.pop()
  764|             else:
  765|                 break
  766|         if tb_lines and tb_lines[0].strip() == 'Traceback (most recent call last):':
  767|             start_line = 1
  768|             frame_re = _frame_re
  769|         elif len(tb_lines) > 1 and tb_lines[-2].lstrip().startswith('^'):
  770|             # This is to handle the slight formatting difference
  771|             # associated with SyntaxErrors, which also don't really
  772|             # have tracebacks
  773|             start_line = 0
  774|             frame_re = _se_frame_re
  775|         else:
  776|             raise ValueError('unrecognized traceback string format')
  777| 
  778|         frames = []
  779|         line_no = start_line
  780|         while line_no < len(tb_lines):
  781|             frame_line = tb_lines[line_no].strip()
  782|             frame_match = frame_re.match(frame_line)
  783|             if frame_match:
  784|                 frame_dict = frame_match.groupdict()
  785|                 try:
  786|                     next_line = tb_lines[line_no + 1]
  787|                 except IndexError:
  788|                     # We read what we could
  789|                     next_line = ''
  790|                 next_line_stripped = next_line.strip()
  791|                 if (
  792|                         frame_re.match(next_line_stripped) or
  793|                         # The exception message will not be indented
  794|                         # This check is to avoid overrunning on eval-like
  795|                         # tracebacks where the last frame doesn't have source
  796|                         # code in the traceback
  797|                         not next_line.startswith(' ')
  798|                 ):
  799|                     frame_dict['source_line'] = ''
  800|                 else:
  801|                     frame_dict['source_line'] = next_line_stripped
  802|                     line_no += 1
  803|                     if (line_no + 1 < len(tb_lines)
  804|                             and _underline_re.match(tb_lines[line_no + 1])):
  805|                         # To deal with anchors
  806|                         line_no += 1
  807|             else:
  808|                 break
  809|             line_no += 1
  810|             frames.append(frame_dict)
  811| 
  812|         try:
  813|             exc_line = '\n'.join(tb_lines[line_no:])
  814|             exc_type, _, exc_msg = exc_line.partition(': ')
  815|         except Exception:
  816|             exc_type, exc_msg = '', ''
  817| 
  818|         return cls(exc_type, exc_msg, frames)
  819| 
  820| 
  821| ParsedTB = ParsedException  # legacy alias

