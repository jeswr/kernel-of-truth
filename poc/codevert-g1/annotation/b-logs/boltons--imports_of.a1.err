   72| class Callpoint:
   73|     """The Callpoint is a lightweight object used to represent a single
   74|     entry in the code of a call stack. It stores the code-related
   75|     metadata of a given frame. Available attributes are the same as
   76|     the parameters below.
   77| 
   78|     Args:
   79|         func_name (str): the function name
   80|         lineno (int): the line number
   81|         module_name (str): the module name
   82|         module_path (str): the filesystem path of the module
   83|         lasti (int): the index of bytecode execution
   84|         line (str): the single-line code content (if available)
   85| 
   86|     """
   87|     __slots__ = ('func_name', 'lineno', 'module_name', 'module_path', 'lasti',
   88|                  'line')
   89| 
   90|     def __init__(self, module_name, module_path, func_name,
   91|                  lineno, lasti, line=None):
   92|         self.func_name = func_name
   93|         self.lineno = lineno
   94|         self.module_name = module_name
   95|         self.module_path = module_path
   96|         self.lasti = lasti
   97|         self.line = line
   98| 
   99|     def to_dict(self):
  100|         "Get a :class:`dict` copy of the Callpoint. Useful for serialization."
  101|         ret = {}
  102|         for slot in self.__slots__:
  103|             try:
  104|                 val = getattr(self, slot)
  105|             except AttributeError:
  106|                 pass
  107|             else:
  108|                 ret[slot] = str(val) if isinstance(val, _DeferredLine) else val
  109|         return ret
  110| 
  111|     @classmethod
  112|     def from_current(cls, level=1):
  113|         "Creates a Callpoint from the location of the calling function."
  114|         frame = sys._getframe(level)
  115|         return cls.from_frame(frame)
  116| 
  117|     @classmethod
  118|     def from_frame(cls, frame):
  119|         "Create a Callpoint object from data extracted from the given frame."
  120|         func_name = frame.f_code.co_name
  121|         lineno = frame.f_lineno
  122|         module_name = frame.f_globals.get('__name__', '')
  123|         module_path = frame.f_code.co_filename
  124|         lasti = frame.f_lasti
  125|         line = _DeferredLine(module_path, lineno, frame.f_globals)
  126|         return cls(module_name, module_path, func_name,
  127|                    lineno, lasti, line=line)
  128| 
  129|     @classmethod
  130|     def from_tb(cls, tb):
  131|         """Create a Callpoint from the traceback of the current
  132|         exception. Main difference with :meth:`from_frame` is that
  133|         ``lineno`` and ``lasti`` come from the traceback, which is to
  134|         say the line that failed in the try block, not the line
  135|         currently being executed (in the except block).
  136|         """
  137|         func_name = tb.tb_frame.f_code.co_name
  138|         lineno = tb.tb_lineno
  139|         lasti = tb.tb_lasti
  140|         module_name = tb.tb_frame.f_globals.get('__name__', '')
  141|         module_path = tb.tb_frame.f_code.co_filename
  142|         line = _DeferredLine(module_path, lineno, tb.tb_frame.f_globals)
  143|         return cls(module_name, module_path, func_name,
  144|                    lineno, lasti, line=line)
  145| 
  146|     def __repr__(self):
  147|         cn = self.__class__.__name__
  148|         args = [getattr(self, s, None) for s in self.__slots__]
  149|         if not any(args):
  150|             return super().__repr__()
  151|         else:
  152|             return '{}({})'.format(cn, ', '.join([repr(a) for a in args]))
  153| 
  154|     def tb_frame_str(self):
  155|         """Render the Callpoint as it would appear in a standard printed
  156|         Python traceback. Returns a string with filename, line number,
  157|         function name, and the actual code line of the error on up to
  158|         two lines.
  159|         """
  160|         ret = '  File "{}", line {}, in {}\n'.format(self.module_path,
  161|                                                  self.lineno,
  162|                                                  self.func_name)
  163|         if self.line:
  164|             ret += f'    {str(self.line).strip()}\n'
  165|         return ret
  166| 
