  257| def test_bytes2human():
  258|     b2h = strutils.bytes2human
  259|     # Exact powers of 1024 must roll over to the next unit, not show the
  260|     # previous unit times 1024.
  261|     assert b2h(1024) == '1K'
  262|     assert b2h(1024 ** 2) == '1M'
  263|     assert b2h(1024 ** 3) == '1G'
  264|     assert b2h(1024 ** 4) == '1T'
  265|     # Just below a boundary stays in the smaller unit.
  266|     assert b2h(1023) == '1023B'
  267|     assert b2h(1024 ** 2 - 1, 1) == '1024.0K'
  268|     # Ordinary mid-range values are unaffected.
  269|     assert b2h(0) == '0B'
  270|     assert b2h(2048) == '2K'
  271|     assert b2h(128991) == '126K'
  272|     # Sign is preserved and negative magnitudes scale like positives.
  273|     assert b2h(-1024) == '-1K'
  274|     assert b2h(-(1024 ** 2)) == '-1M'
  275|     # ndigits controls the fractional part.
  276|     assert b2h(1024, 2) == '1.00K'

