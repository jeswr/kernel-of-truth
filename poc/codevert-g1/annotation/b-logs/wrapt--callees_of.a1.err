  852| class TestContextManagerObjectProxy(unittest.TestCase):
  853| 
  854|     def test_context_manager(self):
  855|         class Class:
  856|             def __enter__(self):
  857|                 return self
  858| 
  859|             def __exit__(*args, **kwargs):
  860|                 return
  861| 
  862|         instance = Class()
  863| 
  864|         wrapper = wrapt.ObjectProxy(instance)
  865| 
  866|         with wrapper:
  867|             pass
  868| 
  869|     def test_async_context_manager(self):
  870|         class Class:
  871|             async def __aenter__(self):
  872|                 return self
  873| 
  874|             async def __aexit__(*args, **kwargs):
  875|                 return
  876| 
  877|         instance = Class()
  878| 
  879|         wrapper = wrapt.ObjectProxy(instance)
  880| 
  881|         async def run():
  882|             async with wrapper:
  883|                 pass
  884| 
  885|         import asyncio
  886| 
  887|         loop = asyncio.new_event_loop()
  888|         asyncio.set_event_loop(loop)
  889|         loop.run_until_complete(run())
  890|         loop.close()
  891| 
  892| 
  893| class TestEqualityObjectProxy(unittest.TestCase):
  894| 
  895|     def test_object_hash(self):
  896|         def function1(*args, **kwargs):
  897|             return args, kwargs
  898| 
  899|         function2 = wrapt.ObjectProxy(function1)
  900| 
  901|         self.assertEqual(hash(function2), hash(function1))
  902| 
  903|     def test_mapping_key(self):
  904|         def function1(*args, **kwargs):
  905|             return args, kwargs
  906| 
  907|         function2 = wrapt.ObjectProxy(function1)
  908| 
  909|         table = dict()
  910|         table[function1] = True
  911| 
  912|         self.assertTrue(table.get(function2))
  913| 
  914|         table = dict()
  915|         table[function2] = True
  916| 
  917|         self.assertTrue(table.get(function1))
  918| 
  919|     def test_comparison(self):
  920|         one = wrapt.ObjectProxy(1)
  921|         two = wrapt.ObjectProxy(2)
  922|         three = wrapt.ObjectProxy(3)
  923| 
  924|         self.assertTrue(two > 1)
  925|         self.assertTrue(two >= 1)
  926|         self.assertTrue(two < 3)
  927|         self.assertTrue(two <= 3)
  928|         self.assertTrue(two != 1)
  929|         self.assertTrue(two == 2)
  930|         self.assertTrue(two != 3)
  931| 
  932|         self.assertTrue(2 > one)
  933|         self.assertTrue(2 >= one)
  934|         self.assertTrue(2 < three)
  935|         self.assertTrue(2 <= three)
  936|         self.assertTrue(2 != one)
  937|         self.assertTrue(2 == two)
  938|         self.assertTrue(2 != three)
  939| 
  940|         self.assertTrue(two > one)
  941|         self.assertTrue(two >= one)
  942|         self.assertTrue(two < three)
  943|         self.assertTrue(two <= three)
  944|         self.assertTrue(two != one)
  945|         self.assertTrue(two == two)
  946|         self.assertTrue(two != three)
  947| 
