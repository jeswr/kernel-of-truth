 2204|                 ".*got multiple values for (keyword )?argument 'self'.*",
 2205|                 str(e.exception),
 2206|             ),
 2207|             None,
 2208|         )
 2209| 
 2210|     def test_self_keyword_argument_on_class_init_renamed(self):
 2211|         class Object:
 2212|             def __init__(_self, *args, **kwargs):
 2213|                 _self._args = args
 2214|                 _self._kwargs = kwargs
 2215| 
 2216|         o = Object(self="self")
 2217| 
 2218|         self.assertEqual(o._args, ())
