 1701| class TestDerivedClassCreation(unittest.TestCase):
 1702| 
 1703|     def test_derived_new(self):
 1704| 
 1705|         class DerivedObjectProxy(wrapt.ObjectProxy):
 1706| 
 1707|             def __new__(cls, wrapped):
 1708|                 instance = super(DerivedObjectProxy, cls).__new__(cls, wrapped)
 1709|                 return instance
 1710| 
 1711|             def __init__(self, wrapped):
 1712|                 super(DerivedObjectProxy, self).__init__(wrapped)
 1713| 
 1714|         def function():
 1715|             pass
 1716| 
 1717|         obj = DerivedObjectProxy(function)
 1718| 
 1719|         self.assertIsInstance(obj, DerivedObjectProxy)
 1720|         self.assertIs(obj.__wrapped__, function)
 1721| 
 1722|     def test_derived_setattr(self):
 1723| 
 1724|         class DerivedObjectProxy(wrapt.ObjectProxy):
 1725| 
 1726|             def __init__(self, wrapped):
 1727|                 self._self_attribute = True
 1728|                 super(DerivedObjectProxy, self).__init__(wrapped)
 1729| 
 1730|         def function():
 1731|             pass
 1732| 
 1733|         obj = DerivedObjectProxy(function)
 1734| 
 1735|     def test_derived_missing_init(self):
 1736| 
 1737|         class DerivedObjectProxy(wrapt.ObjectProxy):
 1738| 
 1739|             def __init__(self, wrapped):
 1740|                 self.__wrapped__ = wrapped
 1741| 
 1742|         def function():
 1743|             pass
 1744| 
 1745|         obj = DerivedObjectProxy(function)
 1746| 
 1747|         self.assertEqual(function, obj)
 1748|         self.assertEqual(function, obj.__wrapped__)
