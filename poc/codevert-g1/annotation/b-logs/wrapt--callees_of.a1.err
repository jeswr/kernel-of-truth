   26| class TestAttributeAccess(unittest.TestCase):
   27| 
   28|     def test_init_not_called(self):
   29|         a = wrapt.ObjectProxy.__new__(wrapt.ObjectProxy, None)
   30|         b = wrapt.ObjectProxy.__new__(wrapt.ObjectProxy, None)
   31| 
   32|         # Pre-init access should raise AttributeError, not ValueError.
   33| 
   34|         with self.assertRaises(AttributeError):
   35|             a.__wrapped__
   36| 
   37|         with self.assertRaises(AttributeError):
   38|             a + b
   39| 
   40|         # hasattr should return False, not raise.
   41| 
   42|         self.assertFalse(hasattr(a, "__wrapped__"))
   43| 
   44|     def test_init_called_wrapped_deleted(self):
   45|         # Post-init deletion of __wrapped__ should raise
   46|         # WrapperNotInitializedError (a ValueError, not AttributeError)
   47|         # so it is not silently swallowed by hasattr/getattr patterns.
   48|         # We use a LazyObjectProxy to reach a state where __init__ was
   49|         # called (init_called=True) but __wrapped__ is not set, by
   50|         # removing the factory before __wrapped__ is accessed.
   51| 
   52|         a = wrapt.LazyObjectProxy(lambda: 42)
   53| 
   54|         del a.__wrapped_factory__
   55| 
   56|         # Removing the class-level __wrapped_factory__ is necessary to
   57|         # observe the post-init / pre-wrapped state, but the attribute
   58|         # must be restored so later tests in the suite that construct a
   59|         # LazyObjectProxy do not see it missing.
   60| 
   61|         restore = []
   62|         for cls in type(a).__mro__:
   63|             if "__wrapped_factory__" in cls.__dict__:
   64|                 restore.append((cls, cls.__dict__["__wrapped_factory__"]))
   65|                 delattr(cls, "__wrapped_factory__")
   66|                 break
   67| 
   68|         try:
   69|             with self.assertRaises(wrapt.wrappers.WrapperNotInitializedError):
   70|                 a.__wrapped__
   71| 
   72|             with self.assertRaises(ValueError):
   73|                 a.__wrapped__
   74|         finally:
   75|             for cls, attr in restore:
   76|                 setattr(cls, "__wrapped_factory__", attr)
   77| 
