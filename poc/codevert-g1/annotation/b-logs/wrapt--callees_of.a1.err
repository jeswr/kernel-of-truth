 2128| class TestArgumentUnpacking(unittest.TestCase):
 2129| 
 2130|     def test_self_keyword_argument_on_dict(self):
 2131|         # A dict when given self as keyword argument uses it to create item in
 2132|         # the dict and no attempt is made to use a positional argument.
 2133| 
 2134|         d = wrapt.CallableObjectProxy(dict)(self="self")
 2135| 
 2136|         self.assertEqual(d, dict(self="self"))
 2137| 
 2138|     def test_self_positional_argument_on_class_init(self):
 2139|         class Object:
 2140|             def __init__(self, *args, **kwargs):
 2141|                 self._args = args
 2142|                 self._kwargs = kwargs
 2143| 
 2144|         o = Object("arg1")
 2145| 
 2146|         self.assertEqual(o._args, ("arg1",))
 2147|         self.assertEqual(o._kwargs, {})
 2148| 
 2149|         o = wrapt.CallableObjectProxy(Object)("arg1")
 2150| 
 2151|         self.assertEqual(o._args, ("arg1",))
 2152|         self.assertEqual(o._kwargs, {})
 2153| 
 2154|     def test_self_keyword_argument_on_class_init_1(self):
 2155|         class Object:
 2156|             def __init__(self, *args, **kwargs):
 2157|                 self._args = args
 2158|                 self._kwargs = kwargs
 2159| 
 2160|         with self.assertRaises(TypeError) as e:
 2161|             Object(self="self")
 2162| 
 2163|         self.assertNotEqual(
 2164|             re.match(
 2165|                 ".*got multiple values for (keyword )?argument 'self'.*",
 2166|                 str(e.exception),
 2167|             ),
 2168|             None,
 2169|         )
 2170| 
 2171|         with self.assertRaises(TypeError) as e:
 2172|             wrapt.CallableObjectProxy(Object)(self="self")
 2173| 
 2174|         self.assertNotEqual(
 2175|             re.match(
 2176|                 ".*got multiple values for (keyword )?argument 'self'.*",
 2177|                 str(e.exception),
 2178|             ),
 2179|             None,
 2180|         )
 2181| 
 2182|     def test_self_keyword_argument_on_class_init_2(self):
 2183|         class Object:
 2184|             def __init__(self, *args, **kwargs):
 2185|                 self._args = args
 2186|                 self._kwargs = kwargs
 2187| 
 2188|         with self.assertRaises(TypeError) as e:
 2189|             Object(arg1="arg1", self="self")
 2190| 
 2191|         self.assertNotEqual(
 2192|             re.match(
 2193|                 ".*got multiple values for (keyword )?argument 'self'.*",
 2194|                 str(e.exception),
 2195|             ),
 2196|             None,
 2197|         )
 2198| 
 2199|         with self.assertRaises(TypeError) as e:
 2200|             wrapt.CallableObjectProxy(Object)(arg1="arg1", self="self")
 2201| 
 2202|         self.assertNotEqual(
