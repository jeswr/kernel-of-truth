    6| class TestAutoObjectProxy(unittest.TestCase):
    7| 
    8|     def test_call(self):
    9|         class Callable:
   10|             def __call__(self, x):
   11|                 return x + 1
   12| 
   13|         base = wrapt.BaseObjectProxy(object())
   14| 
   15|         self.assertFalse(hasattr(base, "__call__"))
   16|         self.assertFalse(callable(base))
   17| 
   18|         proxy = wrapt.AutoObjectProxy(Callable())
   19| 
   20|         self.assertTrue(hasattr(proxy, "__call__"))
   21|         self.assertTrue(callable(proxy))
   22| 
   23|         self.assertEqual(proxy(2), 3)
   24| 
   25|     def test_iter(self):
   26|         class Iterable:
   27|             def __iter__(self):
   28|                 return iter([1, 2, 3])
   29| 
   30|         base = wrapt.BaseObjectProxy(object())
   31| 
   32|         self.assertFalse(hasattr(base, "__iter__"))
   33|         self.assertFalse(hasattr(base, "__next__"))
   34| 
   35|         proxy = wrapt.AutoObjectProxy(Iterable())
   36| 
   37|         self.assertTrue(hasattr(proxy, "__iter__"))
   38|         self.assertFalse(hasattr(proxy, "__next__"))
   39| 
   40|         self.assertEqual(list(proxy), [1, 2, 3])
   41| 
   42|     def test_next(self):
   43|         class Iterator:
   44|             def __init__(self):
   45|                 self._iter = iter([1, 2, 3])
   46| 
   47|             def __iter__(self):
   48|                 return self
   49| 
   50|             def __next__(self):
   51|                 return next(self._iter)
   52| 
   53|         base = wrapt.BaseObjectProxy(object())
   54| 
   55|         self.assertFalse(hasattr(base, "__iter__"))
   56|         self.assertFalse(hasattr(base, "__next__"))
   57| 
   58|         proxy = wrapt.AutoObjectProxy(Iterator())
   59| 
   60|         self.assertTrue(hasattr(proxy, "__iter__"))
   61|         self.assertTrue(hasattr(proxy, "__next__"))
   62| 
   63|         self.assertEqual(list(proxy), [1, 2, 3])
   64| 
   65|     def test_aiter(self):
   66|         class AsyncIterable:
   67|             def __aiter__(self):
   68|                 self._iter = iter([1, 2, 3])
   69|                 return self
   70| 
   71|             async def __anext__(self):
   72|                 try:
   73|                     return next(self._iter)
   74|                 except StopIteration:
   75|                     raise StopAsyncIteration
   76| 
   77|         base = wrapt.BaseObjectProxy(object())
   78| 
   79|         self.assertFalse(hasattr(base, "__aiter__"))
   80|         self.assertFalse(hasattr(base, "__anext__"))
   81| 
   82|         proxy = wrapt.AutoObjectProxy(AsyncIterable())
   83| 
   84|         self.assertTrue(hasattr(proxy, "__aiter__"))
   85|         self.assertTrue(hasattr(proxy, "__anext__"))
   86| 
   87|         async def iterate():
   88|             result = []
   89|             async for item in proxy:
   90|                 result.append(item)
   91|             return result
   92| 
   93|         import asyncio
   94| 
   95|         self.assertEqual(asyncio.run(iterate()), [1, 2, 3])
   96| 
