  172|     def test_descriptor(self):
  173|         class Descriptor:
  174|             def __init__(self, value):
  175|                 self.value = value
  176| 
  177|             def __get__(self, instance, owner):
  178|                 assert self.name == "attr"
  179|                 assert self.owner == owner
  180|                 if instance is None:
  181|                     return self
  182|                 return self.value
  183| 
  184|             def __set__(self, instance, value):
  185|                 self.value = value
  186| 
  187|             def __delete__(self, instance):
  188|                 del self.value
  189| 
  190|             def __set_name__(self, owner, name):
  191|                 self.owner = owner
  192|                 self.name = name
  193| 
  194|         base = wrapt.BaseObjectProxy(object())
  195| 
  196|         self.assertFalse(hasattr(base, "__get__"))
  197|         self.assertFalse(hasattr(base, "__set__"))
  198|         self.assertFalse(hasattr(base, "__delete__"))
  199|         self.assertFalse(hasattr(base, "__set_name__"))
  200| 
  201|         proxy = wrapt.AutoObjectProxy(Descriptor(42))
  202| 
  203|         self.assertTrue(hasattr(proxy, "__get__"))
  204|         self.assertTrue(hasattr(proxy, "__set__"))
  205|         self.assertTrue(hasattr(proxy, "__delete__"))
  206|         self.assertTrue(hasattr(proxy, "__set_name__"))
  207| 
  208|         class Owner:
  209|             attr = wrapt.AutoObjectProxy(Descriptor(42))
  210| 
  211|         owner = Owner()
  212| 
  213|         self.assertEqual(owner.attr, 42)
  214| 
  215|         owner.attr = 100
  216|         self.assertEqual(owner.attr, 100)
  217| 
  218|         del owner.attr
  219|         self.assertRaises(AttributeError, lambda: owner.attr)
