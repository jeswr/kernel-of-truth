 1751| class DerivedClassAttributes(unittest.TestCase):
 1752| 
 1753|     def test_setup_class_attributes(self):
 1754| 
 1755|         def function():
 1756|             pass
 1757| 
 1758|         class DerivedObjectProxy(wrapt.ObjectProxy):
 1759|             pass
 1760| 
 1761|         obj = DerivedObjectProxy(function)
 1762| 
 1763|         DerivedObjectProxy.ATTRIBUTE = 1
 1764| 
 1765|         self.assertEqual(obj.ATTRIBUTE, 1)
 1766|         self.assertFalse(hasattr(function, "ATTRIBUTE"))
 1767| 
 1768|         del DerivedObjectProxy.ATTRIBUTE
 1769| 
 1770|         self.assertFalse(hasattr(DerivedObjectProxy, "ATTRIBUTE"))
 1771|         self.assertFalse(hasattr(obj, "ATTRIBUTE"))
 1772|         self.assertFalse(hasattr(function, "ATTRIBUTE"))
 1773| 
 1774|     def test_override_class_attributes(self):
 1775| 
 1776|         def function():
 1777|             pass
 1778| 
 1779|         class DerivedObjectProxy(wrapt.ObjectProxy):
 1780|             ATTRIBUTE = 1
 1781| 
 1782|         obj = DerivedObjectProxy(function)
 1783| 
 1784|         self.assertEqual(DerivedObjectProxy.ATTRIBUTE, 1)
 1785|         self.assertEqual(obj.ATTRIBUTE, 1)
 1786| 
 1787|         obj.ATTRIBUTE = 2
 1788| 
 1789|         self.assertEqual(DerivedObjectProxy.ATTRIBUTE, 1)
 1790| 
 1791|         self.assertEqual(obj.ATTRIBUTE, 2)
 1792|         self.assertFalse(hasattr(function, "ATTRIBUTE"))
 1793| 
 1794|         del DerivedObjectProxy.ATTRIBUTE
 1795| 
 1796|         self.assertFalse(hasattr(DerivedObjectProxy, "ATTRIBUTE"))
 1797|         self.assertEqual(obj.ATTRIBUTE, 2)
 1798|         self.assertFalse(hasattr(function, "ATTRIBUTE"))
 1799| 
 1800|     def test_class_properties(self):
 1801| 
 1802|         def function():
 1803|             pass
 1804| 
 1805|         class DerivedObjectProxy(wrapt.ObjectProxy):
 1806|             def __init__(self, wrapped):
 1807|                 super(DerivedObjectProxy, self).__init__(wrapped)
 1808|                 self._self_attribute = 1
 1809| 
 1810|             @property
 1811|             def ATTRIBUTE(self):
 1812|                 return self._self_attribute
 1813| 
 1814|             @ATTRIBUTE.setter
 1815|             def ATTRIBUTE(self, value):
 1816|                 self._self_attribute = value
 1817| 
 1818|             @ATTRIBUTE.deleter
 1819|             def ATTRIBUTE(self):
 1820|                 del self._self_attribute
 1821| 
 1822|         obj = DerivedObjectProxy(function)
 1823| 
 1824|         self.assertEqual(obj.ATTRIBUTE, 1)
 1825| 
 1826|         obj.ATTRIBUTE = 2
 1827| 
 1828|         self.assertEqual(obj.ATTRIBUTE, 2)
 1829|         self.assertFalse(hasattr(function, "ATTRIBUTE"))
 1830| 
 1831|         del obj.ATTRIBUTE
 1832| 
 1833|         self.assertFalse(hasattr(obj, "ATTRIBUTE"))
 1834|         self.assertFalse(hasattr(function, "ATTRIBUTE"))
 1835| 
 1836|         obj.ATTRIBUTE = 1
 1837| 
 1838|         self.assertEqual(obj.ATTRIBUTE, 1)
 1839| 
 1840|         obj.ATTRIBUTE = 2
 1841| 
 1842|         self.assertEqual(obj.ATTRIBUTE, 2)
 1843|         self.assertFalse(hasattr(function, "ATTRIBUTE"))
 1844| 
 1845|         del obj.ATTRIBUTE
 1846| 
 1847|         self.assertFalse(hasattr(obj, "ATTRIBUTE"))
 1848|         self.assertFalse(hasattr(function, "ATTRIBUTE"))
 1849| 
