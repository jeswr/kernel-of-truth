  949| class TestAsNumberObjectProxy(unittest.TestCase):
  950| 
  951|     def test_nonzero(self):
  952|         true = wrapt.ObjectProxy(True)
  953|         false = wrapt.ObjectProxy(False)
  954| 
  955|         self.assertTrue(true)
  956|         self.assertFalse(false)
  957| 
  958|         self.assertTrue(bool(true))
  959|         self.assertFalse(bool(false))
  960| 
  961|         self.assertTrue(not false)
  962|         self.assertFalse(not true)
  963| 
  964|     def test_int(self):
  965|         one = wrapt.ObjectProxy(1)
  966| 
  967|         self.assertEqual(int(one), 1)
  968| 
  969|     def test_float(self):
  970|         one = wrapt.ObjectProxy(1)
  971| 
  972|         self.assertEqual(float(one), 1.0)
  973| 
  974|     def test_add(self):
  975|         one = wrapt.ObjectProxy(1)
  976|         two = wrapt.ObjectProxy(2)
  977| 
  978|         self.assertEqual(one + two, 1 + 2)
  979|         self.assertEqual(1 + two, 1 + 2)
  980|         self.assertEqual(one + 2, 1 + 2)
  981| 
  982|     def test_add_uninitialized_args(self):
  983|         result = object()
  984| 
  985|         one = wrapt.ObjectProxy.__new__(wrapt.ObjectProxy, None)
  986|         two = wrapt.ObjectProxy(2)
  987| 
  988|         try:
  989|             assert one + two == result
  990|         except AttributeError:
  991|             pass
  992| 
  993|         one = wrapt.ObjectProxy(1)
  994|         two = wrapt.ObjectProxy.__new__(wrapt.ObjectProxy, None)
  995| 
  996|         try:
  997|             assert one + two == result
  998|         except AttributeError:
  999|             pass
 1000| 
