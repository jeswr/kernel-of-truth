 1189|     def test_pow_modulo_proxy_raises(self):
 1190|         # Regression test for #108. Passing a proxy as the modulo
 1191|         # argument to pow() previously segfaulted with the C extension
 1192|         # because ternary_op would recurse back into the proxy nb_power
 1193|         # slot indefinitely. A proxy modulo is not supported and must
 1194|         # raise TypeError consistently across implementations.
 1195| 
 1196|         two = wrapt.ObjectProxy(2)
 1197|         three = wrapt.ObjectProxy(3)
 1198|         five = wrapt.ObjectProxy(5)
 1199| 
 1200|         self.assertRaises(TypeError, pow, 2, 3, five)
 1201|         self.assertRaises(TypeError, pow, three, 3, five)
 1202|         self.assertRaises(TypeError, pow, 2, two, five)
 1203|         self.assertRaises(TypeError, pow, three, two, five)
 1204| 
