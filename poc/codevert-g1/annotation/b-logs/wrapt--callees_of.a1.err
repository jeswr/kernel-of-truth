  222| class TestAutoObjectProxyReassignment(unittest.TestCase):
  223| 
  224|     def test_call_added_on_reassignment(self):
  225|         proxy = wrapt.AutoObjectProxy(object())
  226|         self.assertFalse(callable(proxy))
  227|         proxy.__wrapped__ = lambda: 42
  228|         self.assertTrue(callable(proxy))
  229|         self.assertEqual(proxy(), 42)
  230| 
  231|     def test_call_removed_on_reassignment(self):
  232|         proxy = wrapt.AutoObjectProxy(lambda: 42)
  233|         self.assertTrue(callable(proxy))
  234|         proxy.__wrapped__ = object()
  235|         self.assertFalse(callable(proxy))
  236| 
  237|     def test_iter_added_on_reassignment(self):
  238|         proxy = wrapt.AutoObjectProxy(object())
  239|         self.assertFalse(hasattr(proxy, "__iter__"))
  240|         proxy.__wrapped__ = [1, 2, 3]
  241|         self.assertTrue(hasattr(proxy, "__iter__"))
  242|         self.assertEqual(list(proxy), [1, 2, 3])
  243| 
  244|     def test_iter_removed_on_reassignment(self):
  245|         proxy = wrapt.AutoObjectProxy([1, 2, 3])
