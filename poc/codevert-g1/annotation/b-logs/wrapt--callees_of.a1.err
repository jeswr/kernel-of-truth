 1851| class OverrideAttributeAccess(unittest.TestCase):
 1852| 
 1853|     def test_attr_functions(self):
 1854| 
 1855|         def function():
 1856|             pass
 1857| 
 1858|         proxy = wrapt.ObjectProxy(function)
 1859| 
 1860|         self.assertTrue(hasattr(proxy, "__getattr__"))
 1861|         self.assertTrue(hasattr(proxy, "__setattr__"))
 1862|         self.assertTrue(hasattr(proxy, "__delattr__"))
 1863| 
 1864|     def test_override_getattr(self):
 1865| 
 1866|         def function():
 1867|             pass
 1868| 
 1869|         accessed = []
 1870| 
 1871|         class DerivedObjectProxy(wrapt.ObjectProxy):
 1872|             def __getattr__(self, name):
 1873|                 accessed.append(name)
 1874|                 try:
 1875|                     __getattr__ = super(DerivedObjectProxy, self).__getattr__
 1876|                 except AttributeError as e:
 1877|                     raise RuntimeError(str(e))
 1878|                 return __getattr__(name)
 1879| 
 1880|         function.attribute = 1
 1881| 
 1882|         proxy = DerivedObjectProxy(function)
 1883| 
 1884|         self.assertEqual(proxy.attribute, 1)
 1885| 
 1886|         self.assertTrue("attribute" in accessed)
 1887| 
