FILE tests/test_i18n.py:
    1| """Internationalisation tests."""
    2| 
    3| from __future__ import annotations
    4| 
    5| import datetime as dt
    6| import importlib
    7| 
    8| import pytest
    9| from freezegun import freeze_time
   10| 
   11| import humanize
   12| 
   13| with freeze_time("2020-02-02"):
   14|     NOW = dt.datetime.now(tz=dt.timezone.utc)
   15| 
   16| 
   17| @freeze_time("2020-02-02")
   18| def test_i18n() -> None:
   19|     three_seconds = NOW - dt.timedelta(seconds=3)
   20|     one_min_three_seconds = dt.timedelta(milliseconds=67_000)
   21| 
   22|     assert humanize.naturaltime(three_seconds) == "3 seconds ago"
   23|     assert humanize.ordinal(5) == "5th"
   24|     assert humanize.precisedelta(one_min_three_seconds) == "1 minute and 7 seconds"
   25| 
   26|     try:
   27|         humanize.i18n.activate("lv")
   28|         assert humanize.naturaltime(three_seconds) == "pirms 3 sekundēm"
   29|         assert humanize.ordinal(5) == "5."
   30| 
   31|         humanize.i18n.activate("ru_RU")
   32|         assert humanize.naturaltime(three_seconds) == "3 секунды назад"
   33|         assert humanize.ordinal(5) == "5ый"
   34|         assert humanize.precisedelta(one_min_three_seconds) == "1 минута и 7 секунд"
   35| 
   36|     except FileNotFoundError:
   37|         pytest.skip("Generate .mo with scripts/generate-translation-binaries.sh")
   38| 
   39|     finally:
   40|         humanize.i18n.deactivate()
   41|         assert humanize.naturaltime(three_seconds) == "3 seconds ago"
   42|         assert humanize.ordinal(5) == "5th"
   43|         assert humanize.precisedelta(one_min_three_seconds) == "1 minute and 7 seconds"
   44| 
   45| 
   46| def test_intcomma() -> None:
   47|     number = 10_000_000
   48| 
   49|     assert humanize.intcomma(number) == "10,000,000"
   50| 
   51|     try:
   52|         humanize.i18n.activate("de_DE")
   53|         assert humanize.intcomma(number) == "10.000.000"
   54|         assert humanize.intcomma(1_234_567.8901) == "1.234.567,8901"
   55|         assert humanize.intcomma(1_234_567.89) == "1.234.567,89"
   56|         assert humanize.intcomma("1234567,89") == "1.234.567,89"
   57|         assert humanize.intcomma("1.234.567,89") == "1.234.567,89"
   58|         assert humanize.intcomma("1.234.567,8") == "1.234.567,8"
   59| 
   60|         humanize.i18n.activate("fr_FR")
   61|         assert humanize.intcomma(number) == "10 000 000"
   62|         assert humanize.intcomma(1_234_567.89) == "1 234 567.89"
   63|         assert humanize.intcomma("1 234 567.89") == "1 234 567.89"
   64| 
   65|         humanize.i18n.activate("pt_BR")
   66|         assert humanize.intcomma(number) == "10.000.000"
   67| 
