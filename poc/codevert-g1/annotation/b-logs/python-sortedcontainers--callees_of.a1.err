 2302|     def index(self, value, start=None, stop=None):
 2303|         """Return first index of value in sorted-key list.
 2304| 
 2305|         Raise ValueError if `value` is not present.
 2306| 
 2307|         Index must be between `start` and `stop` for the `value` to be
 2308|         considered present. The default value, None, for `start` and `stop`
 2309|         indicate the beginning and end of the sorted-key list.
 2310| 
 2311|         Negative indices are supported.
 2312| 
 2313|         Runtime complexity: `O(log(n))` -- approximate.
 2314| 
 2315|         >>> from operator import neg
 2316|         >>> skl = SortedKeyList([5, 4, 3, 2, 1], key=neg)
 2317|         >>> skl.index(2)
 2318|         3
 2319|         >>> skl.index(0)
 2320|         Traceback (most recent call last):
 2321|           ...
 2322|         ValueError: 0 is not in list
 2323| 
 2324|         :param value: value in sorted-key list
 2325|         :param int start: start index (default None, start of sorted-key list)
 2326|         :param int stop: stop index (default None, end of sorted-key list)
 2327|         :return: index of value
 2328|         :raises ValueError: if value is not present
 2329| 
 2330|         """
 2331|         _len = self._len
 2332| 
 2333|         if not _len:
 2334|             raise ValueError(f'{value!r} is not in list')
 2335| 
 2336|         if start is None:
 2337|             start = 0
 2338|         if start < 0:
 2339|             start += _len
 2340|         if start < 0:
 2341|             start = 0
 2342| 
 2343|         if stop is None:
 2344|             stop = _len
 2345|         if stop < 0:
 2346|             stop += _len
 2347|         if stop > _len:
 2348|             stop = _len
 2349| 
 2350|         if stop <= start:
 2351|             raise ValueError(f'{value!r} is not in list')
 2352| 
 2353|         _maxes = self._maxes
 2354|         key = self._key(value)
 2355|         pos = bisect_left(_maxes, key)
 2356| 
 2357|         if pos == len(_maxes):
 2358|             raise ValueError(f'{value!r} is not in list')
 2359| 
 2360|         stop -= 1
 2361|         _lists = self._lists
 2362|         _keys = self._keys
 2363|         idx = bisect_left(_keys[pos], key)
 2364|         len_keys = len(_keys)
 2365|         len_sublist = len(_keys[pos])
 2366| 
 2367|         while True:
 2368|             if _keys[pos][idx] != key:
 2369|                 raise ValueError(f'{value!r} is not in list')
 2370|             if _lists[pos][idx] == value:
 2371|                 loc = self._loc(pos, idx)
 2372|                 if start <= loc <= stop:
 2373|                     return loc
 2374|                 elif loc > stop:
 2375|                     break
 2376|             idx += 1
 2377|             if idx == len_sublist:
 2378|                 pos += 1
 2379|                 if pos == len_keys:
 2380|                     raise ValueError(f'{value!r} is not in list')
 2381|                 len_sublist = len(_keys[pos])
 2382|                 idx = 0
 2383| 
 2384|         raise ValueError(f'{value!r} is not in list')
 2385| 
 2386|     def __add__(self, other):
 2387|         """Return new sorted-key list containing all values in both sequences.
 2388| 
 2389|         ``skl.__add__(other)`` <==> ``skl + other``
 2390| 
 2391|         Values in `other` do not need to be in sorted-key order.
 2392| 
 2393|         Runtime complexity: `O(n*log(n))`
 2394| 
 2395|         >>> from operator import neg
 2396|         >>> skl1 = SortedKeyList([5, 4, 3], key=neg)
 2397|         >>> skl2 = SortedKeyList([2, 1, 0], key=neg)
 2398|         >>> skl1 + skl2
 2399|         SortedKeyList([5, 4, 3, 2, 1, 0], key=<built-in function neg>)
 2400| 
 2401|         :param other: other iterable
 2402|         :return: new sorted-key list
 2403| 
 2404|         """
 2405|         values = reduce(iadd, self._lists, [])
 2406|         values.extend(other)
 2407|         return self.__class__(values, key=self._key)
 2408| 
 2409|     __radd__ = __add__
 2410| 
 2411|     def __mul__(self, num):
 2412|         """Return new sorted-key list with `num` shallow copies of values.
 2413| 
 2414|         ``skl.__mul__(num)`` <==> ``skl * num``
 2415| 
 2416|         Runtime complexity: `O(n*log(n))`
 2417| 
 2418|         >>> from operator import neg
 2419|         >>> skl = SortedKeyList([3, 2, 1], key=neg)
 2420|         >>> skl * 2
 2421|         SortedKeyList([3, 3, 2, 2, 1, 1], key=<built-in function neg>)
 2422| 
 2423|         :param int num: count of shallow copies
 2424|         :return: new sorted-key list
 2425| 
 2426|         """
 2427|         values = reduce(iadd, self._lists, []) * num
 2428|         return self.__class__(values, key=self._key)
 2429| 
 2430|     def __reduce__(self):
 2431|         values = reduce(iadd, self._lists, [])
 2432|         return (type(self), (values, self.key))
 2433| 
 2434|     @recursive_repr()
 2435|     def __repr__(self):
 2436|         """Return string representation of sorted-key list.
 2437| 
 2438|         ``skl.__repr__()`` <==> ``repr(skl)``
 2439| 
 2440|         :return: string representation
 2441| 
 2442|         """
 2443|         type_name = type(self).__name__
 2444|         return f'{type_name}({list(self)!r}, key={self._key!r})'
