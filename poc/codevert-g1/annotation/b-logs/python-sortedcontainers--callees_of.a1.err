 1231|     def pop(self, index=-1):
 1232|         """Remove and return value at `index` in sorted list.
 1233| 
 1234|         Raise :exc:`IndexError` if the sorted list is empty or index is out of
 1235|         range.
 1236| 
 1237|         Negative indices are supported.
 1238| 
 1239|         Runtime complexity: `O(log(n))` -- approximate.
 1240| 
 1241|         >>> sl = SortedList('abcde')
 1242|         >>> sl.pop()
 1243|         'e'
 1244|         >>> sl.pop(2)
 1245|         'c'
 1246|         >>> sl
 1247|         SortedList(['a', 'b', 'd'])
 1248| 
 1249|         :param int index: index of value (default -1)
 1250|         :return: value
 1251|         :raises IndexError: if index is out of range
 1252| 
 1253|         """
 1254|         if not self._len:
 1255|             raise IndexError('pop index out of range')
 1256| 
 1257|         _lists = self._lists
 1258| 
 1259|         if index == 0:
 1260|             val = _lists[0][0]
 1261|             self._delete(0, 0)
 1262|             return val
 1263| 
 1264|         if index == -1:
 1265|             pos = len(_lists) - 1
 1266|             loc = len(_lists[pos]) - 1
 1267|             val = _lists[pos][loc]
 1268|             self._delete(pos, loc)
 1269|             return val
 1270| 
 1271|         if 0 <= index < len(_lists[0]):
 1272|             val = _lists[0][index]
 1273|             self._delete(0, index)
 1274|             return val
 1275| 
 1276|         len_last = len(_lists[-1])
 1277| 
 1278|         if -len_last < index < 0:
 1279|             pos = len(_lists) - 1
 1280|             loc = len_last + index
 1281|             val = _lists[pos][loc]
 1282|             self._delete(pos, loc)
 1283|             return val
 1284| 
 1285|         pos, idx = self._pos(index)
 1286|         val = _lists[pos][idx]
 1287|         self._delete(pos, idx)
 1288|         return val
 1289| 
 1290|     def index(self, value, start=None, stop=None):
 1291|         """Return first index of value in sorted list.
 1292| 
 1293|         Raise ValueError if `value` is not present.
 1294| 
 1295|         Index must be between `start` and `stop` for the `value` to be
 1296|         considered present. The default value, None, for `start` and `stop`
 1297|         indicate the beginning and end of the sorted list.
 1298| 
 1299|         Negative indices are supported.
 1300| 
 1301|         Runtime complexity: `O(log(n))` -- approximate.
 1302| 
 1303|         >>> sl = SortedList('abcde')
 1304|         >>> sl.index('d')
 1305|         3
 1306|         >>> sl.index('z')
 1307|         Traceback (most recent call last):
 1308|           ...
 1309|         ValueError: 'z' is not in list
 1310| 
 1311|         :param value: value in sorted list
 1312|         :param int start: start index (default None, start of sorted list)
 1313|         :param int stop: stop index (default None, end of sorted list)
 1314|         :return: index of value
 1315|         :raises ValueError: if value is not present
 1316| 
 1317|         """
 1318|         _len = self._len
 1319| 
 1320|         if not _len:
 1321|             raise ValueError(f'{value!r} is not in list')
 1322| 
 1323|         if start is None:
 1324|             start = 0
 1325|         if start < 0:
 1326|             start += _len
 1327|         if start < 0:
 1328|             start = 0
 1329| 
 1330|         if stop is None:
 1331|             stop = _len
 1332|         if stop < 0:
 1333|             stop += _len
 1334|         if stop > _len:
 1335|             stop = _len
 1336| 
 1337|         if stop <= start:
 1338|             raise ValueError(f'{value!r} is not in list')
 1339| 
 1340|         _maxes = self._maxes
 1341|         pos_left = bisect_left(_maxes, value)
 1342| 
 1343|         if pos_left == len(_maxes):
 1344|             raise ValueError(f'{value!r} is not in list')
 1345| 
 1346|         _lists = self._lists
 1347|         idx_left = bisect_left(_lists[pos_left], value)
 1348| 
 1349|         if _lists[pos_left][idx_left] != value:
 1350|             raise ValueError(f'{value!r} is not in list')
 1351| 
 1352|         stop -= 1
 1353|         left = self._loc(pos_left, idx_left)
 1354| 
 1355|         if start <= left:
 1356|             if left <= stop:
 1357|                 return left
 1358|         else:
 1359|             right = self._bisect_right(value) - 1
 1360| 
 1361|             if start <= right:
 1362|                 return start
 1363| 
 1364|         raise ValueError(f'{value!r} is not in list')
 1365| 
 1366|     def __add__(self, other):
 1367|         """Return new sorted list containing all values in both sequences.
 1368| 
 1369|         ``sl.__add__(other)`` <==> ``sl + other``
 1370| 
 1371|         Values in `other` do not need to be in sorted order.
 1372| 
 1373|         Runtime complexity: `O(n*log(n))`
 1374| 
 1375|         >>> sl1 = SortedList('bat')
 1376|         >>> sl2 = SortedList('cat')
 1377|         >>> sl1 + sl2
 1378|         SortedList(['a', 'a', 'b', 'c', 't', 't'])
 1379| 
 1380|         :param other: other iterable
 1381|         :return: new sorted list
 1382| 
 1383|         """
 1384|         values = reduce(iadd, self._lists, [])
 1385|         values.extend(other)
 1386|         return self.__class__(values)
 1387| 
 1388|     __radd__ = __add__
 1389| 
 1390|     def __iadd__(self, other):
 1391|         """Update sorted list with values from `other`.
 1392| 
 1393|         ``sl.__iadd__(other)`` <==> ``sl += other``
 1394| 
 1395|         Values in `other` do not need to be in sorted order.
 1396| 
 1397|         Runtime complexity: `O(k*log(n))` -- approximate.
 1398| 
 1399|         >>> sl = SortedList('bat')
 1400|         >>> sl += 'cat'
 1401|         >>> sl
 1402|         SortedList(['a', 'a', 'b', 'c', 't', 't'])
 1403| 
 1404|         :param other: other iterable
 1405|         :return: existing sorted list
 1406| 
 1407|         """
 1408|         self._update(other)
 1409|         return self
 1410| 
 1411|     def __mul__(self, num):
 1412|         """Return new sorted list with `num` shallow copies of values.
 1413| 
 1414|         ``sl.__mul__(num)`` <==> ``sl * num``
 1415| 
 1416|         Runtime complexity: `O(n*log(n))`
 1417| 
 1418|         >>> sl = SortedList('abc')
 1419|         >>> sl * 3
 1420|         SortedList(['a', 'a', 'a', 'b', 'b', 'b', 'c', 'c', 'c'])
 1421| 
 1422|         :param int num: count of shallow copies
 1423|         :return: new sorted list
 1424| 
 1425|         """
 1426|         values = reduce(iadd, self._lists, []) * num
 1427|         return self.__class__(values)
 1428| 
 1429|     __rmul__ = __mul__
 1430| 
 1431|     def __imul__(self, num):
 1432|         """Update the sorted list with `num` shallow copies of values.
 1433| 
 1434|         ``sl.__imul__(num)`` <==> ``sl *= num``
 1435| 
 1436|         Runtime complexity: `O(n*log(n))`
 1437| 
 1438|         >>> sl = SortedList('abc')
 1439|         >>> sl *= 3
 1440|         >>> sl
 1441|         SortedList(['a', 'a', 'a', 'b', 'b', 'b', 'c', 'c', 'c'])
 1442| 
 1443|         :param int num: count of shallow copies
 1444|         :return: existing sorted list
 1445| 
 1446|         """
 1447|         values = reduce(iadd, self._lists, []) * num
 1448|         self._clear()
 1449|         self._update(values)
 1450|         return self
 1451| 
 1452|     def __make_cmp(seq_op, symbol, doc):
 1453|         "Make comparator method."
 1454| 
 1455|         def comparer(self, other):
 1456|             "Compare method for sorted list and sequence."
 1457|             if not isinstance(other, Sequence):
 1458|                 return NotImplemented
 1459| 
 1460|             self_len = self._len
 1461|             len_other = len(other)
 1462| 
 1463|             if self_len != len_other:
 1464|                 if seq_op is eq:
 1465|                     return False
 1466|                 if seq_op is ne:
 1467|                     return True
 1468| 
 1469|             for alpha, beta in zip(self, other):
 1470|                 if alpha != beta:
 1471|                     return seq_op(alpha, beta)
 1472| 
 1473|             return seq_op(self_len, len_other)
 1474| 
 1475|         seq_op_name = seq_op.__name__
 1476|         comparer.__name__ = f'__{seq_op_name}__'
 1477|         doc_str = """Return true if and only if sorted list is {0} `other`.
 1478| 
 1479|         ``sl.__{1}__(other)`` <==> ``sl {2} other``
 1480| 
 1481|         Comparisons use lexicographical order as with sequences.
 1482| 
 1483|         Runtime complexity: `O(n)`
 1484| 
 1485|         :param other: `other` sequence
 1486|         :return: true if sorted list is {0} `other`
 1487| 
 1488|         """
 1489|         comparer.__doc__ = dedent(doc_str.format(doc, seq_op_name, symbol))
 1490|         return comparer
 1491| 
 1492|     __eq__ = __make_cmp(eq, '==', 'equal to')
 1493|     __ne__ = __make_cmp(ne, '!=', 'not equal to')
 1494|     __lt__ = __make_cmp(lt, '<', 'less than')
 1495|     __gt__ = __make_cmp(gt, '>', 'greater than')
 1496|     __le__ = __make_cmp(le, '<=', 'less than or equal to')
 1497|     __ge__ = __make_cmp(ge, '>=', 'greater than or equal to')
 1498|     __make_cmp = staticmethod(__make_cmp)
 1499| 
 1500|     def __reduce__(self):
 1501|         values = reduce(iadd, self._lists, [])
 1502|         return (type(self), (values,))
 1503| 
 1504|     @recursive_repr()
 1505|     def __repr__(self):
 1506|         """Return string representation of sorted list.
 1507| 
 1508|         ``sl.__repr__()`` <==> ``repr(sl)``
 1509| 
 1510|         :return: string representation
 1511| 
 1512|         """
 1513|         return f'{type(self).__name__}({list(self)!r})'
 1514| 
 1515|     def _check(self):
 1516|         """Check invariants of sorted list.
 1517| 
 1518|         Runtime complexity: `O(n)`
 1519| 
 1520|         """
 1521|         try:
 1522|             assert self._load >= 4
 1523|             assert len(self._maxes) == len(self._lists)
 1524|             assert self._len == sum(len(sublist) for sublist in self._lists)
 1525| 
 1526|             # Check all sublists are sorted.
 1527| 
 1528|             for sublist in self._lists:
 1529|                 for pos in range(1, len(sublist)):
 1530|                     assert sublist[pos - 1] <= sublist[pos]
 1531| 
 1532|             # Check beginning/end of sublists are sorted.
 1533| 
 1534|             for pos in range(1, len(self._lists)):
 1535|                 assert self._lists[pos - 1][-1] <= self._lists[pos][0]
 1536| 
 1537|             # Check _maxes index is the last value of each sublist.
 1538| 
 1539|             for pos in range(len(self._maxes)):
 1540|                 assert self._maxes[pos] == self._lists[pos][-1]
 1541| 
 1542|             # Check sublist lengths are less than double load-factor.
 1543| 
 1544|             double = self._load << 1
 1545|             assert all(len(sublist) <= double for sublist in self._lists)
 1546| 
 1547|             # Check sublist lengths are greater than half load-factor for all
 1548|             # but the last sublist.
 1549| 
 1550|             half = self._load >> 1
 1551|             for pos in range(0, len(self._lists) - 1):
 1552|                 assert len(self._lists[pos]) >= half
 1553| 
 1554|             if self._index:
 1555|                 assert self._len == self._index[0]
 1556|                 assert len(self._index) == self._offset + len(self._lists)
 1557| 
 1558|                 # Check index leaf nodes equal length of sublists.
 1559| 
 1560|                 for pos in range(len(self._lists)):
 1561|                     leaf = self._index[self._offset + pos]
 1562|                     assert leaf == len(self._lists[pos])
 1563| 
 1564|                 # Check index branch nodes are the sum of their children.
 1565| 
 1566|                 for pos in range(self._offset):
 1567|                     child = (pos << 1) + 1
 1568|                     if child >= len(self._index):
 1569|                         assert self._index[pos] == 0
 1570|                     elif child + 1 == len(self._index):
 1571|                         assert self._index[pos] == self._index[child]
 1572|                     else:
 1573|                         child_sum = self._index[child] + self._index[child + 1]
 1574|                         assert child_sum == self._index[pos]
 1575|         except:
 1576|             traceback.print_exc(file=sys.stdout)
 1577|             print('len', self._len)
 1578|             print('load', self._load)
 1579|             print('offset', self._offset)
 1580|             print('len_index', len(self._index))
 1581|             print('index', self._index)
 1582|             print('len_maxes', len(self._maxes))
 1583|             print('maxes', self._maxes)
 1584|             print('len_lists', len(self._lists))
 1585|             print('lists', self._lists)
 1586|             raise
 1587| 
 1588| 
 1589| def identity(value):
 1590|     "Identity function."
 1591|     return value
 1592| 
 1593| 
 1594| class SortedKeyList(SortedList):
 1595|     """Sorted-key list is a subtype of sorted list.
 1596| 
 1597|     The sorted-key list maintains values in comparison order based on the
 1598|     result of a key function applied to every value.
 1599| 
 1600|     All the same methods that are available in :class:`SortedList` are also
 1601|     available in :class:`SortedKeyList`.
 1602| 
 1603|     Additional methods provided:
 1604| 
 1605|     * :attr:`SortedKeyList.key`
 1606|     * :func:`SortedKeyList.bisect_key_left`
 1607|     * :func:`SortedKeyList.bisect_key_right`
 1608|     * :func:`SortedKeyList.irange_key`
 1609| 
 1610|     Some examples below use:
 1611| 
 1612|     >>> from operator import neg
 1613|     >>> neg
 1614|     <built-in function neg>
 1615|     >>> neg(1)
 1616|     -1
 1617| 
 1618|     """
 1619| 
 1620|     def __init__(self, iterable=None, key=identity):
 1621|         """Initialize sorted-key list instance.
 1622| 
 1623|         Optional `iterable` argument provides an initial iterable of values to
 1624|         initialize the sorted-key list.
 1625| 
 1626|         Optional `key` argument defines a callable that, like the `key`
 1627|         argument to Python's `sorted` function, extracts a comparison key from
 1628|         each value. The default is the identity function.
 1629| 
 1630|         Runtime complexity: `O(n*log(n))`
 1631| 
 1632|         >>> from operator import neg
 1633|         >>> skl = SortedKeyList(key=neg)
 1634|         >>> skl
 1635|         SortedKeyList([], key=<built-in function neg>)
 1636|         >>> skl = SortedKeyList([3, 1, 2], key=neg)
 1637|         >>> skl
 1638|         SortedKeyList([3, 2, 1], key=<built-in function neg>)
 1639| 
 1640|         :param iterable: initial values (optional)
 1641|         :param key: function used to extract comparison key (optional)
 1642| 
 1643|         """
 1644|         self._key = key
 1645|         self._len = 0
 1646|         self._load = self.DEFAULT_LOAD_FACTOR
 1647|         self._lists = []
 1648|         self._keys = []
 1649|         self._maxes = []
 1650|         self._index = []
 1651|         self._offset = 0
 1652| 
 1653|         if iterable is not None:
 1654|             self._update(iterable)
 1655| 
 1656|     def __new__(cls, iterable=None, key=identity):
 1657|         return object.__new__(cls)
 1658| 
 1659|     @property
 1660|     def key(self):
 1661|         "Function used to extract comparison key from values."
 1662|         return self._key
 1663| 
 1664|     def clear(self):
 1665|         """Remove all values from sorted-key list.
 1666| 
 1667|         Runtime complexity: `O(n)`
 1668| 
 1669|         """
 1670|         self._len = 0
 1671|         del self._lists[:]
 1672|         del self._keys[:]
 1673|         del self._maxes[:]
 1674|         del self._index[:]
 1675| 
 1676|     _clear = clear
 1677| 
 1678|     def add(self, value):
 1679|         """Add `value` to sorted-key list.
 1680| 
 1681|         Runtime complexity: `O(log(n))` -- approximate.
 1682| 
 1683|         >>> from operator import neg
 1684|         >>> skl = SortedKeyList(key=neg)
 1685|         >>> skl.add(3)
 1686|         >>> skl.add(1)
 1687|         >>> skl.add(2)
 1688|         >>> skl
 1689|         SortedKeyList([3, 2, 1], key=<built-in function neg>)
 1690| 
 1691|         :param value: value to add to sorted-key list
 1692| 
 1693|         """
 1694|         _lists = self._lists
 1695|         _keys = self._keys
 1696|         _maxes = self._maxes
 1697| 
 1698|         key = self._key(value)
 1699| 
 1700|         if _maxes:
 1701|             pos = bisect_right(_maxes, key)
 1702| 
 1703|             if pos == len(_maxes):
 1704|                 pos -= 1
 1705|                 _lists[pos].append(value)
 1706|                 _keys[pos].append(key)
 1707|                 _maxes[pos] = key
 1708|             else:
 1709|                 idx = bisect_right(_keys[pos], key)
 1710|                 _lists[pos].insert(idx, value)
 1711|                 _keys[pos].insert(idx, key)
 1712| 
 1713|             self._expand(pos)
 1714|         else:
 1715|             _lists.append([value])
 1716|             _keys.append([key])
 1717|             _maxes.append(key)
 1718| 
 1719|         self._len += 1
 1720| 
 1721|     def _expand(self, pos):
 1722|         """Split sublists with length greater than double the load-factor.
 1723| 
 1724|         Updates the index when the sublist length is less than double the load
 1725|         level. This requires incrementing the nodes in a traversal from the
 1726|         leaf node to the root. For an example traversal see
 1727|         ``SortedList._loc``.
 1728| 
 1729|         """
 1730|         _lists = self._lists
 1731|         _keys = self._keys
 1732|         _index = self._index
 1733| 
 1734|         if len(_keys[pos]) > (self._load << 1):
 1735|             _maxes = self._maxes
 1736|             _load = self._load
 1737| 
 1738|             _lists_pos = _lists[pos]
 1739|             _keys_pos = _keys[pos]
 1740|             half = _lists_pos[_load:]
 1741|             half_keys = _keys_pos[_load:]
 1742|             del _lists_pos[_load:]
 1743|             del _keys_pos[_load:]
 1744|             _maxes[pos] = _keys_pos[-1]
 1745| 
 1746|             _lists.insert(pos + 1, half)
 1747|             _keys.insert(pos + 1, half_keys)
 1748|             _maxes.insert(pos + 1, half_keys[-1])
 1749| 
 1750|             del _index[:]
 1751|         else:
 1752|             if _index:
 1753|                 child = self._offset + pos
 1754|                 while child:
 1755|                     _index[child] += 1
 1756|                     child = (child - 1) >> 1
 1757|                 _index[0] += 1
 1758| 
 1759|     def update(self, iterable):
 1760|         """Update sorted-key list by adding all values from `iterable`.
 1761| 
 1762|         Runtime complexity: `O(k*log(n))` -- approximate.
 1763| 
 1764|         >>> from operator import neg
 1765|         >>> skl = SortedKeyList(key=neg)
 1766|         >>> skl.update([3, 1, 2])
 1767|         >>> skl
 1768|         SortedKeyList([3, 2, 1], key=<built-in function neg>)
 1769| 
 1770|         :param iterable: iterable of values to add
 1771| 
 1772|         """
 1773|         _lists = self._lists
 1774|         _keys = self._keys
 1775|         _maxes = self._maxes
 1776|         values = sorted(iterable, key=self._key)
 1777| 
 1778|         if _maxes:
 1779|             if len(values) * 4 >= self._len:
 1780|                 _lists.append(values)
 1781|                 values = reduce(iadd, _lists, [])
 1782|                 values.sort(key=self._key)
 1783|                 self._clear()
 1784|             else:
 1785|                 _add = self.add
 1786|                 for val in values:
 1787|                     _add(val)
 1788|                 return
 1789| 
 1790|         _load = self._load
 1791|         _lists.extend(
 1792|             values[pos : (pos + _load)] for pos in range(0, len(values), _load)
 1793|         )
 1794|         _keys.extend(list(map(self._key, _list)) for _list in _lists)
 1795|         _maxes.extend(sublist[-1] for sublist in _keys)
 1796|         self._len = len(values)
 1797|         del self._index[:]
 1798| 
 1799|     _update = update
