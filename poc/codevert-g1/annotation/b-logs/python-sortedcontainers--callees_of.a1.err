  454|     def _loc(self, pos, idx):
  455|         """Convert an index pair (lists index, sublist index) into a single
  456|         index number that corresponds to the position of the value in the
  457|         sorted list.
  458| 
  459|         Many queries require the index be built. Details of the index are
  460|         described in ``SortedList._build_index``.
  461| 
  462|         Indexing requires traversing the tree from a leaf node to the root. The
  463|         parent of each node is easily computable at ``(pos - 1) // 2``.
  464| 
  465|         Left-child nodes are always at odd indices and right-child nodes are
  466|         always at even indices.
  467| 
  468|         When traversing up from a right-child node, increment the total by the
  469|         left-child node.
  470| 
  471|         The final index is the sum from traversal and the index in the sublist.
  472| 
  473|         For example, using the index from ``SortedList._build_index``::
  474| 
  475|             _index = 14 5 9 3 2 4 5
  476|             _offset = 3
  477| 
  478|         Tree::
  479| 
  480|                  14
  481|               5      9
  482|             3   2  4   5
  483| 
  484|         Converting an index pair (2, 3) into a single index involves iterating
  485|         like so:
  486| 
  487|         1. Starting at the leaf node: offset + alpha = 3 + 2 = 5. We identify
  488|            the node as a left-child node. At such nodes, we simply traverse to
  489|            the parent.
  490| 
  491|         2. At node 9, position 2, we recognize the node as a right-child node
  492|            and accumulate the left-child in our total. Total is now 5 and we
  493|            traverse to the parent at position 0.
  494| 
  495|         3. Iteration ends at the root.
  496| 
  497|         The index is then the sum of the total and sublist index: 5 + 3 = 8.
  498| 
  499|         :param int pos: lists index
  500|         :param int idx: sublist index
  501|         :return: index in sorted list
  502| 
  503|         """
  504|         if not pos:
  505|             return idx
  506| 
  507|         _index = self._index
  508| 
  509|         if not _index:
  510|             self._build_index()
  511| 
  512|         total = 0
  513| 
  514|         # Increment pos to point in the index to len(self._lists[pos]).
  515| 
  516|         pos += self._offset
  517| 
  518|         # Iterate until reaching the root of the index tree at pos = 0.
  519| 
  520|         while pos:
  521|             # Right-child nodes are at odd indices. At such indices
  522|             # account the total below the left child node.
  523| 
  524|             if not pos & 1:
  525|                 total += _index[pos - 1]
  526| 
  527|             # Advance pos to the parent node.
  528| 
  529|             pos = (pos - 1) >> 1
  530| 
  531|         return total + idx
  532| 
  533|     def _pos(self, idx):
  534|         """Convert an index into an index pair (lists index, sublist index)
  535|         that can be used to access the corresponding lists position.
  536| 
  537|         Many queries require the index be built. Details of the index are
  538|         described in ``SortedList._build_index``.
  539| 
  540|         Indexing requires traversing the tree to a leaf node. Each node has two
  541|         children which are easily computable. Given an index, pos, the
  542|         left-child is at ``pos * 2 + 1`` and the right-child is at ``pos * 2 +
  543|         2``.
  544| 
  545|         When the index is less than the left-child, traversal moves to the
  546|         left sub-tree. Otherwise, the index is decremented by the left-child
  547|         and traversal moves to the right sub-tree.
  548| 
  549|         At a child node, the indexing pair is computed from the relative
  550|         position of the child node as compared with the offset and the remaining
  551|         index.
  552| 
  553|         For example, using the index from ``SortedList._build_index``::
  554| 
  555|             _index = 14 5 9 3 2 4 5
  556|             _offset = 3
  557| 
  558|         Tree::
  559| 
  560|                  14
  561|               5      9
  562|             3   2  4   5
  563| 
  564|         Indexing position 8 involves iterating like so:
  565| 
  566|         1. Starting at the root, position 0, 8 is compared with the left-child
  567|            node (5) which it is greater than. When greater the index is
  568|            decremented and the position is updated to the right child node.
  569| 
  570|         2. At node 9 with index 3, we again compare the index to the left-child
  571|            node with value 4. Because the index is the less than the left-child
  572|            node, we simply traverse to the left.
  573| 
  574|         3. At node 4 with index 3, we recognize that we are at a leaf node and
  575|            stop iterating.
  576| 
  577|         4. To compute the sublist index, we subtract the offset from the index
  578|            of the leaf node: 5 - 3 = 2. To compute the index in the sublist, we
  579|            simply use the index remaining from iteration. In this case, 3.
  580| 
  581|         The final index pair from our example is (2, 3) which corresponds to
  582|         index 8 in the sorted list.
  583| 
  584|         :param int idx: index in sorted list
  585|         :return: (lists index, sublist index) pair
  586| 
  587|         """
  588|         if idx < 0:
  589|             last_len = len(self._lists[-1])
  590| 
  591|             if (-idx) <= last_len:
  592|                 return len(self._lists) - 1, last_len + idx
  593| 
  594|             idx += self._len
  595| 
  596|             if idx < 0:
  597|                 raise IndexError('list index out of range')
  598|         elif idx >= self._len:
  599|             raise IndexError('list index out of range')
  600| 
  601|         if idx < len(self._lists[0]):
  602|             return 0, idx
  603| 
  604|         _index = self._index
  605| 
  606|         if not _index:
  607|             self._build_index()
  608| 
  609|         pos = 0
  610|         child = 1
  611|         len_index = len(_index)
  612| 
  613|         while child < len_index:
  614|             index_child = _index[child]
  615| 
  616|             if idx < index_child:
  617|                 pos = child
  618|             else:
  619|                 idx -= index_child
  620|                 pos = child + 1
  621| 
  622|             child = (pos << 1) + 1
  623| 
  624|         return (pos - self._offset, idx)
  625| 
  626|     def _build_index(self):
  627|         """Build a positional index for indexing the sorted list.
  628| 
  629|         Indexes are represented as binary trees in a dense array notation
  630|         similar to a binary heap.
  631| 
  632|         For example, given a lists representation storing integers::
  633| 
  634|             0: [1, 2, 3]
  635|             1: [4, 5]
  636|             2: [6, 7, 8, 9]
  637|             3: [10, 11, 12, 13, 14]
  638| 
  639|         The first transformation maps the sub-lists by their length. The
  640|         first row of the index is the length of the sub-lists::
  641| 
  642|             0: [3, 2, 4, 5]
  643| 
  644|         Each row after that is the sum of consecutive pairs of the previous
  645|         row::
  646| 
  647|             1: [5, 9]
  648|             2: [14]
  649| 
  650|         Finally, the index is built by concatenating these lists together::
  651| 
  652|             _index = [14, 5, 9, 3, 2, 4, 5]
  653| 
  654|         An offset storing the start of the first row is also stored::
  655| 
  656|             _offset = 3
  657| 
  658|         When built, the index can be used for efficient indexing into the list.
  659|         See the comment and notes on ``SortedList._pos`` for details.
  660| 
  661|         """
  662|         row0 = list(map(len, self._lists))
  663| 
  664|         if len(row0) == 1:
  665|             self._index[:] = row0
  666|             self._offset = 0
  667|             return
  668| 
  669|         head = iter(row0)
  670|         tail = iter(head)
  671|         row1 = list(starmap(add, zip(head, tail)))
  672| 
  673|         if len(row0) & 1:
  674|             row1.append(row0[-1])
  675| 
  676|         if len(row1) == 1:
  677|             self._index[:] = row1 + row0
  678|             self._offset = 1
  679|             return
  680| 
  681|         size = 2 ** (int(log(len(row1) - 1, 2)) + 1)
  682|         row1.extend(repeat(0, size - len(row1)))
  683|         tree = [row0, row1]
  684| 
  685|         while len(tree[-1]) > 1:
  686|             head = iter(tree[-1])
  687|             tail = iter(head)
  688|             row = list(starmap(add, zip(head, tail)))
  689|             tree.append(row)
  690| 
  691|         reduce(iadd, reversed(tree), self._index)
  692|         self._offset = size * 2 - 1
  693| 
  694|     def __delitem__(self, index):
  695|         """Remove value at `index` from sorted list.
  696| 
  697|         ``sl.__delitem__(index)`` <==> ``del sl[index]``
  698| 
  699|         Supports slicing.
  700| 
  701|         Runtime complexity: `O(log(n))` -- approximate.
  702| 
  703|         >>> sl = SortedList('abcde')
  704|         >>> del sl[2]
  705|         >>> sl
  706|         SortedList(['a', 'b', 'd', 'e'])
  707|         >>> del sl[:2]
  708|         >>> sl
  709|         SortedList(['d', 'e'])
  710| 
  711|         :param index: integer or slice for indexing
  712|         :raises IndexError: if index out of range
  713| 
  714|         """
  715|         if isinstance(index, slice):
  716|             start, stop, step = index.indices(self._len)
  717| 
  718|             if step == 1 and start < stop:
  719|                 if start == 0 and stop == self._len:
  720|                     return self._clear()
  721|                 elif self._len <= 8 * (stop - start):
  722|                     values = self._getitem(slice(None, start))
  723|                     if stop < self._len:
  724|                         values += self._getitem(slice(stop, None))
  725|                     self._clear()
  726|                     return self._update(values)
  727| 
  728|             indices = range(start, stop, step)
  729| 
  730|             # Delete items from greatest index to least so
  731|             # that the indices remain valid throughout iteration.
  732| 
  733|             if step > 0:
  734|                 indices = reversed(indices)
  735| 
  736|             _pos, _delete = self._pos, self._delete
  737| 
  738|             for index in indices:
  739|                 pos, idx = _pos(index)
  740|                 _delete(pos, idx)
  741|         else:
  742|             pos, idx = self._pos(index)
  743|             self._delete(pos, idx)
  744| 
  745|     def __getitem__(self, index):
  746|         """Lookup value at `index` in sorted list.
  747| 
  748|         ``sl.__getitem__(index)`` <==> ``sl[index]``
  749| 
  750|         Supports slicing.
  751| 
  752|         Runtime complexity: `O(log(n))` -- approximate.
  753| 
  754|         >>> sl = SortedList('abcde')
  755|         >>> sl[1]
  756|         'b'
  757|         >>> sl[-1]
  758|         'e'
  759|         >>> sl[2:5]
  760|         ['c', 'd', 'e']
  761| 
  762|         :param index: integer or slice for indexing
  763|         :return: value or list of values
  764|         :raises IndexError: if index out of range
  765| 
  766|         """
  767|         _lists = self._lists
  768| 
  769|         if isinstance(index, slice):
  770|             start, stop, step = index.indices(self._len)
  771| 
  772|             if step == 1 and start < stop:
  773|                 # Whole slice optimization: start to stop slices the whole
  774|                 # sorted list.
  775| 
  776|                 if start == 0 and stop == self._len:
  777|                     return reduce(iadd, self._lists, [])
  778| 
  779|                 start_pos, start_idx = self._pos(start)
  780|                 start_list = _lists[start_pos]
  781|                 stop_idx = start_idx + stop - start
  782| 
  783|                 # Small slice optimization: start index and stop index are
  784|                 # within the start list.
  785| 
  786|                 if len(start_list) >= stop_idx:
  787|                     return start_list[start_idx:stop_idx]
  788| 
  789|                 if stop == self._len:
  790|                     stop_pos = len(_lists) - 1
  791|                     stop_idx = len(_lists[stop_pos])
  792|                 else:
  793|                     stop_pos, stop_idx = self._pos(stop)
  794| 
  795|                 prefix = _lists[start_pos][start_idx:]
  796|                 middle = _lists[(start_pos + 1) : stop_pos]
  797|                 result = reduce(iadd, middle, prefix)
  798|                 result += _lists[stop_pos][:stop_idx]
  799| 
  800|                 return result
  801| 
  802|             if step == -1 and start > stop:
  803|                 result = self._getitem(slice(stop + 1, start + 1))
  804|                 result.reverse()
  805|                 return result
  806| 
  807|             # Return a list because a negative step could
  808|             # reverse the order of the items and this could
  809|             # be the desired behavior.
  810| 
  811|             indices = range(start, stop, step)
  812|             return list(self._getitem(index) for index in indices)
  813|         else:
  814|             if self._len:
  815|                 if index == 0:
  816|                     return _lists[0][0]
  817|                 elif index == -1:
  818|                     return _lists[-1][-1]
  819|             else:
  820|                 raise IndexError('list index out of range')
  821| 
  822|             if 0 <= index < len(_lists[0]):
  823|                 return _lists[0][index]
  824| 
  825|             len_last = len(_lists[-1])
  826| 
  827|             if -len_last < index < 0:
  828|                 return _lists[-1][len_last + index]
  829| 
  830|             pos, idx = self._pos(index)
  831|             return _lists[pos][idx]
  832| 
  833|     _getitem = __getitem__
  834| 
  835|     def __setitem__(self, index, value):
  836|         """Raise not-implemented error.
  837| 
  838|         ``sl.__setitem__(index, value)`` <==> ``sl[index] = value``
  839| 
  840|         :raises NotImplementedError: use ``del sl[index]`` and
  841|             ``sl.add(value)`` instead
  842| 
  843|         """
  844|         message = 'use ``del sl[index]`` and ``sl.add(value)`` instead'
  845|         raise NotImplementedError(message)
  846| 
  847|     def __iter__(self):
  848|         """Return an iterator over the sorted list.
  849| 
  850|         ``sl.__iter__()`` <==> ``iter(sl)``
  851| 
  852|         Iterating the sorted list while adding or deleting values may raise a
  853|         :exc:`RuntimeError` or fail to iterate over all values.
  854| 
  855|         """
  856|         return chain.from_iterable(self._lists)
  857| 
  858|     def __reversed__(self):
  859|         """Return a reverse iterator over the sorted list.
  860| 
  861|         ``sl.__reversed__()`` <==> ``reversed(sl)``
  862| 
  863|         Iterating the sorted list while adding or deleting values may raise a
  864|         :exc:`RuntimeError` or fail to iterate over all values.
  865| 
  866|         """
  867|         return chain.from_iterable(map(reversed, reversed(self._lists)))
  868| 
  869|     def reverse(self):
  870|         """Raise not-implemented error.
  871| 
  872|         Sorted list maintains values in ascending sort order. Values may not be
  873|         reversed in-place.
  874| 
  875|         Use ``reversed(sl)`` for an iterator over values in descending sort
  876|         order.
  877| 
  878|         Implemented to override `MutableSequence.reverse` which provides an
  879|         erroneous default implementation.
  880| 
  881|         :raises NotImplementedError: use ``reversed(sl)`` instead
  882| 
  883|         """
  884|         raise NotImplementedError('use ``reversed(sl)`` instead')
  885| 
  886|     def islice(self, start=None, stop=None, reverse=False):
  887|         """Return an iterator that slices sorted list from `start` to `stop`.
  888| 
  889|         The `start` and `stop` index are treated inclusive and exclusive,
  890|         respectively.
  891| 
  892|         Both `start` and `stop` default to `None` which is automatically
  893|         inclusive of the beginning and end of the sorted list.
  894| 
  895|         When `reverse` is `True` the values are yielded from the iterator in
  896|         reverse order; `reverse` defaults to `False`.
  897| 
  898|         >>> sl = SortedList('abcdefghij')
  899|         >>> it = sl.islice(2, 6)
  900|         >>> list(it)
  901|         ['c', 'd', 'e', 'f']
  902| 
  903|         :param int start: start index (inclusive)
  904|         :param int stop: stop index (exclusive)
  905|         :param bool reverse: yield values in reverse order
  906|         :return: iterator
  907| 
  908|         """
  909|         _len = self._len
  910| 
  911|         if not _len:
  912|             return iter(())
  913| 
  914|         start, stop, _ = slice(start, stop).indices(self._len)
  915| 
  916|         if start >= stop:
  917|             return iter(())
  918| 
  919|         _pos = self._pos
  920| 
  921|         min_pos, min_idx = _pos(start)
  922| 
  923|         if stop == _len:
  924|             max_pos = len(self._lists) - 1
  925|             max_idx = len(self._lists[-1])
  926|         else:
  927|             max_pos, max_idx = _pos(stop)
  928| 
  929|         return self._islice(min_pos, min_idx, max_pos, max_idx, reverse)
  930| 
  931|     def _islice(self, min_pos, min_idx, max_pos, max_idx, reverse):
  932|         """Return an iterator that slices sorted list using two index pairs.
  933| 
  934|         The index pairs are (min_pos, min_idx) and (max_pos, max_idx), the
  935|         first inclusive and the latter exclusive. See `_pos` for details on how
  936|         an index is converted to an index pair.
  937| 
  938|         When `reverse` is `True`, values are yielded from the iterator in
  939|         reverse order.
  940| 
  941|         """
  942|         _lists = self._lists
  943| 
  944|         if min_pos > max_pos:
  945|             return iter(())
  946| 
  947|         if min_pos == max_pos:
  948|             if reverse:
  949|                 indices = reversed(range(min_idx, max_idx))
  950|                 return map(_lists[min_pos].__getitem__, indices)
  951| 
  952|             indices = range(min_idx, max_idx)
  953|             return map(_lists[min_pos].__getitem__, indices)
  954| 
  955|         next_pos = min_pos + 1
  956| 
  957|         if next_pos == max_pos:
  958|             if reverse:
  959|                 min_indices = range(min_idx, len(_lists[min_pos]))
  960|                 max_indices = range(max_idx)
  961|                 return chain(
  962|                     map(_lists[max_pos].__getitem__, reversed(max_indices)),
  963|                     map(_lists[min_pos].__getitem__, reversed(min_indices)),
  964|                 )
  965| 
  966|             min_indices = range(min_idx, len(_lists[min_pos]))
  967|             max_indices = range(max_idx)
  968|             return chain(
  969|                 map(_lists[min_pos].__getitem__, min_indices),
  970|                 map(_lists[max_pos].__getitem__, max_indices),
  971|             )
  972| 
  973|         if reverse:
  974|             min_indices = range(min_idx, len(_lists[min_pos]))
  975|             sublist_indices = range(next_pos, max_pos)
  976|             sublists = map(_lists.__getitem__, reversed(sublist_indices))
  977|             max_indices = range(max_idx)
  978|             return chain(
  979|                 map(_lists[max_pos].__getitem__, reversed(max_indices)),
  980|                 chain.from_iterable(map(reversed, sublists)),
  981|                 map(_lists[min_pos].__getitem__, reversed(min_indices)),
  982|             )
  983| 
  984|         min_indices = range(min_idx, len(_lists[min_pos]))
  985|         sublist_indices = range(next_pos, max_pos)
  986|         sublists = map(_lists.__getitem__, sublist_indices)
  987|         max_indices = range(max_idx)
  988|         return chain(
  989|             map(_lists[min_pos].__getitem__, min_indices),
  990|             chain.from_iterable(sublists),
  991|             map(_lists[max_pos].__getitem__, max_indices),
  992|         )
  993| 
  994|     def irange(self, minimum=None, maximum=None, inclusive=(True, True), reverse=False):
  995|         """Create an iterator of values between `minimum` and `maximum`.
  996| 
  997|         Both `minimum` and `maximum` default to `None` which is automatically
  998|         inclusive of the beginning and end of the sorted list.
  999| 
 1000|         The argument `inclusive` is a pair of booleans that indicates whether
 1001|         the minimum and maximum ought to be included in the range,
 1002|         respectively. The default is ``(True, True)`` such that the range is
 1003|         inclusive of both minimum and maximum.
 1004| 
 1005|         When `reverse` is `True` the values are yielded from the iterator in
 1006|         reverse order; `reverse` defaults to `False`.
 1007| 
 1008|         >>> sl = SortedList('abcdefghij')
 1009|         >>> it = sl.irange('c', 'f')
 1010|         >>> list(it)
 1011|         ['c', 'd', 'e', 'f']
 1012| 
 1013|         :param minimum: minimum value to start iterating
 1014|         :param maximum: maximum value to stop iterating
 1015|         :param inclusive: pair of booleans
 1016|         :param bool reverse: yield values in reverse order
 1017|         :return: iterator
 1018| 
 1019|         """
 1020|         _maxes = self._maxes
 1021| 
 1022|         if not _maxes:
 1023|             return iter(())
 1024| 
 1025|         _lists = self._lists
 1026| 
 1027|         # Calculate the minimum (pos, idx) pair. By default this location
 1028|         # will be inclusive in our calculation.
 1029| 
 1030|         if minimum is None:
 1031|             min_pos = 0
 1032|             min_idx = 0
 1033|         else:
 1034|             if inclusive[0]:
 1035|                 min_pos = bisect_left(_maxes, minimum)
 1036| 
 1037|                 if min_pos == len(_maxes):
 1038|                     return iter(())
 1039| 
 1040|                 min_idx = bisect_left(_lists[min_pos], minimum)
 1041|             else:
 1042|                 min_pos = bisect_right(_maxes, minimum)
 1043| 
 1044|                 if min_pos == len(_maxes):
 1045|                     return iter(())
 1046| 
 1047|                 min_idx = bisect_right(_lists[min_pos], minimum)
 1048| 
 1049|         # Calculate the maximum (pos, idx) pair. By default this location
 1050|         # will be exclusive in our calculation.
 1051| 
 1052|         if maximum is None:
 1053|             max_pos = len(_maxes) - 1
 1054|             max_idx = len(_lists[max_pos])
 1055|         else:
 1056|             if inclusive[1]:
 1057|                 max_pos = bisect_right(_maxes, maximum)
 1058| 
 1059|                 if max_pos == len(_maxes):
 1060|                     max_pos -= 1
 1061|                     max_idx = len(_lists[max_pos])
 1062|                 else:
 1063|                     max_idx = bisect_right(_lists[max_pos], maximum)
 1064|             else:
 1065|                 max_pos = bisect_left(_maxes, maximum)
 1066| 
 1067|                 if max_pos == len(_maxes):
 1068|                     max_pos -= 1
 1069|                     max_idx = len(_lists[max_pos])
 1070|                 else:
 1071|                     max_idx = bisect_left(_lists[max_pos], maximum)
 1072| 
 1073|         return self._islice(min_pos, min_idx, max_pos, max_idx, reverse)
 1074| 
 1075|     def __len__(self):
 1076|         """Return the size of the sorted list.
 1077| 
 1078|         ``sl.__len__()`` <==> ``len(sl)``
 1079| 
 1080|         :return: size of sorted list
 1081| 
 1082|         """
 1083|         return self._len
 1084| 
 1085|     def bisect_left(self, value):
 1086|         """Return an index to insert `value` in the sorted list.
 1087| 
 1088|         If the `value` is already present, the insertion point will be before
 1089|         (to the left of) any existing values.
 1090| 
 1091|         Similar to the `bisect` module in the standard library.
 1092| 
 1093|         Runtime complexity: `O(log(n))` -- approximate.
 1094| 
 1095|         >>> sl = SortedList([10, 11, 12, 13, 14])
 1096|         >>> sl.bisect_left(12)
 1097|         2
 1098| 
 1099|         :param value: insertion index of value in sorted list
 1100|         :return: index
 1101| 
 1102|         """
 1103|         _maxes = self._maxes
 1104| 
 1105|         if not _maxes:
 1106|             return 0
 1107| 
 1108|         pos = bisect_left(_maxes, value)
 1109| 
 1110|         if pos == len(_maxes):
 1111|             return self._len
 1112| 
 1113|         idx = bisect_left(self._lists[pos], value)
 1114|         return self._loc(pos, idx)
 1115| 
 1116|     def bisect_right(self, value):
 1117|         """Return an index to insert `value` in the sorted list.
 1118| 
 1119|         Similar to `bisect_left`, but if `value` is already present, the
 1120|         insertion point will be after (to the right of) any existing values.
 1121| 
 1122|         Similar to the `bisect` module in the standard library.
 1123| 
 1124|         Runtime complexity: `O(log(n))` -- approximate.
 1125| 
 1126|         >>> sl = SortedList([10, 11, 12, 13, 14])
 1127|         >>> sl.bisect_right(12)
 1128|         3
 1129| 
 1130|         :param value: insertion index of value in sorted list
 1131|         :return: index
 1132| 
 1133|         """
 1134|         _maxes = self._maxes
 1135| 
 1136|         if not _maxes:
 1137|             return 0
 1138| 
 1139|         pos = bisect_right(_maxes, value)
 1140| 
 1141|         if pos == len(_maxes):
 1142|             return self._len
 1143| 
 1144|         idx = bisect_right(self._lists[pos], value)
 1145|         return self._loc(pos, idx)
 1146| 
 1147|     bisect = bisect_right
 1148|     _bisect_right = bisect_right
 1149| 
 1150|     def count(self, value):
 1151|         """Return number of occurrences of `value` in the sorted list.
 1152| 
 1153|         Runtime complexity: `O(log(n))` -- approximate.
 1154| 
 1155|         >>> sl = SortedList([1, 2, 2, 3, 3, 3, 4, 4, 4, 4])
 1156|         >>> sl.count(3)
 1157|         3
 1158| 
 1159|         :param value: value to count in sorted list
 1160|         :return: count
 1161| 
 1162|         """
 1163|         _maxes = self._maxes
 1164| 
 1165|         if not _maxes:
 1166|             return 0
 1167| 
 1168|         pos_left = bisect_left(_maxes, value)
 1169| 
 1170|         if pos_left == len(_maxes):
 1171|             return 0
 1172| 
 1173|         _lists = self._lists
 1174|         idx_left = bisect_left(_lists[pos_left], value)
 1175|         pos_right = bisect_right(_maxes, value)
 1176| 
 1177|         if pos_right == len(_maxes):
 1178|             return self._len - self._loc(pos_left, idx_left)
 1179| 
 1180|         idx_right = bisect_right(_lists[pos_right], value)
 1181| 
 1182|         if pos_left == pos_right:
 1183|             return idx_right - idx_left
 1184| 
 1185|         right = self._loc(pos_right, idx_right)
 1186|         left = self._loc(pos_left, idx_left)
 1187|         return right - left
 1188| 
 1189|     def copy(self):
