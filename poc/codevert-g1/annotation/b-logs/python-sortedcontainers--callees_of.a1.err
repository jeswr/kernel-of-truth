 2130|     def bisect_left(self, value):
 2131|         """Return an index to insert `value` in the sorted-key list.
 2132| 
 2133|         If the `value` is already present, the insertion point will be before
 2134|         (to the left of) any existing values.
 2135| 
 2136|         Similar to the `bisect` module in the standard library.
 2137| 
 2138|         Runtime complexity: `O(log(n))` -- approximate.
 2139| 
 2140|         >>> from operator import neg
 2141|         >>> skl = SortedKeyList([5, 4, 3, 2, 1], key=neg)
 2142|         >>> skl.bisect_left(1)
 2143|         4
 2144| 
 2145|         :param value: insertion index of value in sorted-key list
 2146|         :return: index
 2147| 
 2148|         """
 2149|         return self._bisect_key_left(self._key(value))
 2150| 
 2151|     def bisect_right(self, value):
 2152|         """Return an index to insert `value` in the sorted-key list.
 2153| 
 2154|         Similar to `bisect_left`, but if `value` is already present, the
 2155|         insertion point will be after (to the right of) any existing values.
 2156| 
 2157|         Similar to the `bisect` module in the standard library.
 2158| 
 2159|         Runtime complexity: `O(log(n))` -- approximate.
 2160| 
 2161|         >>> from operator import neg
 2162|         >>> skl = SortedList([5, 4, 3, 2, 1], key=neg)
 2163|         >>> skl.bisect_right(1)
 2164|         5
 2165| 
 2166|         :param value: insertion index of value in sorted-key list
 2167|         :return: index
 2168| 
 2169|         """
 2170|         return self._bisect_key_right(self._key(value))
 2171| 
 2172|     bisect = bisect_right
