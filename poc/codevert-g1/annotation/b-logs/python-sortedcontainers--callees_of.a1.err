 2174|     def bisect_key_left(self, key):
 2175|         """Return an index to insert `key` in the sorted-key list.
 2176| 
 2177|         If the `key` is already present, the insertion point will be before (to
 2178|         the left of) any existing keys.
 2179| 
 2180|         Similar to the `bisect` module in the standard library.
 2181| 
 2182|         Runtime complexity: `O(log(n))` -- approximate.
 2183| 
 2184|         >>> from operator import neg
 2185|         >>> skl = SortedKeyList([5, 4, 3, 2, 1], key=neg)
 2186|         >>> skl.bisect_key_left(-1)
 2187|         4
 2188| 
 2189|         :param key: insertion index of key in sorted-key list
 2190|         :return: index
 2191| 
 2192|         """
 2193|         _maxes = self._maxes
 2194| 
 2195|         if not _maxes:
 2196|             return 0
 2197| 
 2198|         pos = bisect_left(_maxes, key)
 2199| 
 2200|         if pos == len(_maxes):
 2201|             return self._len
 2202| 
 2203|         idx = bisect_left(self._keys[pos], key)
 2204| 
 2205|         return self._loc(pos, idx)
 2206| 
 2207|     _bisect_key_left = bisect_key_left
