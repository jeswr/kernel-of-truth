 2245|     def count(self, value):
 2246|         """Return number of occurrences of `value` in the sorted-key list.
 2247| 
 2248|         Runtime complexity: `O(log(n))` -- approximate.
 2249| 
 2250|         >>> from operator import neg
 2251|         >>> skl = SortedKeyList([4, 4, 4, 4, 3, 3, 3, 2, 2, 1], key=neg)
 2252|         >>> skl.count(2)
 2253|         2
 2254| 
 2255|         :param value: value to count in sorted-key list
 2256|         :return: count
 2257| 
 2258|         """
 2259|         _maxes = self._maxes
 2260| 
 2261|         if not _maxes:
 2262|             return 0
 2263| 
 2264|         key = self._key(value)
 2265|         pos = bisect_left(_maxes, key)
 2266| 
 2267|         if pos == len(_maxes):
 2268|             return 0
 2269| 
 2270|         _lists = self._lists
 2271|         _keys = self._keys
 2272|         idx = bisect_left(_keys[pos], key)
 2273|         total = 0
 2274|         len_keys = len(_keys)
 2275|         len_sublist = len(_keys[pos])
 2276| 
 2277|         while True:
 2278|             if _keys[pos][idx] != key:
 2279|                 return total
 2280|             if _lists[pos][idx] == value:
 2281|                 total += 1
 2282|             idx += 1
 2283|             if idx == len_sublist:
 2284|                 pos += 1
 2285|                 if pos == len_keys:
 2286|                     return total
 2287|                 len_sublist = len(_keys[pos])
 2288|                 idx = 0
