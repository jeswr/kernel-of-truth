  193|     def add(self, value):
  194|         """Add `value` to sorted list.
  195| 
  196|         Runtime complexity: `O(log(n))` -- approximate.
  197| 
  198|         >>> sl = SortedList()
  199|         >>> sl.add(3)
  200|         >>> sl.add(1)
  201|         >>> sl.add(2)
  202|         >>> sl
  203|         SortedList([1, 2, 3])
  204| 
  205|         :param value: value to add to sorted list
  206| 
  207|         """
