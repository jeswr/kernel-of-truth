 1801|     def __contains__(self, value):
 1802|         """Return true if `value` is an element of the sorted-key list.
 1803| 
 1804|         ``skl.__contains__(value)`` <==> ``value in skl``
 1805| 
 1806|         Runtime complexity: `O(log(n))`
 1807| 
 1808|         >>> from operator import neg
 1809|         >>> skl = SortedKeyList([1, 2, 3, 4, 5], key=neg)
 1810|         >>> 3 in skl
 1811|         True
 1812| 
 1813|         :param value: search for value in sorted-key list
 1814|         :return: true if `value` in sorted-key list
 1815| 
 1816|         """
 1817|         _maxes = self._maxes
 1818| 
 1819|         if not _maxes:
 1820|             return False
 1821| 
 1822|         key = self._key(value)
 1823|         pos = bisect_left(_maxes, key)
 1824| 
 1825|         if pos == len(_maxes):
 1826|             return False
 1827| 
 1828|         _lists = self._lists
 1829|         _keys = self._keys
 1830| 
 1831|         idx = bisect_left(_keys[pos], key)
 1832| 
 1833|         len_keys = len(_keys)
 1834|         len_sublist = len(_keys[pos])
 1835| 
 1836|         while True:
 1837|             if _keys[pos][idx] != key:
 1838|                 return False
 1839|             if _lists[pos][idx] == value:
 1840|                 return True
 1841|             idx += 1
 1842|             if idx == len_sublist:
 1843|                 pos += 1
 1844|                 if pos == len_keys:
 1845|                     return False
 1846|                 len_sublist = len(_keys[pos])
 1847|                 idx = 0
 1848| 
 1849|     def discard(self, value):
 1850|         """Remove `value` from sorted-key list if it is a member.
 1851| 
 1852|         If `value` is not a member, do nothing.
 1853| 
 1854|         Runtime complexity: `O(log(n))` -- approximate.
 1855| 
 1856|         >>> from operator import neg
 1857|         >>> skl = SortedKeyList([5, 4, 3, 2, 1], key=neg)
 1858|         >>> skl.discard(1)
 1859|         >>> skl.discard(0)
 1860|         >>> skl == [5, 4, 3, 2]
 1861|         True
 1862| 
 1863|         :param value: `value` to discard from sorted-key list
 1864| 
 1865|         """
 1866|         _maxes = self._maxes
 1867| 
 1868|         if not _maxes:
 1869|             return
 1870| 
 1871|         key = self._key(value)
 1872|         pos = bisect_left(_maxes, key)
 1873| 
 1874|         if pos == len(_maxes):
 1875|             return
 1876| 
 1877|         _lists = self._lists
 1878|         _keys = self._keys
 1879|         idx = bisect_left(_keys[pos], key)
 1880|         len_keys = len(_keys)
 1881|         len_sublist = len(_keys[pos])
 1882| 
 1883|         while True:
 1884|             if _keys[pos][idx] != key:
 1885|                 return
 1886|             if _lists[pos][idx] == value:
 1887|                 self._delete(pos, idx)
 1888|                 return
 1889|             idx += 1
 1890|             if idx == len_sublist:
 1891|                 pos += 1
 1892|                 if pos == len_keys:
 1893|                     return
 1894|                 len_sublist = len(_keys[pos])
 1895|                 idx = 0
 1896| 
 1897|     def remove(self, value):
 1898|         """Remove `value` from sorted-key list; `value` must be a member.
 1899| 
 1900|         If `value` is not a member, raise ValueError.
 1901| 
 1902|         Runtime complexity: `O(log(n))` -- approximate.
 1903| 
 1904|         >>> from operator import neg
 1905|         >>> skl = SortedKeyList([1, 2, 3, 4, 5], key=neg)
 1906|         >>> skl.remove(5)
 1907|         >>> skl == [4, 3, 2, 1]
 1908|         True
 1909|         >>> skl.remove(0)
 1910|         Traceback (most recent call last):
 1911|           ...
 1912|         ValueError: 0 not in list
 1913| 
 1914|         :param value: `value` to remove from sorted-key list
 1915|         :raises ValueError: if `value` is not in sorted-key list
 1916| 
 1917|         """
 1918|         _maxes = self._maxes
 1919| 
 1920|         if not _maxes:
 1921|             raise ValueError(f'{value!r} not in list')
 1922| 
 1923|         key = self._key(value)
 1924|         pos = bisect_left(_maxes, key)
 1925| 
 1926|         if pos == len(_maxes):
 1927|             raise ValueError(f'{value!r} not in list')
 1928| 
 1929|         _lists = self._lists
 1930|         _keys = self._keys
 1931|         idx = bisect_left(_keys[pos], key)
 1932|         len_keys = len(_keys)
 1933|         len_sublist = len(_keys[pos])
 1934| 
 1935|         while True:
 1936|             if _keys[pos][idx] != key:
 1937|                 raise ValueError(f'{value!r} not in list')
 1938|             if _lists[pos][idx] == value:
 1939|                 self._delete(pos, idx)
 1940|                 return
 1941|             idx += 1
 1942|             if idx == len_sublist:
 1943|                 pos += 1
 1944|                 if pos == len_keys:
 1945|                     raise ValueError(f'{value!r} not in list')
 1946|                 len_sublist = len(_keys[pos])
 1947|                 idx = 0
 1948| 
 1949|     def _delete(self, pos, idx):
 1950|         """Delete value at the given `(pos, idx)`.
 1951| 
 1952|         Combines lists that are less than half the load level.
 1953| 
 1954|         Updates the index when the sublist length is more than half the load
 1955|         level. This requires decrementing the nodes in a traversal from the
 1956|         leaf node to the root. For an example traversal see
 1957|         ``SortedList._loc``.
 1958| 
 1959|         :param int pos: lists index
 1960|         :param int idx: sublist index
 1961| 
 1962|         """
 1963|         _lists = self._lists
 1964|         _keys = self._keys
 1965|         _maxes = self._maxes
 1966|         _index = self._index
 1967|         keys_pos = _keys[pos]
 1968|         lists_pos = _lists[pos]
 1969| 
 1970|         del keys_pos[idx]
 1971|         del lists_pos[idx]
 1972|         self._len -= 1
 1973| 
 1974|         len_keys_pos = len(keys_pos)
 1975| 
 1976|         if len_keys_pos > (self._load >> 1):
 1977|             _maxes[pos] = keys_pos[-1]
 1978| 
 1979|             if _index:
 1980|                 child = self._offset + pos
 1981|                 while child > 0:
 1982|                     _index[child] -= 1
 1983|                     child = (child - 1) >> 1
 1984|                 _index[0] -= 1
 1985|         elif len(_keys) > 1:
 1986|             if not pos:
 1987|                 pos += 1
 1988| 
 1989|             prev = pos - 1
 1990|             _keys[prev].extend(_keys[pos])
 1991|             _lists[prev].extend(_lists[pos])
 1992|             _maxes[prev] = _keys[prev][-1]
 1993| 
 1994|             del _lists[pos]
 1995|             del _keys[pos]
 1996|             del _maxes[pos]
 1997|             del _index[:]
 1998| 
 1999|             self._expand(prev)
 2000|         elif len_keys_pos:
 2001|             _maxes[pos] = keys_pos[-1]
 2002|         else:
 2003|             del _lists[pos]
 2004|             del _keys[pos]
 2005|             del _maxes[pos]
 2006|             del _index[:]
 2007| 
 2008|     def irange(self, minimum=None, maximum=None, inclusive=(True, True), reverse=False):
 2009|         """Create an iterator of values between `minimum` and `maximum`.
 2010| 
 2011|         Both `minimum` and `maximum` default to `None` which is automatically
 2012|         inclusive of the beginning and end of the sorted-key list.
 2013| 
 2014|         The argument `inclusive` is a pair of booleans that indicates whether
 2015|         the minimum and maximum ought to be included in the range,
 2016|         respectively. The default is ``(True, True)`` such that the range is
 2017|         inclusive of both minimum and maximum.
 2018| 
 2019|         When `reverse` is `True` the values are yielded from the iterator in
 2020|         reverse order; `reverse` defaults to `False`.
 2021| 
 2022|         >>> from operator import neg
 2023|         >>> skl = SortedKeyList([11, 12, 13, 14, 15], key=neg)
 2024|         >>> it = skl.irange(14.5, 11.5)
 2025|         >>> list(it)
 2026|         [14, 13, 12]
 2027| 
 2028|         :param minimum: minimum value to start iterating
 2029|         :param maximum: maximum value to stop iterating
 2030|         :param inclusive: pair of booleans
 2031|         :param bool reverse: yield values in reverse order
 2032|         :return: iterator
 2033| 
 2034|         """
 2035|         min_key = self._key(minimum) if minimum is not None else None
 2036|         max_key = self._key(maximum) if maximum is not None else None
 2037|         return self._irange_key(
 2038|             min_key=min_key,
 2039|             max_key=max_key,
 2040|             inclusive=inclusive,
 2041|             reverse=reverse,
 2042|         )
 2043| 
 2044|     def irange_key(
 2045|         self, min_key=None, max_key=None, inclusive=(True, True), reverse=False
 2046|     ):
 2047|         """Create an iterator of values between `min_key` and `max_key`.
 2048| 
 2049|         Both `min_key` and `max_key` default to `None` which is automatically
 2050|         inclusive of the beginning and end of the sorted-key list.
 2051| 
 2052|         The argument `inclusive` is a pair of booleans that indicates whether
 2053|         the minimum and maximum ought to be included in the range,
 2054|         respectively. The default is ``(True, True)`` such that the range is
 2055|         inclusive of both minimum and maximum.
 2056| 
 2057|         When `reverse` is `True` the values are yielded from the iterator in
 2058|         reverse order; `reverse` defaults to `False`.
 2059| 
 2060|         >>> from operator import neg
 2061|         >>> skl = SortedKeyList([11, 12, 13, 14, 15], key=neg)
 2062|         >>> it = skl.irange_key(-14, -12)
 2063|         >>> list(it)
 2064|         [14, 13, 12]
 2065| 
 2066|         :param min_key: minimum key to start iterating
 2067|         :param max_key: maximum key to stop iterating
 2068|         :param inclusive: pair of booleans
 2069|         :param bool reverse: yield values in reverse order
 2070|         :return: iterator
 2071| 
 2072|         """
 2073|         _maxes = self._maxes
 2074| 
 2075|         if not _maxes:
 2076|             return iter(())
 2077| 
 2078|         _keys = self._keys
 2079| 
 2080|         # Calculate the minimum (pos, idx) pair. By default this location
 2081|         # will be inclusive in our calculation.
 2082| 
 2083|         if min_key is None:
 2084|             min_pos = 0
 2085|             min_idx = 0
 2086|         else:
 2087|             if inclusive[0]:
 2088|                 min_pos = bisect_left(_maxes, min_key)
 2089| 
 2090|                 if min_pos == len(_maxes):
 2091|                     return iter(())
 2092| 
 2093|                 min_idx = bisect_left(_keys[min_pos], min_key)
 2094|             else:
 2095|                 min_pos = bisect_right(_maxes, min_key)
 2096| 
 2097|                 if min_pos == len(_maxes):
 2098|                     return iter(())
 2099| 
 2100|                 min_idx = bisect_right(_keys[min_pos], min_key)
 2101| 
 2102|         # Calculate the maximum (pos, idx) pair. By default this location
 2103|         # will be exclusive in our calculation.
 2104| 
 2105|         if max_key is None:
 2106|             max_pos = len(_maxes) - 1
 2107|             max_idx = len(_keys[max_pos])
 2108|         else:
 2109|             if inclusive[1]:
 2110|                 max_pos = bisect_right(_maxes, max_key)
 2111| 
 2112|                 if max_pos == len(_maxes):
 2113|                     max_pos -= 1
 2114|                     max_idx = len(_keys[max_pos])
 2115|                 else:
 2116|                     max_idx = bisect_right(_keys[max_pos], max_key)
 2117|             else:
 2118|                 max_pos = bisect_left(_maxes, max_key)
 2119| 
 2120|                 if max_pos == len(_maxes):
 2121|                     max_pos -= 1
 2122|                     max_idx = len(_keys[max_pos])
 2123|                 else:
 2124|                     max_idx = bisect_left(_keys[max_pos], max_key)
 2125| 
 2126|         return self._islice(min_pos, min_idx, max_pos, max_idx, reverse)
 2127| 
 2128|     _irange_key = irange_key
