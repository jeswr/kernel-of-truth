 2209|     def bisect_key_right(self, key):
 2210|         """Return an index to insert `key` in the sorted-key list.
 2211| 
 2212|         Similar to `bisect_key_left`, but if `key` is already present, the
 2213|         insertion point will be after (to the right of) any existing keys.
 2214| 
 2215|         Similar to the `bisect` module in the standard library.
 2216| 
 2217|         Runtime complexity: `O(log(n))` -- approximate.
 2218| 
 2219|         >>> from operator import neg
 2220|         >>> skl = SortedList([5, 4, 3, 2, 1], key=neg)
 2221|         >>> skl.bisect_key_right(-1)
 2222|         5
 2223| 
 2224|         :param key: insertion index of key in sorted-key list
 2225|         :return: index
 2226| 
 2227|         """
 2228|         _maxes = self._maxes
 2229| 
 2230|         if not _maxes:
 2231|             return 0
 2232| 
 2233|         pos = bisect_right(_maxes, key)
 2234| 
 2235|         if pos == len(_maxes):
 2236|             return self._len
 2237| 
 2238|         idx = bisect_right(self._keys[pos], key)
 2239| 
 2240|         return self._loc(pos, idx)
 2241| 
 2242|     bisect_key = bisect_key_right
