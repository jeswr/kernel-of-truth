  415|         _maxes = self._maxes
  416|         _index = self._index
  417| 
  418|         _lists_pos = _lists[pos]
  419| 
  420|         del _lists_pos[idx]
  421|         self._len -= 1
  422| 
  423|         len_lists_pos = len(_lists_pos)
  424| 
  425|         if len_lists_pos > (self._load >> 1):
  426|             _maxes[pos] = _lists_pos[-1]
