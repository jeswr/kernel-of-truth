   16| def calc_percentile(data, percentile):
   17|     n = len(data)
   18|     p = n * percentile / 100
   19|     sorted_data = sorted(data)
   20| 
   21|     return sorted_data[int(p)] if p.is_integer() else sorted_data[int(ceil(p)) - 1]
