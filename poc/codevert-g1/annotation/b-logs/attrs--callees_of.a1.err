  580| class TestAssoc:
  581|     """
  582|     Tests for `assoc`.
  583|     """
  584| 
  585|     @given(slots=st.booleans(), frozen=st.booleans())
  586|     def test_empty(self, slots, frozen):
  587|         """
  588|         Empty classes without changes get copied.
  589|         """
  590| 
  591|         @attr.s(slots=slots, frozen=frozen)
  592|         class C:
  593|             pass
  594| 
  595|         i1 = C()
  596|         i2 = assoc(i1)
  597| 
  598|         assert i1 is not i2
  599|         assert i1 == i2
  600| 
  601|     @given(simple_classes())
  602|     def test_no_changes(self, C):
  603|         """
  604|         No changes means a verbatim copy.
  605|         """
  606|         i1 = C()
  607|         i2 = assoc(i1)
  608| 
  609|         assert i1 is not i2
  610|         assert i1 == i2
  611| 
  612|     @given(simple_classes(), st.data())
  613|     def test_change(self, C, data):
  614|         """
  615|         Changes work.
  616|         """
  617|         # Take the first attribute, and change it.
  618|         assume(fields(C))  # Skip classes with no attributes.
  619|         field_names = [a.name for a in fields(C)]
