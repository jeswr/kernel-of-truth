  340| def test_hookrelay_registry(pm: PluginManager) -> None:
  341|     """Verify hook caller instances are registered by name onto the relay
  342|     and can be likewise unregistered."""
  343| 
  344|     class Api:
  345|         @hookspec
  346|         def hello(self, arg: object) -> None:
  347|             "api hook 1"
  348| 
  349|     pm.add_hookspecs(Api)
  350|     hook = pm.hook
  351|     assert hasattr(hook, "hello")
  352|     assert repr(hook.hello).find("hello") != -1
  353| 
  354|     class Plugin:
  355|         @hookimpl
  356|         def hello(self, arg):
  357|             return arg + 1
  358| 
  359|     plugin = Plugin()
  360|     pm.register(plugin)
  361|     out = hook.hello(arg=3)
  362|     assert out == [4]
  363|     assert not hasattr(hook, "world")
  364|     pm.unregister(plugin)
  365|     assert hook.hello(arg=3) == []
  366| 
  367| 
