  445| def test_call_extra_hook_order(hc: HookCaller, addmeth: AddMeth) -> None:
  446|     """Ensure that call_extra is calling hooks in the right order."""
  447|     order = []
  448| 
  449|     @addmeth(tryfirst=True)
  450|     def method1() -> str:
  451|         order.append("1")
  452|         return "1"
  453| 
  454|     @addmeth()
  455|     def method2() -> str:
  456|         order.append("2")
  457|         return "2"
  458| 
  459|     @addmeth(trylast=True)
  460|     def method3() -> str:
  461|         order.append("3")
  462|         return "3"
  463| 
  464|     @addmeth(wrapper=True, tryfirst=True)
