  416|         @hookimpl(specname="bar")
  417|         def hello(self, arg: int) -> int:
  418|             return arg + 1  # pragma: no cover
  419| 
  420|     pm.register(Plugin2())
  421|     with pytest.raises(PluginValidationError):
  422|         pm.check_pending()
