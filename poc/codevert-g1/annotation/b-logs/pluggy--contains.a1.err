  393| def test_hookrelay_registration_by_specname_raises(pm: PluginManager) -> None:
  394|     """Verify using specname still raises the types of errors during registration as it
  395|     would have without using specname."""
  396| 
  397|     class Api:
  398|         @hookspec
  399|         def hello(self, arg: object) -> None:
  400|             "api hook 1"
  401| 
  402|     pm.add_hookspecs(Api)
  403| 
  404|     # make sure a bad signature still raises an error when using specname
  405|     class Plugin:
  406|         @hookimpl(specname="hello")
  407|         def foo(self, arg: int, too, many, args) -> int:
  408|             return arg + 1  # pragma: no cover
  409| 
  410|     with pytest.raises(PluginValidationError):
  411|         pm.register(Plugin())
  412| 
  413|     # make sure check_pending still fails if specname doesn't have a
  414|     # corresponding spec.  EVEN if the function name matches one.
