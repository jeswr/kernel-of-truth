   14| def run_cli(*argv, stdin=None):
   15|     """Invoke ``cli.main`` with ``argv`` and capture (rc, stdout, stderr).
   16| 
   17|     Pass ``stdin`` as a string to simulate a piped stdin; omit it to
   18|     simulate an interactive terminal.
   19|     """
   20|     out = io.StringIO()
   21|     err = io.StringIO()
   22|     with redirect_stdout(out), redirect_stderr(err), _patched_stdin(stdin):
   23|         rc = cli.main(list(argv))
   24|     return rc, out.getvalue(), err.getvalue()
   25| 
   26| 
   27| class _FakeStdin(io.StringIO):
   28|     """``io.StringIO`` with a configurable ``isatty`` result."""
   29| 
   30|     def __init__(self, data: str, is_tty: bool) -> None:
   31|         super().__init__(data)
   32|         self._is_tty = is_tty
   33| 
   34|     def isatty(self) -> bool:
   35|         return self._is_tty
   36| 
   37| 
   38| @contextmanager
   39| def _patched_stdin(data):
   40|     """Replace ``sys.stdin`` with a fake stream and isatty() result."""
   41|     stream = _FakeStdin("" if data is None else data, is_tty=data is None)
   42|     with mock.patch.object(sys, "stdin", stream):
   43|         yield
   44| 
