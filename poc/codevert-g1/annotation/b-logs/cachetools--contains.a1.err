  340|     def test_tlru_clear(self):
  341|         def ttu(_k, _v, t):
  342|             return t + 2
  343| 
  344|         cache = TLRUCache[int, int, int](maxsize=2, ttu=ttu, timer=Timer())
  345| 
  346|         cache[1] = 1
  347|         cache[2] = 2
  348|         cache.clear()
  349| 
  350|         self.assertEqual(0, len(cache))
  351|         self.assertEqual(0, cache.currsize)
  352| 
  353|         # verify LRU eviction order is reset after clear
  354|         cache[3] = 3
  355|         cache[4] = 4
  356|         cache[3]  # access 3 to make it most recently used
  357|         cache[5] = 5  # should evict 4 (least recently used)
  358| 
  359|         self.assertEqual(2, len(cache))
  360|         self.assertIn(3, cache)
  361|         self.assertIn(5, cache)
  362|         self.assertNotIn(4, cache)
