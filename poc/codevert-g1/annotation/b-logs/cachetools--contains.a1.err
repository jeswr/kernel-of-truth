  147|     def test_ttu_expire(self):
  148|         def ttu(_k, _v, t):
  149|             return t + 3
  150| 
  151|         cache = TLRUCache[int, int, int](maxsize=3, ttu=ttu, timer=Timer())
  152|         with cache.timer as time:
  153|             self.assertEqual(time, cache.timer())
  154| 
  155|         cache[1] = 1
  156|         cache.timer.tick()
  157|         cache[2] = 2
  158|         cache.timer.tick()
  159|         cache[3] = 3
  160|         self.assertEqual(2, cache.timer())
  161| 
  162|         self.assertEqual({1, 2, 3}, set(cache))
  163|         self.assertEqual(3, len(cache))
  164|         self.assertEqual(1, cache[1])
  165|         self.assertEqual(2, cache[2])
  166|         self.assertEqual(3, cache[3])
  167| 
  168|         items = cache.expire()
  169|         self.assertEqual(set(), set(items))
  170|         self.assertEqual({1, 2, 3}, set(cache))
  171|         self.assertEqual(3, len(cache))
  172|         self.assertEqual(1, cache[1])
  173|         self.assertEqual(2, cache[2])
  174|         self.assertEqual(3, cache[3])
  175| 
  176|         items = cache.expire(3)
  177|         self.assertEqual({(1, 1)}, set(items))
  178|         self.assertEqual({2, 3}, set(cache))
  179|         self.assertEqual(2, len(cache))
  180|         self.assertNotIn(1, cache)
  181|         self.assertEqual(2, cache[2])
  182|         self.assertEqual(3, cache[3])
  183| 
  184|         items = cache.expire(4)
  185|         self.assertEqual({(2, 2)}, set(items))
  186|         self.assertEqual({3}, set(cache))
  187|         self.assertEqual(1, len(cache))
  188|         self.assertNotIn(1, cache)
  189|         self.assertNotIn(2, cache)
  190|         self.assertEqual(3, cache[3])
  191| 
  192|         items = cache.expire(5)
  193|         self.assertEqual({(3, 3)}, set(items))
  194|         self.assertEqual(set(), set(cache))
  195|         self.assertEqual(0, len(cache))
  196|         self.assertNotIn(1, cache)
  197|         self.assertNotIn(2, cache)
  198|         self.assertNotIn(3, cache)
