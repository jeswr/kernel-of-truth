  291|     def test_ttu_heap_cleanup(self):
  292|         def ttu(_k, _v, t):
  293|             return t + 1
  294| 
  295|         cache = TLRUCache[int, int, int](maxsize=4, ttu=ttu, timer=Timer())
  296|         self.assertEqual(0, cache.timer())
  297| 
  298|         cache[1] = 1
  299|         cache[2] = 2
  300| 
  301|         # replace items to accumulate removed entries in the internal heap
  302|         for i in range(5):
  303|             cache[1] = 10 + i
  304|             cache[2] = 20 + i
  305| 
  306|         # this should compact the internal heap
  307|         expired = cache.expire()
  308|         self.assertEqual([], expired)
  309| 
  310|         # verify cache is functional after cleanup
  311|         self.assertEqual(2, len(cache))
  312|         self.assertEqual(14, cache[1])
  313|         self.assertEqual(24, cache[2])
  314|         cache[3] = 3
  315|         cache[4] = 4
  316|         self.assertEqual(4, len(cache))
  317| 
  318|         cache.timer.tick()
  319|         expired = cache.expire()
  320|         self.assertEqual(4, len(expired))
  321|         self.assertEqual(0, len(cache))
  322| 
  323|     def test_tlru_datetime(self):
  324|         from datetime import datetime, timedelta
  325| 
  326|         def ttu(_k, _v, t):
  327|             return t + timedelta(days=1)
