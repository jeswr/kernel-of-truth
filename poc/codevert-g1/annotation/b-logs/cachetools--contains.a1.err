  384| class CountedLock:
  385|     def __init__(self):
  386|         self.count = 0
  387| 
  388|     def __enter__(self):
  389|         self.count += 1
  390| 
  391|     def __exit__(self, *exc):
  392|         pass
  393| 
  394| 
  395| class CountedCondition(CountedLock):
  396|     def __init__(self):
  397|         super().__init__()
  398|         self.wait_count = 0
  399|         self.notify_count = 0
  400| 
  401|     # only wait_for() and notify_all() are currently used, but wait()
  402|     # and notify() are also required according to the docs...
  403| 
  404|     def wait(self, timeout=None):
  405|         self.wait_count += 1
  406|         return True
  407| 
  408|     def wait_for(self, predicate, timeout=None):
  409|         res = predicate()
  410|         self.wait_count += 1
  411|         return res
  412| 
  413|     def notify(self, n=1):
  414|         self.notify_count += 1
  415| 
  416|     def notify_all(self):
  417|         self.notify_count += 1

