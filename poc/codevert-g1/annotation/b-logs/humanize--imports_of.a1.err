   10| 
   11| 
   12| def natural_list(items: list[Any]) -> str:
   13|     """Natural list.
   14| 
   15|     Convert a list of items into a human-readable string with commas and 'and'.
   16| 
   17|     Examples:
   18|         >>> natural_list(["one", "two", "three"])
   19|         'one, two and three'
   20|         >>> natural_list(["one", "two"])
   21|         'one and two'
   22|         >>> natural_list(["one"])
   23|         'one'
   24| 
   25|     Args:
   26|         items (list): An iterable of items.
   27| 
   28|     Returns:
   29|         str: A string with commas and 'and' in the right places.
   30|     """
   31|     if not items:
   32|         return ""
   33|     if len(items) == 1:
   34|         return str(items[0])
   35|     elif len(items) == 2:
   36|         return f"{str(items[0])} and {str(items[1])}"
   37|     else:
   38|         return ", ".join([str(item) for item in items[:-1]]) + f" and {str(items[-1])}"

