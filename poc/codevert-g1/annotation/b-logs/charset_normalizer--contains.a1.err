   99|     def __init__(self, character: str) -> None:
  100|         """Compute all properties for *character* (built once per codepoint,
  101|         every branch assigns every slot)."""
  102|         self.character = character
  103| 
  104|         # ASCII fast-path: for characters with ord < 128, we can skip
  105|         # _character_flags() entirely and derive most properties from ord.
  106|         o: int = ord(character)
  107|         if o < 128:
  108|             self.is_ascii = True
  109|             self.accentuated = False
  110|             self.is_cjk = False
  111|             self.is_arabic = False
  112|             self.is_glyph = False
  113|             # ASCII alpha: a-z (97-122) or A-Z (65-90)
  114|             if 65 <= o <= 90:
  115|                 # Uppercase ASCII letter
  116|                 self.alpha = True
  117|                 self.upper = True
  118|                 self.lower = False
  119|                 self.space = False
  120|                 self.digit = False
  121|                 self.printable = True
  122|                 self.case_variable = True
  123|                 self.flags = _LATIN
  124|                 self.latin = True
