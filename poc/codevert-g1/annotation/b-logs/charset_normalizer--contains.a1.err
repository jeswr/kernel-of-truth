  751| @final
  752| class ArabicIsolatedFormPlugin(MessDetectorPlugin):
  753|     __slots__ = ("_character_count", "_isolated_form_count")
  754| 
  755|     def __init__(self) -> None:
  756|         self._character_count: int = 0
  757|         self._isolated_form_count: int = 0
  758| 
  759|     def reset(self) -> None:  # Abstract
  760|         self._character_count = 0
  761|         self._isolated_form_count = 0
  762| 
  763|     def feed_info(self, character: str, info: CharInfo) -> None:
  764|         """Optimized feed using pre-computed character info."""
  765|         self._character_count += 1
  766| 
  767|         if info.flags & _ARABIC_ISOLATED_FORM:
  768|             self._isolated_form_count += 1
  769| 
  770|     @property
  771|     def ratio(self) -> float:
  772|         if self._character_count < 8:
  773|             return 0.0
  774| 
  775|         isolated_form_usage: float = self._isolated_form_count / self._character_count
  776| 
  777|         return isolated_form_usage
