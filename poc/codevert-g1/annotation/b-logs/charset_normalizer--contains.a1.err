  131|                 self.lower = True
  132|                 self.space = False
  133|                 self.digit = False
  134|                 self.printable = True
  135|                 self.case_variable = True
  136|                 self.flags = _LATIN
  137|                 self.latin = True
  138|                 self.punct = False
  139|                 self.sym = False
  140|             elif 48 <= o <= 57:
  141|                 # ASCII digit 0-9
  142|                 self.alpha = False
  143|                 self.upper = False
  144|                 self.lower = False
  145|                 self.space = False
  146|                 self.digit = True
  147|                 self.printable = True
  148|                 self.case_variable = False
  149|                 self.flags = 0
