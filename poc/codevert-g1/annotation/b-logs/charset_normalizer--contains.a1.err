  467| @final
  468| class SuperWeirdWordPlugin(MessDetectorPlugin):
  469|     __slots__ = (
  470|         "_word_count",
  471|         "_bad_word_count",
  472|         "_foreign_long_count",
  473|         "_is_current_word_bad",
  474|         "_foreign_long_watch",
  475|         "_character_count",
  476|         "_bad_character_count",
  477|         "_buffer_length",
  478|         "_buffer_last_char",
  479|         "_buffer_last_char_accentuated",
  480|         "_buffer_accent_count",
  481|         "_buffer_glyph_count",
  482|         "_buffer_upper_count",
  483|         "_buffer_first_lower",
  484|         "_buffer_has_non_ascii",
  485|     )
  486| 
  487|     def __init__(self) -> None:
  488|         self._word_count: int = 0
  489|         self._bad_word_count: int = 0
  490|         self._foreign_long_count: int = 0
  491| 
  492|         self._is_current_word_bad: bool = False
  493|         self._foreign_long_watch: bool = False
  494| 
  495|         self._character_count: int = 0
  496|         self._bad_character_count: int = 0
  497| 
  498|         self._buffer_length: int = 0
  499|         self._buffer_last_char: str | None = None
  500|         self._buffer_last_char_accentuated: bool = False
  501|         self._buffer_accent_count: int = 0
  502|         self._buffer_glyph_count: int = 0
  503|         self._buffer_upper_count: int = 0
  504|         self._buffer_first_lower: bool = False
  505|         self._buffer_has_non_ascii: bool = False
  506| 
  507|     def feed_info(self, character: str, info: CharInfo) -> None:
  508|         """Optimized feed using pre-computed character info."""
  509|         if info.alpha:
  510|             if self._buffer_length == 0:
  511|                 self._buffer_first_lower = info.lower
  512|             self._buffer_length += 1
  513|             self._buffer_last_char = character
  514| 
  515|             if info.upper:
  516|                 self._buffer_upper_count += 1
  517|             if not info.is_ascii:
  518|                 self._buffer_has_non_ascii = True
  519| 
  520|             self._buffer_last_char_accentuated = info.accentuated
  521| 
  522|             if info.accentuated:
  523|                 self._buffer_accent_count += 1
  524|             if (
  525|                 not self._foreign_long_watch
  526|                 and (not info.latin or info.accentuated)
  527|                 and not info.is_glyph
  528|             ):
  529|                 self._foreign_long_watch = True
  530|             if info.is_glyph:
  531|                 self._buffer_glyph_count += 1
  532|             return
  533|         if not self._buffer_length:
  534|             return
  535|         if info.space or info.punct or info.sep:
  536|             self._word_count += 1
  537|             buffer_length: int = self._buffer_length
  538| 
  539|             self._character_count += buffer_length
  540| 
  541|             if buffer_length >= 4:
  542|                 if self._buffer_accent_count / buffer_length >= 0.5:
  543|                     self._is_current_word_bad = True
  544|                 elif (
  545|                     self._buffer_last_char_accentuated
  546|                     and self._buffer_last_char.isupper()  # type: ignore[union-attr]
  547|                     and self._buffer_upper_count != buffer_length
  548|                 ):
  549|                     self._foreign_long_count += 1
  550|                     self._is_current_word_bad = True
  551|                 elif self._buffer_glyph_count == 1:
  552|                     self._is_current_word_bad = True
  553|                     self._foreign_long_count += 1
  554|                 elif (
  555|                     self._buffer_has_non_ascii
  556|                     and self._buffer_first_lower
  557|                     and self._buffer_upper_count == buffer_length - 1
  558|                 ):
  559|                     # Inverse capitalization detector.
  560|                     # No natural writing produces such words.
  561|                     # see https://github.com/jawah/charset_normalizer/issues/731
  562|                     self._foreign_long_count += 1
  563|                     self._is_current_word_bad = True
  564|             if buffer_length >= 24 and self._foreign_long_watch:
  565|                 probable_camel_cased: bool = (
  566|                     self._buffer_upper_count > 0
  567|                     and self._buffer_upper_count / buffer_length <= 0.3
  568|                 )
  569| 
  570|                 if not probable_camel_cased:
  571|                     self._foreign_long_count += 1
  572|                     self._is_current_word_bad = True
  573| 
  574|             if self._is_current_word_bad:
  575|                 self._bad_word_count += 1
  576|                 self._bad_character_count += buffer_length
  577|                 self._is_current_word_bad = False
  578| 
  579|             self._foreign_long_watch = False
  580|             self._buffer_length = 0
  581|             self._buffer_last_char = None
  582|             self._buffer_last_char_accentuated = False
  583|             self._buffer_accent_count = 0
  584|             self._buffer_glyph_count = 0
  585|             self._buffer_upper_count = 0
  586|             self._buffer_first_lower = False
  587|             self._buffer_has_non_ascii = False
  588|         elif (
  589|             character not in {"<", ">", "-", "=", "~", "|", "_"}
  590|             and not info.digit
  591|             and info.sym
  592|         ):
  593|             self._is_current_word_bad = True
  594|             self._buffer_length += 1
  595|             self._buffer_last_char = character
  596|             self._buffer_last_char_accentuated = False
  597| 
  598|     def reset(self) -> None:  # Abstract
  599|         self._buffer_length = 0
  600|         self._buffer_last_char = None
  601|         self._buffer_last_char_accentuated = False
  602|         self._is_current_word_bad = False
  603|         self._foreign_long_watch = False
  604|         self._bad_word_count = 0
  605|         self._word_count = 0
  606|         self._character_count = 0
  607|         self._bad_character_count = 0
  608|         self._foreign_long_count = 0
  609|         self._buffer_accent_count = 0
  610|         self._buffer_glyph_count = 0
  611|         self._buffer_upper_count = 0
  612|         self._buffer_first_lower = False
  613|         self._buffer_has_non_ascii = False
  614| 
  615|     @property
  616|     def ratio(self) -> float:
  617|         if self._word_count <= 10 and self._foreign_long_count == 0:
  618|             return 0.0
  619| 
  620|         return self._bad_character_count / self._character_count
  621| 
  622| 
  623| @final
  624| class CjkUncommonPlugin(MessDetectorPlugin):
  625|     """
  626|     Detect messy CJK text that probably means nothing.
  627|     """
  628| 
  629|     __slots__ = ("_character_count", "_uncommon_count")
  630| 
  631|     def __init__(self) -> None:
  632|         self._character_count: int = 0
  633|         self._uncommon_count: int = 0
  634| 
  635|     def feed_info(self, character: str, info: CharInfo) -> None:
  636|         """Optimized feed using pre-computed character info."""
  637|         self._character_count += 1
  638| 
  639|         if not info.common_cjk:
  640|             self._uncommon_count += 1
  641| 
  642|     def reset(self) -> None:  # Abstract
  643|         self._character_count = 0
  644|         self._uncommon_count = 0
  645| 
  646|     @property
  647|     def ratio(self) -> float:
  648|         if self._character_count < 8:
  649|             return 0.0
  650| 
  651|         uncommon_form_usage: float = self._uncommon_count / self._character_count
  652| 
  653|         # we can be pretty sure it's garbage when uncommon characters are widely
  654|         # used. otherwise it could just be traditional chinese for example.
  655|         return uncommon_form_usage / 10 if uncommon_form_usage > 0.5 else 0.0
  656| 
  657| 
  658| @final
  659| class ArchaicUpperLowerPlugin(MessDetectorPlugin):
  660|     __slots__ = (
  661|         "_buf",
  662|         "_character_count_since_last_sep",
  663|         "_successive_upper_lower_count",
  664|         "_successive_upper_lower_count_final",
  665|         "_character_count",
  666|         "_last_alpha_seen",
  667|         "_last_alpha_seen_upper",
  668|         "_last_alpha_seen_lower",
  669|         "_current_ascii_only",
  670|     )
  671| 
  672|     def __init__(self) -> None:
  673|         self._buf: bool = False
  674| 
  675|         self._character_count_since_last_sep: int = 0
  676| 
  677|         self._successive_upper_lower_count: int = 0
  678|         self._successive_upper_lower_count_final: int = 0
  679| 
  680|         self._character_count: int = 0
  681| 
  682|         self._last_alpha_seen: str | None = None
  683|         self._last_alpha_seen_upper: bool = False
  684|         self._last_alpha_seen_lower: bool = False
  685|         self._current_ascii_only: bool = True
  686| 
  687|     def feed_info(self, character: str, info: CharInfo) -> None:
  688|         """Optimized feed using pre-computed character info."""
  689|         is_concerned: bool = info.alpha and info.case_variable
  690|         chunk_sep: bool = not is_concerned
  691| 
  692|         if chunk_sep and self._character_count_since_last_sep > 0:
  693|             if (
  694|                 self._character_count_since_last_sep <= 64
  695|                 and not info.digit
  696|                 and not self._current_ascii_only
  697|             ):
  698|                 self._successive_upper_lower_count_final += (
  699|                     self._successive_upper_lower_count
  700|                 )
  701| 
  702|             self._successive_upper_lower_count = 0
  703|             self._character_count_since_last_sep = 0
  704|             self._last_alpha_seen = None
  705|             self._buf = False
  706|             self._character_count += 1
  707|             self._current_ascii_only = True
  708| 
  709|             return
  710| 
  711|         if self._current_ascii_only and not info.is_ascii:
  712|             self._current_ascii_only = False
  713| 
  714|         if self._last_alpha_seen is not None:
  715|             if (info.upper and self._last_alpha_seen_lower) or (
  716|                 info.lower and self._last_alpha_seen_upper
  717|             ):
  718|                 if self._buf:
  719|                     self._successive_upper_lower_count += 2
  720|                     self._buf = False
  721|                 else:
  722|                     self._buf = True
  723|             else:
  724|                 self._buf = False
  725| 
  726|         self._character_count += 1
  727|         self._character_count_since_last_sep += 1
  728|         self._last_alpha_seen = character
  729|         self._last_alpha_seen_upper = info.upper
  730|         self._last_alpha_seen_lower = info.lower
  731| 
  732|     def reset(self) -> None:  # Abstract
  733|         self._character_count = 0
  734|         self._character_count_since_last_sep = 0
  735|         self._successive_upper_lower_count = 0
  736|         self._successive_upper_lower_count_final = 0
  737|         self._last_alpha_seen = None
  738|         self._last_alpha_seen_upper = False
  739|         self._last_alpha_seen_lower = False
  740|         self._buf = False
  741|         self._current_ascii_only = True
  742| 
  743|     @property
  744|     def ratio(self) -> float:
  745|         if self._character_count == 0:  # Defensive:
  746|             return 0.0
  747| 
  748|         return self._successive_upper_lower_count_final / self._character_count
  749| 
