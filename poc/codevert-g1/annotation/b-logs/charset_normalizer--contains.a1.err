   11| 
   12| class TestLogBehaviorClass:
   13|     def setup_method(self):
   14|         self.logger = logging.getLogger("charset_normalizer")
   15|         self.logger.handlers.clear()
   16|         self.logger.addHandler(logging.NullHandler())
   17|         self.logger.level = logging.WARNING
   18| 
   19|     def test_explain_true_behavior(self, caplog):
   20|         test_sequence = b"This is a test sequence of bytes that should be sufficient"
   21|         from_bytes(test_sequence, steps=1, chunk_size=50, explain=True)
   22|         assert explain_handler not in self.logger.handlers
   23|         for record in caplog.records:
   24|             assert record.levelname in ["Level 5", "DEBUG"]
   25| 
   26|     def test_explain_false_handler_set_behavior(self, caplog):
   27|         test_sequence = b"This is a test sequence of bytes that should be sufficient"
   28|         set_logging_handler(level=TRACE, format_string="%(message)s")
