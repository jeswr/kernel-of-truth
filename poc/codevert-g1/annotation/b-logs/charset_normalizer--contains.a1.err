  780| @lru_cache(maxsize=1024)
  781| def is_suspiciously_successive_range(
  782|     unicode_range_a: str | None, unicode_range_b: str | None
  783| ) -> bool:
  784|     """
  785|     Determine if two Unicode range seen next to each other can be considered as suspicious.
  786|     """
  787|     if unicode_range_a is None or unicode_range_b is None:
  788|         return True
  789| 
  790|     if unicode_range_a == unicode_range_b:
  791|         return False
  792| 
  793|     if "Latin" in unicode_range_a and "Latin" in unicode_range_b:
  794|         return False
  795| 
  796|     if "Emoticons" in unicode_range_a or "Emoticons" in unicode_range_b:
  797|         return False
  798| 
  799|     # Latin characters can be accompanied with a combining diacritical mark
  800|     # eg. Vietnamese.
  801|     if ("Latin" in unicode_range_a or "Latin" in unicode_range_b) and (
  802|         "Combining" in unicode_range_a or "Combining" in unicode_range_b
  803|     ):
  804|         return False
  805| 
  806|     keywords_range_a, keywords_range_b = (
  807|         unicode_range_a.split(" "),
  808|         unicode_range_b.split(" "),
  809|     )
  810| 
  811|     for el in keywords_range_a:
  812|         if el in UNICODE_SECONDARY_RANGE_KEYWORD:
  813|             continue
  814|         if el in keywords_range_b:
  815|             return False
  816| 
  817|     # Japanese Exception
  818|     range_a_jp_chars, range_b_jp_chars = (
  819|         unicode_range_a
  820|         in (
  821|             "Hiragana",
  822|             "Katakana",
  823|         ),
  824|         unicode_range_b in ("Hiragana", "Katakana"),
  825|     )
  826|     if (range_a_jp_chars or range_b_jp_chars) and (
  827|         "CJK" in unicode_range_a or "CJK" in unicode_range_b
  828|     ):
  829|         return False
  830|     if range_a_jp_chars and range_b_jp_chars:
  831|         return False
  832| 
  833|     if "Hangul" in unicode_range_a or "Hangul" in unicode_range_b:
  834|         if "CJK" in unicode_range_a or "CJK" in unicode_range_b:
  835|             return False
  836|         if unicode_range_a == "Basic Latin" or unicode_range_b == "Basic Latin":
  837|             return False
  838| 
  839|     # Chinese/Japanese use dedicated range for punctuation and/or separators.
  840|     if ("CJK" in unicode_range_a or "CJK" in unicode_range_b) or (
  841|         unicode_range_a in ["Katakana", "Hiragana"]
  842|         and unicode_range_b in ["Katakana", "Hiragana"]
  843|     ):
  844|         if "Punctuation" in unicode_range_a or "Punctuation" in unicode_range_b:
  845|             return False
  846|         if "Forms" in unicode_range_a or "Forms" in unicode_range_b:
  847|             return False
  848|         if unicode_range_a == "Basic Latin" or unicode_range_b == "Basic Latin":
  849|             return False
  850| 
  851|     return True
  852| 
  853| 
  854| def mess_ratio(
  855|     decoded_sequence: str, maximum_threshold: float = 0.2, debug: bool = False
  856| ) -> float:
  857|     """
  858|     Compute a mess ratio given a decoded bytes sequence. The maximum threshold does stop the computation earlier.
  859|     """
  860| 
  861|     seq_len: int = len(decoded_sequence)
  862| 
  863|     if seq_len < 511:
  864|         step: int = 32
  865|     elif seq_len < 1024:
  866|         step = 64
  867|     else:
  868|         step = 128
  869| 
  870|     # str.isascii() is O(1) (the flag lives in the str header). Six of the
  871|     # nine detectors provably keep a 0.0 ratio on ASCII-only input and are
  872|     # therefore not fed at all.
  873|     is_pure_ascii: bool = decoded_sequence.isascii()
  874| 
  875|     # Cached per-codepoint character properties (see CharInfo). ASCII
  876|     # characters resolve through the immutable import-time table; anything
  877|     # else goes through the lru_cache-backed slow path.
  878|     ascii_info = _ASCII_CHAR_INFO
  879|     char_info = _char_info
  880| 
  881|     mean_mess_ratio: float
  882|     info: CharInfo
  883| 
  884|     # Create each detector as a named local variable (unrolled from the generic loop).
  885|     # This eliminates per-character iteration over the detector list and
  886|     # per-character eligible() virtual dispatch, while keeping every plugin class
  887|     # intact and fully readable.
  888|     d_sp: TooManySymbolOrPunctuationPlugin = TooManySymbolOrPunctuationPlugin()
  889|     d_ta: TooManyAccentuatedPlugin = TooManyAccentuatedPlugin()
  890|     d_up: UnprintablePlugin = UnprintablePlugin()
  891|     d_sda: SuspiciousDuplicateAccentPlugin = SuspiciousDuplicateAccentPlugin()
  892|     d_sr: SuspiciousRange = SuspiciousRange()
  893|     d_sw: SuperWeirdWordPlugin = SuperWeirdWordPlugin()
  894|     d_cu: CjkUncommonPlugin = CjkUncommonPlugin()
  895|     d_au: ArchaicUpperLowerPlugin = ArchaicUpperLowerPlugin()
  896|     d_ai: ArabicIsolatedFormPlugin = ArabicIsolatedFormPlugin()
  897| 
  898|     # Local references for feed_info methods called in the hot loop.
  899|     d_sp_feed = d_sp.feed_info
  900|     d_ta_feed = d_ta.feed_info
  901|     d_up_feed = d_up.feed_info
  902|     d_sda_feed = d_sda.feed_info
  903|     d_sr_feed = d_sr.feed_info
  904|     d_sw_feed = d_sw.feed_info
  905|     d_cu_feed = d_cu.feed_info
  906|     d_au_feed = d_au.feed_info
  907|     d_ai_feed = d_ai.feed_info
  908| 
  909|     for block_start in range(0, seq_len, step):
  910|         for character in decoded_sequence[block_start : block_start + step]:
  911|             # Character properties computed once per distinct codepoint
  912|             # (shared across all plugins and all mess_ratio calls).
  913|             # ord() doubles as the ASCII table index and, unlike
  914|             # str.isascii(), lowers to a mypyc primitive.
  915|             codepoint: int = ord(character)
  916|             if codepoint < 128:
  917|                 info = ascii_info[codepoint]
  918|             else:
  919|                 info = char_info(character)
  920| 
  921|             # Detectors with eligible() == always True
  922|             d_up_feed(character, info)
  923|             d_sw_feed(character, info)
  924| 
  925|             if is_pure_ascii:
  926|                 # The six remaining detectors provably stay at 0.0 (see above).
  927|                 if info.printable:
  928|                     d_sp_feed(character, info)
  929|                 continue
  930| 
  931|             d_au_feed(character, info)
  932| 
  933|             # Detectors with eligible() == isprintable
  934|             if info.printable:
  935|                 d_sp_feed(character, info)
  936|                 d_sr_feed(character, info)
  937| 
  938|             # Detectors with eligible() == isalpha
  939|             if info.alpha:
  940|                 d_ta_feed(character, info)
  941|                 # SuspiciousDuplicateAccent: isalpha() and is_latin()
  942|                 if info.latin:
  943|                     d_sda_feed(character, info)
  944|                 # CjkUncommon: is_cjk()
  945|                 if info.is_cjk:
  946|                     d_cu_feed(character, info)
  947|                 # ArabicIsolatedForm: is_arabic()
  948|                 if info.is_arabic:
  949|                     d_ai_feed(character, info)
  950| 
  951|         mean_mess_ratio = (
  952|             d_sp.ratio
  953|             + d_ta.ratio
  954|             + d_up.ratio
  955|             + d_sda.ratio
  956|             + d_sr.ratio
  957|             + d_sw.ratio
  958|             + d_cu.ratio
  959|             + d_au.ratio
  960|             + d_ai.ratio
  961|         )
  962| 
  963|         if mean_mess_ratio >= maximum_threshold:
  964|             break
  965|     else:
  966|         # Flush last word buffer in SuperWeirdWordPlugin via trailing newline.
  967|         nl_info = ascii_info[10]  # "\n"
  968|         d_sw_feed("\n", nl_info)
  969|         if not is_pure_ascii:
  970|             d_au_feed("\n", nl_info)
  971|         d_up_feed("\n", nl_info)
  972| 
  973|         mean_mess_ratio = (
  974|             d_sp.ratio
  975|             + d_ta.ratio
  976|             + d_up.ratio
  977|             + d_sda.ratio
  978|             + d_sr.ratio
  979|             + d_sw.ratio
  980|             + d_cu.ratio
  981|             + d_au.ratio
  982|             + d_ai.ratio
  983|         )
  984| 
  985|     if debug:  # Defensive:
  986|         logger = getLogger("charset_normalizer")
  987| 
  988|         logger.log(
  989|             TRACE,
  990|             "Mess-detector extended-analysis start. "
  991|             f"intermediary_mean_mess_ratio_calc={step} mean_mess_ratio={mean_mess_ratio} "
  992|             f"maximum_threshold={maximum_threshold}",
  993|         )
  994| 
  995|         if seq_len > 16:
  996|             logger.log(TRACE, f"Starting with: {decoded_sequence[:16]}")
  997|             logger.log(TRACE, f"Ending with: {decoded_sequence[-16::]}")
  998| 
  999|         for dt in [d_sp, d_ta, d_up, d_sda, d_sr, d_sw, d_cu, d_au, d_ai]:
 1000|             logger.log(TRACE, f"{dt.__class__}: {dt.ratio}")
 1001| 
 1002|     return round(mean_mess_ratio, 3)

