  563| 
  564|         # Carry back up - equivalent to:
  565|         # (days=-2, hours=-2, minutes=0, seconds=-2, microseconds=-3)
  566|         rd3 = relativedelta(days=-1.5, hours=-13, minutes=-59.50045,
  567|                             seconds=-31.473, microseconds=-500003)
  568|         self.assertEqual(rd3.normalized(),
  569|             relativedelta(days=-2, hours=-2, minutes=0,
  570|                           seconds=-2, microseconds=-3))
