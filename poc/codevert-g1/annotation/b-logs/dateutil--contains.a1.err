  715| class RelativeDeltaWeeksPropertyGetterTest(unittest.TestCase):
  716|     """Test the weeks property getter"""
  717| 
  718|     def test_one_day(self):
  719|         rd = relativedelta(days=1)
  720|         self.assertEqual(rd.days, 1)
  721|         self.assertEqual(rd.weeks, 0)
  722| 
  723|     def test_minus_one_day(self):
  724|         rd = relativedelta(days=-1)
  725|         self.assertEqual(rd.days, -1)
  726|         self.assertEqual(rd.weeks, 0)
  727| 
  728|     def test_height_days(self):
  729|         rd = relativedelta(days=8)
  730|         self.assertEqual(rd.days, 8)
  731|         self.assertEqual(rd.weeks, 1)
  732| 
  733|     def test_minus_height_days(self):
  734|         rd = relativedelta(days=-8)
  735|         self.assertEqual(rd.days, -8)
  736|         self.assertEqual(rd.weeks, -1)
  737| 
  738| 
  739| class RelativeDeltaWeeksPropertySetterTest(unittest.TestCase):
  740|     """Test the weeks setter which makes a "smart" update of the days attribute"""
  741| 
  742|     def test_one_day_set_one_week(self):
  743|         rd = relativedelta(days=1)
  744|         rd.weeks = 1  # add 7 days
  745|         self.assertEqual(rd.days, 8)
  746|         self.assertEqual(rd.weeks, 1)
  747| 
  748|     def test_minus_one_day_set_one_week(self):
  749|         rd = relativedelta(days=-1)
  750|         rd.weeks = 1  # add 7 days
  751|         self.assertEqual(rd.days, 6)
  752|         self.assertEqual(rd.weeks, 0)
  753| 
  754|     def test_height_days_set_minus_one_week(self):
  755|         rd = relativedelta(days=8)
  756|         rd.weeks = -1  # change from 1 week, 1 day to -1 week, 1 day
  757|         self.assertEqual(rd.days, -6)
  758|         self.assertEqual(rd.weeks, 0)
  759| 
  760|     def test_minus_height_days_set_minus_one_week(self):
  761|         rd = relativedelta(days=-8)
  762|         rd.weeks = -1  # does not change anything
  763|         self.assertEqual(rd.days, -8)
  764|         self.assertEqual(rd.weeks, -1)
  765| 
