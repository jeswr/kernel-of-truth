   78|     ("1996.July.10 AD 12:08 PM", datetime(1996, 7, 10, 12, 8), "random format"),
   79|     ("July 4, 1976", datetime(1976, 7, 4), "random format"),
   80|     ("7 4 1976", datetime(1976, 7, 4), "random format"),
   81|     ("4 jul 1976", datetime(1976, 7, 4), "random format"),
   82|     ("4 Jul 1976", datetime(1976, 7, 4), "'%-d %b %Y' format"),
   83|     ("7-4-76", datetime(1976, 7, 4), "random format"),
   84|     ("19760704", datetime(1976, 7, 4), "random format"),
   85|     ("0:01:02 on July 4, 1976", datetime(1976, 7, 4, 0, 1, 2), "random format"),
   86|     ("July 4, 1976 12:01:02 am", datetime(1976, 7, 4, 0, 1, 2), "random format"),
   87|     ("Mon Jan  2 04:24:27 1995", datetime(1995, 1, 2, 4, 24, 27), "random format"),
   88|     ("04.04.95 00:22", datetime(1995, 4, 4, 0, 22), "random format"),
   89|     ("Jan 1 1999 11:23:34.578", datetime(1999, 1, 1, 11, 23, 34, 578000), "random format"),
   90|     ("950404 122212", datetime(1995, 4, 4, 12, 22, 12), "random format"),
   91|     ("3rd of May 2001", datetime(2001, 5, 3), "random format"),
   92|     ("5th of March 2001", datetime(2001, 3, 5), "random format"),
   93|     ("1st of May 2003", datetime(2003, 5, 1), "random format"),
   94|     ('0099-01-01T00:00:00', datetime(99, 1, 1, 0, 0), "99 ad"),
   95|     ('0031-01-01T00:00:00', datetime(31, 1, 1, 0, 0), "31 ad"),
   96|     ("20080227T21:26:01.123456789", datetime(2008, 2, 27, 21, 26, 1, 123456), "high precision seconds"),
   97|     ('13NOV2017', datetime(2017, 11, 13), "dBY (See GH360)"),
   98|     ('0003-03-04', datetime(3, 3, 4), "pre 12 year same month (See GH PR #293)"),
   99|     ('December.0031.30', datetime(31, 12, 30), "BYd corner case (GH#687)"),
  100| 
  101|     # Cases with legacy h/m/s format, candidates for deprecation (GH#886)
  102|     ("2016-12-21 04.2h", datetime(2016, 12, 21, 4, 12), "Fractional Hours"),
  103| ]
  104| # Check that we don't have any duplicates
  105| assert len(set([x[0] for x in PARSER_TEST_CASES])) == len(PARSER_TEST_CASES)
  106| 
