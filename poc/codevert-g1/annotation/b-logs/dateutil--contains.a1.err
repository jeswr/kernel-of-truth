  548| 
  549|         # Equivalent to (days=-1)
  550|         rd2 = relativedelta(days=-1.5, hours=12)
  551|         self.assertEqual(rd2.normalized(),
  552|             relativedelta(days=-1))
  553| 
  554|         # Equivalent to (days=-1, hours=-14, minutes=-45)
  555|         rd3 = relativedelta(days=-1.5, hours=-2.5, minutes=-15)
