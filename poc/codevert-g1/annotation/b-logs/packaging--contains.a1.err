  531|     def test_c_hash_equals_rc_hash(self, major: int, minor: int, num: int) -> None:
  532|         """hash(Version('X.YcN')) == hash(Version('X.YrcN'))."""
  533|         c_ver = Version(f"{major}.{minor}c{num}")
  534|         rc_ver = Version(f"{major}.{minor}rc{num}")
  535|         assert hash(c_ver) == hash(rc_ver)
