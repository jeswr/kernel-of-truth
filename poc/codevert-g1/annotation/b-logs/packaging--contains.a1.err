  878| class TestDevReleasesArePreReleases:
  879|     """Do note that development releases are considered a type of pre-release when
  880|     handling them."""
  881| 
  882|     @given(version=dev_release_versions())
  883|     @SETTINGS
  884|     def test_dev_is_prerelease(self, version: Version) -> None:
  885|         """A dev release has is_prerelease == True."""
  886|         assert version.is_prerelease
  887| 
  888|     @given(
  889|         major=small_ints,
  890|         minor=small_ints,
  891|         dev_num=small_ints,
  892|     )
  893|     @SETTINGS
  894|     def test_dev_excluded_by_default_from_specifier(
  895|         self, major: int, minor: int, dev_num: int
  896|     ) -> None:
  897|         """Dev releases are excluded from specifier matching by default
  898|         (since they are pre-releases)."""
  899|         dev = Version(f"{major}.{minor}.dev{dev_num}")
  900|         spec = SpecifierSet(f">={major}.{minor}.dev0")
  901|         # When prereleases=False (the default behavior for non-pre specifiers),
  902|         # dev releases should be excluded. But a specifier that itself references
  903|         # a pre-release enables pre-release matching.
  904|         assert dev in spec
  905| 
  906|     @given(
  907|         major=small_ints,
  908|         minor=small_ints,
  909|         dev_num=small_ints,
  910|     )
  911|     @SETTINGS
  912|     def test_dev_excluded_by_non_pre_specifier(
  913|         self, major: int, minor: int, dev_num: int
  914|     ) -> None:
  915|         """Dev releases are excluded from a non-pre-release specifier by default."""
  916|         dev = Version(f"{major}.{minor}.dev{dev_num}")
  917|         # Use a specifier that does not reference pre-releases.
  918|         spec = Specifier(f">={major}.{minor}")
  919|         # With prereleases not explicitly set, dev releases should be excluded.
  920|         assert not spec.contains(dev)
  921| 
