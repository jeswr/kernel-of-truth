  982| class TestEpochMotivation:
  983|     """Most version identifiers will not include an epoch, as an explicit epoch is
  984|     only needed if a project *changes* the way it handles version numbering in
  985|     a way that means the normal version ordering rules will give the wrong
  986|     answer. For example, if a project is using date based versions like
  987|     ``2014.04`` and would like to switch to semantic versions like ``1.0``, then
  988|     the new releases would be identified as *older* than the date based releases
  989|     when using the normal sorting scheme::
  990| 
  991|         1.0
  992|         1.1
  993|         2.0
  994|         2013.10
  995|         2014.04"""
  996| 
  997|     @SETTINGS
  998|     @given(data=st.data())
  999|     def test_without_epoch_date_sorts_after_semver(self, data: st.DataObject) -> None:
 1000|         """Without epochs, date-based versions sort after smaller semver versions."""
 1001|         versions = [
 1002|             Version("1.0"),
 1003|             Version("1.1"),
 1004|             Version("2.0"),
 1005|             Version("2013.10"),
 1006|             Version("2014.04"),
 1007|         ]
 1008|         i = data.draw(st.integers(min_value=0, max_value=len(versions) - 1))
 1009|         j = data.draw(st.integers(min_value=0, max_value=len(versions) - 1))
 1010|         if i < j:
 1011|             assert versions[i] < versions[j]
 1012|         elif i == j:
 1013|             assert versions[i] == versions[j]
 1014|         else:
 1015|             assert versions[i] > versions[j]
 1016| 
 1017| 
 1018| class TestEpochReorderingExample:
 1019|     """However, by specifying an explicit epoch, the sort order can be changed
 1020|     appropriately, as all versions from a later epoch are sorted after versions
 1021|     from an earlier epoch::
 1022| 
 1023|         2013.10
 1024|         2014.04
 1025|         1!1.0
 1026|         1!1.1
 1027|         1!2.0"""
 1028| 
 1029|     @SETTINGS
 1030|     @given(data=st.data())
 1031|     def test_epoch_example_ordering(self, data: st.DataObject) -> None:
 1032|         """The example with epochs produces the expected ordering."""
 1033|         versions = [
 1034|             Version("2013.10"),
 1035|             Version("2014.04"),
 1036|             Version("1!1.0"),
 1037|             Version("1!1.1"),
 1038|             Version("1!2.0"),
 1039|         ]
 1040|         i = data.draw(st.integers(min_value=0, max_value=len(versions) - 1))
 1041|         j = data.draw(st.integers(min_value=0, max_value=len(versions) - 1))
 1042|         if i < j:
 1043|             assert versions[i] < versions[j]
 1044|         elif i == j:
 1045|             assert versions[i] == versions[j]
 1046|         else:
 1047|             assert versions[i] > versions[j]
 1048| 
 1049|     @given(
 1050|         epoch_a=st.integers(min_value=0, max_value=5),
 1051|         epoch_b=st.integers(min_value=0, max_value=5),
 1052|         rel_a=st.tuples(small_ints, small_ints),
 1053|         rel_b=st.tuples(small_ints, small_ints),
 1054|     )
 1055|     @SETTINGS
 1056|     def test_later_epoch_always_greater(
 1057|         self,
 1058|         epoch_a: int,
 1059|         epoch_b: int,
 1060|         rel_a: tuple[int, int],
 1061|         rel_b: tuple[int, int],
 1062|     ) -> None:
 1063|         """All versions from a later epoch sort after versions from an earlier epoch."""
 1064|         assume(epoch_a != epoch_b)
 1065|         va_str = (
 1066|             f"{rel_a[0]}.{rel_a[1]}"
 1067|             if epoch_a == 0
 1068|             else f"{epoch_a}!{rel_a[0]}.{rel_a[1]}"
 1069|         )
 1070|         vb_str = (
 1071|             f"{rel_b[0]}.{rel_b[1]}"
 1072|             if epoch_b == 0
 1073|             else f"{epoch_b}!{rel_b[0]}.{rel_b[1]}"
 1074|         )
 1075|         va = Version(va_str)
 1076|         vb = Version(vb_str)
 1077|         if epoch_a < epoch_b:
 1078|             assert va < vb
 1079|         else:
 1080|             assert va > vb

