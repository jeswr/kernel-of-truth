  432| class TestPreReleasePhaseOrdering:
  433|     """The pre-release segment consists of an alphabetical identifier for the
  434|     pre-release phase, along with a non-negative integer value. Pre-releases for
  435|     a given release are ordered first by phase (alpha, beta, release candidate)
  436|     and then by the numerical component within that phase."""
  437| 
  438|     @given(
  439|         major=small_ints,
  440|         minor=small_ints,
  441|         num=small_ints,
  442|     )
  443|     @SETTINGS
  444|     def test_alpha_before_beta(self, major: int, minor: int, num: int) -> None:
  445|         """Alpha comes before beta for the same release and number."""
  446|         alpha = Version(f"{major}.{minor}a{num}")
  447|         beta = Version(f"{major}.{minor}b{num}")
  448|         assert alpha < beta
  449| 
  450|     @given(
  451|         major=small_ints,
  452|         minor=small_ints,
  453|         num=small_ints,
  454|     )
  455|     @SETTINGS
  456|     def test_beta_before_rc(self, major: int, minor: int, num: int) -> None:
  457|         """Beta comes before release candidate for the same release and number."""
  458|         beta = Version(f"{major}.{minor}b{num}")
  459|         rc = Version(f"{major}.{minor}rc{num}")
  460|         assert beta < rc
  461| 
  462|     @given(
  463|         major=small_ints,
  464|         minor=small_ints,
  465|         num=small_ints,
  466|     )
  467|     @SETTINGS
  468|     def test_alpha_before_rc(self, major: int, minor: int, num: int) -> None:
  469|         """Alpha comes before release candidate for the same release and number."""
  470|         alpha = Version(f"{major}.{minor}a{num}")
  471|         rc = Version(f"{major}.{minor}rc{num}")
  472|         assert alpha < rc
  473| 
  474|     @given(
  475|         major=small_ints,
  476|         minor=small_ints,
  477|         phase=pre_tags,
  478|         number_a=small_ints,
  479|         number_b=small_ints,
  480|     )
  481|     @SETTINGS
  482|     def test_numerical_ordering_within_phase(
  483|         self, major: int, minor: int, phase: str, number_a: int, number_b: int
  484|     ) -> None:
  485|         """Within the same phase, ordering is by the numerical component."""
  486|         assume(number_a != number_b)
  487|         v1 = Version(f"{major}.{minor}{phase}{number_a}")
  488|         v2 = Version(f"{major}.{minor}{phase}{number_b}")
  489|         assert (v1 < v2) == (number_a < number_b)
  490| 
