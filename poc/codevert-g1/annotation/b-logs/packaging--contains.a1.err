  314|     @given(major=small_ints, minor=small_ints, micro=small_ints)
  315|     @SETTINGS
  316|     def test_specifier_match_equivalent(
  317|         self, major: int, minor: int, micro: int
  318|     ) -> None:
  319|         """X.Y and X.Y.0 match the same specifiers involving
