  791|         self, major: int, minor: int, dev_num: int, prev_micro: int, prev_post: int
  792|     ) -> None:
  793|         """A dev release follows any previous release including post-releases.
  794| 
  795|         For X.Y.Z.devN, the previous release segment is X.Y.(Z-1). We test
  796|         that X.Y.1.devN > X.Y.0.postM.
  797|         """
  798|         # Use a concrete case: X.Y.1.devN should be after X.Y.0.postM
  799|         prev = Version(f"{major}.{minor}.{prev_micro}.post{prev_post}")
  800|         dev = Version(f"{major}.{minor}.{prev_micro + 1}.dev{dev_num}")
  801|         assert dev > prev
