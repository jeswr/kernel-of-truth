  397|         num=small_ints,
  398|     )
  399|     @SETTINGS
  400|     def test_pre_release_before_final(
  401|         self, major: int, minor: int, phase: str, num: int
  402|     ) -> None:
  403|         """Any pre-release X.Y{a,b,rc}N sorts before the final release X.Y."""
  404|         pre = Version(f"{major}.{minor}{phase}{num}")
  405|         final = Version(f"{major}.{minor}")
  406|         assert pre < final
