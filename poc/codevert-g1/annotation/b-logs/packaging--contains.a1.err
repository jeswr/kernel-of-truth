  294| class TestXYEqualsXY0:
  295|     """.. note::
  296| 
  297|     ``X.Y`` and ``X.Y.0`` are not considered distinct release numbers, as
  298|     the release segment comparison rules implicitly expand the two component
  299|     form to ``X.Y.0`` when comparing it to any release segment that includes
  300|     three components."""
  301| 
  302|     @given(major=small_ints, minor=small_ints)
  303|     @SETTINGS
  304|     def test_xy_equals_xy0(self, major: int, minor: int) -> None:
  305|         """X.Y == X.Y.0."""
  306|         assert Version(f"{major}.{minor}") == Version(f"{major}.{minor}.0")
  307| 
  308|     @given(major=small_ints, minor=small_ints)
  309|     @SETTINGS
  310|     def test_xy_hash_equals_xy0_hash(self, major: int, minor: int) -> None:
  311|         """hash(X.Y) == hash(X.Y.0) since they are equal."""
  312|         assert hash(Version(f"{major}.{minor}")) == hash(Version(f"{major}.{minor}.0"))
