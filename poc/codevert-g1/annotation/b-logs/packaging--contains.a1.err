  194| class TestReleaseSegmentComparison:
  195|     """Comparison and ordering of release segments considers the numeric value
  196|     of each component of the release segment in turn. When comparing release
  197|     segments with different numbers of components, the shorter segment is
  198|     padded out with additional zeros as necessary."""
  199| 
  200|     @given(
  201|         major=small_ints,
  202|         minor=small_ints,
  203|     )
  204|     @SETTINGS
  205|     def test_zero_padding_two_vs_three(self, major: int, minor: int) -> None:
  206|         """X.Y compares equal to X.Y.0 due to zero-padding."""
  207|         v2 = Version(f"{major}.{minor}")
  208|         v3 = Version(f"{major}.{minor}.0")
  209|         assert v2 == v3
  210| 
  211|     @given(
  212|         major=small_ints,
  213|         minor=small_ints,
  214|     )
  215|     @SETTINGS
  216|     def test_zero_padding_extended(self, major: int, minor: int) -> None:
  217|         """X.Y compares equal to X.Y.0.0.0 due to zero-padding."""
  218|         v2 = Version(f"{major}.{minor}")
  219|         v5 = Version(f"{major}.{minor}.0.0.0")
  220|         assert v2 == v5
  221| 
  222|     @given(
  223|         version_a=st.sampled_from(FINAL_POOL),
  224|         version_b=st.sampled_from(FINAL_POOL),
  225|     )
  226|     @SETTINGS
  227|     def test_component_wise_ordering(
  228|         self, version_a: Version, version_b: Version
  229|     ) -> None:
  230|         """Ordering is determined by comparing components left to right."""
  231|         # Pad both release tuples to the same length for comparison.
  232|         len_max = max(len(version_a.release), len(version_b.release))
  233|         a_padded = version_a.release + (0,) * (len_max - len(version_a.release))
  234|         b_padded = version_b.release + (0,) * (len_max - len(version_b.release))
  235|         assert (version_a < version_b) == (a_padded < b_padded)
  236|         assert (version_a == version_b) == (a_padded == b_padded)
  237| 
  238|     @given(
  239|         components=st.lists(small_ints, min_size=1, max_size=5),
  240|         extra_zeros=st.integers(min_value=1, max_value=4),
  241|     )
  242|     @SETTINGS
  243|     def test_trailing_zeros_are_ignored(
  244|         self, components: list[int], extra_zeros: int
  245|     ) -> None:
  246|         """Trailing zeros do not change the version identity."""
  247|         base = ".".join(str(c) for c in components)
  248|         extended = base + ".0" * extra_zeros
  249|         assert Version(base) == Version(extended)
  250| 
