  626|     ) -> None:
  627|         """A post-release comes before any subsequent release."""
  628|         post = Version(f"{major}.{minor}.post{post_num}")
  629|         subsequent = Version(f"{major}.{minor}.{next_micro}")
  630|         assert post < subsequent
