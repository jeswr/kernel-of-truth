  923| class TestEpochFormat:
  924|     """If included in a version identifier, the epoch appears before all other
  925|     components, separated from the release segment by an exclamation mark::
  926| 
  927|         E!X.Y  # Version identifier with epoch"""
  928| 
  929|     @given(
  930|         epoch=st.integers(min_value=1, max_value=10),
  931|         major=small_ints,
  932|         minor=small_ints,
  933|     )
  934|     @SETTINGS
  935|     def test_epoch_parsed_correctly(self, epoch: int, major: int, minor: int) -> None:
  936|         """The epoch is parsed from E!X.Y format."""
  937|         v = Version(f"{epoch}!{major}.{minor}")
  938|         assert v.epoch == epoch
  939|         assert v.release == (major, minor)
  940| 
  941|     @given(
