  199| def _predecessor_boundary(version: Version) -> BoundaryVersion | None:
  200|     """The boundary whose least successor is *version*, or ``None``.
  201| 
  202|     Inverse of :func:`~packaging._ranges.least_version_above`. A plain version
  203|     that is exactly such a successor (``1.0a2.dev0`` sits just above
  204|     ``AFTER_POSTS(1.0a1)``) folds back to that boundary, so ``>=1.0a2.dev0`` and
  205|     ``>1.0a1`` share one form. The proposed boundary is confirmed by
  206|     round-tripping through ``least_version_above``.
  207|     """
  208|     # Only a least successor carries a dev segment, so nothing else can fold.
  209|     if version.dev is None:
  210|         return None
  211| 
  212|     candidate: BoundaryVersion | None = None
  213|     if version.pre is not None and version.dev == 0 and version.post is None:
  214|         # 1.0a2.dev0 -> AFTER_POSTS(1.0a1)
  215|         kind, number = version.pre
  216|         if number >= 1:
  217|             candidate = BoundaryVersion(
  218|                 version.__replace__(pre=(kind, number - 1), dev=None),
  219|                 BoundaryKind.AFTER_POSTS,
  220|             )
  221|     elif version.dev >= 1:
  222|         # 1.0.dev3 -> AFTER_LOCALS(1.0.dev2)
  223|         candidate = BoundaryVersion(
  224|             version.__replace__(dev=version.dev - 1), BoundaryKind.AFTER_LOCALS
  225|         )
  226|     elif version.dev == 0 and version.post is not None:
  227|         # 1.0.post1.dev0 -> AFTER_LOCALS(1.0.post0); 1.0.post0.dev0 -> AFTER_LOCALS(1.0)
  228|         base = (
  229|             version.__replace__(post=None, dev=None)
  230|             if version.post == 0
  231|             else version.__replace__(post=version.post - 1, dev=None)
  232|         )
  233|         candidate = BoundaryVersion(base, BoundaryKind.AFTER_LOCALS)
  234| 
  235|     if candidate is not None and least_version_above(candidate) == version:
  236|         return candidate
  237|     return None
  238| 
  239| 
  240| def _canonicalize(bounds: tuple[Interval, ...]) -> tuple[Interval, ...]:
  241|     """Fold least-successor bounds to their boundary form.
  242| 
  243|     ``>=1.0a2.dev0`` and ``>1.0a1`` denote the same set, so both must reduce to
  244|     one representation for ``==`` and ``hash`` to agree. An inclusive lower or
  245|     exclusive upper sitting on a boundary's least successor becomes that
  246|     boundary; the engine's emptiness check has already dropped the synthetic
  247|     gaps such intervals would otherwise leave.
  248|     """
  249|     result: list[Interval] = []
  250|     for lower, upper in bounds:
  251|         new_lower, new_upper = lower, upper
  252| 
  253|         if isinstance(lower.version, Version) and lower.inclusive:
  254|             boundary = _predecessor_boundary(lower.version)
  255|             if boundary is not None:
  256|                 new_lower = LowerBound(boundary, inclusive=False)
  257| 
  258|         if isinstance(upper.version, Version) and not upper.inclusive:
  259|             boundary = _predecessor_boundary(upper.version)
  260|             if boundary is not None:
  261|                 new_upper = UpperBound(boundary, inclusive=True)
  262| 
  263|         result.append((new_lower, new_upper))
  264|     return tuple(result)
  265| 
  266| 
  267| def _struct_admits(
  268|     bounds: tuple[Interval, ...], admit_arbitrary: bool, literal: str
  269| ) -> bool:
  270|     """True when the bounds (plus arbitrary admission) admit ``literal``.
  271| 
  272|     Skips the explicit admit/reject sets, which the caller layers on top. A
  273|     non-version string matches via ``admit_arbitrary`` only on full bounds;
  274|     on narrower bounds the flag is metadata only.
  275|     """
  276|     parsed = coerce_version(literal)
  277|     if parsed is None:
  278|         return admit_arbitrary and bounds == FULL_RANGE
  279| 
  280|     return matches_bounds_only(bounds, parsed)
  281| 
  282| 
