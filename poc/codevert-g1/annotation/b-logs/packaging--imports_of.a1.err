  286| def _bound_version_str(value: BoundaryVersion | Version) -> str:
  287|     """Printout for a bound's inner value, kind-tagged for boundaries."""
  288|     if isinstance(value, BoundaryVersion):
  289|         return f"{value.version}[{value.kind.name}]"
  290|     return str(value)
  291| 
  292| 
  293| def _format_lower(bound: LowerBound) -> str:
  294|     if bound.version is None:
  295|         return "(-inf"
  296|     bracket = "[" if bound.inclusive else "("
  297|     return f"{bracket}{_bound_version_str(bound.version)}"
  298| 
  299| 
  300| def _format_upper(bound: UpperBound) -> str:
  301|     if bound.version is None:
  302|         return "+inf)"
  303|     bracket = "]" if bound.inclusive else ")"
  304|     return f"{_bound_version_str(bound.version)}{bracket}"
  305| 
  306| 
  307| def _format_intervals(intervals: Sequence[Interval]) -> str:
  308|     """Render a sorted interval list as ``lower, upper | lower, upper``."""
  309|     return " | ".join(
  310|         f"{_format_lower(lower)}, {_format_upper(upper)}" for lower, upper in intervals
  311|     )
