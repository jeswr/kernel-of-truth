   27|         ("Foo", "foo"),
   28|         ("fOo", "foo"),
   29|         ("foo.bar", "foo-bar"),
   30|         ("Foo.Bar", "foo-bar"),
   31|         ("Foo.....Bar", "foo-bar"),
   32|         ("foo_bar", "foo-bar"),
   33|         ("foo___bar", "foo-bar"),
   34|         ("foo-bar", "foo-bar"),
   35|         ("foo----bar", "foo-bar"),
   36|     ],
   37| )
   38| def test_canonicalize_name(name: str, expected: str) -> None:
