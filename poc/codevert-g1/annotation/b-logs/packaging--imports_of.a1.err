   79| def _union_ranges(
   80|     left: Sequence[Interval],
   81|     right: Sequence[Interval],
   82| ) -> list[Interval]:
   83|     """Union two sorted, non-overlapping interval lists.
   84| 
   85|     A linear merge over the two pre-sorted inputs followed by a single
   86|     coalescing pass: adjacent or overlapping intervals collapse so the result
   87|     is itself sorted and non-overlapping.
   88|     """
   89|     if not left:
   90|         return list(right)
   91|     if not right:
   92|         return list(left)
   93| 
   94|     merged_input: list[Interval] = []
   95|     left_index = right_index = 0
   96|     while left_index < len(left) and right_index < len(right):
   97|         if left[left_index][0] <= right[right_index][0]:
   98|             merged_input.append(left[left_index])
   99|             left_index += 1
  100|         else:
  101|             merged_input.append(right[right_index])
  102|             right_index += 1
  103|     merged_input.extend(left[left_index:])
  104|     merged_input.extend(right[right_index:])
  105| 
  106|     merged: list[Interval] = [merged_input[0]]
  107|     for lower, upper in merged_input[1:]:
  108|         prev_lower, prev_upper = merged[-1]
  109| 
  110|         if (
  111|             prev_upper.version is None
  112|             or lower.version is None
  113|             or prev_upper.version > lower.version
  114|         ):
  115|             overlaps = True
  116|         elif prev_upper.version == lower.version:
  117|             overlaps = prev_upper.inclusive or lower.inclusive
  118|         else:
  119|             # An ordering gap may still hold no version when the two bounds
  120|             # straddle a synthetic boundary; merge across an empty gap to
  121|             # stay canonical.
  122|             gap_lower = LowerBound(prev_upper.version, not prev_upper.inclusive)
  123|             gap_upper = UpperBound(lower.version, not lower.inclusive)
  124|             overlaps = range_is_empty(gap_lower, gap_upper)
  125| 
  126|         if overlaps:
  127|             merged[-1] = (prev_lower, max(prev_upper, upper))
  128|         else:
  129|             merged.append((lower, upper))
  130| 
  131|     return merged
  132| 
  133| 
  134| def _complement_ranges(ranges: Sequence[Interval]) -> list[Interval]:
  135|     """Complement a sorted, non-overlapping interval list.
  136| 
  137|     Yields the gaps between intervals plus a leading gap before the first and
  138|     a trailing gap after the last. Bound inclusivity flips so that
  139|     complement-of-complement round-trips back to the input.
  140|     """
  141|     if not ranges:
  142|         return list(FULL_RANGE)
  143| 
  144|     result: list[Interval] = []
  145|     prev_upper: UpperBound | None = None
  146| 
  147|     for lower, upper in ranges:
  148|         if prev_upper is None:
  149|             # Leading gap below the first interval. Every range reaching here is
  150|             # floor-canonical: ``_canonical_floor`` has already folded an
  151|             # inclusive lower at or below ``0.dev0`` into ``-inf``. So a finite
  152|             # first lower always leaves a non-empty gap down to ``-inf``, while a
  153|             # ``-inf`` lower leaves no leading gap at all.
  154|             if lower.version is not None:
  155|                 gap_upper = UpperBound(lower.version, not lower.inclusive)
  156|                 result.append((NEG_INF, gap_upper))
  157|         else:
  158|             gap_lower = LowerBound(prev_upper.version, not prev_upper.inclusive)
  159|             gap_upper = UpperBound(lower.version, not lower.inclusive)
  160|             # Input intervals are canonical (sorted, disjoint, non-touching),
  161|             # so the gap between two of them always holds at least one version.
  162|             result.append((gap_lower, gap_upper))
  163|         prev_upper = upper
  164| 
  165|     # The empty-input early return guarantees the loop ran.
  166|     assert prev_upper is not None
  167|     if prev_upper.version is not None:
  168|         gap_lower = LowerBound(prev_upper.version, not prev_upper.inclusive)
  169|         result.append((gap_lower, POS_INF))
  170| 
  171|     return result
  172| 
  173| 
  174| def _canonical_floor(bounds: tuple[Interval, ...]) -> tuple[Interval, ...]:
  175|     """Collapse the PEP 440 floor in a sorted interval list.
  176| 
  177|     Only the first interval can touch ``0.dev0`` (the minimum version). An
  178|     inclusive lower at or below it admits everything below, the same as
  179|     ``-inf``, so ``>=0.dev0`` becomes the one canonical full range. An
  180|     exclusive upper at or below it leaves the interval empty, so it is dropped.
  181|     """
  182|     if not bounds:
  183|         return bounds
  184| 
  185|     lower, upper = bounds[0]
  186|     if range_is_empty(NEG_INF, upper):
  187|         return bounds[1:]
  188| 
  189|     if (
  190|         lower.inclusive
  191|         and isinstance(lower.version, Version)
  192|         and lower.version <= MIN_VERSION
  193|     ):
  194|         return ((NEG_INF, upper), *bounds[1:])
  195| 
  196|     return bounds
  197| 
