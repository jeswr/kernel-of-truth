   20| @pytest.mark.smoke
   21| def test_YMD_could_be_day():
   22|     ymd = _ymd('foo bar 124 baz')
   23| 
   24|     ymd.append(2, 'M')
   25|     assert ymd.has_month
   26|     assert not ymd.has_year
   27|     assert ymd.could_be_day(4)
   28|     assert not ymd.could_be_day(-6)
   29|     assert not ymd.could_be_day(32)
   30| 
   31|     # Assumes leap year
   32|     assert ymd.could_be_day(29)
   33| 
   34|     ymd.append(1999)
   35|     assert ymd.has_year
   36|     assert not ymd.could_be_day(29)
   37| 
   38|     ymd.append(16, 'D')
