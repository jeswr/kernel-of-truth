  436| 
  437| class TzWinFoldMixin(object):
  438|     def get_args(self, tzname):
  439|         return (tzname, )
  440| 
  441|     class context(object):
  442|         def __init__(*args, **kwargs):
  443|             pass
  444| 
  445|         def __enter__(*args, **kwargs):
  446|             pass
  447| 
  448|         def __exit__(*args, **kwargs):
  449|             pass
  450| 
  451|     def get_utc_transitions(self, tzi, year, gap):
  452|         dston, dstoff = tzi.transitions(year)
  453|         if gap:
  454|             t_n = dston - timedelta(minutes=30)
  455| 
  456|             t0_u = t_n.replace(tzinfo=tzi).astimezone(tz.UTC)
  457|             t1_u = t0_u + timedelta(hours=1)
  458|         else:
  459|             # Get 1 hour before the first ambiguous date
  460|             t_n = dstoff - timedelta(minutes=30)
  461| 
  462|             t0_u = t_n.replace(tzinfo=tzi).astimezone(tz.UTC)
  463|             t_n += timedelta(hours=1)                   # Naive ambiguous date
  464|             t0_u = t0_u + timedelta(hours=1)            # First ambiguous date
  465|             t1_u = t0_u + timedelta(hours=1)            # Second ambiguous date
  466| 
  467|         return t_n, t0_u, t1_u
  468| 
  469|     def testFoldPositiveUTCOffset(self):
  470|         # Test that we can resolve ambiguous times
  471|         tzname = 'AUS Eastern Standard Time'
  472|         args = self.get_args(tzname)
  473| 
  474|         with self.context(tzname):
  475|             # Calling fromutc() alters the tzfile object
  476|             SYD = self.tzclass(*args)
  477| 
  478|             # Get the transition time in UTC from the object, because
  479|             # Windows doesn't store historical info
  480|             t_n, t0_u, t1_u = self.get_utc_transitions(SYD, 2012, False)
  481| 
  482|             # Using fresh tzfiles
  483|             t0_syd = t0_u.astimezone(SYD)
  484|             t1_syd = t1_u.astimezone(SYD)
  485| 
  486|             self.assertEqual(t0_syd.replace(tzinfo=None), t_n)
  487| 
  488|             self.assertEqual(t1_syd.replace(tzinfo=None), t_n)
  489| 
  490|             self.assertEqual(t0_syd.utcoffset(), timedelta(hours=11))
  491|             self.assertEqual(t1_syd.utcoffset(), timedelta(hours=10))
  492|             self.assertNotEqual(t0_syd.tzname(), t1_syd.tzname())
  493| 
  494|     def testGapPositiveUTCOffset(self):
  495|         # Test that we don't have a problem around gaps.
  496|         tzname = 'AUS Eastern Standard Time'
  497|         args = self.get_args(tzname)
  498| 
  499|         with self.context(tzname):
  500|             SYD = self.tzclass(*args)
  501| 
  502|             t_n, t0_u, t1_u = self.get_utc_transitions(SYD, 2012, True)
  503| 
  504|             t0 = t0_u.astimezone(SYD)
  505|             t1 = t1_u.astimezone(SYD)
  506| 
  507|             self.assertEqual(t0.replace(tzinfo=None), t_n)
  508| 
  509|             self.assertEqual(t1.replace(tzinfo=None), t_n + timedelta(hours=2))
  510| 
  511|             self.assertEqual(t0.utcoffset(), timedelta(hours=10))
  512|             self.assertEqual(t1.utcoffset(), timedelta(hours=11))
  513| 
  514|     def testFoldNegativeUTCOffset(self):
