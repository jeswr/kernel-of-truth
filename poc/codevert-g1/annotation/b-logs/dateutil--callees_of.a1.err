 1153| @pytest.mark.gettz
 1154| @pytest.mark.xfail(IS_WIN, reason='zoneinfo separately cached')
 1155| def test_gettz_set_cache_size():
 1156|     tz.gettz.cache_clear()
 1157|     tz.gettz.set_cache_size(3)
 1158| 
 1159|     MONACO_ref = weakref.ref(tz.gettz('Europe/Monaco'))
 1160|     EASTER_ref = weakref.ref(tz.gettz('Pacific/Easter'))
 1161|     CURRIE_ref = weakref.ref(tz.gettz('Australia/Currie'))
 1162| 
 1163|     gc.collect()
 1164| 
 1165|     assert MONACO_ref() is not None
 1166|     assert EASTER_ref() is not None
 1167|     assert CURRIE_ref() is not None
 1168| 
 1169|     tz.gettz.set_cache_size(2)
 1170|     gc.collect()
 1171| 
 1172|     assert MONACO_ref() is None
