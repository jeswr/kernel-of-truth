 1292|     def gettz(self, tzname):
 1293|         tzname_map = {'Australia/Sydney': self.TZ_AEST,
 1294|                       'America/Toronto': self.TZ_EST,
 1295|                       'America/New_York': self.TZ_EST,
 1296|                       'Europe/London': self.TZ_LON}
 1297| 
 1298|         return tzname_map[tzname]
 1299| 
 1300|     def testRangeCmp1(self):
 1301|         self.assertEqual(tz.tzstr("EST5EDT"),
 1302|                          tz.tzrange("EST", -18000, "EDT", -14400,
 1303|                                  relativedelta(hours=+2,
 1304|                                                month=4, day=1,
 1305|                                                weekday=SU(+1)),
 1306|                                  relativedelta(hours=+1,
 1307|                                                month=10, day=31,
 1308|                                                weekday=SU(-1))))
 1309| 
 1310|     def testRangeCmp2(self):
 1311|         self.assertEqual(tz.tzstr("EST5EDT"),
 1312|                          tz.tzrange("EST", -18000, "EDT"))
 1313| 
 1314|     def testRangeOffsets(self):
 1315|         TZR = tz.tzrange('EST', -18000, 'EDT', -14400,
 1316|                          start=relativedelta(hours=2, month=4, day=1,
 1317|                                              weekday=SU(+2)),
 1318|                          end=relativedelta(hours=1, month=10, day=31,
 1319|                                            weekday=SU(-1)))
 1320| 
 1321|         dt_std = datetime(2014, 4, 11, 12, 0, tzinfo=TZR)  # STD
 1322|         dt_dst = datetime(2016, 4, 11, 12, 0, tzinfo=TZR)  # DST
 1323| 
 1324|         dst_zero = timedelta(0)
 1325|         dst_hour = timedelta(hours=1)
 1326| 
 1327|         std_offset = timedelta(hours=-5)
 1328|         dst_offset = timedelta(hours=-4)
 1329| 
 1330|         # Check dst()
 1331|         self.assertEqual(dt_std.dst(), dst_zero)
 1332|         self.assertEqual(dt_dst.dst(), dst_hour)
 1333| 
 1334|         # Check utcoffset()
 1335|         self.assertEqual(dt_std.utcoffset(), std_offset)
 1336|         self.assertEqual(dt_dst.utcoffset(), dst_offset)
 1337| 
 1338|         # Check tzname
 1339|         self.assertEqual(dt_std.tzname(), 'EST')
 1340|         self.assertEqual(dt_dst.tzname(), 'EDT')
 1341| 
 1342|     def testTimeOnlyRangeFixed(self):
 1343|         # This is a fixed-offset zone, so tzrange allows this
 1344|         tz_range = tz.tzrange('dflt', stdoffset=timedelta(hours=-3))
 1345|         self.assertEqual(dt_time(13, 20, tzinfo=tz_range).utcoffset(),
 1346|                          timedelta(hours=-3))
 1347| 
 1348|     def testTimeOnlyRange(self):
 1349|         # tzrange returns None because this zone has DST
 1350|         tz_range = tz.tzrange('EST', timedelta(hours=-5),
 1351|                               'EDT', timedelta(hours=-4))
 1352|         self.assertIs(dt_time(13, 20, tzinfo=tz_range).utcoffset(), None)
 1353| 
 1354|     def testBrokenIsDstHandling(self):
 1355|         # tzrange._isdst() was using a date() rather than a datetime().
 1356|         # Issue reported by Lennart Regebro.
 1357|         dt = datetime(2007, 8, 6, 4, 10, tzinfo=tz.UTC)
 1358|         self.assertEqual(dt.astimezone(tz=tz.gettz("GMT+2")),
 1359|                           datetime(2007, 8, 6, 6, 10, tzinfo=tz.tzstr("GMT+2")))
 1360| 
 1361|     def testRangeTimeDelta(self):
