 2589|     def testIncompatibleAmbiguityUnambiguousAware(self):
 2590|         dt_start = datetime(2018, 9, 1, 1, 0)
 2591|         dt_end = datetime(2018, 9, 1, 2, 0)
 2592| 
 2593|         tzi = self._get_ambig_error_tzinfo(dt_start, dt_end)
 2594| 
 2595|         self.assertFalse(tz.datetime_ambiguous(datetime(2018, 10, 1, 12, 30,
