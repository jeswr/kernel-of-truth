  557|     def testFoldIndependence(self):
  558|         tzname = 'Eastern Standard Time'
  559|         args = self.get_args(tzname)
  560| 
  561|         with self.context(tzname):
  562|             NYC = self.tzclass(*args)
  563|             UTC = tz.UTC
  564|             hour = timedelta(hours=1)
  565| 
  566|             # Firmly 2015-11-01 0:30 EDT-4
  567|             t_n, t0_u, t1_u = self.get_utc_transitions(NYC, 2015, False)
  568| 
  569|             pre_dst = (t_n - hour).replace(tzinfo=NYC)
  570| 
  571|             # Currently, there's no way around the fact that this resolves to an
  572|             # ambiguous date, which defaults to EST. I'm not hard-coding in the
  573|             # answer, though, because the preferred behavior would be that this
  574|             # results in a time on the EDT side.
  575| 
  576|             # Ambiguous between 2015-11-01 1:30 EDT-4 and 2015-11-01 1:30 EST-5
  577|             in_dst = pre_dst + hour
  578|             in_dst_tzname_0 = in_dst.tzname()     # Stash the tzname - EDT
  579| 
  580|             # Doing the arithmetic in UTC creates a date that is unambiguously
  581|             # 2015-11-01 1:30 EDT-5
  582|             in_dst_via_utc = (pre_dst.astimezone(UTC) + 2*hour).astimezone(NYC)
  583| 
  584|             # Make sure we got the right folding behavior
  585|             self.assertNotEqual(in_dst_via_utc.tzname(), in_dst_tzname_0)
  586| 
  587|             # Now check to make sure in_dst's tzname hasn't changed
  588|             self.assertEqual(in_dst_tzname_0, in_dst.tzname())
  589| 
  590|     def testInZoneFoldEquality(self):
  591|         # Two datetimes in the same zone are considered to be equal if their
  592|         # wall times are equal, even if they have different absolute times.
  593|         tzname = 'Eastern Standard Time'
  594|         args = self.get_args(tzname)
  595| 
  596|         with self.context(tzname):
  597|             NYC = self.tzclass(*args)
  598|             UTC = tz.UTC
  599| 
  600|             t_n, t0_u, t1_u = self.get_utc_transitions(NYC, 2011, False)
  601| 
  602|             dt0 = t_n.replace(tzinfo=NYC)
  603|             dt1 = tz.enfold(dt0, fold=1)
  604| 
  605|             # Make sure these actually represent different times
  606|             self.assertNotEqual(dt0.astimezone(UTC), dt1.astimezone(UTC))
  607| 
  608|             # Test that they compare equal
  609|             self.assertEqual(dt0, dt1)
  610| 
