 1994| class TZTest(unittest.TestCase):
 1995|     def testFileStart1(self):
 1996|         tzc = tz.tzfile(BytesIO(base64.b64decode(TZFILE_EST5EDT)))
 1997|         self.assertEqual(datetime(2003, 4, 6, 1, 59, tzinfo=tzc).tzname(), "EST")
 1998|         self.assertEqual(datetime(2003, 4, 6, 2, 00, tzinfo=tzc).tzname(), "EDT")
 1999| 
 2000|     def testFileEnd1(self):
 2001|         tzc = tz.tzfile(BytesIO(base64.b64decode(TZFILE_EST5EDT)))
 2002|         self.assertEqual(datetime(2003, 10, 26, 0, 59, tzinfo=tzc).tzname(),
 2003|                          "EDT")
 2004|         end_est = tz.enfold(datetime(2003, 10, 26, 1, 00, tzinfo=tzc))
 2005|         self.assertEqual(end_est.tzname(), "EST")
 2006| 
 2007|     def testFileLastTransition(self):
 2008|         # After the last transition, it goes to standard time in perpetuity
 2009|         tzc = tz.tzfile(BytesIO(base64.b64decode(TZFILE_EST5EDT)))
 2010|         self.assertEqual(datetime(2037, 10, 25, 0, 59, tzinfo=tzc).tzname(),
 2011|                          "EDT")
 2012| 
 2013|         last_date = tz.enfold(datetime(2037, 10, 25, 1, 00, tzinfo=tzc), fold=1)
 2014|         self.assertEqual(last_date.tzname(),
 2015|                          "EST")
 2016| 
 2017|         self.assertEqual(datetime(2038, 5, 25, 12, 0, tzinfo=tzc).tzname(),
 2018|                          "EST")
 2019| 
 2020|     def testInvalidFile(self):
 2021|         # Should throw a ValueError if an invalid file is passed
 2022|         with self.assertRaises(ValueError):
 2023|             tz.tzfile(BytesIO(b'BadFile'))
 2024| 
 2025|     def testFilestreamWithNameRepr(self):
 2026|         # If fileobj is a filestream with a "name" attribute this name should
 2027|         # be reflected in the tz object's repr
 2028|         fileobj = BytesIO(base64.b64decode(TZFILE_EST5EDT))
 2029|         fileobj.name = 'foo'
 2030|         tzc = tz.tzfile(fileobj)
 2031|         self.assertEqual(repr(tzc), 'tzfile(' + repr('foo') + ')')
 2032| 
 2033|     def testLeapCountDecodesProperly(self):
 2034|         # This timezone has leapcnt, and failed to decode until
 2035|         # Eugene Oden notified about the issue.
 2036| 
 2037|         # As leap information is currently unused (and unstored) by tzfile() we
 2038|         # can only indirectly test this: Take advantage of tzfile() not closing
 2039|         # the input file if handed in as an opened file and assert that the
 2040|         # full file content has been read by tzfile(). Note: For this test to
 2041|         # work NEW_YORK must be in TZif version 1 format i.e. no more data
 2042|         # after TZif v1 header + data has been read
 2043|         fileobj = BytesIO(base64.b64decode(NEW_YORK))
 2044|         tz.tzfile(fileobj)
 2045|         # we expect no remaining file content now, i.e. zero-length; if there's
 2046|         # still data we haven't read the file format correctly
 2047|         remaining_tzfile_content = fileobj.read()
 2048|         self.assertEqual(len(remaining_tzfile_content), 0)
 2049| 
 2050|     def testIsStd(self):
 2051|         # NEW_YORK tzfile contains this isstd information:
 2052|         isstd_expected = (0, 0, 0, 1)
 2053|         tzc = tz.tzfile(BytesIO(base64.b64decode(NEW_YORK)))
 2054|         # gather the actual information as parsed by the tzfile class
 2055|         isstd = []
 2056|         for ttinfo in tzc._ttinfo_list:
 2057|             # ttinfo objects contain boolean values
 2058|             isstd.append(int(ttinfo.isstd))
 2059|         # ttinfo list may contain more entries than isstd file content
 2060|         isstd = tuple(isstd[:len(isstd_expected)])
 2061|         self.assertEqual(
 2062|             isstd_expected, isstd,
 2063|             "isstd UTC/local indicators parsed: %s != tzfile contents: %s"
 2064|             % (isstd, isstd_expected))
 2065| 
 2066|     def testGMTHasNoDaylight(self):
 2067|         # tz.tzstr("GMT+2") improperly considered daylight saving time.
 2068|         # Issue reported by Lennart Regebro.
 2069|         dt = datetime(2007, 8, 6, 4, 10)
 2070|         self.assertEqual(tz.gettz("GMT+2").dst(dt), timedelta(0))
 2071| 
 2072|     def testGMTOffset(self):
 2073|         # GMT and UTC offsets have inverted signal when compared to the
 2074|         # usual TZ variable handling.
 2075|         dt = datetime(2007, 8, 6, 4, 10, tzinfo=tz.UTC)
 2076|         self.assertEqual(dt.astimezone(tz=tz.tzstr("GMT+2")),
 2077|                           datetime(2007, 8, 6, 6, 10, tzinfo=tz.tzstr("GMT+2")))
 2078|         self.assertEqual(dt.astimezone(tz=tz.gettz("UTC-2")),
 2079|                           datetime(2007, 8, 6, 2, 10, tzinfo=tz.tzstr("UTC-2")))
 2080| 
