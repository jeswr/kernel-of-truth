 2263| @unittest.skipUnless(IS_WIN, "Requires Windows")
 2264| class TzWinLocalTest(unittest.TestCase, TzWinFoldMixin):
 2265| 
 2266|     def setUp(self):
 2267|         self.tzclass = tzwin.tzwinlocal
 2268|         self.context = TZWinContext
 2269| 
 2270|     def get_args(self, tzname):
 2271|         return ()
 2272| 
 2273|     def testLocal(self):
 2274|         # Not sure how to pin a local time zone, so for now we're just going
 2275|         # to run this and make sure it doesn't raise an error
 2276|         # See GitHub Issue #135: https://github.com/dateutil/dateutil/issues/135
 2277|         datetime.now(tzwin.tzwinlocal())
 2278| 
 2279|     def testTzwinLocalUTCOffset(self):
 2280|         with TZWinContext('Eastern Standard Time'):
 2281|             tzwl = tzwin.tzwinlocal()
 2282|             self.assertEqual(datetime(2014, 3, 11, tzinfo=tzwl).utcoffset(),
 2283|                              timedelta(hours=-4))
 2284| 
 2285|     def testTzwinLocalName(self):
 2286|         # https://github.com/dateutil/dateutil/issues/143
 2287|         ESTs = 'Eastern Standard Time'
 2288|         EDTs = 'Eastern Daylight Time'
 2289|         transition_dates = [(datetime(2015, 3, 8, 0, 59), ESTs),
 2290|                             (datetime(2015, 3, 8, 3, 1), EDTs),
 2291|                             (datetime(2015, 11, 1, 0, 59), EDTs),
 2292|                             (datetime(2015, 11, 1, 3, 1), ESTs),
 2293|                             (datetime(2016, 3, 13, 0, 59), ESTs),
 2294|                             (datetime(2016, 3, 13, 3, 1), EDTs),
 2295|                             (datetime(2016, 11, 6, 0, 59), EDTs),
 2296|                             (datetime(2016, 11, 6, 3, 1), ESTs)]
 2297| 
 2298|         with TZWinContext('Eastern Standard Time'):
 2299|             tw = tz.tzwinlocal()
 2300| 
 2301|             for t_date, expected in transition_dates:
 2302|                 self.assertEqual(t_date.replace(tzinfo=tw).tzname(), expected)
 2303| 
 2304|     def testTzWinLocalRepr(self):
 2305|         tw = tz.tzwinlocal()
 2306|         self.assertEqual(repr(tw), 'tzwinlocal()')
 2307| 
 2308|     def testTzwinLocalRepr(self):
 2309|         # https://github.com/dateutil/dateutil/issues/143
 2310|         with TZWinContext('Eastern Standard Time'):
 2311|             tw = tz.tzwinlocal()
 2312| 
 2313|             self.assertEqual(str(tw), 'tzwinlocal(' +
 2314|                                       repr('Eastern Standard Time') + ')')
 2315| 
 2316|         with TZWinContext('Pacific Standard Time'):
 2317|             tw = tz.tzwinlocal()
 2318| 
 2319|             self.assertEqual(str(tw), 'tzwinlocal(' +
 2320|                                       repr('Pacific Standard Time') + ')')
 2321| 
 2322|     def testTzwinLocalEquality(self):
 2323|         tw_est = tz.tzwin('Eastern Standard Time')
 2324|         tw_pst = tz.tzwin('Pacific Standard Time')
 2325| 
 2326|         with TZWinContext('Eastern Standard Time'):
 2327|             twl1 = tz.tzwinlocal()
 2328|             twl2 = tz.tzwinlocal()
 2329| 
 2330|             self.assertEqual(twl1, twl2)
 2331|             self.assertEqual(twl1, tw_est)
 2332|             self.assertNotEqual(twl1, tw_pst)
 2333| 
 2334|         with TZWinContext('Pacific Standard Time'):
 2335|             twl1 = tz.tzwinlocal()
 2336|             twl2 = tz.tzwinlocal()
 2337|             tw = tz.tzwin('Pacific Standard Time')
 2338| 
 2339|             self.assertEqual(twl1, twl2)
 2340|             self.assertEqual(twl1, tw)
 2341|             self.assertEqual(twl1, tw_pst)
 2342|             self.assertNotEqual(twl1, tw_est)
 2343| 
 2344|     def testTzwinLocalTimeOnlyDST(self):
