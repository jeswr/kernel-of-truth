 2234|         self.assertIs(dt_time(14, 10, tzinfo=tw_est).dst(), None)
 2235| 
 2236|         # This zone has no DST, so .dst() can return 0
 2237|         tw_sast = tz.tzwin('South Africa Standard Time')
 2238|         self.assertEqual(dt_time(14, 10, tzinfo=tw_sast).dst(),
 2239|                          timedelta(0))
