  836| @pytest.mark.parametrize('args,kwargs', [
  837|     (('EST', -18000), {}),
  838|     (('EST', timedelta(hours=-5)), {}),
  839|     (('EST',), {'offset': -18000}),
  840|     (('EST',), {'offset': timedelta(hours=-5)}),
  841|     (tuple(), {'name': 'EST', 'offset': -18000})
  842| ])
  843| def test_tzoffset_is(args, kwargs):
  844|     tz_ref = tz.tzoffset('EST', -18000)
  845|     assert tz.tzoffset(*args, **kwargs) is tz_ref
  846| 
  847| 
  848| def test_tzoffset_is_not():
  849|     assert tz.tzoffset('EDT', -14400) is not tz.tzoffset('EST', -18000)
