 1200| class ZoneInfoGettzTest(GettzTest):
 1201|     def gettz(self, name):
 1202|         zoneinfo_file = zoneinfo.get_zonefile_instance()
 1203|         return zoneinfo_file.get(name)
 1204| 
 1205|     def testZoneInfoFileStart1(self):
 1206|         tz = self.gettz("EST5EDT")
 1207|         self.assertEqual(datetime(2003, 4, 6, 1, 59, tzinfo=tz).tzname(), "EST",
 1208|                          MISSING_TARBALL)
 1209|         self.assertEqual(datetime(2003, 4, 6, 2, 00, tzinfo=tz).tzname(), "EDT")
 1210| 
 1211|     def testZoneInfoFileEnd1(self):
 1212|         tzc = self.gettz("EST5EDT")
 1213|         self.assertEqual(datetime(2003, 10, 26, 0, 59, tzinfo=tzc).tzname(),
 1214|                          "EDT", MISSING_TARBALL)
 1215| 
 1216|         end_est = tz.enfold(datetime(2003, 10, 26, 1, 00, tzinfo=tzc), fold=1)
 1217|         self.assertEqual(end_est.tzname(), "EST")
 1218| 
 1219|     def testZoneInfoOffsetSignal(self):
 1220|         utc = self.gettz("UTC")
 1221|         nyc = self.gettz("America/New_York")
 1222|         self.assertNotEqual(utc, None, MISSING_TARBALL)
 1223|         self.assertNotEqual(nyc, None)
 1224|         t0 = datetime(2007, 11, 4, 0, 30, tzinfo=nyc)
 1225|         t1 = t0.astimezone(utc)
 1226|         t2 = t1.astimezone(nyc)
 1227|         self.assertEqual(t0, t2)
 1228|         self.assertEqual(nyc.dst(t0), timedelta(hours=1))
 1229| 
 1230|     def testZoneInfoCopy(self):
 1231|         # copy.copy() called on a ZoneInfo file was returning the same instance
 1232|         CHI = self.gettz('America/Chicago')
 1233|         CHI_COPY = copy.copy(CHI)
 1234| 
 1235|         self.assertIsNot(CHI, CHI_COPY)
 1236|         self.assertEqual(CHI, CHI_COPY)
 1237| 
 1238|     def testZoneInfoDeepCopy(self):
 1239|         CHI = self.gettz('America/Chicago')
 1240|         CHI_COPY = copy.deepcopy(CHI)
 1241| 
 1242|         self.assertIsNot(CHI, CHI_COPY)
 1243|         self.assertEqual(CHI, CHI_COPY)
 1244| 
 1245|     def testZoneInfoInstanceCaching(self):
 1246|         zif_0 = zoneinfo.get_zonefile_instance()
 1247|         zif_1 = zoneinfo.get_zonefile_instance()
 1248| 
 1249|         self.assertIs(zif_0, zif_1)
 1250| 
 1251|     def testZoneInfoNewInstance(self):
 1252|         zif_0 = zoneinfo.get_zonefile_instance()
 1253|         zif_1 = zoneinfo.get_zonefile_instance(new_instance=True)
 1254|         zif_2 = zoneinfo.get_zonefile_instance()
 1255| 
 1256|         self.assertIsNot(zif_0, zif_1)
 1257|         self.assertIs(zif_1, zif_2)
 1258| 
 1259|     def testZoneInfoDeprecated(self):
 1260|         with pytest.warns(DeprecationWarning):
 1261|             zoneinfo.gettz('US/Eastern')
 1262| 
 1263|     def testZoneInfoMetadataDeprecated(self):
 1264|         with pytest.warns(DeprecationWarning):
 1265|             zoneinfo.gettz_db_metadata()
