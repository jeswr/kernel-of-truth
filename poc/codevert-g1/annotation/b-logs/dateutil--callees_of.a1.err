 1174| @pytest.mark.xfail(IS_WIN, reason="Windows does not use system zoneinfo")
 1175| @pytest.mark.smoke
 1176| @pytest.mark.gettz
 1177| def test_gettz_weakref():
 1178|     tz.gettz.cache_clear()
 1179|     tz.gettz.set_cache_size(2)
 1180|     NYC1 = tz.gettz('America/New_York')
 1181|     NYC_ref = weakref.ref(tz.gettz('America/New_York'))
 1182| 
 1183|     assert NYC1 is NYC_ref()
 1184| 
 1185|     del NYC1
 1186|     gc.collect()
 1187| 
 1188|     assert NYC_ref() is not None        # Should still be in the strong cache
 1189|     assert tz.gettz('America/New_York') is NYC_ref()
 1190| 
 1191|     # Populate strong cache with other timezones
 1192|     tz.gettz('Europe/Monaco')
 1193|     tz.gettz('Pacific/Easter')
 1194|     tz.gettz('Australia/Currie')
 1195| 
 1196|     gc.collect()
 1197|     assert NYC_ref() is None    # Should have been pushed out
 1198|     assert tz.gettz('America/New_York') is not NYC_ref()
