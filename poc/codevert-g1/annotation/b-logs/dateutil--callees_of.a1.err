 2598|     def testIncompatibleAmbiguityFoldDSTOnly(self):
 2599|         dt_start = datetime(2018, 9, 1, 1, 0)
 2600|         dt_end = datetime(2018, 9, 1, 2, 0)
 2601| 
 2602|         tzi = self._get_ambig_error_tzinfo(dt_start, dt_end, dst_only=True)
 2603| 
