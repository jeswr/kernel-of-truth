 2552|     def _get_ambig_error_tzinfo(self, dt_start, dt_end, dst_only=False):
 2553|         cTzInfo = self._get_no_support_tzinfo_class(dt_start, dt_end, dst_only)
 2554| 
 2555|         # Takes the wrong number of arguments and raises an error anyway.
 2556|         class FoldTzInfoRaises(cTzInfo):
 2557|             def is_ambiguous(self, dt, other_arg):
 2558|                 raise NotImplementedError('This is not implemented')
 2559| 
 2560|         return FoldTzInfoRaises()
 2561| 
 2562|     def testIncompatibleAmbiguityFoldNaive(self):
 2563|         dt_start = datetime(2018, 9, 1, 1, 0)
 2564|         dt_end = datetime(2018, 9, 1, 2, 0)
