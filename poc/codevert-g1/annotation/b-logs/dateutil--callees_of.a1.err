 1709|             'TZID:US-Eastern',
 1710|             'BEGIN:STANDARD',
 1711|             'DTSTART:19971029T020000',
 1712|             'RRULE:FREQ=YEARLY;BYDAY=+1SU;BYMONTH=11',
 1713|             'TZOFFSETFROM:-0400',
 1714|             'TZOFFSETTO:-0500',
 1715|             'TZNAME:EST',
 1716|             'END:STANDARD',
 1717|             'BEGIN:DAYLIGHT',
 1718|             'DTSTART:19980301T020000',
 1719|             'RRULE:FREQ=YEARLY;BYDAY=+2SU;BYMONTH=03',
 1720|             'TZOFFSETFROM:-0500',
 1721|             'TZOFFSETTO:-0400',
 1722|             'TZNAME:EDT',
 1723|             'END:DAYLIGHT',
 1724|             'END:VTIMEZONE'
 1725|         )
 1726| 
 1727|         TZ_PST = (
 1728|             'BEGIN:VTIMEZONE',
 1729|             'TZID:US-Pacific',
 1730|             'BEGIN:STANDARD',
 1731|             'DTSTART:19971029T020000',
