 2164|                             (datetime(2015, 3, 8, 3, 1), EDTs),
 2165|                             (datetime(2015, 11, 1, 0, 59), EDTs),
 2166|                             (datetime(2015, 11, 1, 3, 1), ESTs),
 2167|                             (datetime(2016, 3, 13, 0, 59), ESTs),
 2168|                             (datetime(2016, 3, 13, 3, 1), EDTs),
 2169|                             (datetime(2016, 11, 6, 0, 59), EDTs),
 2170|                             (datetime(2016, 11, 6, 3, 1), ESTs)]
 2171| 
 2172|         for t_date, expected in transition_dates:
