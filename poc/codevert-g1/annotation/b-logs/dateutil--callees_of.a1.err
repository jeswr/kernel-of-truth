  419|     @unittest.skip("Known failure in Python 3.6.")
  420|     def testEqualAmbiguousComparison(self):
  421|         tzname = self._get_tzname('Australia/Sydney')
  422| 
  423|         with self._gettz_context(tzname):
  424|             SYD0 = self.gettz(tzname)
  425|             SYD1 = self.gettz(tzname)
  426| 
  427|             t0_u = datetime(2012, 3, 31, 14, 30, tzinfo=tz.UTC)  # AEST
  428| 
  429|             t0_syd0 = t0_u.astimezone(SYD0)
  430|             t0_syd1 = t0_u.astimezone(SYD1)
  431| 
  432|             # This is considered an "inter-zone comparison" because it's an
  433|             # ambiguous datetime.
  434|             self.assertEqual(t0_syd0, t0_syd1)
