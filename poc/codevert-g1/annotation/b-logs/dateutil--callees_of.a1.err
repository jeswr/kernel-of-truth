  739| @pytest.mark.smoke
  740| @pytest.mark.tzoffset
  741| def test_tzoffset_weakref():
  742|     UTC1 = tz.tzoffset('UTC', 0)
  743|     UTC_ref = weakref.ref(tz.tzoffset('UTC', 0))
  744|     UTC1 is UTC_ref()
  745|     del UTC1
  746|     gc.collect()
  747| 
  748|     assert UTC_ref() is not None    # Should be in the strong cache
  749|     assert UTC_ref() is tz.tzoffset('UTC', 0)
  750| 
  751|     # Fill the strong cache with other items
  752|     for offset in range(5,15):
  753|         tz.tzoffset('RandomZone', offset)
  754| 
  755|     gc.collect()
  756|     assert UTC_ref() is  None
  757|     assert UTC_ref() is not tz.tzoffset('UTC', 0)
  758| 
  759| 
  760| @pytest.mark.tzoffset
  761| @pytest.mark.parametrize('args', [
  762|     ('UTC', 0),
  763|     ('EST', -18000),
  764|     ('EST', timedelta(hours=-5)),
  765|     (None, timedelta(hours=3)),
  766| ])
  767| def test_tzoffset_singleton(args):
  768|     tz1 = tz.tzoffset(*args)
  769|     tz2 = tz.tzoffset(*args)
  770| 
  771|     assert tz1 is tz2
