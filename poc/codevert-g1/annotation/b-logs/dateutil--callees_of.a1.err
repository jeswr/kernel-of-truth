 2692|         assert getattr(dt2, 'fold', 0) == 0
 2693| 
 2694|     def test_fold_replace_args(self):
 2695|         # This test can be dropped when Python < 3.6 is dropped, since it
 2696|         # is mainly to cover the `replace` method on _DatetimeWithFold
 2697|         dt = tz.enfold(datetime(1950, 1, 2, 12, 30, 15, 8), fold=1)
 2698| 
 2699|         dt2 = dt.replace(1952, 2, 3, 13, 31, 16, 9)
 2700|         assert dt2 == tz.enfold(datetime(1952, 2, 3, 13, 31, 16, 9), fold=1)
 2701|         assert dt2.fold == 1
 2702| 
 2703|     def test_fold_replace_exception_duplicate_args(self):
 2704|         dt = tz.enfold(datetime(1999, 1, 3), fold=1)
 2705| 
 2706|         with pytest.raises(TypeError):
 2707|             dt.replace(1950, year=2000)
