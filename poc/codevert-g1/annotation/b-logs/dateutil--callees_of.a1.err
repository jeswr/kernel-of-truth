 2436| class DatetimeAmbiguousTest(unittest.TestCase):
 2437|     """ Test the datetime_exists / datetime_ambiguous functions """
 2438| 
 2439|     def testNoTzSpecified(self):
 2440|         with self.assertRaises(ValueError):
 2441|             tz.datetime_ambiguous(datetime(2016, 4, 1, 2, 9))
 2442| 
 2443|     def _get_no_support_tzinfo_class(self, dt_start, dt_end, dst_only=False):
 2444|         # Generates a class of tzinfo with no support for is_ambiguous
 2445|         # where dates between dt_start and dt_end are ambiguous.
 2446| 
 2447|         class FoldingTzInfo(tzinfo):
 2448|             def utcoffset(self, dt):
 2449|                 if not dst_only:
 2450|                     dt_n = dt.replace(tzinfo=None)
 2451| 
 2452|                     if dt_start <= dt_n < dt_end and getattr(dt_n, 'fold', 0):
 2453|                         return timedelta(hours=-1)
 2454| 
 2455|                 return timedelta(hours=0)
 2456| 
 2457|             def dst(self, dt):
 2458|                 dt_n = dt.replace(tzinfo=None)
 2459| 
 2460|                 if dt_start <= dt_n < dt_end and getattr(dt_n, 'fold', 0):
 2461|                     return timedelta(hours=1)
 2462|                 else:
 2463|                     return timedelta(0)
 2464| 
 2465|         return FoldingTzInfo
 2466| 
 2467|     def _get_no_support_tzinfo(self, dt_start, dt_end, dst_only=False):
 2468|         return self._get_no_support_tzinfo_class(dt_start, dt_end, dst_only)()
 2469| 
 2470|     def testNoSupportAmbiguityFoldNaive(self):
 2471|         dt_start = datetime(2018, 9, 1, 1, 0)
 2472|         dt_end = datetime(2018, 9, 1, 2, 0)
 2473| 
 2474|         tzi = self._get_no_support_tzinfo(dt_start, dt_end)
 2475| 
 2476|         self.assertTrue(tz.datetime_ambiguous(datetime(2018, 9, 1, 1, 30),
 2477|                                               tz=tzi))
 2478| 
 2479|     def testNoSupportAmbiguityFoldAware(self):
 2480|         dt_start = datetime(2018, 9, 1, 1, 0)
 2481|         dt_end = datetime(2018, 9, 1, 2, 0)
 2482| 
 2483|         tzi = self._get_no_support_tzinfo(dt_start, dt_end)
 2484| 
 2485|         self.assertTrue(tz.datetime_ambiguous(datetime(2018, 9, 1, 1, 30,
 2486|                                                        tzinfo=tzi)))
 2487| 
 2488|     def testNoSupportAmbiguityUnambiguousNaive(self):
 2489|         dt_start = datetime(2018, 9, 1, 1, 0)
 2490|         dt_end = datetime(2018, 9, 1, 2, 0)
 2491| 
 2492|         tzi = self._get_no_support_tzinfo(dt_start, dt_end)
 2493| 
 2494|         self.assertFalse(tz.datetime_ambiguous(datetime(2018, 10, 1, 12, 30),
 2495|                                               tz=tzi))
 2496| 
 2497|     def testNoSupportAmbiguityUnambiguousAware(self):
 2498|         dt_start = datetime(2018, 9, 1, 1, 0)
 2499|         dt_end = datetime(2018, 9, 1, 2, 0)
 2500| 
 2501|         tzi = self._get_no_support_tzinfo(dt_start, dt_end)
 2502| 
 2503|         self.assertFalse(tz.datetime_ambiguous(datetime(2018, 10, 1, 12, 30,
 2504|                                                         tzinfo=tzi)))
 2505| 
 2506|     def testNoSupportAmbiguityFoldDSTOnly(self):
 2507|         dt_start = datetime(2018, 9, 1, 1, 0)
 2508|         dt_end = datetime(2018, 9, 1, 2, 0)
 2509| 
 2510|         tzi = self._get_no_support_tzinfo(dt_start, dt_end, dst_only=True)
 2511| 
 2512|         self.assertTrue(tz.datetime_ambiguous(datetime(2018, 9, 1, 1, 30),
 2513|                                               tz=tzi))
 2514| 
 2515|     def testNoSupportAmbiguityUnambiguousDSTOnly(self):
 2516|         dt_start = datetime(2018, 9, 1, 1, 0)
 2517|         dt_end = datetime(2018, 9, 1, 2, 0)
 2518| 
 2519|         tzi = self._get_no_support_tzinfo(dt_start, dt_end, dst_only=True)
