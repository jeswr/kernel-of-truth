  534|     def testGapNegativeUTCOffset(self):
  535|         # Test that we don't have a problem around gaps.
  536|         tzname = 'Eastern Standard Time'
  537|         args = self.get_args(tzname)
  538| 
  539|         with self.context(tzname):
  540|             TOR = self.tzclass(*args)
  541| 
  542|             t_n, t0_u, t1_u = self.get_utc_transitions(TOR, 2011, True)
  543| 
  544|             t0 = t0_u.astimezone(TOR)
  545|             t1 = t1_u.astimezone(TOR)
  546| 
  547|             self.assertEqual(t0.replace(tzinfo=None),
  548|                              t_n)
  549| 
  550|             self.assertEqual(t1.replace(tzinfo=None),
  551|                              t_n + timedelta(hours=2))
  552| 
  553|             self.assertNotEqual(t0.tzname(), t1.tzname())
  554|             self.assertEqual(t0.utcoffset(), timedelta(hours=-5.0))
  555|             self.assertEqual(t1.utcoffset(), timedelta(hours=-4.0))
