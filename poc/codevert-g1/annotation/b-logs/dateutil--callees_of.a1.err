 2722|         dt_act = tz.resolve_imaginary(dt)
 2723|         dt_exp = datetime(2018, 3, 25, 2, 30, tzinfo=tzi)
 2724|         self.assertEqual(dt_act, dt_exp)
 2725| 
 2726|     def testKeivForward(self):
