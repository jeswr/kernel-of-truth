 2112| @pytest.mark.tzfile
 2113| def test_samoa_transition():
 2114|     # utcoffset() was erroneously returning +14:00 an hour early (GH #812)
 2115|     APIA = tz.gettz('Pacific/Apia')
 2116|     dt = datetime(2011, 12, 29, 23, 59, tzinfo=APIA)
 2117|     assert dt.utcoffset() == timedelta(hours=-10)
 2118| 
 2119|     # Make sure the transition actually works, too
 2120|     dt_after = (dt.astimezone(tz.UTC) + timedelta(minutes=1)).astimezone(APIA)
 2121|     assert dt_after == datetime(2011, 12, 31, tzinfo=APIA)
 2122|     assert dt_after.utcoffset() == timedelta(hours=14)
 2123| 
