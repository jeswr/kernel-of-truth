 2241|     def testTzwinTimeOnlyUTCOffset(self):
 2242|         # For zones with DST, .utcoffset() should return None
 2243|         tw_est = tz.tzwin('Eastern Standard Time')
 2244|         self.assertIs(dt_time(14, 10, tzinfo=tw_est).utcoffset(), None)
 2245| 
 2246|         # This zone has no DST, so .utcoffset() returns standard offset
 2247|         tw_sast = tz.tzwin('South Africa Standard Time')
 2248|         self.assertEqual(dt_time(14, 10, tzinfo=tw_sast).utcoffset(),
 2249|                          timedelta(hours=2))
 2250| 
 2251|     def testTzwinTimeOnlyTZName(self):
 2252|         # For zones with DST, the name defaults to standard time
 2253|         tw_est = tz.tzwin('Eastern Standard Time')
 2254|         self.assertEqual(dt_time(14, 10, tzinfo=tw_est).tzname(),
 2255|                          'Eastern Standard Time')
 2256| 
 2257|         # For zones with no DST, this should work normally.
 2258|         tw_sast = tz.tzwin('South Africa Standard Time')
 2259|         self.assertEqual(dt_time(14, 10, tzinfo=tw_sast).tzname(),
 2260|                          'South Africa Standard Time')
