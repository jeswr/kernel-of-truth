 1371|     def testRangeEquality(self):
 1372|         TZR1 = tz.tzrange('EST', -18000, 'EDT', -14400)
 1373| 
 1374|         # Standard abbreviation different
 1375|         TZR2 = tz.tzrange('ET', -18000, 'EDT', -14400)
 1376|         self.assertNotEqual(TZR1, TZR2)
 1377| 
 1378|         # DST abbreviation different
 1379|         TZR3 = tz.tzrange('EST', -18000, 'EMT', -14400)
 1380|         self.assertNotEqual(TZR1, TZR3)
 1381| 
 1382|         # STD offset different
 1383|         TZR4 = tz.tzrange('EST', -14000, 'EDT', -14400)
 1384|         self.assertNotEqual(TZR1, TZR4)
 1385| 
 1386|         # DST offset different
 1387|         TZR5 = tz.tzrange('EST', -18000, 'EDT', -18000)
 1388|         self.assertNotEqual(TZR1, TZR5)
 1389| 
 1390|         # Start delta different
 1391|         TZR6 = tz.tzrange('EST', -18000, 'EDT', -14400,
 1392|                           start=relativedelta(hours=+1, month=3,
 1393|                                               day=1, weekday=SU(+2)))
 1394|         self.assertNotEqual(TZR1, TZR6)
 1395| 
 1396|         # End delta different
 1397|         TZR7 = tz.tzrange('EST', -18000, 'EDT', -14400,
 1398|             end=relativedelta(hours=+1, month=11,
 1399|                               day=1, weekday=SU(+2)))
 1400|         self.assertNotEqual(TZR1, TZR7)
 1401| 
 1402|     def testRangeInequalityUnsupported(self):
 1403|         TZR = tz.tzrange('EST', -18000, 'EDT', -14400)
 1404| 
 1405|         self.assertFalse(TZR == 4)
 1406|         self.assertTrue(TZR == ComparesEqual)
 1407|         self.assertFalse(TZR != ComparesEqual)
