  305|     def testFoldIndependence(self):
  306|         tzname = self._get_tzname('America/New_York')
  307| 
  308|         with self._gettz_context(tzname):
  309|             NYC = self.gettz(tzname)
  310|             UTC = tz.UTC
  311|             hour = timedelta(hours=1)
  312| 
  313|             # Firmly 2015-11-01 0:30 EDT-4
  314|             pre_dst = datetime(2015, 11, 1, 0, 30, tzinfo=NYC)
  315| 
  316|             # Ambiguous between 2015-11-01 1:30 EDT-4 and 2015-11-01 1:30 EST-5
  317|             in_dst = pre_dst + hour
  318|             in_dst_tzname_0 = in_dst.tzname()     # Stash the tzname - EDT
  319| 
  320|             # Doing the arithmetic in UTC creates a date that is unambiguously
  321|             # 2015-11-01 1:30 EDT-5
  322|             in_dst_via_utc = (pre_dst.astimezone(UTC) + 2*hour).astimezone(NYC)
  323| 
  324|             # Make sure the dates are actually ambiguous
  325|             self.assertEqual(in_dst, in_dst_via_utc)
  326| 
  327|             # Make sure we got the right folding behavior
  328|             self.assertNotEqual(in_dst_via_utc.tzname(), in_dst_tzname_0)
  329| 
  330|             # Now check to make sure in_dst's tzname hasn't changed
  331|             self.assertEqual(in_dst_tzname_0, in_dst.tzname())
  332| 
  333|     def testInZoneFoldEquality(self):
  334|         # Two datetimes in the same zone are considered to be equal if their
  335|         # wall times are equal, even if they have different absolute times.
  336| 
  337|         tzname = self._get_tzname('America/New_York')
  338| 
  339|         with self._gettz_context(tzname):
  340|             NYC = self.gettz(tzname)
  341|             UTC = tz.UTC
  342| 
  343|             dt0 = datetime(2011, 11, 6, 1, 30, tzinfo=NYC)
  344|             dt1 = tz.enfold(dt0, fold=1)
  345| 
  346|             # Make sure these actually represent different times
  347|             self.assertNotEqual(dt0.astimezone(UTC), dt1.astimezone(UTC))
  348| 
  349|             # Test that they compare equal
  350|             self.assertEqual(dt0, dt1)
  351| 
