 1410| @pytest.mark.tzstr
 1411| class TZStrTest(unittest.TestCase, TzFoldMixin):
 1412|     # POSIX string indicating change to summer time on the 2nd Sunday in March
 1413|     # at 2AM, and ending the 1st Sunday in November at 2AM. (valid >= 2007)
 1414|     TZ_EST = 'EST+5EDT,M3.2.0/2,M11.1.0/2'
 1415| 
 1416|     # POSIX string for AEST/AEDT (valid >= 2008)
 1417|     TZ_AEST = 'AEST-10AEDT,M10.1.0/2,M4.1.0/3'
 1418| 
 1419|     # POSIX string for GMT/BST
 1420|     TZ_LON = 'GMT0BST,M3.5.0,M10.5.0'
 1421| 
 1422|     def gettz(self, tzname):
 1423|         # Actual time zone changes are handled by the _gettz_context function
 1424|         tzname_map = {'Australia/Sydney': self.TZ_AEST,
 1425|                       'America/Toronto': self.TZ_EST,
 1426|                       'America/New_York': self.TZ_EST,
 1427|                       'Europe/London': self.TZ_LON}
 1428| 
 1429|         return tz.tzstr(tzname_map[tzname])
 1430| 
 1431|     def testStrStr(self):
 1432|         # Test that tz.tzstr() won't throw an error if given a str instead
 1433|         # of a unicode literal.
 1434|         self.assertEqual(datetime(2003, 4, 6, 1, 59,
 1435|                                   tzinfo=tz.tzstr(str("EST5EDT"))).tzname(), "EST")
 1436|         self.assertEqual(datetime(2003, 4, 6, 2, 00,
 1437|                                   tzinfo=tz.tzstr(str("EST5EDT"))).tzname(), "EDT")
 1438| 
 1439|     def testStrInequality(self):
 1440|         TZS1 = tz.tzstr('EST5EDT4')
 1441| 
 1442|         # Standard abbreviation different
 1443|         TZS2 = tz.tzstr('ET5EDT4')
 1444|         self.assertNotEqual(TZS1, TZS2)
 1445| 
 1446|         # DST abbreviation different
 1447|         TZS3 = tz.tzstr('EST5EMT')
 1448|         self.assertNotEqual(TZS1, TZS3)
 1449| 
 1450|         # STD offset different
 1451|         TZS4 = tz.tzstr('EST4EDT4')
 1452|         self.assertNotEqual(TZS1, TZS4)
 1453| 
 1454|         # DST offset different
 1455|         TZS5 = tz.tzstr('EST5EDT3')
 1456|         self.assertNotEqual(TZS1, TZS5)
 1457| 
 1458|     def testStrInequalityStartEnd(self):
 1459|         TZS1 = tz.tzstr('EST5EDT4')
 1460| 
 1461|         # Start delta different
 1462|         TZS2 = tz.tzstr('EST5EDT4,M4.2.0/02:00:00,M10-5-0/02:00')
 1463|         self.assertNotEqual(TZS1, TZS2)
 1464| 
 1465|         # End delta different
 1466|         TZS3 = tz.tzstr('EST5EDT4,M4.2.0/02:00:00,M11-5-0/02:00')
 1467|         self.assertNotEqual(TZS1, TZS3)
 1468| 
 1469|     def testPosixOffset(self):
 1470|         TZ1 = tz.tzstr('UTC-3')
 1471|         self.assertEqual(datetime(2015, 1, 1, tzinfo=TZ1).utcoffset(),
 1472|                          timedelta(hours=-3))
 1473| 
 1474|         TZ2 = tz.tzstr('UTC-3', posix_offset=True)
 1475|         self.assertEqual(datetime(2015, 1, 1, tzinfo=TZ2).utcoffset(),
 1476|                          timedelta(hours=+3))
 1477| 
 1478|     def testStrInequalityUnsupported(self):
 1479|         TZS = tz.tzstr('EST5EDT')
 1480| 
 1481|         self.assertFalse(TZS == 4)
 1482|         self.assertTrue(TZS == ComparesEqual)
 1483|         self.assertFalse(TZS != ComparesEqual)
 1484| 
 1485|     def testTzStrRepr(self):
 1486|         TZS1 = tz.tzstr('EST5EDT4')
 1487|         TZS2 = tz.tzstr('EST')
 1488| 
 1489|         self.assertEqual(repr(TZS1), "tzstr(" + repr('EST5EDT4') + ")")
 1490|         self.assertEqual(repr(TZS2), "tzstr(" + repr('EST') + ")")
 1491| 
 1492|     def testTzStrFailure(self):
 1493|         with self.assertRaises(ValueError):
 1494|             tz.tzstr('InvalidString;439999')
 1495| 
 1496|     def testTzStrSingleton(self):
 1497|         tz1 = tz.tzstr('EST5EDT')
 1498|         tz2 = tz.tzstr('CST4CST')
 1499|         tz3 = tz.tzstr('EST5EDT')
 1500| 
 1501|         self.assertIsNot(tz1, tz2)
 1502|         self.assertIs(tz1, tz3)
 1503| 
 1504|     def testTzStrSingletonPosix(self):
 1505|         tz_t1 = tz.tzstr('GMT+3', posix_offset=True)
 1506|         tz_f1 = tz.tzstr('GMT+3', posix_offset=False)
 1507| 
 1508|         tz_t2 = tz.tzstr('GMT+3', posix_offset=True)
 1509|         tz_f2 = tz.tzstr('GMT+3', posix_offset=False)
 1510| 
 1511|         self.assertIs(tz_t1, tz_t2)
 1512|         self.assertIsNot(tz_t1, tz_f1)
 1513| 
 1514|         self.assertIs(tz_f1, tz_f2)
 1515| 
 1516|     def testTzStrInstance(self):
 1517|         tz1 = tz.tzstr('EST5EDT')
 1518|         tz2 = tz.tzstr.instance('EST5EDT')
 1519|         tz3 = tz.tzstr.instance('EST5EDT')
 1520| 
 1521|         assert tz1 is not tz2
 1522|         assert tz2 is not tz3
 1523| 
 1524|         # Ensure that these still are all the same zone
 1525|         assert tz1 == tz2 == tz3
 1526| 
