  993| @mark_tzlocal_nix
  994| @pytest.mark.parametrize('tzvar, tzoff', [
  995|     ('EST5', tz.tzoffset('EST', -18000)),
  996|     ('GMT0', tz.tzoffset('GMT', 0)),
  997|     ('YAKT-9', tz.tzoffset('YAKT', timedelta(hours=9))),
  998|     ('JST-9', tz.tzoffset('JST', timedelta(hours=9))),
  999| ])
 1000| def test_tzlocal_offset_equal(tzvar, tzoff):
 1001|     with TZEnvContext(tzvar):
 1002|         # Including both to test both __eq__ and __ne__
 1003|         assert tz.tzlocal() == tzoff
 1004|         assert not (tz.tzlocal() != tzoff)
 1005| 
