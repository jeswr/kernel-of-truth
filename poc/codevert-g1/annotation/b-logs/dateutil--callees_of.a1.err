 1268| class TZRangeTest(unittest.TestCase, TzFoldMixin):
 1269|     TZ_EST = tz.tzrange('EST', timedelta(hours=-5),
 1270|                         'EDT', timedelta(hours=-4),
 1271|                         start=relativedelta(month=3, day=1, hour=2,
 1272|                                             weekday=SU(+2)),
 1273|                         end=relativedelta(month=11, day=1, hour=1,
 1274|                                           weekday=SU(+1)))
 1275| 
 1276|     TZ_AEST = tz.tzrange('AEST', timedelta(hours=10),
 1277|                          'AEDT', timedelta(hours=11),
 1278|                          start=relativedelta(month=10, day=1, hour=2,
 1279|                                              weekday=SU(+1)),
 1280|                          end=relativedelta(month=4, day=1, hour=2,
 1281|                                            weekday=SU(+1)))
 1282| 
 1283|     TZ_LON = tz.tzrange('GMT', timedelta(hours=0),
 1284|                         'BST', timedelta(hours=1),
 1285|                         start=relativedelta(month=3, day=31, weekday=SU(-1),
 1286|                                             hours=2),
 1287|                         end=relativedelta(month=10, day=31, weekday=SU(-1),
 1288|                                           hours=1))
 1289|     # POSIX string for UTC
 1290|     UTC = 'UTC'
