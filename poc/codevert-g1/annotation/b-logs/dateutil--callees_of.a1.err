  613| class TzUTCTest(unittest.TestCase):
  614|     def testSingleton(self):
  615|         UTC_0 = tz.tzutc()
  616|         UTC_1 = tz.tzutc()
  617| 
  618|         self.assertIs(UTC_0, UTC_1)
  619| 
  620|     def testOffset(self):
  621|         ct = datetime(2009, 4, 1, 12, 11, 13, tzinfo=tz.tzutc())
  622| 
  623|         self.assertEqual(ct.utcoffset(), timedelta(seconds=0))
