  518| 
  519|         with self.context(tzname):
  520|             TOR = self.tzclass(*args)
  521| 
  522|             t_n, t0_u, t1_u = self.get_utc_transitions(TOR, 2011, False)
  523| 
  524|             t0_tor = t0_u.astimezone(TOR)
  525|             t1_tor = t1_u.astimezone(TOR)
  526| 
  527|             self.assertEqual(t0_tor.replace(tzinfo=None), t_n)
  528|             self.assertEqual(t1_tor.replace(tzinfo=None), t_n)
  529| 
  530|             self.assertNotEqual(t0_tor.tzname(), t1_tor.tzname())
  531|             self.assertEqual(t0_tor.utcoffset(), timedelta(hours=-4.0))
  532|             self.assertEqual(t1_tor.utcoffset(), timedelta(hours=-5.0))
