  980|     'Europe/London', 'America/New_York',
  981|     'GMT0BST', 'EST5EDT'])
  982| def test_tzlocal_utc_unequal(tzvar):
  983|     with TZEnvContext(tzvar):
  984|         assert tz.tzlocal() != tz.UTC
