 1632|         start=relativedelta(hours=+2, month=5, day=1, weekday=SU(+4)),
 1633|         end=relativedelta(hours=+1, month=11, day=31, weekday=SU(-3)))),
 1634| ])
 1635| def test_valid_dateutil_format(tz_str, expected):
