 2574| 
 2575|         tzi = self._get_ambig_error_tzinfo(dt_start, dt_end)
 2576| 
 2577|         self.assertTrue(tz.datetime_ambiguous(datetime(2018, 9, 1, 1, 30,
 2578|                                                        tzinfo=tzi)))
 2579| 
 2580|     def testIncompatibleAmbiguityUnambiguousNaive(self):
 2581|         dt_start = datetime(2018, 9, 1, 1, 0)
 2582|         dt_end = datetime(2018, 9, 1, 2, 0)
 2583| 
 2584|         tzi = self._get_ambig_error_tzinfo(dt_start, dt_end)
 2585| 
