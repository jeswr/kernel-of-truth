 1528| @pytest.mark.smoke
 1529| @pytest.mark.tzstr
 1530| def test_tzstr_weakref():
 1531|     tz_t1 = tz.tzstr('EST5EDT')
 1532|     tz_t2_ref = weakref.ref(tz.tzstr('EST5EDT'))
 1533|     assert tz_t1 is tz_t2_ref()
 1534| 
 1535|     del tz_t1
 1536|     gc.collect()
 1537| 
 1538|     assert tz_t2_ref() is not None
 1539|     assert tz.tzstr('EST5EDT') is tz_t2_ref()
 1540| 
 1541|     for offset in range(5,15):
 1542|         tz.tzstr('GMT+{}'.format(offset))
 1543|     gc.collect()
 1544| 
 1545|     assert tz_t2_ref() is None
 1546|     assert tz.tzstr('EST5EDT') is not tz_t2_ref()
 1547| 
 1548| 
 1549| @pytest.mark.tzstr
 1550| @pytest.mark.parametrize('tz_str,expected', [
 1551|     # From https://www.gnu.org/software/libc/manual/html_node/TZ-Variable.html
 1552|     ('', tz.tzrange(None)),     # TODO: Should change this so tz.tzrange('') works
 1553|     ('EST+5EDT,M3.2.0/2,M11.1.0/12',
 1554|      tz.tzrange('EST', -18000, 'EDT', -14400,
 1555|         start=relativedelta(month=3, day=1, weekday=SU(2), hours=2),
 1556|         end=relativedelta(month=11, day=1, weekday=SU(1), hours=11))),
 1557|     ('WART4WARST,J1/0,J365/25',  # This is DST all year, Western Argentina Summer Time
 1558|      tz.tzrange('WART', timedelta(hours=-4), 'WARST',
 1559|         start=relativedelta(month=1, day=1, hours=0),
 1560|         end=relativedelta(month=12, day=31, days=1))),
 1561|     ('IST-2IDT,M3.4.4/26,M10.5.0',      # Israel Standard / Daylight Time
 1562|      tz.tzrange('IST', timedelta(hours=2), 'IDT',
 1563|         start=relativedelta(month=3, day=1, weekday=TH(4), days=1, hours=2),
 1564|         end=relativedelta(month=10, day=31, weekday=SU(-1), hours=1))),
 1565|     ('WGT3WGST,M3.5.0/2,M10.5.0/1',
 1566|      tz.tzrange('WGT', timedelta(hours=-3), 'WGST',
 1567|         start=relativedelta(month=3, day=31, weekday=SU(-1), hours=2),
 1568|         end=relativedelta(month=10, day=31, weekday=SU(-1), hours=0))),
 1569| 
 1570|     # Different offset specifications
 1571|     ('WGT0300WGST',
 1572|      tz.tzrange('WGT', timedelta(hours=-3), 'WGST')),
 1573|     ('WGT03:00WGST',
 1574|      tz.tzrange('WGT', timedelta(hours=-3), 'WGST')),
 1575|     ('AEST-1100AEDT',
 1576|      tz.tzrange('AEST', timedelta(hours=11), 'AEDT')),
 1577|     ('AEST-11:00AEDT',
 1578|      tz.tzrange('AEST', timedelta(hours=11), 'AEDT')),
 1579| 
 1580|     # Different time formats
 1581|     ('EST5EDT,M3.2.0/4:00,M11.1.0/3:00',
 1582|      tz.tzrange('EST', timedelta(hours=-5), 'EDT',
 1583|         start=relativedelta(month=3, day=1, weekday=SU(2), hours=4),
 1584|         end=relativedelta(month=11, day=1, weekday=SU(1), hours=2))),
 1585|     ('EST5EDT,M3.2.0/04:00,M11.1.0/03:00',
 1586|      tz.tzrange('EST', timedelta(hours=-5), 'EDT',
 1587|         start=relativedelta(month=3, day=1, weekday=SU(2), hours=4),
 1588|         end=relativedelta(month=11, day=1, weekday=SU(1), hours=2))),
 1589|     ('EST5EDT,M3.2.0/0400,M11.1.0/0300',
 1590|      tz.tzrange('EST', timedelta(hours=-5), 'EDT',
 1591|         start=relativedelta(month=3, day=1, weekday=SU(2), hours=4),
 1592|         end=relativedelta(month=11, day=1, weekday=SU(1), hours=2))),
 1593| ])
 1594| def test_valid_GNU_tzstr(tz_str, expected):
 1595|     tzi = tz.tzstr(tz_str)
 1596| 
 1597|     assert tzi == expected
 1598| 
 1599| 
