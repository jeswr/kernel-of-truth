 1795|     def _gettz_str(self, tzname):
 1796|         return '\n'.join(self._gettz_str_tuple(tzname))
 1797| 
 1798|     def _tzstr_dtstart_with_params(self, tzname, param_str):
 1799|         # Adds parameters to the DTSTART values of a given tzstr
 1800|         tz_str_tuple = self._gettz_str_tuple(tzname)
 1801| 
 1802|         out_tz = []
 1803|         for line in tz_str_tuple:
 1804|             if line.startswith('DTSTART'):
 1805|                 name, value = line.split(':', 1)
 1806|                 line = name + ';' + param_str + ':' + value
 1807| 
 1808|             out_tz.append(line)
 1809| 
 1810|         return '\n'.join(out_tz)
 1811| 
 1812|     def gettz(self, tzname):
 1813|         tz_str = self._gettz_str(tzname)
 1814| 
 1815|         tzc = tz.tzical(StringIO(tz_str)).get()
 1816| 
 1817|         return tzc
 1818| 
 1819|     def testRepr(self):
 1820|         instr = StringIO(TZICAL_PST8PDT)
 1821|         instr.name = 'StringIO(PST8PDT)'
 1822|         tzc = tz.tzical(instr)
 1823| 
 1824|         self.assertEqual(repr(tzc), "tzical(" + repr(instr.name) + ")")
 1825| 
 1826|     # Test performance
 1827|     def _test_us_zone(self, tzc, func, values, start):
 1828|         if start:
 1829|             dt1 = datetime(2003, 3, 9, 1, 59)
 1830|             dt2 = datetime(2003, 3, 9, 2, 00)
 1831|             fold = [0, 0]
 1832|         else:
 1833|             dt1 = datetime(2003, 11, 2, 0, 59)
 1834|             dt2 = datetime(2003, 11, 2, 1, 00)
 1835|             fold = [0, 1]
 1836| 
 1837|         dts = (tz.enfold(dt.replace(tzinfo=tzc), fold=f)
 1838|                for dt, f in zip((dt1, dt2), fold))
 1839| 
 1840|         for value, dt in zip(values, dts):
 1841|             self.assertEqual(func(dt), value)
 1842| 
 1843|     def _test_multi_zones(self, tzstrs, tzids, func, values, start):
 1844|         tzic = tz.tzical(StringIO('\n'.join(tzstrs)))
 1845|         for tzid, vals in zip(tzids, values):
 1846|             tzc = tzic.get(tzid)
 1847| 
 1848|             self._test_us_zone(tzc, func, vals, start)
 1849| 
 1850|     def _prepare_EST(self):
 1851|         tz_str = self._gettz_str('America/New_York')
 1852|         return tz.tzical(StringIO(tz_str)).get()
 1853| 
 1854|     def _testEST(self, start, test_type, tzc=None):
 1855|         if tzc is None:
 1856|             tzc = self._prepare_EST()
 1857| 
 1858|         argdict = {
 1859|             'name':   (datetime.tzname, ('EST', 'EDT')),
 1860|             'offset': (datetime.utcoffset, (timedelta(hours=-5),
 1861|                                             timedelta(hours=-4))),
 1862|             'dst':    (datetime.dst, (timedelta(hours=0),
 1863|                                       timedelta(hours=1)))
 1864|         }
 1865| 
 1866|         func, values = argdict[test_type]
 1867| 
 1868|         if not start:
 1869|             values = reversed(values)
 1870| 
 1871|         self._test_us_zone(tzc, func, values, start=start)
 1872| 
