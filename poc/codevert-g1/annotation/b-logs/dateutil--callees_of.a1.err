  182| class TzFoldMixin(object):
  183|     """ Mix-in class for testing ambiguous times """
  184|     def gettz(self, tzname):
  185|         raise NotImplementedError
  186| 
  187|     def _get_tzname(self, tzname):
  188|         return tzname
  189| 
  190|     def _gettz_context(self, tzname):
  191|         return context_passthrough()
  192| 
  193|     def testFoldPositiveUTCOffset(self):
  194|         # Test that we can resolve ambiguous times
  195|         tzname = self._get_tzname('Australia/Sydney')
  196| 
  197|         with self._gettz_context(tzname):
  198|             SYD = self.gettz(tzname)
  199| 
  200|             t0_u = datetime(2012, 3, 31, 15, 30, tzinfo=tz.UTC)  # AEST
  201|             t1_u = datetime(2012, 3, 31, 16, 30, tzinfo=tz.UTC)  # AEDT
  202| 
  203|             t0_syd0 = t0_u.astimezone(SYD)
  204|             t1_syd1 = t1_u.astimezone(SYD)
  205| 
  206|             self.assertEqual(t0_syd0.replace(tzinfo=None),
  207|                              datetime(2012, 4, 1, 2, 30))
  208| 
  209|             self.assertEqual(t1_syd1.replace(tzinfo=None),
  210|                              datetime(2012, 4, 1, 2, 30))
  211| 
  212|             self.assertEqual(t0_syd0.utcoffset(), timedelta(hours=11))
  213|             self.assertEqual(t1_syd1.utcoffset(), timedelta(hours=10))
  214| 
  215|     def testGapPositiveUTCOffset(self):
  216|         # Test that we don't have a problem around gaps.
  217|         tzname = self._get_tzname('Australia/Sydney')
  218| 
  219|         with self._gettz_context(tzname):
  220|             SYD = self.gettz(tzname)
  221| 
  222|             t0_u = datetime(2012, 10, 6, 15, 30, tzinfo=tz.UTC)  # AEST
  223|             t1_u = datetime(2012, 10, 6, 16, 30, tzinfo=tz.UTC)  # AEDT
  224| 
  225|             t0 = t0_u.astimezone(SYD)
  226|             t1 = t1_u.astimezone(SYD)
  227| 
  228|             self.assertEqual(t0.replace(tzinfo=None),
  229|                              datetime(2012, 10, 7, 1, 30))
  230| 
  231|             self.assertEqual(t1.replace(tzinfo=None),
  232|                              datetime(2012, 10, 7, 3, 30))
  233| 
  234|             self.assertEqual(t0.utcoffset(), timedelta(hours=10))
  235|             self.assertEqual(t1.utcoffset(), timedelta(hours=11))
  236| 
  237|     def testFoldNegativeUTCOffset(self):
  238|             # Test that we can resolve ambiguous times
  239|             tzname = self._get_tzname('America/Toronto')
  240| 
  241|             with self._gettz_context(tzname):
  242|                 TOR = self.gettz(tzname)
  243| 
  244|                 t0_u = datetime(2011, 11, 6, 5, 30, tzinfo=tz.UTC)
  245|                 t1_u = datetime(2011, 11, 6, 6, 30, tzinfo=tz.UTC)
  246| 
  247|                 t0_tor = t0_u.astimezone(TOR)
  248|                 t1_tor = t1_u.astimezone(TOR)
  249| 
  250|                 self.assertEqual(t0_tor.replace(tzinfo=None),
  251|                                  datetime(2011, 11, 6, 1, 30))
  252| 
  253|                 self.assertEqual(t1_tor.replace(tzinfo=None),
  254|                                  datetime(2011, 11, 6, 1, 30))
  255| 
  256|                 self.assertNotEqual(t0_tor.tzname(), t1_tor.tzname())
  257|                 self.assertEqual(t0_tor.utcoffset(), timedelta(hours=-4.0))
  258|                 self.assertEqual(t1_tor.utcoffset(), timedelta(hours=-5.0))
  259| 
  260|     def testGapNegativeUTCOffset(self):
