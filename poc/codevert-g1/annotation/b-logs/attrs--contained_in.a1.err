  830|     @pytest.mark.usefixtures("with_and_without_validation")
  831|     def test_pre_init_kw_only_work_with_defaults(self):
  832|         """
  833|         Default values together with kw_only don't break __attrs__pre_init__.
  834|         """
  835|         val = None
  836| 
  837|         @attr.define
  838|         class KWOnlyAndDefault:
  839|             kw_and_default: int = attr.field(kw_only=True, default=3)
  840| 
