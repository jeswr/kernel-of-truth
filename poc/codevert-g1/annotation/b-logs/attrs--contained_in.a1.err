 1538|     def test_generic_dynamic_class(self):
 1539|         """
 1540|         make_class can create generic dynamic classes.
 1541| 
 1542|         https://github.com/python-attrs/attrs/issues/756
 1543|         https://bugs.python.org/issue33188
 1544|         """
 1545|         from types import new_class
 1546|         from typing import Generic, TypeVar
 1547| 
 1548|         MyTypeVar = TypeVar("MyTypeVar")
 1549|         MyParent = new_class("MyParent", (Generic[MyTypeVar],), {})
 1550| 
 1551|         attr.make_class("test", {"id": attr.ib(type=str)}, (MyParent[int],))
 1552| 
 1553|     def test_annotations(self):
 1554|         """
 1555|         make_class fills the __annotations__ dict for attributes with a known
 1556|         type.
 1557|         """
 1558|         a = attr.ib(type=bool)
 1559|         b = attr.ib(
 1560|             type=None
 1561|         )  # Won't be added to ann. b/c of unfavorable default
 1562|         c = attr.ib()
 1563| 
 1564|         C = attr.make_class("C", {"a": a, "b": b, "c": c})
 1565|         C = attr.resolve_types(C)
 1566| 
 1567|         assert {"a": bool} == C.__annotations__
 1568| 
 1569|     def test_annotations_resolve(self):
 1570|         """
 1571|         resolve_types() resolves the annotations added by make_class().
 1572|         """
 1573|         a = attr.ib(type="bool")
 1574| 
 1575|         C = attr.make_class("C", {"a": a})
 1576|         C = attr.resolve_types(C)
 1577| 
 1578|         assert attr.fields(C).a.type is bool
 1579|         assert {"a": "bool"} == C.__annotations__
 1580| 
