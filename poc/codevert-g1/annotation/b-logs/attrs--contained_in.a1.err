 1843| class TestValidate:
 1844|     """
 1845|     Tests for `validate`.
 1846|     """
 1847| 
 1848|     def test_success(self):
 1849|         """
 1850|         If the validator succeeds, nothing gets raised.
 1851|         """
 1852|         C = make_class(
 1853|             "C", {"x": attr.ib(validator=lambda *a: None), "y": attr.ib()}
 1854|         )
 1855|         validate(C(1, 2))
 1856| 
 1857|     def test_propagates(self):
 1858|         """
 1859|         The exception of the validator is handed through.
 1860|         """
 1861| 
 1862|         def raiser(_, __, value):
 1863|             if value == 42:
 1864|                 raise FloatingPointError
 1865| 
 1866|         C = make_class("C", {"x": attr.ib(validator=raiser)})
 1867|         i = C(1)
 1868|         i.x = 42
 1869| 
 1870|         with pytest.raises(FloatingPointError):
 1871|             validate(i)
 1872| 
 1873|     def test_run_validators(self):
 1874|         """
 1875|         Setting `_run_validators` to False prevents validators from running.
 1876|         """
 1877|         _config._run_validators = False
 1878|         obj = object()
 1879| 
 1880|         def raiser(_, __, ___):
 1881|             raise Exception(obj)
 1882| 
 1883|         C = make_class("C", {"x": attr.ib(validator=raiser)})
 1884|         c = C(1)
 1885|         validate(c)
 1886|         assert 1 == c.x
 1887|         _config._run_validators = True
 1888| 
 1889|         with pytest.raises(Exception):
 1890|             validate(c)
 1891| 
 1892|         with pytest.raises(Exception) as e:
 1893|             C(1)
 1894|         assert (obj,) == e.value.args
 1895| 
 1896|     def test_multiple_validators(self):
 1897|         """
 1898|         If a list is passed as a validator, all of its items are treated as one
 1899|         and must pass.
 1900|         """
 1901| 
 1902|         def v1(_, __, value):
 1903|             if value == 23:
 1904|                 raise TypeError("omg")
 1905| 
 1906|         def v2(_, __, value):
 1907|             if value == 42:
 1908|                 raise ValueError("omg")
 1909| 
 1910|         C = make_class("C", {"x": attr.ib(validator=[v1, v2])})
 1911| 
 1912|         validate(C(1))
 1913| 
 1914|         with pytest.raises(TypeError) as e:
 1915|             C(23)
 1916| 
 1917|         assert "omg" == e.value.args[0]
 1918| 
 1919|         with pytest.raises(ValueError) as e:
 1920|             C(42)
 1921| 
 1922|         assert "omg" == e.value.args[0]
 1923| 
 1924|     def test_multiple_empty(self):
 1925|         """
 1926|         Empty list/tuple for validator is the same as None.
