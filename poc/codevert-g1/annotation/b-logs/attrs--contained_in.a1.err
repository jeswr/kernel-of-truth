 1499| 
 1500|         def echo_func(cls, *args):
 1501|             return args
 1502| 
 1503|         cls = make_class("C", {}, class_body={"echo": classmethod(echo_func)})
 1504| 
 1505|         assert ("a", "b") == cls.echo("a", "b")
 1506| 
 1507|     def test_clean_class(self, slots):
