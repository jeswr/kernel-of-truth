 1385| class TestMakeClass:
 1386|     """
 1387|     Tests for `make_class`.
 1388|     """
 1389| 
 1390|     @pytest.mark.parametrize("ls", [list, tuple])
 1391|     def test_simple(self, ls):
 1392|         """
 1393|         Passing a list of strings creates attributes with default args.
 1394|         """
 1395|         C1 = make_class("C1", ls(["a", "b"]))
 1396| 
 1397|         @attr.s
 1398|         class C2:
 1399|             a = attr.ib()
 1400|             b = attr.ib()
 1401| 
 1402|         assert C1.__attrs_attrs__ == C2.__attrs_attrs__
 1403| 
 1404|     def test_dict(self):
 1405|         """
 1406|         Passing a dict of name: _CountingAttr creates an equivalent class.
 1407|         """
 1408|         C1 = make_class(
 1409|             "C1", {"a": attr.ib(default=42), "b": attr.ib(default=None)}
 1410|         )
 1411| 
 1412|         @attr.s
 1413|         class C2:
 1414|             a = attr.ib(default=42)
 1415|             b = attr.ib(default=None)
 1416| 
 1417|         assert C1.__attrs_attrs__ == C2.__attrs_attrs__
 1418| 
 1419|     def test_attr_args(self):
 1420|         """
 1421|         attributes_arguments are passed to attributes
 1422|         """
 1423|         C = make_class("C", ["x"], repr=False)
 1424| 
 1425|         assert repr(C(1)).startswith("<tests.test_make.C object at 0x")
 1426| 
 1427|     def test_normalized_unicode_attr_args(self):
 1428|         """
 1429|         Unicode identifiers are valid in Python.
 1430|         """
 1431|         clsname = "ü"
 1432| 
 1433|         assert clsname == unicodedata.normalize("NFKC", clsname)
 1434| 
 1435|         attrname = "ß"
 1436| 
 1437|         assert attrname == unicodedata.normalize("NFKC", attrname)
 1438| 
 1439|         C = make_class(clsname, [attrname], repr=False)
 1440| 
 1441|         assert repr(C(1)).startswith("<tests.test_make.ü object at 0x")
 1442| 
 1443|         kwargs = {"ß": 1}
 1444|         c = C(**kwargs)
 1445| 
 1446|         assert 1 == c.ß
 1447| 
 1448|     def test_unnormalized_unicode_attr_args(self):
 1449|         """
 1450|         Unicode identifiers are normalized to NFKC form in Python.
 1451|         """
 1452| 
 1453|         clsname = "Ŀ"
 1454| 
 1455|         assert clsname != unicodedata.normalize("NFKC", clsname)
 1456| 
 1457|         attrname = "ㅁ"
 1458| 
 1459|         assert attrname != unicodedata.normalize("NFKC", attrname)
 1460| 
 1461|         C = make_class(clsname, [attrname], repr=False)
 1462|         assert repr(C(1)).startswith("<tests.test_make.L· object at 0x")
 1463| 
 1464|         kwargs = {unicodedata.normalize("NFKC", attrname): 1}
 1465|         c = C(**kwargs)
 1466| 
 1467|         assert 1 == c.ㅁ
 1468| 
 1469|     def test_catches_wrong_attrs_type(self):
 1470|         """
 1471|         Raise `TypeError` if an invalid type for attrs is passed.
 1472|         """
 1473|         with pytest.raises(TypeError) as e:
 1474|             make_class("C", object())
 1475| 
 1476|         assert ("attrs argument must be a dict or a list.",) == e.value.args
 1477| 
 1478|     def test_bases(self):
 1479|         """
 1480|         Parameter bases default to (object,) and subclasses correctly
 1481|         """
 1482| 
 1483|         class D:
 1484|             pass
 1485| 
 1486|         cls = make_class("C", {})
 1487| 
 1488|         assert cls.__mro__[-1] is object
 1489| 
 1490|         cls = make_class("C", {}, bases=(D,))
 1491| 
 1492|         assert D in cls.__mro__
 1493|         assert isinstance(cls(), D)
 1494| 
 1495|     def test_additional_class_body(self):
