 2134|     @pytest.mark.parametrize(
 2135|         "meth_name",
 2136|         [
 2137|             "__init__",
 2138|             "__hash__",
 2139|             "__repr__",
 2140|             "__str__",
 2141|             "__eq__",
 2142|             "__lt__",
 2143|             "__le__",
 2144|             "__gt__",
 2145|             "__ge__",
 2146|         ],
 2147|     )
 2148|     def test_attaches_meta_dunders(self, meth_name):
 2149|         """
 2150|         Generated methods have correct __module__, __name__, and __qualname__
 2151|         attributes.
 2152|         """
 2153| 
 2154|         @attr.s(unsafe_hash=True, str=True)
 2155|         class C:
 2156|             def organic(self):
 2157|                 pass
 2158| 
 2159|         @attr.s(unsafe_hash=True, str=True)
 2160|         class D:
 2161|             pass
 2162| 
 2163|         meth_C = getattr(C, meth_name)
 2164|         meth_D = getattr(D, meth_name)
 2165| 
 2166|         assert meth_name == meth_C.__name__ == meth_D.__name__
 2167|         assert C.organic.__module__ == meth_C.__module__ == meth_D.__module__
 2168|         # This is assertion that would fail if a single __ne__ instance
 2169|         # was reused across multiple _make_eq calls.
 2170|         organic_prefix = C.organic.__qualname__.rsplit(".", 1)[0]
 2171|         assert organic_prefix + "." + meth_name == meth_C.__qualname__
 2172| 
 2173|     def test_handles_missing_meta_on_class(
 2174|         self, monkeypatch: pytest.MonkeyPatch
 2175|     ):
 2176|         """
 2177|         If the class hasn't a __module__ or __qualname__, the method hasn't
 2178|         either.
 2179|         """
 2180| 
 2181|         class C:
 2182|             pass
 2183| 
 2184|         orig_hasattr = __builtins__["hasattr"]
 2185| 
 2186|         def our_hasattr(obj, name, /) -> bool:
 2187|             if name in ("__module__", "__qualname__"):
 2188|                 return False
 2189|             return orig_hasattr(obj, name)
 2190| 
 2191|         monkeypatch.setitem(
 2192|             _ClassBuilder.__init__.__globals__["__builtins__"],
 2193|             "hasattr",
 2194|             our_hasattr,
 2195|         )
 2196| 
 2197|         b = _ClassBuilder(
 2198|             C,
 2199|             these=None,
 2200|             auto_attribs=False,
 2201|             props=ClassProps(
 2202|                 is_exception=False,
 2203|                 is_slotted=False,
 2204|                 is_frozen=False,
 2205|                 added_init=True,
 2206|                 added_repr=True,
 2207|                 added_eq=True,
 2208|                 added_ordering=False,
 2209|                 hashability=ClassProps.Hashability.UNHASHABLE,
 2210|                 added_match_args=True,
 2211|                 kw_only=ClassProps.KeywordOnly.NO,
 2212|                 has_weakref_slot=True,
 2213|                 collected_fields_by_mro=True,
 2214|                 added_str=False,
 2215|                 added_pickling=True,
 2216|                 on_setattr_hook=None,
 2217|                 field_transformer=None,
 2218|             ),
 2219|             has_custom_setattr=False,
 2220|         )
 2221| 
 2222|         def fake_meth(self):
 2223|             pass
 2224| 
 2225|         fake_meth.__module__ = "42"
 2226|         fake_meth.__qualname__ = "23"
 2227| 
 2228|         b._cls = {}  # No module and qualname
 2229| 
 2230|         rv = b._add_method_dunders(fake_meth)
 2231| 
 2232|         assert "42" == rv.__module__ == fake_meth.__module__
 2233|         assert "23" == rv.__qualname__ == fake_meth.__qualname__
 2234| 
 2235|     def test_weakref_setstate(self):
 2236|         """
 2237|         __weakref__ is not set on in setstate because it's not writable in
 2238|         slotted classes.
 2239|         """
 2240| 
 2241|         @attr.s(slots=True)
 2242|         class C:
 2243|             __weakref__ = attr.ib(
 2244|                 init=False, hash=False, repr=False, eq=False, order=False
 2245|             )
 2246| 
 2247|         assert C() == copy.deepcopy(C())
 2248| 
 2249|     def test_no_references_to_original(self):
 2250|         """
 2251|         When subclassing a slotted class, there are no stray references to the
 2252|         original class.
 2253|         """
 2254| 
 2255|         @attr.s(slots=True)
 2256|         class C:
 2257|             pass
 2258| 
 2259|         @attr.s(slots=True)
 2260|         class C2(C):
 2261|             pass
 2262| 
 2263|         # The original C2 is in a reference cycle, so force a collect:
 2264|         gc.collect()
 2265| 
 2266|         assert [C2] == C.__subclasses__()
 2267| 
 2268|     def test_no_references_to_original_when_using_cached_property(self):
 2269|         """
 2270|         When subclassing a slotted class and using cached property, there are
 2271|         no stray references to the original class.
 2272|         """
 2273| 
 2274|         @attr.s(slots=True)
 2275|         class C:
 2276|             pass
 2277| 
 2278|         @attr.s(slots=True)
 2279|         class C2(C):
 2280|             @functools.cached_property
 2281|             def value(self) -> int:
 2282|                 return 0
 2283| 
 2284|         # The original C2 is in a reference cycle, so force a collect:
 2285|         gc.collect()
 2286| 
 2287|         assert [C2] == C.__subclasses__()
 2288| 
 2289|     def _get_copy_kwargs(include_slots=True):
 2290|         """
 2291|         Generate a list of compatible attr.s arguments for the `copy` tests.
 2292|         """
 2293|         options = ["frozen", "unsafe_hash", "cache_hash"]
 2294| 
 2295|         if include_slots:
 2296|             options.extend(["slots", "weakref_slot"])
 2297| 
 2298|         out_kwargs = []
 2299|         for args in itertools.product([True, False], repeat=len(options)):
 2300|             kwargs = dict(zip(options, args))
 2301| 
 2302|             kwargs["unsafe_hash"] = kwargs["unsafe_hash"] or None
 2303| 
 2304|             if kwargs["cache_hash"] and not (
 2305|                 kwargs["frozen"] or kwargs["unsafe_hash"]
 2306|             ):
 2307|                 continue
 2308| 
 2309|             out_kwargs.append(kwargs)
 2310| 
 2311|         return out_kwargs
 2312| 
 2313|     @pytest.mark.parametrize("kwargs", _get_copy_kwargs())
 2314|     def test_copy(self, kwargs):
 2315|         """
 2316|         Ensure that an attrs class can be copied successfully.
 2317|         """
 2318| 
 2319|         @attr.s(eq=True, **kwargs)
 2320|         class C:
 2321|             x = attr.ib()
 2322| 
 2323|         a = C(1)
 2324|         b = copy.deepcopy(a)
 2325| 
 2326|         assert a == b
 2327| 
 2328|     @pytest.mark.parametrize("kwargs", _get_copy_kwargs(include_slots=False))
 2329|     def test_copy_custom_setstate(self, kwargs):
 2330|         """
 2331|         Ensure that non-slots classes respect a custom __setstate__.
 2332|         """
 2333| 
 2334|         @attr.s(eq=True, **kwargs)
 2335|         class C:
 2336|             x = attr.ib()
 2337| 
 2338|             def __getstate__(self):
 2339|                 return self.__dict__
 2340| 
 2341|             def __setstate__(self, state):
 2342|                 state["x"] *= 5
 2343|                 self.__dict__.update(state)
 2344| 
 2345|         expected = C(25)
 2346|         actual = copy.copy(C(5))
 2347| 
 2348|         assert actual == expected
 2349| 
 2350| 
 2351| class TestInitAlias:
 2352|     """
 2353|     Tests for Attribute alias handling.
 2354|     """
 2355| 
 2356|     def test_default_and_specify(self):
 2357|         """
 2358|         alias is present on the Attributes returned from attr.fields.
 2359| 
 2360|         If left unspecified, it defaults to standard private-attribute
 2361|         handling.  If specified, it passes through the explicit alias.
 2362|         """
 2363| 
 2364|         # alias is None by default on _CountingAttr
 2365|         default_counting = attr.ib()
 2366|         assert default_counting.alias is None
 2367| 
 2368|         override_counting = attr.ib(alias="specified")
 2369|         assert override_counting.alias == "specified"
 2370| 
 2371|         @attr.s
 2372|         class Cases:
 2373|             public_default = attr.ib()
 2374|             _private_default = attr.ib()
 2375|             __dunder_default__ = attr.ib()
 2376| 
 2377|             public_override = attr.ib(alias="public")
 2378|             _private_override = attr.ib(alias="_private")
 2379|             __dunder_override__ = attr.ib(alias="__dunder__")
 2380| 
 2381|         cases = attr.fields_dict(Cases)
 2382| 
 2383|         # Default applies private-name mangling logic
 2384|         assert cases["public_default"].name == "public_default"
 2385|         assert cases["public_default"].alias == "public_default"
 2386| 
 2387|         assert cases["_private_default"].name == "_private_default"
 2388|         assert cases["_private_default"].alias == "private_default"
 2389| 
 2390|         assert cases["__dunder_default__"].name == "__dunder_default__"
 2391|         assert cases["__dunder_default__"].alias == "dunder_default__"
 2392| 
 2393|         # Override is passed through
 2394|         assert cases["public_override"].name == "public_override"
 2395|         assert cases["public_override"].alias == "public"
 2396| 
 2397|         assert cases["_private_override"].name == "_private_override"
 2398|         assert cases["_private_override"].alias == "_private"
 2399| 
 2400|         assert cases["__dunder_override__"].name == "__dunder_override__"
 2401|         assert cases["__dunder_override__"].alias == "__dunder__"
 2402| 
 2403|         # And aliases are applied to the __init__ signature
 2404|         example = Cases(
 2405|             public_default=1,
 2406|             private_default=2,
 2407|             dunder_default__=3,
 2408|             public=4,
 2409|             _private=5,
 2410|             __dunder__=6,
 2411|         )
 2412| 
 2413|         assert example.public_default == 1
 2414|         assert example._private_default == 2
 2415|         assert example.__dunder_default__ == 3
 2416|         assert example.public_override == 4
 2417|         assert example._private_override == 5
 2418|         assert example.__dunder_override__ == 6
 2419| 
 2420|     def test_evolve(self):
 2421|         """
 2422|         attr.evolve uses Attribute.alias to determine parameter names.
 2423|         """
 2424| 
 2425|         @attr.s
 2426|         class EvolveCase:
 2427|             _override = attr.ib(alias="_override")
 2428|             __mangled = attr.ib()
 2429|             __dunder__ = attr.ib()
 2430| 
 2431|         org = EvolveCase(1, 2, 3)
 2432| 
 2433|         # Previous behavior of evolve as broken for double-underscore
 2434|         # passthrough, and would raise here due to mis-mapping the __dunder__
 2435|         # alias
 2436|         assert attr.evolve(org) == org
 2437| 
 2438|         # evolve uses the alias to match __init__ signature
 2439|         assert attr.evolve(
 2440|             org,
 2441|             _override=0,
 2442|         ) == EvolveCase(0, 2, 3)
 2443| 
 2444|         # and properly passes through dunders and mangles
 2445|         assert attr.evolve(
 2446|             org,
 2447|             EvolveCase__mangled=4,
 2448|             dunder__=5,
 2449|         ) == EvolveCase(1, 4, 5)
 2450| 
 2451|     def test_alias_is_default(self):
 2452|         """
 2453|         alias_is_default is True for auto-generated aliases and False for
 2454|         explicitly provided ones -- even if the explicit value matches the
 2455|         auto-generated default.
 2456|         """
 2457| 
 2458|         @attrs.define
 2459|         class C:
 2460|             auto: int
 2461|             _private_auto: int
 2462|             explicit: int = attrs.field(alias="custom")
 2463|             _matches_default: int = attrs.field(alias="matches_default")
 2464| 
 2465|         fields = attr.fields_dict(C)
 2466| 
 2467|         assert fields["auto"].alias_is_default is True
 2468|         assert fields["_private_auto"].alias_is_default is True
 2469|         assert fields["explicit"].alias_is_default is False
 2470|         assert fields["_matches_default"].alias_is_default is False
 2471| 
 2472|     def test_alias_is_default_pickle_roundtrip(self):
 2473|         """
 2474|         alias_is_default survives pickle round-tripping.
 2475|         """
 2476| 
 2477|         @attrs.define
 2478|         class C:
 2479|             auto: int
 2480|             explicit: int = attrs.field(alias="custom")
 2481| 
 2482|         fields = attr.fields(C)
 2483| 
 2484|         for a in fields:
 2485|             restored = pickle.loads(pickle.dumps(a))
 2486| 
 2487|             assert a.alias == restored.alias
 2488|             assert a.alias_is_default == restored.alias_is_default
 2489| 
 2490|     X = (
 2491|         b"\x80\x05\x95_\x00\x00\x00\x00\x00\x00\x00\x8c\nattr._make\x94\x8c\tAttrib"
 2492|         b"ute\x94\x93\x94)\x81\x94(\x8c\x01x\x94h\x00\x8c\x08_Nothing\x94\x93"
 2493|         b"\x94K\x01\x85\x94R\x94N\x88\x88N\x88NN\x88}\x94\x8c\x08builtins\x94"
 2494|         b"\x8c\x03int\x94\x93\x94N\x89\x89Nh\x04t\x94b."
 2495|     )
 2496|     Y = (
 2497|         b"\x80\x05\x95b\x00\x00\x00\x00\x00\x00\x00\x8c\nattr._make\x94\x8c\tAttrib"
 2498|         b"ute\x94\x93\x94)\x81\x94(\x8c\x02_y\x94h\x00\x8c\x08_Nothing\x94"
 2499|         b"\x93\x94K\x01\x85\x94R\x94N\x88\x88N\x88NN\x88}\x94\x8c\x08builtins"
 2500|         b"\x94\x8c\x03int\x94\x93\x94N\x89\x89N\x8c\x01y\x94t\x94b."
 2501|     )
 2502|     Z = (
 2503|         b"\x80\x05\x95c\x00\x00\x00\x00\x00\x00\x00\x8c\nattr._make\x94\x8c\tAttrib"
 2504|         b"ute\x94\x93\x94)\x81\x94(\x8c\x01z\x94h\x00\x8c\x08_Nothing\x94\x93"
 2505|         b"\x94K\x01\x85\x94R\x94N\x88\x88N\x88NN\x88}\x94\x8c\x08builtins\x94"
 2506|         b"\x8c\x03int\x94\x93\x94N\x89\x89N\x8c\x03_z_\x94t\x94b."
 2507|     )
 2508| 
 2509|     @pytest.mark.parametrize(
 2510|         ("pickle_data", "name", "alias", "alias_is_default"),
 2511|         [
 2512|             (X, "x", "x", True),
 2513|             (Y, "_y", "y", True),
 2514|             (Z, "z", "_z_", False),
 2515|         ],
 2516|     )
 2517|     def test_can_unpickle_25_3_attributes(
 2518|         self, pickle_data, name, alias, alias_is_default
 2519|     ):
 2520|         """
 2521|         Can unpickle attributes created in 25.3.
 2522|         """
 2523| 
 2524|         assert Attribute(
 2525|             name=name,
 2526|             alias=alias,
 2527|             alias_is_default=alias_is_default,
 2528|             default=attrs.NOTHING,
 2529|             validator=None,
 2530|             repr=True,
 2531|             cmp=None,
 2532|             eq=True,
 2533|             eq_key=None,
 2534|             order=True,
 2535|             order_key=None,
 2536|             hash=None,
 2537|             init=True,
 2538|             metadata=types.MappingProxyType({}),
 2539|             type=int,
 2540|             converter=None,
 2541|             kw_only=False,
 2542|             inherited=False,
 2543|             on_setattr=None,
 2544|         ) == pickle.loads(pickle_data)
 2545| 
 2546| 
 2547| class TestMakeOrder:
 2548|     """
 2549|     Tests for _make_order().
 2550|     """
 2551| 
 2552|     def test_subclasses_cannot_be_compared(self):
 2553|         """
 2554|         Calling comparison methods on subclasses raises a TypeError.
 2555| 
 2556|         We use the actual operation so we get an error raised.
 2557|         """
 2558| 
 2559|         @attr.s
 2560|         class A:
 2561|             a = attr.ib()
 2562| 
 2563|         @attr.s
 2564|         class B(A):
 2565|             pass
 2566| 
 2567|         a = A(42)
 2568|         b = B(42)
 2569| 
 2570|         assert a <= a
 2571|         assert a >= a
 2572|         assert not a < a
 2573|         assert not a > a
 2574| 
 2575|         assert (
 2576|             NotImplemented
 2577|             == a.__lt__(b)
 2578|             == a.__le__(b)
 2579|             == a.__gt__(b)
 2580|             == a.__ge__(b)
 2581|         )
 2582| 
 2583|         with pytest.raises(TypeError):
 2584|             a <= b
 2585| 
 2586|         with pytest.raises(TypeError):
 2587|             a >= b
 2588| 
 2589|         with pytest.raises(TypeError):
 2590|             a < b
 2591| 
 2592|         with pytest.raises(TypeError):
 2593|             a > b
 2594| 
 2595| 
 2596| class TestDetermineAttrsEqOrder:
 2597|     def test_default(self):
 2598|         """
 2599|         If all are set to None, set both eq and order to the passed default.
 2600|         """
 2601|         assert (42, 42) == _determine_attrs_eq_order(None, None, None, 42)
 2602| 
 2603|     @pytest.mark.parametrize("eq", [True, False])
 2604|     def test_order_mirrors_eq_by_default(self, eq):
 2605|         """
 2606|         If order is None, it mirrors eq.
 2607|         """
 2608|         assert (eq, eq) == _determine_attrs_eq_order(None, eq, None, True)
 2609| 
 2610|     def test_order_without_eq(self):
 2611|         """
 2612|         eq=False, order=True raises a meaningful ValueError.
 2613|         """
 2614|         with pytest.raises(
 2615|             ValueError, match="`order` can only be True if `eq` is True too"
 2616|         ):
 2617|             _determine_attrs_eq_order(None, False, True, True)
 2618| 
 2619|     @given(cmp=booleans(), eq=optional_bool, order=optional_bool)
 2620|     def test_mix(self, cmp, eq, order):
 2621|         """
 2622|         If cmp is not None, eq and order must be None and vice versa.
 2623|         """
 2624|         assume(eq is not None or order is not None)
 2625| 
 2626|         with pytest.raises(
 2627|             ValueError, match="Don't mix `cmp` with `eq' and `order`"
 2628|         ):
 2629|             _determine_attrs_eq_order(cmp, eq, order, True)
 2630| 
