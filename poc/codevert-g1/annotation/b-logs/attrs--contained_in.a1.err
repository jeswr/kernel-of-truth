  849|     @pytest.mark.usefixtures("with_and_without_validation")
  850|     def test_pre_init_with_mixture_of_defaults_and_kw_only(self):
  851|         """
  852|         Attrs should properly handle a mixture of positional, positional with
  853|         default, keyword-only, and keyword-only with default attributes when
  854|         passing values to __attrs_pre_init__.
  855|         """
  856|         g_val1 = None
  857|         g_val2 = None
  858|         g_val3 = None
  859|         g_val4 = None
  860|         g_val5 = None
  861|         g_val6 = None
  862| 
  863|         @attr.define
  864|         class MixtureClass:
  865|             val1: int
  866|             val2: int = 100
  867|             val3: int = attr.field(factory=int)
  868|             val4: int = attr.field(kw_only=True)
  869|             val5: int = attr.field(default=100, kw_only=True)
  870|             val6: int = attr.field(factory=int, kw_only=True)
  871| 
  872|             def __attrs_pre_init__(self, val1, val2, val3, val4, val5, val6):
  873|                 nonlocal g_val1, g_val2, g_val3, g_val4, g_val5, g_val6
  874|                 g_val1 = val1
  875|                 g_val2 = val2
  876|                 g_val3 = val3
  877|                 g_val4 = val4
  878|                 g_val5 = val5
  879|                 g_val6 = val6
  880| 
  881|         inst = MixtureClass(
  882|             val1=200, val2=200, val3=200, val4=200, val5=200, val6=200
  883|         )
  884| 
  885|         assert 200 == g_val1 == inst.val1
  886|         assert 200 == g_val2 == inst.val2
  887|         assert 200 == g_val3 == inst.val3
  888|         assert 200 == g_val4 == inst.val4
  889|         assert 200 == g_val5 == inst.val5
  890|         assert 200 == g_val6 == inst.val6
  891| 
