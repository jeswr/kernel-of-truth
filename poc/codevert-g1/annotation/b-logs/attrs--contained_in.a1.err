 1601|         ):
 1602|             fields(object())
 1603| 
 1604|     def test_handler_non_attrs_class(self):
 1605|         """
 1606|         Raises `ValueError` if passed a non-*attrs* instance.
 1607|         """
 1608|         with pytest.raises(NotAnAttrsClassError) as e:
 1609|             fields(object)
 1610| 
 1611|         assert (
 1612|             f"{object!r} is not an attrs-decorated class."
 1613|         ) == e.value.args[0]
 1614| 
 1615|     def test_handler_non_attrs_generic_class(self):
 1616|         """
 1617|         Raises `ValueError` if passed a non-*attrs* generic class.
 1618|         """
 1619|         T = TypeVar("T")
 1620| 
 1621|         class B(Generic[T]):
 1622|             pass
 1623| 
 1624|         with pytest.raises(NotAnAttrsClassError) as e:
 1625|             fields(B[str])
 1626| 
 1627|         assert (
 1628|             f"{B[str]!r} is not an attrs-decorated class."
 1629|         ) == e.value.args[0]
 1630| 
