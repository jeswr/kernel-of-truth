  288|     def test_kw_only(self):
  289|         """
  290|         Converts all attributes in the current class if `kw_only` is provided.
  291|         Base class attributes are **not** affected.
  292|         """
  293| 
  294|         @attr.s
  295|         class B:
  296|             b = attr.ib()
