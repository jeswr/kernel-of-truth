 2950|     def test_override_eq(self, slots, frozen):
 2951|         """
 2952|         If eq=True is passed, ignore __eq__ and __ne__.
 2953|         """
 2954| 
 2955|         @attr.s(eq=True, auto_detect=True, slots=slots, frozen=frozen)
 2956|         class C:
 2957|             x = attr.ib()
 2958| 
 2959|             def __eq__(self, o):
 2960|                 pytest.fail("should not be called")
 2961| 
 2962|             def __ne__(self, o):
 2963|                 pytest.fail("should not be called")
