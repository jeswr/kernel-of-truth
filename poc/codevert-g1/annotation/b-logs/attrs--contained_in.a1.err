 2002|     @given(lists(simple_attrs_without_metadata, min_size=2, max_size=5))
 2003|     def test_empty_countingattr_metadata_independent(self, list_of_attrs):
 2004|         """
 2005|         All empty metadata attributes are independent before ``@attr.s``.
 2006|         """
