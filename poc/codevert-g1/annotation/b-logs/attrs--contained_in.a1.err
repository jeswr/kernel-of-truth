 1526|     def test_make_class_ordered(self):
 1527|         """
 1528|         If `make_class()` is passed ordered attrs, their order is respected
 1529|         instead of the counter.
 1530|         """
 1531|         b = attr.ib(default=2)
 1532|         a = attr.ib(default=1)
 1533| 
 1534|         C = attr.make_class("C", {"a": a, "b": b})
 1535| 
 1536|         assert "C(a=1, b=2)" == repr(C())
