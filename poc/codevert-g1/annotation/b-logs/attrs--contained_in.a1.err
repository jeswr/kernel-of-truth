 2966| 
 2967|     @pytest.mark.parametrize(
 2968|         ("eq", "order", "cmp"),
 2969|         [
 2970|             (True, None, None),
 2971|             (True, True, None),
 2972|             (None, True, None),
 2973|             (None, None, True),
 2974|         ],
 2975|     )
 2976|     def test_override_order(self, slots, frozen, eq, order, cmp):
 2977|         """
 2978|         If order=True is passed, ignore __le__, __lt__, __gt__, __ge__.
 2979| 
 2980|         eq=True and cmp=True both imply order=True so test it too.
 2981|         """
 2982| 
 2983|         def meth(self, o):
 2984|             pytest.fail("should not be called")
 2985| 
 2986|         @attr.s(
 2987|             cmp=cmp,
 2988|             order=order,
 2989|             eq=eq,
 2990|             auto_detect=True,
 2991|             slots=slots,
 2992|             frozen=frozen,
 2993|         )
 2994|         class C:
 2995|             x = attr.ib()
 2996|             __le__ = __lt__ = __gt__ = __ge__ = meth
 2997| 
 2998|         assert C(1) < C(2)
 2999|         assert C(1) <= C(2)
 3000|         assert C(2) > C(1)
 3001|         assert C(2) >= C(1)
 3002| 
 3003|     @pytest.mark.parametrize("first", [True, False])
 3004|     def test_total_ordering(self, slots, first):
 3005|         """
 3006|         functools.total_ordering works as expected if an order method and an eq
 3007|         method are detected.
 3008| 
 3009|         Ensure the order doesn't matter.
 3010|         """
 3011| 
 3012|         class C:
 3013|             x = attr.ib()
 3014|             own_eq_called = attr.ib(default=False)
 3015|             own_le_called = attr.ib(default=False)
 3016| 
 3017|             def __eq__(self, o):
 3018|                 self.own_eq_called = True
 3019|                 return self.x == o.x
 3020| 
 3021|             def __le__(self, o):
 3022|                 self.own_le_called = True
 3023|                 return self.x <= o.x
 3024| 
 3025|         if first:
 3026|             C = functools.total_ordering(
 3027|                 attr.s(auto_detect=True, slots=slots)(C)
 3028|             )
 3029|         else:
 3030|             C = attr.s(auto_detect=True, slots=slots)(
 3031|                 functools.total_ordering(C)
 3032|             )
 3033| 
 3034|         c1, c2 = C(1), C(2)
 3035| 
 3036|         assert c1 < c2
 3037|         assert c1.own_le_called
 3038| 
 3039|         c1, c2 = C(1), C(2)
 3040| 
 3041|         assert c2 > c1
 3042|         assert c2.own_le_called
 3043| 
 3044|         c1, c2 = C(1), C(2)
 3045| 
 3046|         assert c2 != c1
 3047|         assert c1 == c1
 3048| 
 3049|         assert c1.own_eq_called
 3050| 
 3051|     def test_detects_setstate_getstate(self, slots):
 3052|         """
 3053|         __getstate__ and __setstate__ are not overwritten if either is present.
 3054|         """
 3055| 
 3056|         @attr.s(slots=slots, auto_detect=True)
 3057|         class C:
 3058|             def __getstate__(self):
 3059|                 return ("hi",)
 3060| 
 3061|         assert getattr(object, "__setstate__", None) is getattr(
 3062|             C, "__setstate__", None
 3063|         )
 3064| 
 3065|         @attr.s(slots=slots, auto_detect=True)
 3066|         class C:
 3067|             called = attr.ib(False)
 3068| 
 3069|             def __setstate__(self, state):
 3070|                 self.called = True
 3071| 
 3072|         i = C()
 3073| 
 3074|         assert False is i.called
 3075| 
 3076|         i.__setstate__(())
 3077| 
 3078|         assert True is i.called
