 1968|     @given(simple_classes(), text())
 1969|     def test_metadata_immutability(self, C, string):
 1970|         """
 1971|         The metadata dict should be best-effort immutable.
 1972|         """
 1973|         for a in fields(C):
 1974|             with pytest.raises(TypeError):
 1975|                 a.metadata[string] = string
 1976|             with pytest.raises(AttributeError):
 1977|                 a.metadata.update({string: string})
 1978|             with pytest.raises(AttributeError):
 1979|                 a.metadata.clear()
 1980|             with pytest.raises(AttributeError):
 1981|                 a.metadata.setdefault(string, string)
 1982| 
 1983|             for k in a.metadata:
 1984|                 # For some reason, MappingProxyType throws an IndexError for
 1985|                 # deletes on a large integer key.
 1986|                 with pytest.raises((TypeError, IndexError)):
 1987|                     del a.metadata[k]
 1988|                 with pytest.raises(AttributeError):
 1989|                     a.metadata.pop(k)
 1990|             with pytest.raises(AttributeError):
 1991|                 a.metadata.popitem()
 1992| 
