 1644|             assert getattr(fields(C), attribute.name) is attribute
 1645| 
 1646|     def test_generics(self):
 1647|         """
 1648|         Fields work with generic classes.
 1649|         """
 1650|         T = TypeVar("T")
 1651| 
 1652|         @attr.define
 1653|         class A(Generic[T]):
 1654|             a: T
 1655| 
 1656|         assert len(fields(A)) == 1
 1657|         assert fields(A).a.name == "a"
 1658|         assert fields(A).a.default is attr.NOTHING
 1659| 
 1660|         assert len(fields(A[str])) == 1
 1661|         assert fields(A[str]).a.name == "a"
 1662|         assert fields(A[str]).a.default is attr.NOTHING
