 1928|         C1 = make_class("C", {"x": attr.ib(validator=[])})
 1929|         C2 = make_class("C", {"x": attr.ib(validator=None)})
 1930| 
 1931|         assert inspect.getsource(C1.__init__) == inspect.getsource(C2.__init__)
