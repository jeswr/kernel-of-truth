  958|     def test_factory_sugar(self):
  959|         """
  960|         Passing factory=f is syntactic sugar for passing default=Factory(f).
  961|         """
  962| 
  963|         @attr.s
  964|         class C:
  965|             x = attr.ib(factory=list)
  966| 
  967|         assert Factory(list) == attr.fields(C).x.default
  968| 
  969|     def test_sugar_factory_mutex(self):
  970|         """
  971|         Passing both default and factory raises ValueError.
  972|         """
  973|         with pytest.raises(ValueError, match="mutually exclusive"):
  974| 
  975|             @attr.s
  976|             class C:
  977|                 x = attr.ib(factory=list, default=Factory(list))
  978| 
  979|     def test_sugar_callable(self):
  980|         """
  981|         Factory has to be a callable to prevent people from passing Factory
  982|         into it.
  983|         """
  984|         with pytest.raises(ValueError, match="must be a callable"):
  985| 
  986|             @attr.s
  987|             class C:
  988|                 x = attr.ib(factory=Factory(list))
  989| 
  990|     def test_inherited_does_not_affect_hashing_and_equality(self):
  991|         """
  992|         Whether or not an Attribute has been inherited doesn't affect how it's
  993|         hashed and compared.
  994|         """
  995| 
  996|         @attr.s
  997|         class BaseClass:
  998|             x = attr.ib()
  999| 
 1000|         @attr.s
 1001|         class SubClass(BaseClass):
 1002|             pass
 1003| 
 1004|         ba = attr.fields(BaseClass)[0]
 1005|         sa = attr.fields(SubClass)[0]
 1006| 
 1007|         assert ba == sa
 1008|         assert hash(ba) == hash(sa)
 1009| 
 1010| 
 1011| class TestKeywordOnlyAttributes:
 1012|     """
 1013|     Tests for keyword-only attributes.
 1014|     """
 1015| 
 1016|     def test_adds_keyword_only_arguments(self):
 1017|         """
 1018|         Attributes can be added as keyword-only.
 1019|         """
 1020| 
 1021|         @attr.s
 1022|         class C:
 1023|             a = attr.ib()
 1024|             b = attr.ib(default=2, kw_only=True)
 1025|             c = attr.ib(kw_only=True)
 1026|             d = attr.ib(default=attr.Factory(lambda: 4), kw_only=True)
 1027| 
 1028|         c = C(1, c=3)
 1029| 
 1030|         assert c.a == 1
 1031|         assert c.b == 2
 1032|         assert c.c == 3
 1033|         assert c.d == 4
 1034| 
 1035|     def test_ignores_kw_only_when_init_is_false(self):
 1036|         """
 1037|         Specifying ``kw_only=True`` when ``init=False`` is essentially a no-op.
 1038|         """
 1039| 
 1040|         @attr.s
 1041|         class C:
 1042|             x = attr.ib(init=False, default=0, kw_only=True)
 1043|             y = attr.ib()
 1044| 
 1045|         c = C(1)
 1046| 
 1047|         assert c.x == 0
 1048|         assert c.y == 1
 1049| 
 1050|     def test_keyword_only_attributes_presence(self):
 1051|         """
 1052|         Raises `TypeError` when keyword-only arguments are
 1053|         not specified.
 1054|         """
 1055| 
 1056|         @attr.s
 1057|         class C:
 1058|             x = attr.ib(kw_only=True)
 1059| 
 1060|         with pytest.raises(TypeError) as e:
 1061|             C()
 1062| 
 1063|         assert (
 1064|             "missing 1 required keyword-only argument: 'x'"
 1065|         ) in e.value.args[0]
 1066| 
 1067|     def test_keyword_only_attributes_unexpected(self):
 1068|         """
 1069|         Raises `TypeError` when unexpected keyword argument passed.
 1070|         """
 1071| 
 1072|         @attr.s
 1073|         class C:
 1074|             x = attr.ib(kw_only=True)
 1075| 
 1076|         with pytest.raises(TypeError) as e:
 1077|             C(x=5, y=10)
 1078| 
 1079|         assert "got an unexpected keyword argument 'y'" in e.value.args[0]
 1080| 
 1081|     def test_keyword_only_attributes_can_come_in_any_order(self):
 1082|         """
 1083|         Mandatory vs non-mandatory attr order only matters when they are part
 1084|         of the __init__ signature and when they aren't kw_only (which are
 1085|         moved to the end and can be mandatory or non-mandatory in any order,
 1086|         as they will be specified as keyword args anyway).
 1087|         """
 1088| 
 1089|         @attr.s
 1090|         class C:
 1091|             a = attr.ib(kw_only=True)
 1092|             b = attr.ib(kw_only=True, default="b")
 1093|             c = attr.ib(kw_only=True)
 1094|             d = attr.ib()
 1095|             e = attr.ib(default="e")
 1096|             f = attr.ib(kw_only=True)
 1097|             g = attr.ib(kw_only=True, default="g")
 1098|             h = attr.ib(kw_only=True)
 1099|             i = attr.ib(init=False)
 1100| 
 1101|         c = C("d", a="a", c="c", f="f", h="h")
 1102| 
 1103|         assert c.a == "a"
 1104|         assert c.b == "b"
 1105|         assert c.c == "c"
 1106|         assert c.d == "d"
 1107|         assert c.e == "e"
 1108|         assert c.f == "f"
 1109|         assert c.g == "g"
 1110|         assert c.h == "h"
 1111| 
 1112|     def test_keyword_only_attributes_allow_subclassing(self):
 1113|         """
 1114|         Subclass can define keyword-only attributed without defaults,
 1115|         when the base class has attributes with defaults.
 1116|         """
 1117| 
 1118|         @attr.s
 1119|         class Base:
 1120|             x = attr.ib(default=0)
 1121| 
 1122|         @attr.s
 1123|         class C(Base):
 1124|             y = attr.ib(kw_only=True)
 1125| 
 1126|         c = C(y=1)
 1127| 
 1128|         assert c.x == 0
 1129|         assert c.y == 1
 1130| 
 1131|     def test_keyword_only_class_level(self):
 1132|         """
 1133|         `kw_only` can be provided at the attr.s level, converting all
 1134|         attributes to `kw_only.`
 1135|         """
 1136| 
 1137|         @attr.s(kw_only=True)
 1138|         class C:
 1139|             x = attr.ib()
 1140|             y = attr.ib(kw_only=True)
 1141| 
 1142|         with pytest.raises(TypeError):
 1143|             C(0, y=1)
 1144| 
 1145|         c = C(x=0, y=1)
 1146| 
 1147|         assert c.x == 0
 1148|         assert c.y == 1
 1149| 
 1150|     def test_keyword_only_class_level_subclassing(self):
 1151|         """
 1152|         When `force_kw_only=True`, subclass `kw_only` propagates to attrs
 1153|         inherited from the base, allowing non-default following default.
 1154|         """
 1155| 
 1156|         @attr.s
 1157|         class Base:
 1158|             x = attr.ib(default=0)
 1159| 
 1160|         @attr.s(kw_only=True)
 1161|         class C(Base):
 1162|             y = attr.ib()
 1163| 
 1164|         with pytest.raises(TypeError):
 1165|             C(1)
 1166|         with pytest.raises(TypeError):
 1167|             C(0, y=1)
 1168| 
 1169|         c = C(x=0, y=1)
 1170| 
 1171|         assert c.x == 0
 1172|         assert c.y == 1
 1173| 
 1174|         @attr.s(kw_only=True, force_kw_only=False)
 1175|         class C(Base):
 1176|             y = attr.ib()
 1177| 
 1178|         c = C(0, y=1)
 1179| 
 1180|         assert c.x == 0
 1181|         assert c.y == 1
 1182| 
 1183|     def test_init_false_attribute_after_keyword_attribute(self):
 1184|         """
 1185|         A positional attribute cannot follow a `kw_only` attribute,
 1186|         but an `init=False` attribute can because it won't appear
 1187|         in `__init__`
 1188|         """
 1189| 
 1190|         @attr.s
 1191|         class KwArgBeforeInitFalse:
 1192|             kwarg = attr.ib(kw_only=True)
 1193|             non_init_function_default = attr.ib(init=False)
 1194|             non_init_keyword_default = attr.ib(
 1195|                 init=False, default="default-by-keyword"
 1196|             )
 1197| 
 1198|             @non_init_function_default.default
 1199|             def _init_to_init(self):
 1200|                 return self.kwarg + "b"
 1201| 
 1202|         c = KwArgBeforeInitFalse(kwarg="a")
 1203| 
 1204|         assert c.kwarg == "a"
 1205|         assert c.non_init_function_default == "ab"
 1206|         assert c.non_init_keyword_default == "default-by-keyword"
 1207| 
 1208|     def test_init_false_attribute_after_keyword_attribute_with_inheritance(
 1209|         self,
 1210|     ):
 1211|         """
 1212|         A positional attribute cannot follow a `kw_only` attribute,
 1213|         but an `init=False` attribute can because it won't appear
 1214|         in `__init__`. This test checks that we allow this
 1215|         even when the `kw_only` attribute appears in a parent class
 1216|         """
 1217| 
 1218|         @attr.s
 1219|         class KwArgBeforeInitFalseParent:
 1220|             kwarg = attr.ib(kw_only=True)
 1221| 
 1222|         @attr.s
 1223|         class KwArgBeforeInitFalseChild(KwArgBeforeInitFalseParent):
 1224|             non_init_function_default = attr.ib(init=False)
 1225|             non_init_keyword_default = attr.ib(
 1226|                 init=False, default="default-by-keyword"
 1227|             )
 1228| 
 1229|             @non_init_function_default.default
 1230|             def _init_to_init(self):
 1231|                 return self.kwarg + "b"
 1232| 
 1233|         c = KwArgBeforeInitFalseChild(kwarg="a")
 1234| 
 1235|         assert c.kwarg == "a"
 1236|         assert c.non_init_function_default == "ab"
 1237|         assert c.non_init_keyword_default == "default-by-keyword"
 1238| 
 1239|     def test_attr_level_kw_only_and_class_level_kw_only(self):
 1240|         """
 1241|         If a field explicitly sets 'kw_only=False', it should not be made
 1242|         keyword-only even if the class sets 'kw_only=True'.
 1243|         """
 1244| 
 1245|         @attr.s(kw_only=True)
 1246|         class OldClassOldBehavior:
 1247|             yes = attr.ib()
 1248|             no = attr.ib(kw_only=False)
 1249| 
 1250|         @attr.s(kw_only=True, force_kw_only=False)
 1251|         class OldClassNewBehavior:
 1252|             yes = attr.ib()
 1253|             no = attr.ib(kw_only=False)
 1254| 
 1255|         @attr.define(kw_only=True, force_kw_only=True)
 1256|         class NewClassOldBehavior:
 1257|             yes = attr.field()
 1258|             no = attr.field(kw_only=False)
 1259| 
 1260|         @attr.define(kw_only=True)
 1261|         class NewClassNewBehavior:
 1262|             yes = attr.field()
 1263|             no = attr.field(kw_only=False)
 1264| 
 1265|         for cls in [OldClassNewBehavior, NewClassNewBehavior]:
 1266|             fs = fields_dict(cls)
 1267|             assert fs["yes"].kw_only is True
 1268|             assert fs["no"].kw_only is False
 1269| 
 1270|         for cls in [OldClassOldBehavior, NewClassOldBehavior]:
 1271|             fs = fields_dict(cls)
 1272| 
 1273|             assert fs["yes"].kw_only is True
 1274|             assert fs["no"].kw_only is True
 1275| 
 1276|     def test_kw_only_inheritance(self):
 1277|         """
 1278|         Comprehensive test about how `kw_only` works when there's multiple
 1279|         levels of inheritance with different `kw_only` settings.
 1280|         """
 1281| 
 1282|         @attr.define()
 1283|         class A:
 1284|             a = attr.field()
 1285|             a_t = attr.field(kw_only=True)
 1286|             a_f = attr.field(kw_only=False)
 1287| 
 1288|         @attr.define(kw_only=True)
 1289|         class B(A):
 1290|             b = attr.field()
 1291|             b_t = attr.field(kw_only=True)
 1292|             b_f = attr.field(kw_only=False)
 1293| 
 1294|         @attr.define(kw_only=False)
 1295|         class C(B):
 1296|             c = attr.field()
 1297|             c_t = attr.field(kw_only=True)
 1298|             c_f = attr.field(kw_only=False)
 1299| 
 1300|         fs = fields_dict(A)
 1301| 
 1302|         assert fs["a"].kw_only is False
 1303|         assert fs["a_t"].kw_only is True
 1304|         assert fs["a_f"].kw_only is False
 1305| 
 1306|         fs = fields_dict(B)
 1307| 
 1308|         assert fs["a"].kw_only is False
 1309|         assert fs["a_t"].kw_only is True
 1310|         assert fs["a_f"].kw_only is False
 1311|         assert fs["b"].kw_only is True
 1312|         assert fs["b_t"].kw_only is True
 1313|         assert fs["b_f"].kw_only is False
 1314| 
 1315|         fs = fields_dict(C)
 1316| 
 1317|         assert fs["a"].kw_only is False
 1318|         assert fs["a_t"].kw_only is True
 1319|         assert fs["a_f"].kw_only is False
 1320|         assert fs["b"].kw_only is True
 1321|         assert fs["b_t"].kw_only is True
 1322|         assert fs["b_f"].kw_only is False
 1323|         assert fs["c"].kw_only is False
 1324|         assert fs["c_t"].kw_only is True
 1325|         assert fs["c_f"].kw_only is False
 1326| 
 1327|     def test_kw_only_inheritance_force_kw_only(self):
 1328|         """
 1329|         Similar to above, but when `force_kw_only` (pre-25.3.0 behavior).
 1330|         """
 1331| 
 1332|         @attr.define(force_kw_only=True)
 1333|         class A:
 1334|             a = attr.field()
 1335|             a_t = attr.field(kw_only=True)
 1336|             a_f = attr.field(kw_only=False)
 1337| 
 1338|         @attr.define(kw_only=True, force_kw_only=True)
 1339|         class B(A):
 1340|             b = attr.field()
 1341|             b_t = attr.field(kw_only=True)
 1342|             b_f = attr.field(kw_only=False)
 1343| 
 1344|         @attr.define(kw_only=False, force_kw_only=True)
 1345|         class C(B):
 1346|             c = attr.field()
 1347|             c_t = attr.field(kw_only=True)
 1348|             c_f = attr.field(kw_only=False)
 1349| 
 1350|         fs = fields_dict(A)
 1351| 
 1352|         assert fs["a"].kw_only is False
 1353|         assert fs["a_t"].kw_only is True
 1354|         assert fs["a_f"].kw_only is False
 1355| 
 1356|         fs = fields_dict(B)
 1357| 
 1358|         assert fs["a"].kw_only is True
 1359|         assert fs["a_t"].kw_only is True
 1360|         assert fs["a_f"].kw_only is True
 1361|         assert fs["b"].kw_only is True
 1362|         assert fs["b_t"].kw_only is True
 1363|         assert fs["b_f"].kw_only is True
 1364| 
 1365|         fs = fields_dict(C)
 1366| 
 1367|         assert fs["a"].kw_only is False
 1368|         assert fs["a_t"].kw_only is True
 1369|         assert fs["a_f"].kw_only is False
 1370|         assert fs["b"].kw_only is True
 1371|         assert fs["b_t"].kw_only is True
 1372|         assert fs["b_f"].kw_only is True
 1373|         assert fs["c"].kw_only is False
 1374|         assert fs["c_t"].kw_only is True
 1375|         assert fs["c_f"].kw_only is False
 1376| 
