  491|             def xx(self):
  492|                 return 50
  493| 
  494|         @attr.s(collect_by_mro=True)
  495|         class D(B, C):
  496|             pass
  497| 
  498|         d = D()
  499| 
  500|         assert d.x == d.xx()
  501| 
  502|     def test_inherited(self):
  503|         """
  504|         Inherited Attributes have `.inherited` True, otherwise False.
  505|         """
  506| 
  507|         @attr.s
  508|         class A:
  509|             a = attr.ib()
  510| 
  511|         @attr.s
  512|         class B(A):
  513|             b = attr.ib()
  514| 
  515|         @attr.s
  516|         class C(B):
  517|             a = attr.ib()
  518|             c = attr.ib()
  519| 
  520|         f = attr.fields
  521| 
  522|         assert False is f(A).a.inherited
  523| 
  524|         assert True is f(B).a.inherited
  525|         assert False is f(B).b.inherited
  526| 
  527|         assert False is f(C).a.inherited
  528|         assert True is f(C).b.inherited
  529|         assert False is f(C).c.inherited
  530| 
  531| 
  532| class TestAttributes:
  533|     """
  534|     Tests for the `attrs`/`attr.s` class decorator.
  535|     """
  536| 
  537|     def test_sets_attrs(self):
  538|         """
  539|         Sets the `__attrs_attrs__` class attribute with a list of `Attribute`s.
  540|         """
  541| 
  542|         @attr.s
  543|         class C:
  544|             x = attr.ib()
  545| 
  546|         assert "x" == C.__attrs_attrs__[0].name
  547|         assert all(isinstance(a, Attribute) for a in C.__attrs_attrs__)
  548| 
  549|     def test_sets_attrs_props(self):
  550|         """
  551|         Sets the `__attrs_props__` class attribute with the effective decorator
  552|         properties.
  553|         """
  554| 
  555|         @attr.s(
  556|             slots=True,
  557|             frozen=True,
  558|             repr=True,
  559|             eq=True,
  560|             order=True,
  561|             unsafe_hash=True,
  562|             init=True,
  563|             match_args=False,
  564|             kw_only=True,
  565|             auto_attribs=True,
  566|             cache_hash=True,
  567|             str=True,
  568|         )
  569|         class C:
  570|             x: int = attr.ib()
  571| 
  572|         assert ClassProps(
  573|             is_exception=False,
  574|             is_slotted=True,
  575|             is_frozen=True,
  576|             added_init=True,
  577|             added_repr=True,
  578|             added_eq=True,
  579|             added_ordering=True,
  580|             hashability=ClassProps.Hashability.HASHABLE_CACHED,
  581|             added_match_args=False,
  582|             kw_only=ClassProps.KeywordOnly.FORCE,
  583|             has_weakref_slot=True,
  584|             collected_fields_by_mro=False,
  585|             added_str=True,
  586|             added_pickling=True,
  587|             on_setattr_hook=None,
  588|             field_transformer=None,
  589|         ) == attrs.inspect(C)
  590| 
  591|     def test_sets_attrs_props_defaults(self):
  592|         """
  593|         Default values are derived in `__attrs_props__` when not specified in
  594|         the decorator.
  595|         """
  596| 
  597|         @attr.s
  598|         class CDef:
  599|             x = attr.ib()
  600| 
  601|         assert ClassProps(
  602|             is_exception=False,
  603|             is_slotted=False,
  604|             is_frozen=False,
  605|             added_init=True,
  606|             added_repr=True,
  607|             added_eq=True,
  608|             added_ordering=True,
  609|             hashability=ClassProps.Hashability.UNHASHABLE,
  610|             added_match_args=True,
  611|             kw_only=ClassProps.KeywordOnly.NO,
  612|             has_weakref_slot=True,
  613|             collected_fields_by_mro=False,
  614|             added_str=False,
  615|             added_pickling=False,
  616|             on_setattr_hook=None,
  617|             field_transformer=None,
  618|         ) == attrs.inspect(CDef)
  619| 
  620|     def test_empty(self):
  621|         """
  622|         No attributes, no problems.
  623|         """
  624| 
  625|         @attr.s
  626|         class C3:
  627|             pass
  628| 
  629|         assert "C3()" == repr(C3())
  630|         assert C3() == C3()
  631| 
  632|     @given(attr=attrs_st, attr_name=sampled_from(Attribute.__slots__))
  633|     def test_immutable(self, attr, attr_name):
  634|         """
  635|         Attribute instances are immutable.
  636|         """
  637|         with pytest.raises(AttributeError):
  638|             setattr(attr, attr_name, 1)
  639| 
  640|     @pytest.mark.parametrize(
  641|         "method_name", ["__repr__", "__eq__", "__hash__", "__init__"]
  642|     )
  643|     def test_adds_all_by_default(self, method_name):
  644|         """
  645|         If no further arguments are supplied, all add_XXX functions except
  646|         add_hash are applied.  __hash__ is set to None.
  647|         """
  648|         # Set the method name to a sentinel and check whether it has been
  649|         # overwritten afterwards.
  650|         sentinel = object()
  651| 
  652|         class C:
  653|             x = attr.ib()
  654| 
  655|         setattr(C, method_name, sentinel)
  656| 
  657|         C = attr.s(C)
  658|         meth = getattr(C, method_name)
  659| 
  660|         assert sentinel != meth
  661|         if method_name == "__hash__":
  662|             assert meth is None
  663| 
  664|     @pytest.mark.parametrize(
  665|         ("arg_name", "method_name"),
  666|         [
  667|             ("repr", "__repr__"),
  668|             ("eq", "__eq__"),
  669|             ("order", "__le__"),
  670|             ("unsafe_hash", "__hash__"),
  671|             ("init", "__init__"),
  672|         ],
  673|     )
  674|     def test_respects_add_arguments(self, arg_name, method_name):
  675|         """
  676|         If a certain `XXX` is `False`, `__XXX__` is not added to the class.
  677|         """
  678|         # Set the method name to a sentinel and check whether it has been
  679|         # overwritten afterwards.
  680|         sentinel = object()
  681| 
  682|         am_args = {
  683|             "repr": True,
  684|             "eq": True,
  685|             "order": True,
  686|             "unsafe_hash": True,
  687|             "init": True,
  688|         }
  689|         am_args[arg_name] = False
  690|         if arg_name == "eq":
  691|             am_args["order"] = False
  692| 
  693|         class C:
  694|             x = attr.ib()
  695| 
  696|         setattr(C, method_name, sentinel)
  697| 
  698|         C = attr.s(**am_args)(C)
  699| 
  700|         assert sentinel == getattr(C, method_name)
  701| 
  702|     @pytest.mark.parametrize("init", [True, False])
  703|     def test_respects_init_attrs_init(self, init):
  704|         """
  705|         If init=False, adds __attrs_init__ to the class.
  706|         Otherwise, it does not.
  707|         """
  708| 
  709|         class C:
  710|             x = attr.ib()
  711| 
  712|         C = attr.s(init=init)(C)
  713|         assert hasattr(C, "__attrs_init__") != init
  714| 
  715|     @given(slots_outer=booleans(), slots_inner=booleans())
  716|     def test_repr_qualname(self, slots_outer, slots_inner):
  717|         """
  718|         The name in repr is the __qualname__.
  719|         """
  720| 
  721|         @attr.s(slots=slots_outer)
  722|         class C:
  723|             @attr.s(slots=slots_inner)
  724|             class D:
  725|                 pass
  726| 
  727|         assert "C.D()" == repr(C.D())
  728|         assert "GC.D()" == repr(GC.D())
  729| 
  730|     @given(slots_outer=booleans(), slots_inner=booleans())
  731|     def test_repr_fake_qualname(self, slots_outer, slots_inner):
  732|         """
  733|         Setting repr_ns overrides a potentially guessed namespace.
  734|         """
  735| 
  736|         with pytest.deprecated_call(match="The `repr_ns` argument"):
  737| 
  738|             @attr.s(slots=slots_outer)
  739|             class C:
  740|                 @attr.s(repr_ns="C", slots=slots_inner)
  741|                 class D:
  742|                     pass
  743| 
  744|         assert "C.D()" == repr(C.D())
  745| 
  746|     @given(slots_outer=booleans(), slots_inner=booleans())
  747|     def test_name_not_overridden(self, slots_outer, slots_inner):
  748|         """
  749|         __name__ is different from __qualname__.
  750|         """
  751| 
  752|         @attr.s(slots=slots_outer)
  753|         class C:
  754|             @attr.s(slots=slots_inner)
  755|             class D:
  756|                 pass
  757| 
  758|         assert C.D.__name__ == "D"
  759|         assert C.D.__qualname__ == C.__qualname__ + ".D"
  760| 
  761|     @pytest.mark.usefixtures("with_and_without_validation")
