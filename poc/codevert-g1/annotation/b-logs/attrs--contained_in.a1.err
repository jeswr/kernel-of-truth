 1703| class TestConverter:
 1704|     """
 1705|     Tests for attribute conversion.
 1706|     """
 1707| 
 1708|     def test_converter(self):
 1709|         """
 1710|         Return value of converter is used as the attribute's value.
 1711|         """
 1712|         C = make_class(
 1713|             "C", {"x": attr.ib(converter=lambda v: v + 1), "y": attr.ib()}
 1714|         )
 1715|         c = C(1, 2)
 1716| 
 1717|         assert c.x == 2
 1718|         assert c.y == 2
 1719| 
 1720|     def test_converter_wrapped_takes_self(self):
 1721|         """
 1722|         When wrapped and passed `takes_self`, the converter receives the
 1723|         instance that's being initializes -- and the return value is used as
 1724|         the field's value.
 1725|         """
 1726| 
 1727|         def converter_with_self(v, self_):
 1728|             return v * self_.y
 1729| 
 1730|         @attr.define
 1731|         class C:
 1732|             x: int = attr.field(
 1733|                 converter=attr.Converter(converter_with_self, takes_self=True)
 1734|             )
 1735|             y = 42
 1736| 
 1737|         assert 84 == C(2).x
 1738| 
 1739|     def test_converter_wrapped_takes_field(self):
 1740|         """
 1741|         When wrapped and passed `takes_field`, the converter receives the field
 1742|         definition -- and the return value is used as the field's value.
 1743|         """
 1744| 
 1745|         def converter_with_field(v, field):
 1746|             assert isinstance(field, attr.Attribute)
 1747|             return v * field.metadata["x"]
 1748| 
 1749|         @attr.define
 1750|         class C:
 1751|             x: int = attr.field(
 1752|                 converter=attr.Converter(
 1753|                     converter_with_field, takes_field=True
 1754|                 ),
 1755|                 metadata={"x": 42},
 1756|             )
 1757| 
 1758|         assert 84 == C(2).x
 1759| 
 1760|     def test_converter_decorated(self):
 1761|         """
 1762|         Same as Converter with both `takes_field` and `takes_self`
 1763|         """
 1764| 
 1765|         @attr.define
 1766|         class C:
 1767|             factor: int = 5
 1768|             x: int = attr.field(default=0, metadata={"offset": 200})
 1769| 
 1770|             @x.converter
 1771|             def _convert_x(self, field, value):
 1772|                 assert isinstance(field, attr.Attribute)
 1773|                 return int(value) * self.factor + field.metadata["offset"]
 1774| 
 1775|         assert 410 == C(x="42").x
 1776| 
 1777|     @given(integers(), booleans())
 1778|     def test_convert_property(self, val, init):
 1779|         """
 1780|         Property tests for attributes using converter.
 1781|         """
 1782|         C = make_class(
 1783|             "C",
 1784|             {
 1785|                 "y": attr.ib(),
 1786|                 "x": attr.ib(
 1787|                     init=init, default=val, converter=lambda v: v + 1
 1788|                 ),
 1789|             },
 1790|         )
 1791|         c = C(2)
 1792| 
 1793|         assert c.x == val + 1
 1794|         assert c.y == 2
 1795| 
 1796|     @given(integers(), booleans())
 1797|     def test_converter_factory_property(self, val, init):
 1798|         """
 1799|         Property tests for attributes with converter, and a factory default.
 1800|         """
 1801|         C = make_class(
 1802|             "C",
 1803|             {
 1804|                 "y": attr.ib(),
 1805|                 "x": attr.ib(
 1806|                     init=init,
 1807|                     default=Factory(lambda: val),
 1808|                     converter=lambda v: v + 1,
 1809|                 ),
 1810|             },
 1811|         )
 1812|         c = C(2)
 1813| 
 1814|         assert c.x == val + 1
 1815|         assert c.y == 2
