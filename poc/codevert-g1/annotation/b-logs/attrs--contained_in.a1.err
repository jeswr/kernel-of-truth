 1941| class TestMetadata:
 1942|     """
 1943|     Tests for metadata handling.
 1944|     """
 1945| 
 1946|     @given(sorted_lists_of_attrs)
 1947|     def test_metadata_present(self, list_of_attrs):
 1948|         """
 1949|         Assert dictionaries are copied and present.
 1950|         """
 1951|         C = make_class("C", dict(zip(gen_attr_names(), list_of_attrs)))
 1952| 
 1953|         for hyp_attr, class_attr in zip(list_of_attrs, fields(C)):
 1954|             if hyp_attr.metadata is None:
 1955|                 # The default is a singleton empty dict.
 1956|                 assert class_attr.metadata is not None
 1957|                 assert len(class_attr.metadata) == 0
 1958|             else:
 1959|                 assert hyp_attr.metadata == class_attr.metadata
 1960| 
 1961|                 # Once more, just to assert getting items and iteration.
 1962|                 for k in class_attr.metadata:
 1963|                     assert hyp_attr.metadata[k] == class_attr.metadata[k]
 1964|                     assert hyp_attr.metadata.get(k) == class_attr.metadata.get(
 1965|                         k
 1966|                     )
