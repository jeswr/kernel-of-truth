 2699| class TestDocs:
 2700|     @pytest.mark.parametrize(
 2701|         "meth_name",
 2702|         [
 2703|             "__init__",
 2704|             "__repr__",
 2705|             "__eq__",
 2706|             "__lt__",
 2707|             "__le__",
 2708|             "__gt__",
 2709|             "__ge__",
 2710|         ],
 2711|     )
 2712|     def test_docs(self, meth_name):
 2713|         """
 2714|         Tests the presence and correctness of the documentation
 2715|         for the generated methods
 2716|         """
 2717| 
 2718|         @attr.s
 2719|         class A:
 2720|             pass
 2721| 
 2722|         if hasattr(A, "__qualname__"):
 2723|             method = getattr(A, meth_name)
 2724|             expected = f"Method generated by attrs for class {A.__qualname__}."
 2725|             assert expected == method.__doc__
 2726| 
 2727| 
 2728| class BareC:
 2729|     pass
 2730| 
 2731| 
 2732| class BareSlottedC:
 2733|     __slots__ = ()
 2734| 
 2735| 
 2736| class TestAutoDetect:
 2737|     @pytest.mark.parametrize("C", [BareC, BareSlottedC])
 2738|     def test_determine_detects_non_presence_correctly(self, C):
 2739|         """
 2740|         On an empty class, nothing should be detected.
 2741|         """
 2742|         assert True is _determine_whether_to_implement(
 2743|             C, None, True, ("__init__",)
 2744|         )
 2745|         assert True is _determine_whether_to_implement(
 2746|             C, None, True, ("__repr__",)
 2747|         )
 2748|         assert True is _determine_whether_to_implement(
 2749|             C, None, True, ("__eq__", "__ne__")
 2750|         )
 2751|         assert True is _determine_whether_to_implement(
 2752|             C, None, True, ("__le__", "__lt__", "__ge__", "__gt__")
 2753|         )
 2754| 
 2755|     def test_make_all_by_default(self, slots, frozen):
 2756|         """
 2757|         If nothing is there to be detected, imply init=True, repr=True,
 2758|         unsafe_hash=None, eq=True, order=True.
 2759|         """
 2760| 
 2761|         @attr.s(auto_detect=True, slots=slots, frozen=frozen)
 2762|         class C:
 2763|             x = attr.ib()
 2764| 
 2765|         i = C(1)
 2766|         o = object()
 2767| 
 2768|         assert i.__init__ is not o.__init__
 2769|         assert i.__repr__ is not o.__repr__
 2770|         assert i.__eq__ is not o.__eq__
 2771|         assert i.__ne__ is not o.__ne__
 2772|         assert i.__le__ is not o.__le__
 2773|         assert i.__lt__ is not o.__lt__
 2774|         assert i.__ge__ is not o.__ge__
 2775|         assert i.__gt__ is not o.__gt__
 2776| 
 2777|     def test_detect_auto_init(self, slots, frozen):
 2778|         """
 2779|         If auto_detect=True and an __init__ exists, don't write one.
 2780|         """
 2781| 
 2782|         @attr.s(auto_detect=True, slots=slots, frozen=frozen)
 2783|         class CI:
 2784|             x = attr.ib()
 2785| 
 2786|             def __init__(self):
 2787|                 object.__setattr__(self, "x", 42)
 2788| 
 2789|         assert 42 == CI().x
 2790| 
 2791|     def test_detect_auto_repr(self, slots, frozen):
 2792|         """
 2793|         If auto_detect=True and an __repr__ exists, don't write one.
 2794|         """
 2795| 
 2796|         @attr.s(auto_detect=True, slots=slots, frozen=frozen)
 2797|         class C:
 2798|             x = attr.ib()
 2799| 
 2800|             def __repr__(self):
 2801|                 return "hi"
 2802| 
 2803|         assert "hi" == repr(C(42))
 2804| 
 2805|     def test_hash_uses_eq(self, slots, frozen):
 2806|         """
 2807|         If eq is passed in, then __hash__ should use the eq callable
 2808|         to generate the hash code.
 2809|         """
 2810| 
 2811|         @attr.s(slots=slots, frozen=frozen, unsafe_hash=True)
 2812|         class C:
 2813|             x = attr.ib(eq=str)
 2814| 
 2815|         @attr.s(slots=slots, frozen=frozen, unsafe_hash=True)
 2816|         class D:
 2817|             x = attr.ib()
 2818| 
 2819|         # These hashes should be the same because 1 is turned into
 2820|         # string before hashing.
 2821|         assert hash(C("1")) == hash(C(1))
 2822|         assert hash(D("1")) != hash(D(1))
 2823| 
 2824|     def test_detect_auto_hash(self, slots, frozen):
 2825|         """
 2826|         If auto_detect=True and an __hash__ exists, don't write one.
 2827|         """
 2828| 
 2829|         @attr.s(auto_detect=True, slots=slots, frozen=frozen)
 2830|         class C:
 2831|             x = attr.ib()
 2832| 
 2833|             def __hash__(self):
 2834|                 return 0xC0FFEE
 2835| 
 2836|         assert 0xC0FFEE == hash(C(42))
 2837| 
 2838|     def test_detect_auto_eq(self, slots, frozen):
 2839|         """
 2840|         If auto_detect=True and an __eq__ or an __ne__, exist, don't write one.
 2841|         """
 2842| 
 2843|         @attr.s(auto_detect=True, slots=slots, frozen=frozen)
 2844|         class C:
 2845|             x = attr.ib()
 2846| 
 2847|             def __eq__(self, o):
 2848|                 raise ValueError("worked")
 2849| 
 2850|         with pytest.raises(ValueError, match="worked"):
 2851|             C(1) == C(1)
 2852| 
 2853|         @attr.s(auto_detect=True, slots=slots, frozen=frozen)
 2854|         class D:
 2855|             x = attr.ib()
 2856| 
 2857|             def __ne__(self, o):
 2858|                 raise ValueError("worked")
 2859| 
 2860|         with pytest.raises(ValueError, match="worked"):
 2861|             D(1) != D(1)
 2862| 
 2863|     def test_detect_auto_order(self, slots, frozen):
 2864|         """
 2865|         If auto_detect=True and an __ge__, __gt__, __le__, or and __lt__ exist,
 2866|         don't write one.
 2867| 
 2868|         It's surprisingly difficult to test this programmatically, so we do it
 2869|         by hand.
 2870|         """
 2871| 
 2872|         def assert_not_set(cls, ex, meth_name):
 2873|             __tracebackhide__ = True
 2874| 
 2875|             a = getattr(cls, meth_name)
 2876|             if meth_name == ex:
 2877|                 assert a == 42
 2878|             else:
 2879|                 assert a is getattr(object, meth_name)
 2880| 
 2881|         def assert_none_set(cls, ex):
 2882|             __tracebackhide__ = True
 2883| 
 2884|             for m in ("le", "lt", "ge", "gt"):
 2885|                 assert_not_set(cls, ex, "__" + m + "__")
 2886| 
 2887|         @attr.s(auto_detect=True, slots=slots, frozen=frozen)
 2888|         class LE:
 2889|             __le__ = 42
 2890| 
 2891|         @attr.s(auto_detect=True, slots=slots, frozen=frozen)
 2892|         class LT:
 2893|             __lt__ = 42
 2894| 
 2895|         @attr.s(auto_detect=True, slots=slots, frozen=frozen)
 2896|         class GE:
 2897|             __ge__ = 42
 2898| 
 2899|         @attr.s(auto_detect=True, slots=slots, frozen=frozen)
 2900|         class GT:
 2901|             __gt__ = 42
 2902| 
 2903|         assert_none_set(LE, "__le__")
 2904|         assert_none_set(LT, "__lt__")
 2905|         assert_none_set(GE, "__ge__")
 2906|         assert_none_set(GT, "__gt__")
 2907| 
 2908|     def test_override_init(self, slots, frozen):
