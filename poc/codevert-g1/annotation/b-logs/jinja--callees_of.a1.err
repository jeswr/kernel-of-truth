  671| @pass_environment
  672| def do_last(environment: "Environment", seq: "t.Reversible[V]") -> "V | Undefined":
  673|     """Return the last item of a sequence.
  674| 
  675|     Note: Does not work with generators. You may want to explicitly
  676|     convert it to a list:
  677| 
  678|     .. sourcecode:: jinja
  679| 
  680|         {{ data | selectattr('name', '==', 'Jinja') | list | last }}
  681|     """
  682|     try:
  683|         return next(iter(reversed(seq)))
  684|     except StopIteration:
  685|         return environment.undefined("No last item, sequence was empty.")
  686| 
  687| 
  688| # No async do_last, it may not be safe in async mode.
  689| 
  690| 
  691| @pass_context
  692| def do_random(context: "Context", seq: "t.Sequence[V]") -> "V | Undefined":
  693|     """Return a random item from the sequence."""
  694|     try:
  695|         return random.choice(seq)
  696|     except IndexError:
  697|         return context.environment.undefined("No random item, sequence was empty.")
  698| 
  699| 
  700| def do_filesizeformat(value: str | float | int, binary: bool = False) -> str:
  701|     """Format the value like a 'human-readable' file size (i.e. 13 kB,
  702|     4.1 MB, 102 Bytes, etc).  Per default decimal prefixes are used (Mega,
  703|     Giga, etc.), if the second parameter is set to `True` the binary
  704|     prefixes are used (Mebi, Gibi).
  705|     """
  706|     bytes = float(value)
  707|     base = 1024 if binary else 1000
  708|     prefixes = [
  709|         ("KiB" if binary else "kB"),
  710|         ("MiB" if binary else "MB"),
  711|         ("GiB" if binary else "GB"),
  712|         ("TiB" if binary else "TB"),
  713|         ("PiB" if binary else "PB"),
  714|         ("EiB" if binary else "EB"),
  715|         ("ZiB" if binary else "ZB"),
  716|         ("YiB" if binary else "YB"),
  717|     ]
  718| 
  719|     if bytes == 1:
  720|         return "1 Byte"
  721|     elif bytes < base:
  722|         return f"{int(bytes)} Bytes"
  723|     else:
  724|         for i, prefix in enumerate(prefixes):
  725|             unit = base ** (i + 2)
  726| 
  727|             if bytes < unit:
  728|                 return f"{base * bytes / unit:.1f} {prefix}"
  729| 
  730|         return f"{base * bytes / unit:.1f} {prefix}"
  731| 
  732| 
  733| def do_pprint(value: t.Any) -> str:
  734|     """Pretty print a variable. Useful for debugging."""
  735|     return pformat(value)
  736| 
  737| 
  738| _uri_scheme_re = re.compile(r"^([\w.+-]{2,}:(/){0,2})$")
  739| 
  740| 
  741| @pass_eval_context
  742| def do_urlize(
  743|     eval_ctx: "EvalContext",
  744|     value: str,
  745|     trim_url_limit: int | None = None,
  746|     nofollow: bool = False,
  747|     target: str | None = None,
  748|     rel: str | None = None,
  749|     extra_schemes: t.Iterable[str] | None = None,
  750| ) -> str:
  751|     """Convert URLs in text into clickable links.
  752| 
  753|     This may not recognize links in some situations. Usually, a more
  754|     comprehensive formatter, such as a Markdown library, is a better
  755|     choice.
  756| 
  757|     Works on ``http://``, ``https://``, ``www.``, ``mailto:``, and email
  758|     addresses. Links with trailing punctuation (periods, commas, closing
  759|     parentheses) and leading punctuation (opening parentheses) are
  760|     recognized excluding the punctuation. Email addresses that include
  761|     header fields are not recognized (for example,
  762|     ``mailto:address@example.com?cc=copy@example.com``).
  763| 
  764|     :param value: Original text containing URLs to link.
  765|     :param trim_url_limit: Shorten displayed URL values to this length.
  766|     :param nofollow: Add the ``rel=nofollow`` attribute to links.
  767|     :param target: Add the ``target`` attribute to links.
  768|     :param rel: Add the ``rel`` attribute to links.
  769|     :param extra_schemes: Recognize URLs that start with these schemes
  770|         in addition to the default behavior. Defaults to
  771|         ``env.policies["urlize.extra_schemes"]``, which defaults to no
  772|         extra schemes.
  773| 
  774|     .. versionchanged:: 3.0
  775|         The ``extra_schemes`` parameter was added.
  776| 
  777|     .. versionchanged:: 3.0
  778|         Generate ``https://`` links for URLs without a scheme.
  779| 
  780|     .. versionchanged:: 3.0
  781|         The parsing rules were updated. Recognize email addresses with
  782|         or without the ``mailto:`` scheme. Validate IP addresses. Ignore
  783|         parentheses and brackets in more cases.
  784| 
  785|     .. versionchanged:: 2.8
  786|        The ``target`` parameter was added.
  787|     """
  788|     policies = eval_ctx.environment.policies
  789|     rel_parts = set((rel or "").split())
  790| 
  791|     if nofollow:
  792|         rel_parts.add("nofollow")
  793| 
  794|     rel_parts.update((policies["urlize.rel"] or "").split())
  795|     rel = " ".join(sorted(rel_parts)) or None
  796| 
  797|     if target is None:
  798|         target = policies["urlize.target"]
  799| 
  800|     if extra_schemes is None:
  801|         extra_schemes = policies["urlize.extra_schemes"] or ()
  802| 
  803|     for scheme in extra_schemes:
  804|         if _uri_scheme_re.fullmatch(scheme) is None:
  805|             raise FilterArgumentError(f"{scheme!r} is not a valid URI scheme prefix.")
  806| 
  807|     rv = urlize(
  808|         value,
  809|         trim_url_limit=trim_url_limit,
  810|         rel=rel,
  811|         target=target,
  812|         extra_schemes=extra_schemes,
  813|     )
  814| 
  815|     if eval_ctx.autoescape:
  816|         rv = Markup(rv)
  817| 
  818|     return rv
  819| 
  820| 
  821| def do_indent(
  822|     s: str, width: int | str = 4, first: bool = False, blank: bool = False
  823| ) -> str:
  824|     """Return a copy of the string with each line indented by 4 spaces. The
  825|     first line and blank lines are not indented by default.
  826| 
  827|     :param width: Number of spaces, or a string, to indent by.
  828|     :param first: Don't skip indenting the first line.
  829|     :param blank: Don't skip indenting empty lines.
  830| 
  831|     .. versionchanged:: 3.0
  832|         ``width`` can be a string.
  833| 
  834|     .. versionchanged:: 2.10
  835|         Blank lines are not indented by default.
  836| 
  837|         Rename the ``indentfirst`` argument to ``first``.
  838|     """
  839|     if isinstance(width, str):
  840|         indention = width
  841|     else:
  842|         indention = " " * width
  843| 
  844|     newline = "\n"
  845| 
  846|     if isinstance(s, Markup):
  847|         indention = Markup(indention)
  848|         newline = Markup(newline)
  849| 
  850|     s += newline  # this quirk is necessary for splitlines method
  851| 
  852|     if blank:
  853|         rv = (newline + indention).join(s.splitlines())
  854|     else:
  855|         lines = s.splitlines()
  856|         rv = lines.pop(0)
  857| 
  858|         if lines:
  859|             rv += newline + newline.join(
  860|                 indention + line if line else line for line in lines
  861|             )
  862| 
  863|     if first:
  864|         rv = indention + rv
  865| 
  866|     return rv
  867| 
  868| 
  869| @pass_environment
  870| def do_truncate(
  871|     env: "Environment",
  872|     s: str,
  873|     length: int = 255,
  874|     killwords: bool = False,
  875|     end: str = "...",
  876|     leeway: int | None = None,
  877| ) -> str:
  878|     """Return a truncated copy of the string. The length is specified
  879|     with the first parameter which defaults to ``255``. If the second
  880|     parameter is ``true`` the filter will cut the text at length. Otherwise
  881|     it will discard the last word. If the text was in fact
  882|     truncated it will append an ellipsis sign (``"..."``). If you want a
  883|     different ellipsis sign than ``"..."`` you can specify it using the
  884|     third parameter. Strings that only exceed the length by the tolerance
  885|     margin given in the fourth parameter will not be truncated.
  886| 
  887|     .. sourcecode:: jinja
  888| 
  889|         {{ "foo bar baz qux"|truncate(9) }}
  890|             -> "foo..."
  891|         {{ "foo bar baz qux"|truncate(9, True) }}
  892|             -> "foo ba..."
  893|         {{ "foo bar baz qux"|truncate(11) }}
  894|             -> "foo bar baz qux"
  895|         {{ "foo bar baz qux"|truncate(11, False, '...', 0) }}
  896|             -> "foo bar..."
  897| 
  898|     The default leeway on newer Jinja versions is 5 and was 0 before but
  899|     can be reconfigured globally.
  900|     """
  901|     if leeway is None:
  902|         leeway = env.policies["truncate.leeway"]
  903| 
  904|     assert length >= len(end), f"expected length >= {len(end)}, got {length}"
  905|     assert leeway >= 0, f"expected leeway >= 0, got {leeway}"
  906| 
  907|     if len(s) <= length + leeway:
  908|         return s
  909| 
  910|     if killwords:
  911|         return s[: length - len(end)] + end
  912| 
  913|     result = s[: length - len(end)].rsplit(" ", 1)[0]
  914|     return result + end
  915| 
  916| 
  917| @pass_environment
  918| def do_wordwrap(
  919|     environment: "Environment",
  920|     s: str,
  921|     width: int = 79,
  922|     break_long_words: bool = True,
  923|     wrapstring: str | None = None,
  924|     break_on_hyphens: bool = True,
  925| ) -> str:
  926|     """Wrap a string to the given width. Existing newlines are treated
  927|     as paragraphs to be wrapped separately.
  928| 
  929|     :param s: Original text to wrap.
  930|     :param width: Maximum length of wrapped lines.
  931|     :param break_long_words: If a word is longer than ``width``, break
  932|         it across lines.
  933|     :param break_on_hyphens: If a word contains hyphens, it may be split
  934|         across lines.
  935|     :param wrapstring: String to join each wrapped line. Defaults to
  936|         :attr:`Environment.newline_sequence`.
  937| 
  938|     .. versionchanged:: 2.11
  939|         Existing newlines are treated as paragraphs wrapped separately.
  940| 
  941|     .. versionchanged:: 2.11
  942|         Added the ``break_on_hyphens`` parameter.
  943| 
  944|     .. versionchanged:: 2.7
  945|         Added the ``wrapstring`` parameter.
  946|     """
  947|     import textwrap
  948| 
  949|     if wrapstring is None:
  950|         wrapstring = environment.newline_sequence
  951| 
  952|     # textwrap.wrap doesn't consider existing newlines when wrapping.
  953|     # If the string has a newline before width, wrap will still insert
  954|     # a newline at width, resulting in a short line. Instead, split and
  955|     # wrap each paragraph individually.
  956|     return wrapstring.join(
  957|         [
  958|             wrapstring.join(
  959|                 textwrap.wrap(
  960|                     line,
  961|                     width=width,
  962|                     expand_tabs=False,
  963|                     replace_whitespace=False,
  964|                     break_long_words=break_long_words,
  965|                     break_on_hyphens=break_on_hyphens,
  966|                 )
  967|             )
  968|             for line in s.splitlines()
  969|         ]
  970|     )
  971| 
  972| 
  973| _word_re = re.compile(r"\w+")
  974| 
  975| 
  976| def do_wordcount(s: str) -> int:
  977|     """Count the words in that string."""
  978|     return len(_word_re.findall(soft_str(s)))
  979| 
  980| 
  981| def do_int(value: t.Any, default: int = 0, base: int = 10) -> int:
  982|     """Convert the value into an integer. If the
  983|     conversion doesn't work it will return ``0``. You can
  984|     override this default using the first parameter. You
  985|     can also override the default base (10) in the second
  986|     parameter, which handles input with prefixes such as
  987|     0b, 0o and 0x for bases 2, 8 and 16 respectively.
  988|     The base is ignored for decimal numbers and non-string values.
  989|     """
  990|     try:
  991|         if isinstance(value, str):
  992|             return int(value, base)
  993| 
  994|         return int(value)
  995|     except (TypeError, ValueError):
  996|         # this quirk is necessary so that "42.23"|int gives 42.
  997|         try:
  998|             return int(float(value))
  999|         except (TypeError, ValueError, OverflowError):
 1000|             return default
 1001| 
 1002| 
 1003| def do_float(value: t.Any, default: float = 0.0) -> float:
 1004|     """Convert the value into a floating point number. If the
 1005|     conversion doesn't work it will return ``0.0``. You can
 1006|     override this default using the first parameter.
 1007|     """
 1008|     try:
 1009|         return float(value)
 1010|     except (TypeError, ValueError):
 1011|         return default
 1012| 
 1013| 
 1014| def do_format(value: str, *args: t.Any, **kwargs: t.Any) -> str:
 1015|     """Apply the given values to a `printf-style`_ format string, like
 1016|     ``string % values``.
 1017| 
 1018|     .. sourcecode:: jinja
 1019| 
 1020|         {{ "%s, %s!"|format(greeting, name) }}
 1021|         Hello, World!
 1022| 
 1023|     In most cases it should be more convenient and efficient to use the
 1024|     ``%`` operator or :meth:`str.format`.
 1025| 
 1026|     .. code-block:: text
 1027| 
 1028|         {{ "%s, %s!" % (greeting, name) }}
 1029|         {{ "{}, {}!".format(greeting, name) }}
 1030| 
 1031|     .. _printf-style: https://docs.python.org/library/stdtypes.html
 1032|         #printf-style-string-formatting
 1033|     """
 1034|     if args and kwargs:
 1035|         raise FilterArgumentError(
 1036|             "can't handle positional and keyword arguments at the same time"
 1037|         )
 1038| 
 1039|     return soft_str(value) % (kwargs or args)
 1040| 
 1041| 
 1042| def do_trim(value: str, chars: str | None = None) -> str:
 1043|     """Strip leading and trailing characters, by default whitespace."""
 1044|     return soft_str(value).strip(chars)
 1045| 
 1046| 
 1047| def do_striptags(value: "str | HasHTML") -> str:
 1048|     """Strip SGML/XML tags and replace adjacent whitespace by one space."""
 1049|     if hasattr(value, "__html__"):
 1050|         value = t.cast("HasHTML", value).__html__()
 1051| 
 1052|     return Markup(str(value)).striptags()
 1053| 
 1054| 
 1055| def sync_do_slice(
 1056|     value: "t.Collection[V]", slices: int, fill_with: "V | None" = None
 1057| ) -> "t.Iterator[list[V]]":
 1058|     """Slice an iterator and return a list of lists containing
 1059|     those items. Useful if you want to create a div containing
 1060|     three ul tags that represent columns:
 1061| 
 1062|     .. sourcecode:: html+jinja
 1063| 
 1064|         <div class="columnwrapper">
 1065|           {%- for column in items|slice(3) %}
 1066|             <ul class="column-{{ loop.index }}">
 1067|             {%- for item in column %}
 1068|               <li>{{ item }}</li>
 1069|             {%- endfor %}
 1070|             </ul>
 1071|           {%- endfor %}
 1072|         </div>
 1073| 
 1074|     If you pass it a second argument it's used to fill missing
 1075|     values on the last iteration.
 1076|     """
 1077|     seq = list(value)
 1078|     length = len(seq)
 1079|     items_per_slice = length // slices
 1080|     slices_with_extra = length % slices
 1081|     offset = 0
 1082| 
 1083|     for slice_number in range(slices):
 1084|         start = offset + slice_number * items_per_slice
 1085| 
 1086|         if slice_number < slices_with_extra:
 1087|             offset += 1
 1088| 
 1089|         end = offset + (slice_number + 1) * items_per_slice
 1090|         tmp = seq[start:end]
 1091| 
 1092|         if fill_with is not None and slice_number >= slices_with_extra:
 1093|             tmp.append(fill_with)
 1094| 
 1095|         yield tmp
 1096| 
 1097| 
 1098| @async_variant(sync_do_slice)  # type: ignore
 1099| async def do_slice(
 1100|     value: "t.AsyncIterable[V] | t.Iterable[V]",
 1101|     slices: int,
 1102|     fill_with: t.Any | None = None,
 1103| ) -> "t.Iterator[list[V]]":
 1104|     return sync_do_slice(await auto_to_list(value), slices, fill_with)
 1105| 
 1106| 
 1107| def do_batch(
 1108|     value: "t.Iterable[V]", linecount: int, fill_with: "V | None" = None
 1109| ) -> "t.Iterator[list[V]]":
 1110|     """
 1111|     A filter that batches items. It works pretty much like `slice`
 1112|     just the other way round. It returns a list of lists with the
 1113|     given number of items. If you provide a second parameter this
 1114|     is used to fill up missing items. See this example:
 1115| 
 1116|     .. sourcecode:: html+jinja
 1117| 
 1118|         <table>
 1119|         {%- for row in items|batch(3, '&nbsp;') %}
 1120|           <tr>
 1121|           {%- for column in row %}
 1122|             <td>{{ column }}</td>
 1123|           {%- endfor %}
 1124|           </tr>
 1125|         {%- endfor %}
 1126|         </table>
 1127|     """
 1128|     tmp: list[V] = []
 1129| 
 1130|     for item in value:
 1131|         if len(tmp) == linecount:
 1132|             yield tmp
 1133|             tmp = []
 1134| 
 1135|         tmp.append(item)
 1136| 
 1137|     if tmp:
 1138|         if fill_with is not None and len(tmp) < linecount:
 1139|             tmp += [fill_with] * (linecount - len(tmp))
 1140| 
 1141|         yield tmp
 1142| 
 1143| 
 1144| def do_round(
 1145|     value: float,
 1146|     precision: int = 0,
 1147|     method: 'te.Literal["common", "ceil", "floor"]' = "common",
 1148| ) -> float:
 1149|     """Round the number to a given precision. The first
 1150|     parameter specifies the precision (default is ``0``), the
 1151|     second the rounding method:
 1152| 
 1153|     - ``'common'`` rounds either up or down
 1154|     - ``'ceil'`` always rounds up
 1155|     - ``'floor'`` always rounds down
 1156| 
 1157|     If you don't specify a method ``'common'`` is used.
 1158| 
 1159|     .. sourcecode:: jinja
 1160| 
 1161|         {{ 42.55|round }}
 1162|             -> 43.0
 1163|         {{ 42.55|round(1, 'floor') }}
 1164|             -> 42.5
 1165| 
 1166|     Note that even if rounded to 0 precision, a float is returned.  If
 1167|     you need a real integer, pipe it through `int`:
 1168| 
 1169|     .. sourcecode:: jinja
 1170| 
 1171|         {{ 42.55|round|int }}
 1172|             -> 43
 1173|     """
 1174|     if method not in {"common", "ceil", "floor"}:
 1175|         raise FilterArgumentError("method must be common, ceil or floor")
 1176| 
 1177|     if method == "common":
 1178|         return round(value, precision)
 1179| 
 1180|     func = getattr(math, method)
 1181|     return t.cast(float, func(value * (10**precision)) / (10**precision))
 1182| 
 1183| 
 1184| class _GroupTuple(t.NamedTuple):
 1185|     grouper: t.Any
 1186|     list: list[t.Any]
 1187| 
 1188|     # Use the regular tuple repr to hide this subclass if users print
 1189|     # out the value during debugging.
 1190|     def __repr__(self) -> str:
 1191|         return tuple.__repr__(self)
 1192| 
 1193|     def __str__(self) -> str:
 1194|         return tuple.__str__(self)
 1195| 
 1196| 
 1197| @pass_environment
 1198| def sync_do_groupby(
 1199|     environment: "Environment",
 1200|     value: "t.Iterable[V]",
 1201|     attribute: str | int,
 1202|     default: t.Any | None = None,
 1203|     case_sensitive: bool = False,
 1204| ) -> "list[_GroupTuple]":
 1205|     """Group a sequence of objects by an attribute using Python's
 1206|     :func:`itertools.groupby`. The attribute can use dot notation for
 1207|     nested access, like ``"address.city"``. Unlike Python's ``groupby``,
 1208|     the values are sorted first so only one group is returned for each
 1209|     unique value.
 1210| 
 1211|     For example, a list of ``User`` objects with a ``city`` attribute
 1212|     can be rendered in groups. In this example, ``grouper`` refers to
 1213|     the ``city`` value of the group.
 1214| 
 1215|     .. sourcecode:: html+jinja
 1216| 
 1217|         <ul>{% for city, items in users|groupby("city") %}
 1218|           <li>{{ city }}
 1219|             <ul>{% for user in items %}
 1220|               <li>{{ user.name }}
 1221|             {% endfor %}</ul>
 1222|           </li>
 1223|         {% endfor %}</ul>
 1224| 
 1225|     ``groupby`` yields namedtuples of ``(grouper, list)``, which
 1226|     can be used instead of the tuple unpacking above. ``grouper`` is the
 1227|     value of the attribute, and ``list`` is the items with that value.
 1228| 
 1229|     .. sourcecode:: html+jinja
 1230| 
 1231|         <ul>{% for group in users|groupby("city") %}
 1232|           <li>{{ group.grouper }}: {{ group.list|join(", ") }}
 1233|         {% endfor %}</ul>
 1234| 
 1235|     You can specify a ``default`` value to use if an object in the list
 1236|     does not have the given attribute.
 1237| 
 1238|     .. sourcecode:: jinja
 1239| 
 1240|         <ul>{% for city, items in users|groupby("city", default="NY") %}
 1241|           <li>{{ city }}: {{ items|map(attribute="name")|join(", ") }}</li>
 1242|         {% endfor %}</ul>
 1243| 
 1244|     Like the :func:`~jinja-filters.sort` filter, sorting and grouping is
 1245|     case-insensitive by default. The ``key`` for each group will have
 1246|     the case of the first item in that group of values. For example, if
 1247|     a list of users has cities ``["CA", "NY", "ca"]``, the "CA" group
 1248|     will have two values. This can be disabled by passing
 1249|     ``case_sensitive=True``.
 1250| 
 1251|     .. versionchanged:: 3.1
 1252|         Added the ``case_sensitive`` parameter. Sorting and grouping is
 1253|         case-insensitive by default, matching other filters that do
 1254|         comparisons.
 1255| 
 1256|     .. versionchanged:: 3.0
 1257|         Added the ``default`` parameter.
 1258| 
 1259|     .. versionchanged:: 2.6
 1260|         The attribute supports dot notation for nested access.
 1261|     """
 1262|     expr = make_attrgetter(
 1263|         environment,
 1264|         attribute,
 1265|         postprocess=ignore_case if not case_sensitive else None,
 1266|         default=default,
 1267|     )
 1268|     out = [
 1269|         _GroupTuple(key, list(values))
 1270|         for key, values in groupby(sorted(value, key=expr), expr)
 1271|     ]
 1272| 
 1273|     if not case_sensitive:
 1274|         # Return the real key from the first value instead of the lowercase key.
 1275|         output_expr = make_attrgetter(environment, attribute, default=default)
 1276|         out = [_GroupTuple(output_expr(values[0]), values) for _, values in out]
 1277| 
 1278|     return out
 1279| 
 1280| 
 1281| @async_variant(sync_do_groupby)  # type: ignore
 1282| async def do_groupby(
 1283|     environment: "Environment",
 1284|     value: "t.AsyncIterable[V] | t.Iterable[V]",
 1285|     attribute: str | int,
 1286|     default: t.Any | None = None,
 1287|     case_sensitive: bool = False,
 1288| ) -> "list[_GroupTuple]":
 1289|     expr = make_attrgetter(
 1290|         environment,
 1291|         attribute,
 1292|         postprocess=ignore_case if not case_sensitive else None,
 1293|         default=default,
 1294|     )
 1295|     out = [
 1296|         _GroupTuple(key, await auto_to_list(values))
 1297|         for key, values in groupby(sorted(await auto_to_list(value), key=expr), expr)
 1298|     ]
 1299| 
 1300|     if not case_sensitive:
 1301|         # Return the real key from the first value instead of the lowercase key.
 1302|         output_expr = make_attrgetter(environment, attribute, default=default)
 1303|         out = [_GroupTuple(output_expr(values[0]), values) for _, values in out]
 1304| 
 1305|     return out
 1306| 
 1307| 
 1308| @pass_environment
 1309| def sync_do_sum(
 1310|     environment: "Environment",
 1311|     iterable: "t.Iterable[V]",
 1312|     attribute: str | int | None = None,
 1313|     start: V = 0,  # type: ignore
 1314| ) -> V:
 1315|     """Returns the sum of a sequence of numbers plus the value of parameter
 1316|     'start' (which defaults to 0).  When the sequence is empty it returns
 1317|     start.
 1318| 
 1319|     It is also possible to sum up only certain attributes:
 1320| 
 1321|     .. sourcecode:: jinja
 1322| 
 1323|         Total: {{ items|sum(attribute='price') }}
 1324| 
 1325|     .. versionchanged:: 2.6
 1326|        The ``attribute`` parameter was added to allow summing up over
 1327|        attributes.  Also the ``start`` parameter was moved on to the right.
 1328|     """
 1329|     if attribute is not None:
 1330|         iterable = map(make_attrgetter(environment, attribute), iterable)
 1331| 
 1332|     return sum(iterable, start)  # type: ignore[no-any-return, call-overload]
 1333| 
 1334| 
 1335| @async_variant(sync_do_sum)  # type: ignore
 1336| async def do_sum(
 1337|     environment: "Environment",
 1338|     iterable: "t.AsyncIterable[V] | t.Iterable[V]",
 1339|     attribute: str | int | None = None,
 1340|     start: V = 0,  # type: ignore
 1341| ) -> V:
 1342|     rv = start
 1343| 
 1344|     if attribute is not None:
 1345|         func = make_attrgetter(environment, attribute)
 1346|     else:
 1347| 
 1348|         def func(x: V) -> V:
 1349|             return x
 1350| 
 1351|     async for item in auto_aiter(iterable):
 1352|         rv += func(item)
 1353| 
 1354|     return rv
 1355| 
 1356| 
