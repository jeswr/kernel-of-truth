 1682|     value: "t.AsyncIterable[V] | t.Iterable[V]",
 1683|     *args: t.Any,
 1684|     **kwargs: t.Any,
 1685| ) -> "t.AsyncIterator[V]":
 1686|     return async_select_or_reject(context, value, args, kwargs, lambda x: not x, True)
