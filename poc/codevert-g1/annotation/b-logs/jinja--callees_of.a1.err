 1358|     """Convert the value into a list.  If it was a string the returned list
 1359|     will be a list of characters.
 1360|     """
 1361|     return list(value)
 1362| 
 1363| 
 1364| @async_variant(sync_do_list)  # type: ignore
 1365| async def do_list(value: "t.AsyncIterable[V] | t.Iterable[V]") -> "list[V]":
 1366|     return await auto_to_list(value)
