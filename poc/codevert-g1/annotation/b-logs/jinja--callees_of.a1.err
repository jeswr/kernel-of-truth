 1381| @typing.overload
 1382| def do_reverse(value: str) -> str: ...
 1383| 
 1384| 
 1385| @typing.overload
 1386| def do_reverse(value: "t.Iterable[V]") -> "t.Iterable[V]": ...
 1387| 
 1388| 
 1389| def do_reverse(value: str | t.Iterable[V]) -> str | t.Iterable[V]:
 1390|     """Reverse the object or return an iterator that iterates over it the other
 1391|     way round.
 1392|     """
 1393|     if isinstance(value, str):
 1394|         return value[::-1]
 1395| 
 1396|     try:
 1397|         return reversed(value)  # type: ignore
 1398|     except TypeError:
 1399|         try:
 1400|             rv = list(value)
 1401|             rv.reverse()
 1402|             return rv
 1403|         except TypeError as e:
 1404|             raise FilterArgumentError("argument must be iterable") from e
 1405| 
