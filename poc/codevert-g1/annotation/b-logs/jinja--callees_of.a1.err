  652| @pass_environment
  653| def sync_do_first(environment: "Environment", seq: "t.Iterable[V]") -> "V | Undefined":
  654|     """Return the first item of a sequence."""
  655|     try:
  656|         return next(iter(seq))
  657|     except StopIteration:
  658|         return environment.undefined("No first item, sequence was empty.")
  659| 
  660| 
  661| @async_variant(sync_do_first)  # type: ignore
  662| async def do_first(
  663|     environment: "Environment", seq: "t.AsyncIterable[V] | t.Iterable[V]"
  664| ) -> "V | Undefined":
  665|     try:
  666|         return await auto_aiter(seq).__anext__()
