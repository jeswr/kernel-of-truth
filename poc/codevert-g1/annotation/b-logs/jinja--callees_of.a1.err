 1438| 
 1439| 
 1440| @typing.overload
 1441| def sync_do_map(
 1442|     context: "Context",
 1443|     value: t.Iterable[t.Any],
 1444|     *,
 1445|     attribute: str = ...,
 1446|     default: t.Any | None = None,
 1447| ) -> t.Iterable[t.Any]: ...
