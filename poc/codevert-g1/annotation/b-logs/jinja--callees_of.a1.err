 1407| @pass_environment
 1408| def do_attr(environment: "Environment", obj: t.Any, name: str) -> Undefined | t.Any:
 1409|     """Get an attribute of an object. ``foo|attr("bar")`` works like
 1410|     ``foo.bar``, but returns undefined instead of falling back to ``foo["bar"]``
 1411|     if the attribute doesn't exist.
 1412| 
 1413|     See :ref:`Notes on subscriptions <notes-on-subscriptions>` for more details.
 1414|     """
 1415|     # Environment.getattr will fall back to obj[name] if obj.name doesn't exist.
 1416|     # But we want to call env.getattr to get behavior such as sandboxing.
 1417|     # Determine if the attr exists first, so we know the fallback won't trigger.
 1418|     try:
 1419|         # This avoids executing properties/descriptors, but misses __getattr__
 1420|         # and __getattribute__ dynamic attrs.
 1421|         getattr_static(obj, name)
 1422|     except AttributeError:
 1423|         # This finds dynamic attrs, and we know it's not a descriptor at this point.
 1424|         if not hasattr(obj, name):
 1425|             return environment.undefined(obj=obj, name=name)
 1426| 
 1427|     return environment.getattr(obj, name)
 1428| 
 1429| 
