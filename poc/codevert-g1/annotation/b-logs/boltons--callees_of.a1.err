  168| class _DeferredLine:
  169|     """The _DeferredLine type allows Callpoints and TracebackInfos to be
  170|     constructed without potentially hitting the filesystem, as is the
  171|     normal behavior of the standard Python :mod:`traceback` and
  172|     :mod:`linecache` modules. Calling :func:`str` fetches and caches
  173|     the line.
  174| 
  175|     Args:
  176|         filename (str): the path of the file containing the line
  177|         lineno (int): the number of the line in question
  178|         module_globals (dict): an optional dict of module globals,
  179|             used to handle advanced use cases using custom module loaders.
  180| 
  181|     """
  182|     __slots__ = ('filename', 'lineno', '_line', '_mod_name', '_mod_loader')
  183| 
  184|     def __init__(self, filename, lineno, module_globals=None):
  185|         self.filename = filename
  186|         self.lineno = lineno
  187|         if module_globals is None:
  188|             self._mod_name = None
  189|             self._mod_loader = None
  190|         else:
  191|             self._mod_name = module_globals.get('__name__')
  192|             self._mod_loader = module_globals.get('__loader__')
  193| 
  194|     def __eq__(self, other):
  195|         return (self.lineno, self.filename) == (other.lineno, other.filename)
  196| 
  197|     def __ne__(self, other):
  198|         return not self == other
  199| 
  200|     def __str__(self):
  201|         ret = getattr(self, '_line', None)
  202|         if ret is not None:
  203|             return ret
  204|         try:
  205|             linecache.checkcache(self.filename)
  206|             mod_globals = {'__name__': self._mod_name,
  207|                            '__loader__': self._mod_loader}
  208|             line = linecache.getline(self.filename,
  209|                                      self.lineno,
  210|                                      mod_globals)
  211|             line = line.rstrip()
  212|         except KeyError:
  213|             line = ''
  214|         self._line = line
  215|         return line
  216| 
  217|     def __repr__(self):
  218|         return repr(str(self))
  219| 
  220|     def __len__(self):
  221|         return len(str(self))
  222| 
