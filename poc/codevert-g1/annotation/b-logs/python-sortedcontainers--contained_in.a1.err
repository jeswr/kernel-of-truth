  252|     def __make_cmp(set_op, symbol, doc):
  253|         "Make comparator method."
  254| 
  255|         def comparer(self, other):
  256|             "Compare method for sorted set and set."
  257|             if isinstance(other, SortedSet):
  258|                 return set_op(self._set, other._set)
  259|             elif isinstance(other, Set):
  260|                 return set_op(self._set, other)
  261|             return NotImplemented
  262| 
  263|         set_op_name = set_op.__name__
  264|         comparer.__name__ = f'__{set_op_name}__'
  265|         doc_str = """Return true if and only if sorted set is {0} `other`.
  266| 
  267|         ``ss.__{1}__(other)`` <==> ``ss {2} other``
  268| 
  269|         Comparisons use subset and superset semantics as with sets.
  270| 
  271|         Runtime complexity: `O(n)`
  272| 
  273|         :param other: `other` set
  274|         :return: true if sorted set is {0} `other`
  275| 
  276|         """
  277|         comparer.__doc__ = dedent(doc_str.format(doc, set_op_name, symbol))
  278|         return comparer
  279| 
