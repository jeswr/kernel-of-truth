  167| def test_irange():
  168|     ss = SortedSet()
  169|     ss._reset(7)
  170| 
  171|     assert [] == list(ss.irange())
  172| 
  173|     values = list(range(53))
  174|     ss.update(values)
  175| 
  176|     for start in range(53):
  177|         for end in range(start, 53):
  178|             assert list(ss.irange(start, end)) == values[start : (end + 1)]
  179|             assert (
  180|                 list(ss.irange(start, end, reverse=True))
  181|                 == values[start : (end + 1)][::-1]
  182|             )
  183| 
  184|     for start in range(53):
  185|         for end in range(start, 53):
  186|             assert list(range(start, end)) == list(ss.irange(start, end, (True, False)))
  187| 
  188|     for start in range(53):
  189|         for end in range(start, 53):
  190|             assert list(range(start + 1, end + 1)) == list(
  191|                 ss.irange(start, end, (False, True))
  192|             )
  193| 
  194|     for start in range(53):
  195|         for end in range(start, 53):
  196|             assert list(range(start + 1, end)) == list(
  197|                 ss.irange(start, end, (False, False))
  198|             )
  199| 
  200|     for start in range(53):
  201|         assert list(range(start, 53)) == list(ss.irange(start))
  202| 
  203|     for end in range(53):
  204|         assert list(range(0, end)) == list(ss.irange(None, end, (True, False)))
  205| 
  206|     assert values == list(ss.irange(inclusive=(False, False)))
  207| 
  208|     assert [] == list(ss.irange(53))
  209|     assert values == list(ss.irange(None, 53, (True, False)))
