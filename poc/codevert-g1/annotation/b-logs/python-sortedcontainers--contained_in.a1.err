  180|     def __contains__(self, value):
  181|         """Return true if `value` is an element of the sorted set.
  182| 
  183|         ``ss.__contains__(value)`` <==> ``value in ss``
  184| 
  185|         Runtime complexity: `O(1)`
  186| 
  187|         >>> ss = SortedSet([1, 2, 3, 4, 5])
  188|         >>> 3 in ss
  189|         True
  190| 
  191|         :param value: search for value in sorted set
  192|         :return: true if `value` in sorted set
  193| 
  194|         """
  195|         return value in self._set
  196| 
  197|     def __getitem__(self, index):
  198|         """Lookup value at `index` in sorted set.
  199| 
  200|         ``ss.__getitem__(index)`` <==> ``ss[index]``
  201| 
  202|         Supports slicing.
  203| 
  204|         Runtime complexity: `O(log(n))` -- approximate.
  205| 
  206|         >>> ss = SortedSet('abcde')
  207|         >>> ss[2]
  208|         'c'
  209|         >>> ss[-1]
  210|         'e'
  211|         >>> ss[2:5]
  212|         ['c', 'd', 'e']
  213| 
  214|         :param index: integer or slice for indexing
  215|         :return: value or list of values
  216|         :raises IndexError: if index out of range
  217| 
  218|         """
  219|         return self._list[index]
