   97|     def __init__(self, iterable=None, key=None):
   98|         """Initialize sorted set instance.
   99| 
  100|         Optional `iterable` argument provides an initial iterable of values to
  101|         initialize the sorted set.
  102| 
  103|         Optional `key` argument defines a callable that, like the `key`
  104|         argument to Python's `sorted` function, extracts a comparison key from
  105|         each value. The default, none, compares values directly.
  106| 
  107|         Runtime complexity: `O(n*log(n))`
  108| 
  109|         >>> ss = SortedSet([3, 1, 2, 5, 4])
  110|         >>> ss
  111|         SortedSet([1, 2, 3, 4, 5])
  112|         >>> from operator import neg
  113|         >>> ss = SortedSet([3, 1, 2, 5, 4], neg)
  114|         >>> ss
  115|         SortedSet([5, 4, 3, 2, 1], key=<built-in function neg>)
  116| 
  117|         :param iterable: initial values (optional)
  118|         :param key: function used to extract comparison key (optional)
  119| 
  120|         """
