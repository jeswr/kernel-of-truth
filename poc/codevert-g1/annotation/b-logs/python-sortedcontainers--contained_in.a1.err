  122| 
  123|         # SortedSet._fromset calls SortedSet.__init__ after initializing the
  124|         # _set attribute. So only create a new set if the _set attribute is not
  125|         # already present.
  126| 
  127|         if not hasattr(self, '_set'):
  128|             self._set = set()
  129| 
  130|         self._list = SortedList(self._set, key=key)
  131| 
  132|         # Expose some set methods publicly.
  133| 
