  281|     __ne__ = __make_cmp(ne, '!=', 'not equal to')
  282|     __lt__ = __make_cmp(lt, '<', 'a proper subset of')
  283|     __gt__ = __make_cmp(gt, '>', 'a proper superset of')
  284|     __le__ = __make_cmp(le, '<=', 'a subset of')
  285|     __ge__ = __make_cmp(ge, '>=', 'a superset of')
