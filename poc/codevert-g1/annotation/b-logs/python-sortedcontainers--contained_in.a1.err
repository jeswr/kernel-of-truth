  221|     def __delitem__(self, index):
  222|         """Remove value at `index` from sorted set.
  223| 
  224|         ``ss.__delitem__(index)`` <==> ``del ss[index]``
  225| 
  226|         Supports slicing.
  227| 
  228|         Runtime complexity: `O(log(n))` -- approximate.
  229| 
  230|         >>> ss = SortedSet('abcde')
  231|         >>> del ss[2]
  232|         >>> ss
  233|         SortedSet(['a', 'b', 'd', 'e'])
  234|         >>> del ss[:2]
  235|         >>> ss
  236|         SortedSet(['d', 'e'])
  237| 
  238|         :param index: integer or slice for indexing
  239|         :raises IndexError: if index out of range
  240| 
  241|         """
  242|         _set = self._set
  243|         _list = self._list
  244|         if isinstance(index, slice):
  245|             values = _list[index]
  246|             _set.difference_update(values)
  247|         else:
  248|             value = _list[index]
  249|             _set.remove(value)
  250|         del _list[index]
