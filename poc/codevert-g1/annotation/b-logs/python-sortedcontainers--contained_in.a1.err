  212| def test_irange_key():
  213|     values = sorted(range(100), key=modulo)
  214| 
  215|     for load in range(5, 16):
  216|         ss = SortedSet(range(100), key=modulo)
  217|         ss._reset(load)
  218| 
  219|         for start in range(10):
  220|             for end in range(start, 10):
  221|                 temp = list(ss.irange_key(start, end))
  222|                 assert temp == values[(start * 10) : ((end + 1) * 10)]
  223| 
  224|                 temp = list(ss.irange_key(start, end, reverse=True))
  225|                 assert temp == values[(start * 10) : ((end + 1) * 10)][::-1]
  226| 
  227|         for start in range(10):
  228|             for end in range(start, 10):
  229|                 temp = list(ss.irange_key(start, end, inclusive=(True, False)))
  230|                 assert temp == values[(start * 10) : (end * 10)]
  231| 
  232|         for start in range(10):
  233|             for end in range(start, 10):
  234|                 temp = list(ss.irange_key(start, end, (False, True)))
  235|                 assert temp == values[((start + 1) * 10) : ((end + 1) * 10)]
  236| 
  237|         for start in range(10):
  238|             for end in range(start, 10):
  239|                 temp = list(ss.irange_key(start, end, inclusive=(False, False)))
  240|                 assert temp == values[((start + 1) * 10) : (end * 10)]
  241| 
  242|         for start in range(10):
  243|             temp = list(ss.irange_key(min_key=start))
  244|             assert temp == values[(start * 10) :]
  245| 
  246|         for end in range(10):
  247|             temp = list(ss.irange_key(max_key=end))
  248|             assert temp == values[: (end + 1) * 10]
