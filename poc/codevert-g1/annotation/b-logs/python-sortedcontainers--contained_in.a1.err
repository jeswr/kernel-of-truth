  452|     def difference(self, *iterables):
  453|         """Return the difference of two or more sets as a new sorted set.
  454| 
  455|         The `difference` method also corresponds to operator ``-``.
  456| 
  457|         ``ss.__sub__(iterable)`` <==> ``ss - iterable``
  458| 
  459|         The difference is all values that are in this sorted set but not the
  460|         other `iterables`.
  461| 
  462|         >>> ss = SortedSet([1, 2, 3, 4, 5])
  463|         >>> ss.difference([4, 5, 6, 7])
  464|         SortedSet([1, 2, 3])
  465| 
  466|         :param iterables: iterable arguments
  467|         :return: new sorted set
  468| 
  469|         """
  470|         diff = self._set.difference(*iterables)
  471|         return self._fromset(diff, key=self._key)
  472| 
  473|     __sub__ = difference
  474| 
  475|     def difference_update(self, *iterables):
  476|         """Remove all values of `iterables` from this sorted set.
  477| 
  478|         The `difference_update` method also corresponds to operator ``-=``.
  479| 
  480|         ``ss.__isub__(iterable)`` <==> ``ss -= iterable``
  481| 
  482|         >>> ss = SortedSet([1, 2, 3, 4, 5])
  483|         >>> _ = ss.difference_update([4, 5, 6, 7])
  484|         >>> ss
  485|         SortedSet([1, 2, 3])
  486| 
  487|         :param iterables: iterable arguments
  488|         :return: itself
  489| 
  490|         """
  491|         _set = self._set
  492|         _list = self._list
  493|         values = set(chain(*iterables))
  494|         if (4 * len(values)) > len(_set):
  495|             _set.difference_update(values)
  496|             _list.clear()
  497|             _list.update(_set)
  498|         else:
  499|             _discard = self._discard
  500|             for value in values:
  501|                 _discard(value)
  502|         return self
  503| 
  504|     __isub__ = difference_update
  505| 
  506|     def intersection(self, *iterables):
  507|         """Return the intersection of two or more sets as a new sorted set.
  508| 
  509|         The `intersection` method also corresponds to operator ``&``.
  510| 
  511|         ``ss.__and__(iterable)`` <==> ``ss & iterable``
  512| 
  513|         The intersection is all values that are in this sorted set and each of
  514|         the other `iterables`.
  515| 
  516|         >>> ss = SortedSet([1, 2, 3, 4, 5])
  517|         >>> ss.intersection([4, 5, 6, 7])
  518|         SortedSet([4, 5])
  519| 
  520|         :param iterables: iterable arguments
  521|         :return: new sorted set
  522| 
  523|         """
  524|         intersect = self._set.intersection(*iterables)
  525|         return self._fromset(intersect, key=self._key)
  526| 
  527|     __and__ = intersection
  528|     __rand__ = __and__
  529| 
  530|     def intersection_update(self, *iterables):
  531|         """Update the sorted set with the intersection of `iterables`.
  532| 
  533|         The `intersection_update` method also corresponds to operator ``&=``.
  534| 
  535|         ``ss.__iand__(iterable)`` <==> ``ss &= iterable``
  536| 
  537|         Keep only values found in itself and all `iterables`.
  538| 
  539|         >>> ss = SortedSet([1, 2, 3, 4, 5])
  540|         >>> _ = ss.intersection_update([4, 5, 6, 7])
  541|         >>> ss
  542|         SortedSet([4, 5])
  543| 
  544|         :param iterables: iterable arguments
  545|         :return: itself
  546| 
  547|         """
  548|         _set = self._set
  549|         _list = self._list
  550|         _set.intersection_update(*iterables)
  551|         _list.clear()
  552|         _list.update(_set)
  553|         return self
  554| 
  555|     __iand__ = intersection_update
  556| 
  557|     def symmetric_difference(self, other):
  558|         """Return the symmetric difference with `other` as a new sorted set.
  559| 
  560|         The `symmetric_difference` method also corresponds to operator ``^``.
  561| 
  562|         ``ss.__xor__(other)`` <==> ``ss ^ other``
  563| 
  564|         The symmetric difference is all values tha are in exactly one of the
  565|         sets.
  566| 
  567|         >>> ss = SortedSet([1, 2, 3, 4, 5])
  568|         >>> ss.symmetric_difference([4, 5, 6, 7])
  569|         SortedSet([1, 2, 3, 6, 7])
  570| 
  571|         :param other: `other` iterable
  572|         :return: new sorted set
  573| 
  574|         """
  575|         diff = self._set.symmetric_difference(other)
  576|         return self._fromset(diff, key=self._key)
  577| 
  578|     __xor__ = symmetric_difference
  579|     __rxor__ = __xor__
  580| 
  581|     def symmetric_difference_update(self, other):
  582|         """Update the sorted set with the symmetric difference with `other`.
  583| 
  584|         The `symmetric_difference_update` method also corresponds to operator
  585|         ``^=``.
  586| 
  587|         ``ss.__ixor__(other)`` <==> ``ss ^= other``
  588| 
  589|         Keep only values found in exactly one of itself and `other`.
  590| 
  591|         >>> ss = SortedSet([1, 2, 3, 4, 5])
  592|         >>> _ = ss.symmetric_difference_update([4, 5, 6, 7])
  593|         >>> ss
  594|         SortedSet([1, 2, 3, 6, 7])
  595| 
  596|         :param other: `other` iterable
  597|         :return: itself
  598| 
  599|         """
  600|         _set = self._set
  601|         _list = self._list
  602|         _set.symmetric_difference_update(other)
  603|         _list.clear()
  604|         _list.update(_set)
  605|         return self
  606| 
  607|     __ixor__ = symmetric_difference_update
  608| 
  609|     def union(self, *iterables):
  610|         """Return new sorted set with values from itself and all `iterables`.
  611| 
  612|         The `union` method also corresponds to operator ``|``.
  613| 
  614|         ``ss.__or__(iterable)`` <==> ``ss | iterable``
  615| 
  616|         >>> ss = SortedSet([1, 2, 3, 4, 5])
  617|         >>> ss.union([4, 5, 6, 7])
  618|         SortedSet([1, 2, 3, 4, 5, 6, 7])
  619| 
  620|         :param iterables: iterable arguments
  621|         :return: new sorted set
  622| 
  623|         """
  624|         return self.__class__(chain(iter(self), *iterables), key=self._key)
  625| 
  626|     __or__ = union
  627|     __ror__ = __or__
  628| 
  629|     def update(self, *iterables):
  630|         """Update the sorted set adding values from all `iterables`.
  631| 
  632|         The `update` method also corresponds to operator ``|=``.
  633| 
  634|         ``ss.__ior__(iterable)`` <==> ``ss |= iterable``
  635| 
  636|         >>> ss = SortedSet([1, 2, 3, 4, 5])
  637|         >>> _ = ss.update([4, 5, 6, 7])
  638|         >>> ss
  639|         SortedSet([1, 2, 3, 4, 5, 6, 7])
  640| 
  641|         :param iterables: iterable arguments
  642|         :return: itself
  643| 
  644|         """
  645|         _set = self._set
  646|         _list = self._list
  647|         values = set(chain(*iterables))
  648|         if (4 * len(values)) > len(_set):
  649|             _list = self._list
  650|             _set.update(values)
  651|             _list.clear()
  652|             _list.update(_set)
  653|         else:
  654|             _add = self._add
  655|             for value in values:
  656|                 _add(value)
  657|         return self
  658| 
  659|     __ior__ = update
  660|     _update = update
  661| 
  662|     def __reduce__(self):
  663|         """Support for pickle.
  664| 
  665|         The tricks played with exposing methods in :func:`SortedSet.__init__`
  666|         confuse pickle so customize the reducer.
  667| 
  668|         """
  669|         return (type(self), (self._set, self._key))
  670| 
  671|     @recursive_repr()
  672|     def __repr__(self):
  673|         """Return string representation of sorted set.
  674| 
  675|         ``ss.__repr__()`` <==> ``repr(ss)``
  676| 
  677|         :return: string representation
  678| 
  679|         """
  680|         _key = self._key
  681|         key = '' if _key is None else f', key={_key!r}'
  682|         type_name = type(self).__name__
  683|         return f'{type_name}({list(self)!r}{key})'
  684| 
  685|     def _check(self):
  686|         """Check invariants of sorted set.
  687| 
  688|         Runtime complexity: `O(n)`
  689| 
  690|         """
  691|         _set = self._set
  692|         _list = self._list
  693|         _list._check()
  694|         assert len(_set) == len(_list)
  695|         assert all(value in _set for value in _list)

