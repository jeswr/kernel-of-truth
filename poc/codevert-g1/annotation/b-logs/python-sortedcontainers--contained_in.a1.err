  159|     @classmethod
  160|     def _fromset(cls, values, key=None):
  161|         """Initialize sorted set from existing set.
  162| 
  163|         Used internally by set operations that return a new set.
  164| 
  165|         """
  166|         sorted_set = object.__new__(cls)
  167|         sorted_set._set = values
  168|         sorted_set.__init__(key=key)
  169|         return sorted_set
  170| 
