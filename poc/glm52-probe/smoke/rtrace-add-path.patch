+/* GLM-5.2 backend-smoke TEACHER-FORCED router-trace path (READ-ONLY).
+ * Reached via TRACE_SCORE=<manifest> (needs RTRACE=<file> to record anything).
+ * Manifest: one item per line, whitespace ints:  item_id  T  n_prompt  t_0..t_{T-1}
+ *   item_id  = integer probe id (joined to the corpus by index on the host)
+ *   T        = sequence length (prompt + teacher-forced target)
+ *   n_prompt = number of prompt tokens; positions [0,n_prompt) are tagged io=0
+ *              (input), [n_prompt,T) io=1 (target)
+ *   t_*      = token ids (host pre-tokenised with the model tokenizer; tiny model
+ *              uses raw ids < vocab)
+ * Per item: RESET the trace (rtrace_begin_item), ONE prefill (splice-free; moe()
+ * emits per-token router rows), rtrace_end_item flushes the per-item fingerprint.
+ * Nothing carries across items (the anti-contamination invariant). */
+static void run_trace_score(Model *m, const char *path){
+    Cfg *c=&m->c; int D=c->hidden;
+    FILE *f=fopen(path,"rb"); if(!f){perror(path);exit(1);}
+    int maxT=1; { char *ln=NULL; size_t cp=0;
+        while(getline(&ln,&cp,f)>0){ long id,T; char *e;
+            id=strtol(ln,&e,10); if(e==ln) continue; T=strtol(e,&e,10);
+            if(T>maxT) maxT=(int)T; (void)id; }
+        free(ln); }
+    kv_alloc(m,maxT);
+    float *x=falloc((int64_t)maxT*D);
+    int *ids=malloc((size_t)maxT*sizeof(int));
+    int topk_rec = g_topk>0 ? (g_topk<c->topk?g_topk:c->topk) : c->topk;
+    rewind(f); char *ln=NULL; size_t cp=0; int nreq=0; double t0=now_s();
+    while(getline(&ln,&cp,f)>0){
+        char *p=ln, *e;
+        long item=strtol(p,&e,10); if(e==p){ continue; } p=e;             /* blank line */
+        long T=strtol(p,&e,10); if(e==p){ fprintf(stderr,"[trace] bad T\n"); continue; } p=e;
+        long np=strtol(p,&e,10); if(e==p){ fprintf(stderr,"[trace] bad n_prompt\n"); continue; } p=e;
+        int bad=(T<1 || T>maxT || np<0 || np>T);
+        for(long i=0;i<T && !bad;i++){ long v=strtol(p,&e,10); if(e==p){bad=1;break;} p=e;
+            if(v<0 || v>=c->vocab) bad=1; else ids[i]=(int)v; }
+        if(bad){ fprintf(stderr,"[trace] ERR item %ld (bad token/len)\n",item); continue; }
+        rtrace_begin_item(g_rt, item, (int)T, (int)np, topk_rec, g_draft);
+        for(int s=0;s<T;s++) embed_row(m, ids[s], x+(int64_t)s*D);
+        layers_forward(m,x,(int)T,0);                                     /* ONE prefill; moe() emits */
+        rtrace_end_item(g_rt);
+        if(++nreq%4==0) fprintf(stderr,"[trace %d item | %.1fs | RSS %.2f GB | hit %.0f%%]\n",
+            nreq, now_s()-t0, rss_gb(), (m->hits+m->miss)?100.0*m->hits/(m->hits+m->miss):0.0);
+    }
+    free(ln); free(ids); free(x); fclose(f);
+}
