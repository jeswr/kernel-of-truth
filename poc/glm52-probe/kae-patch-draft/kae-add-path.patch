+        for(long i=0;i<T && !bad;i++){ long v=strtol(p,&e,10); if(e==p){bad=1;break;} p=e;
+            if(v< -1 || (m->kae && v>=m->kae->nc)) bad=1; else spans[i]=(int)v; }
+        if(bad){ printf("ERR item\n"); fflush(stdout); kae_reset_spans(m->kae); continue; }
