+    if(nreq!=n_lines){ fprintf(stderr,"[KAE-DUMP] processed %d lines != header %d -> abort\n",nreq,n_lines); exit(1); }
+    if(kaed_finish(kd)) exit(1);
+    fprintf(stderr,"[kae-dump done: %d lines, %d layers, D=%d | %.1fs]\n",
+            nreq, kd->nl, kd->D, now_s()-t0);
+    free(ln); free(ids); free(spans); free(x); fclose(f);
+}
