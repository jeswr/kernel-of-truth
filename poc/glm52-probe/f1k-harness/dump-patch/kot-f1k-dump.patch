+    rewind(f); char *ln=NULL; size_t cp=0; int nreq=0; double t0=now_s();
+    while(getline(&ln,&cp,f)>0){
+        char *p=ln,*e;
+        long T=strtol(p,&e,10); if(e==p) continue; p=e;      /* blank line */
+        if(T<1||T>maxT){ fprintf(stderr,"[KAE-DUMP] line %d: bad T=%ld -> abort\n",nreq,T); exit(1); }
+        for(long i=0;i<T;i++){ long v=strtol(p,&e,10);
+            if(e==p||v<0||v>=c->vocab){ fprintf(stderr,"[KAE-DUMP] line %d: bad token id -> abort\n",nreq); exit(1); }
+            p=e; ids[i]=(int)v; }
+        long gated=0;
+        for(long i=0;i<T;i++){ long v=strtol(p,&e,10);
+            if(e==p||v<-1){ fprintf(stderr,"[KAE-DUMP] line %d: bad span slot -> abort\n",nreq); exit(1); }
+            p=e; spans[i]=(v<0)?-1:(int)v; if(spans[i]>=0) gated++; }
+        if(!gated){ fprintf(stderr,"[KAE-DUMP] line %d has zero gated positions -> abort\n",nreq); exit(1); }
+        /* REUSED per-item span binding (same semantics as run_kae_score) */
