{
  "schema": "dts-style-rules/1",
  "comment": "Pinned deterministic style-transform rule tables for the truthstyle-2x2 probe (docs/design-truthstyle-2x2-f2-taxonomy.md section 3). Tier-1 shapes open-vocabulary WordNet 3.1 gloss text TOWARD the NSM register (weak proxy, fidelity-gated); tier-2 plainifies kernel canonical glosses AWAY from the NSM register via the inverse of the f2b-transfer section-4.7 S6 reading key (closed controlled vocabulary, high fidelity). Rules are ordered, case-sensitive on lowercased text, applied left-to-right with plain string replacement unless prefixed 're:' (then a Python regex with backreferences). Changing ANY byte of this file is a probe-instrument version change: re-pin, rebuild d-ts, re-freeze.",
  "tier1_nsm_preamble": "it is like this: ",
  "tier1_plain_preamble": "it is defined as: ",
  "tier1_nsm_substitutions": [
    ["a person who", "someone who"],
    ["somebody who", "someone who"],
    ["a person", "someone"],
    ["somebody", "someone"],
    ["anyone", "someone"],
    ["anything", "something"],
    ["the act of", "something people do: "],
    ["the quality of", "something people can say about a thing: "],
    ["cannot", "can not"],
    ["extremely", "very"],
    ["large", "big"]
  ],
  "tier2_plainify_substitutions": [
    ["re:somethings of kind ([a-z][a-z-]*)", "\\1 things"],
    ["re:something of kind ([a-z][a-z-]*)", "a \\1"],
    ["this someone's", "the person's"],
    ["this someone", "the person"],
    ["this something", "the thing"],
    ["these someones", "these people"],
    ["someone who", "a person who"],
    ["someones", "people"],
    ["someone", "a person"],
    ["because of this,", "as a result,"],
    ["because of this", "as a result"],
    ["thinks like this:", "thinks that"],
    ["feels something bad", "feels bad"],
    ["feels something good", "feels good"],
    ["after now", "in the future"],
    ["before now", "in the past"],
    ["at some times", "sometimes"],
    ["for some time", "for a while"],
    ["very bad", "terrible"],
    ["very good", "excellent"],
    ["very big", "huge"],
    ["very small", "tiny"],
    ["one kind", "one type"],
    ["of kind", "of type"],
    ["can not", "cannot"]
  ],
  "nsm_register_markers": [
