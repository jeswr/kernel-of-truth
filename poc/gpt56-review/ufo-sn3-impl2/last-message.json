=== FILE: crates/sparq-conformance/tests/ufo_sn3/vocab/ufo-sn3.ttl ===
@prefix ufo:  <urn:ufo-sn3:> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

ufo:
    a owl:Ontology ;
    rdfs:label "UFO-SN3 reference vocabulary" ;
    rdfs:comment
        "Finite, situation-scoped UFO projection for range-restricted N3 reasoning. Proposition nodes use explicit subject, predicate, and object properties because the SPARQ N3 Term model does not contain RDF-star triple terms." .

# Core categories

ufo:Entity a owl:Class .
ufo:Type a owl:Class .
ufo:Endurant a owl:Class ; rdfs:subClassOf ufo:Entity .
ufo:Substantial a owl:Class ; rdfs:subClassOf ufo:Endurant .
ufo:Moment a owl:Class ; rdfs:subClassOf ufo:Endurant .
ufo:Sortal a owl:Class ; rdfs:subClassOf ufo:Type .
ufo:NonSortal a owl:Class ; rdfs:subClassOf ufo:Type .

# UFO-A substantials and type metaproperties

ufo:Kind
    a owl:Class ;
    rdfs:subClassOf ufo:Sortal .

ufo:Role
    a owl:Class ;
    rdfs:subClassOf ufo:Sortal .

ufo:Phase
    a owl:Class ;
    rdfs:subClassOf ufo:Sortal .

ufo:Category
    a owl:Class ;
    rdfs:subClassOf ufo:NonSortal .

ufo:RoleMixin
    a owl:Class ;
    rdfs:subClassOf ufo:NonSortal .

ufo:Mixin
    a owl:Class ;
    rdfs:subClassOf ufo:NonSortal .

ufo:RigidityMarker a owl:Class .
ufo:Rigid a ufo:RigidityMarker .
ufo:AntiRigid a ufo:RigidityMarker .
ufo:SemiRigid a ufo:RigidityMarker .

ufo:rigidity
    a owl:ObjectProperty ;
    rdfs:domain ufo:Type ;
    rdfs:range ufo:RigidityMarker .

ufo:IdentityCriterion a owl:Class .

ufo:identityCriterion
    a owl:ObjectProperty ;
    rdfs:domain ufo:Type ;
    rdfs:range ufo:IdentityCriterion .

ufo:identityProvider
    a owl:ObjectProperty ;
    rdfs:domain ufo:Type ;
    rdfs:range ufo:Kind .

ufo:keyProperty
    a owl:ObjectProperty ;
    rdfs:domain ufo:IdentityCriterion ;
    rdfs:range rdf:Property .

ufo:identityKey
    a owl:ObjectProperty ;
    rdfs:domain ufo:Type ;
    rdfs:range rdf:Property .

ufo:sameContinuant
    a owl:ObjectProperty, owl:SymmetricProperty ;
    rdfs:domain ufo:Endurant ;
    rdfs:range ufo:Endurant .

ufo:contingentFor
    a owl:ObjectProperty ;
    rdfs:domain ufo:Type ;
    rdfs:range ufo:Endurant .

# UFO-A moments

ufo:Quality
    a owl:Class ;
    rdfs:subClassOf ufo:Moment .

ufo:Quale a owl:Class .

ufo:QualityStructure a owl:Class .

ufo:Mode
    a owl:Class ;
    rdfs:subClassOf ufo:Moment .

ufo:Disposition
    a owl:Class ;
    rdfs:subClassOf ufo:Mode .

ufo:Relator
    a owl:Class ;
    rdfs:subClassOf ufo:Moment .

ufo:QuaIndividual
    a owl:Class ;
    rdfs:subClassOf ufo:Mode .

ufo:inheresIn
    a owl:ObjectProperty ;
    rdfs:domain ufo:Moment ;
    rdfs:range ufo:Endurant .

ufo:existentiallyDependsOn
    a owl:ObjectProperty ;
    rdfs:domain ufo:Entity ;
    rdfs:range ufo:Entity .

ufo:externallyDependsOn
    a owl:ObjectProperty ;
    rdfs:subPropertyOf ufo:existentiallyDependsOn .

ufo:hasQuale
    a owl:ObjectProperty ;
    rdfs:domain ufo:Quality ;
    rdfs:range ufo:Quale .

ufo:inStructure
    a owl:ObjectProperty ;
    rdfs:domain ufo:Quale ;
    rdfs:range ufo:QualityStructure .

ufo:mediates
    a owl:ObjectProperty ;
    rdfs:domain ufo:Relator ;
    rdfs:range ufo:Endurant .

ufo:truthmaker
    a owl:ObjectProperty ;
    rdfs:domain ufo:Proposition ;
    rdfs:range ufo:Relator .

ufo:triggerCondition
    a owl:ObjectProperty ;
    rdfs:domain ufo:Disposition ;
    rdfs:range ufo:Proposition .

ufo:activatedIn
    a owl:ObjectProperty ;
    rdfs:domain ufo:Disposition ;
    rdfs:range ufo:Situation .

ufo:manifestsIn
    a owl:ObjectProperty ;
    rdfs:domain ufo:Disposition ;
    rdfs:range ufo:Event .

ufo:manifestationOf
    a owl:ObjectProperty ;
    rdfs:domain ufo:Event ;
    rdfs:range ufo:Disposition .

# UFO-B

ufo:Event
    a owl:Class ;
    rdfs:subClassOf ufo:Entity .

ufo:Participation a owl:Class .
ufo:Activation
    a owl:Class ;
    rdfs:subClassOf ufo:Event .

ufo:Manifestation
    a owl:Class ;
    rdfs:subClassOf ufo:Event .

ufo:event
    a owl:ObjectProperty ;
    rdfs:domain ufo:Participation ;
    rdfs:range ufo:Event .

ufo:participant
    a owl:ObjectProperty ;
    rdfs:domain ufo:Participation ;
    rdfs:range ufo:Endurant .

ufo:participantRole
    a owl:ObjectProperty ;
    rdfs:domain ufo:Participation ;
    rdfs:range ufo:Type .

ufo:hasParticipant
    a owl:ObjectProperty ;
    rdfs:domain ufo:Event ;
    rdfs:range ufo:Endurant .

ufo:participatesIn
    a owl:ObjectProperty ;
    owl:inverseOf ufo:hasParticipant .

ufo:occursIn
    a owl:ObjectProperty ;
    rdfs:domain ufo:Event ;
    rdfs:range ufo:Situation .

# UFO-C

ufo:Agent
    a owl:Class ;
    rdfs:subClassOf ufo:Substantial .

ufo:Goal a owl:Class .

ufo:SocialObject
    a owl:Class ;
    rdfs:subClassOf ufo:Entity .

ufo:Commitment
    a owl:Class ;
    rdfs:subClassOf ufo:Mode .

ufo:Claim
    a owl:Class ;
    rdfs:subClassOf ufo:Mode .

ufo:Norm
    a owl:Class ;
    rdfs:subClassOf ufo:SocialObject .

ufo:NormativeDescription
    a owl:Class ;
    rdfs:subClassOf ufo:SocialObject .

ufo:Obligation
    a owl:Class ;
    rdfs:subClassOf ufo:SocialObject .

ufo:goal
    a owl:ObjectProperty ;
    rdfs:range ufo:Goal .

ufo:debtor
    a owl:ObjectProperty ;
    rdfs:domain ufo:Commitment ;
    rdfs:range ufo:Agent .

ufo:creditor
    a owl:ObjectProperty ;
    rdfs:domain ufo:Commitment ;
    rdfs:range ufo:Agent .

ufo:content
    a owl:ObjectProperty ;
    rdfs:range ufo:Proposition .

ufo:counterpart
    a owl:ObjectProperty, owl:SymmetricProperty .

ufo:condition
    a owl:ObjectProperty ;
    rdfs:domain ufo:Norm ;
    rdfs:range ufo:Proposition .

ufo:consequent
    a owl:ObjectProperty ;
    rdfs:domain ufo:Norm ;
    rdfs:range ufo:Proposition .

ufo:generatedBy
    a owl:ObjectProperty ;
    rdfs:domain ufo:Obligation ;
    rdfs:range ufo:Norm .

ufo:groundedIn
    a owl:ObjectProperty ;
    rdfs:domain ufo:Commitment ;
    rdfs:range ufo:Obligation .

ufo:appliesIn
    a owl:ObjectProperty ;
    rdfs:range ufo:Situation .

ufo:activeIn
    a owl:ObjectProperty ;
    rdfs:range ufo:Situation .

# Situations, worlds, and reification-node propositions

ufo:Situation a owl:Class .

ufo:World
    a owl:Class ;
    rdfs:subClassOf ufo:Situation .

ufo:Proposition a owl:Class .

ufo:subj
    a owl:ObjectProperty ;
    rdfs:domain ufo:Proposition .

ufo:pred
    a owl:ObjectProperty ;
    rdfs:domain ufo:Proposition ;
    rdfs:range rdf:Property .

ufo:obj
    a rdf:Property ;
    rdfs:domain ufo:Proposition .

ufo:holdsIn
    a owl:ObjectProperty ;
    rdfs:domain ufo:Proposition ;
    rdfs:range ufo:Situation .

ufo:notHoldsIn
    a owl:ObjectProperty ;
    rdfs:domain ufo:Proposition ;
    rdfs:range ufo:Situation .

ufo:existsIn
    a owl:ObjectProperty ;
    rdfs:domain ufo:Entity ;
    rdfs:range ufo:Situation .

ufo:accessible
    a owl:ObjectProperty ;
    rdfs:domain ufo:Situation ;
    rdfs:range ufo:Situation .

ufo:necessaryIn
    a owl:ObjectProperty ;
    rdfs:domain ufo:Proposition ;
    rdfs:range ufo:Situation .

# Closed validation

ufo:ValidationScope a owl:Class .
ufo:ValidationResult a owl:Class .

ufo:closedFor
    a owl:ObjectProperty ;
    rdfs:domain ufo:Situation ;
    rdfs:range ufo:ValidationScope .

ufo:requiredProposition
    a owl:ObjectProperty ;
    rdfs:domain ufo:ValidationScope ;
    rdfs:range ufo:Proposition .

ufo:refutedIn
    a owl:ObjectProperty ;
    rdfs:domain ufo:Proposition ;
    rdfs:range ufo:Situation .

ufo:hasFinding
    a owl:ObjectProperty ;
    rdfs:domain ufo:ValidationScope ;
    rdfs:range ufo:Proposition .

ufo:rigidityViolationIn
    a owl:ObjectProperty ;
    rdfs:domain ufo:Proposition ;
    rdfs:range ufo:Situation .

=== FILE: crates/sparq-conformance/tests/ufo_sn3/rules/ufo-sn3.n3 ===
@prefix ufo:  <urn:ufo-sn3:> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .

# UFO-SN3 v1 is function-free and range-restricted. Every term in a rule
# conclusion is bound by its premise. No rule creates a world, proposition,
# event, relator, obligation, or blank node.

# --- Type metaproperties -------------------------------------------------

# Kinds and Categories are rigid in this executable projection.
{
    ?type a ufo:Kind.
}
=>
{
    ?type ufo:rigidity ufo:Rigid.
}.

{
    ?type a ufo:Category.
}
=>
{
    ?type ufo:rigidity ufo:Rigid.
}.

# Roles and Phases are anti-rigid.
{
    ?type a ufo:Role.
}
=>
{
    ?type ufo:rigidity ufo:AntiRigid.
}.

{
    ?type a ufo:Phase.
}
=>
{
    ?type ufo:rigidity ufo:AntiRigid.
}.

# --- Inherence and existential dependence -------------------------------

{
    ?moment ufo:inheresIn ?bearer.
}
=>
{
    ?moment ufo:existentiallyDependsOn ?bearer.
}.

{
    ?dependent ufo:existentiallyDependsOn ?dependency.
    ?dependent ufo:existsIn ?world.
}
=>
{
    ?dependency ufo:existsIn ?world.
}.

# --- Rigidity and anti-rigidity ------------------------------------------

# A rigid membership proposition propagates to an accessible situation only
# while the represented individual exists there. The proposition node is
# reused; no RDF-star triple term or fresh proposition is required.
{
    ?type ufo:rigidity ufo:Rigid.
    ?membership a ufo:Proposition;
        ufo:subj ?individual;
        ufo:pred rdf:type;
        ufo:obj ?type;
        ufo:holdsIn ?source.
    ?source ufo:accessible ?target.
    ?individual ufo:existsIn ?target.
}
=>
{
    ?membership ufo:holdsIn ?target.
}.

# An explicit contrary proposition in an accessible situation refutes rigid
# membership. Explicit falsity avoids treating open-world absence as falsity.
{
    ?type ufo:rigidity ufo:Rigid.
    ?membership a ufo:Proposition;
        ufo:subj ?individual;
        ufo:pred rdf:type;
        ufo:obj ?type;
        ufo:holdsIn ?source;
        ufo:notHoldsIn ?target.
    ?source ufo:accessible ?target.
    ?individual ufo:existsIn ?target.
}
=>
{
    ?membership ufo:rigidityViolationIn ?target.
}.

# A supplied accessible counter-situation witnesses contingent membership
# for a Role or Phase.
{
    ?type ufo:rigidity ufo:AntiRigid.
    ?membership a ufo:Proposition;
        ufo:subj ?individual;
        ufo:pred rdf:type;
        ufo:obj ?type;
        ufo:holdsIn ?source;
        ufo:notHoldsIn ?target.
    ?source ufo:accessible ?target.
    ?individual ufo:existsIn ?target.
}
=>
{
    ?type ufo:contingentFor ?individual.
}.

# --- Identity criteria ---------------------------------------------------

# A Kind directly exposes the key compiled from its supplied criterion.
{
    ?type ufo:identityCriterion ?criterion.
    ?criterion ufo:keyProperty ?keyProperty.
}
=>
{
    ?type ufo:identityKey ?keyProperty.
}.

# Roles, Phases, and other dependent sortals inherit the provider's compiled
# operational key.
{
    ?type ufo:identityProvider ?provider.
    ?provider ufo:identityCriterion ?criterion.
    ?criterion ufo:keyProperty ?keyProperty.
}
=>
{
    ?type ufo:identityKey ?keyProperty.
}.

# Two represented instances of the same type with the same key value in one
# situation are marked as the same continuant. Situation records are not
# collapsed with owl:sameAs.
{
    ?type ufo:identityKey ?keyProperty.

    ?leftType a ufo:Proposition;
        ufo:subj ?left;
        ufo:pred rdf:type;
        ufo:obj ?type;
        ufo:holdsIn ?world.
    ?rightType a ufo:Proposition;
        ufo:subj ?right;
        ufo:pred rdf:type;
        ufo:obj ?type;
        ufo:holdsIn ?world.

    ?leftKey a ufo:Proposition;
        ufo:subj ?left;
        ufo:pred ?keyProperty;
        ufo:obj ?key;
        ufo:holdsIn ?world.
    ?rightKey a ufo:Proposition;
        ufo:subj ?right;
        ufo:pred ?keyProperty;
        ufo:obj ?key;
        ufo:holdsIn ?world.
}
=>
{
    ?left ufo:sameContinuant ?right.
}.

# --- Relators ------------------------------------------------------------

# A relator existentially depends on every entity it mediates.
{
    ?relator a ufo:Relator;
        ufo:mediates ?participant.
}
=>
{
    ?relator ufo:existentiallyDependsOn ?participant.
}.

# If the relator exists in a situation, each mediated participant exists there.
{
    ?relator a ufo:Relator;
        ufo:mediates ?participant;
        ufo:existsIn ?world.
}
=>
{
    ?participant ufo:existsIn ?world.
}.

# A supplied proposition whose truthmaker is an existing relator obtains when
# the relator mediates its two explicitly distinct endpoints.
{
    ?relator a ufo:Relator;
        ufo:mediates ?left;
        ufo:mediates ?right;
        ufo:existsIn ?world.
    ?left owl:differentFrom ?right.
    ?proposition a ufo:Proposition;
        ufo:truthmaker ?relator;
        ufo:subj ?left;
        ufo:pred ?relation;
        ufo:obj ?right.
}
=>
{
    ?proposition ufo:holdsIn ?world.
}.

# --- Events and participation -------------------------------------------

{
    ?participation a ufo:Participation;
        ufo:event ?event;
        ufo:participant ?participant;
        ufo:occursIn ?world.
}
=>
{
    ?event ufo:hasParticipant ?participant;
        ufo:existsIn ?world.
    ?participant ufo:participatesIn ?event;
        ufo:existsIn ?world.
    ?participation ufo:existsIn ?world.
}.

# --- Dispositions --------------------------------------------------------

# A disposition activates when its supplied trigger proposition holds.
{
    ?disposition a ufo:Disposition;
        ufo:triggerCondition ?trigger.
    ?trigger a ufo:Proposition;
        ufo:holdsIn ?world.
}
=>
{
    ?disposition ufo:activatedIn ?world.
}.

# A supplied manifestation event occurs in the activation situation.
{
    ?disposition a ufo:Disposition;
        ufo:activatedIn ?world;
        ufo:manifestsIn ?event.
}
=>
{
    ?event ufo:manifestationOf ?disposition;
        ufo:occursIn ?world.
}.

# --- Commitments and norms ----------------------------------------------

# A satisfied norm condition activates an already supplied obligation record.
{
    ?norm a ufo:Norm;
        ufo:condition ?condition;
        ufo:consequent ?content.
    ?condition a ufo:Proposition;
        ufo:holdsIn ?world.
    ?obligation a ufo:Obligation;
        ufo:generatedBy ?norm;
        ufo:content ?content;
        ufo:appliesIn ?world.
}
=>
{
    ?obligation ufo:activeIn ?world.
}.

# A supplied commitment/claim pair becomes active with its grounding
# obligation. No social moment is invented by the rule.
{
    ?obligation a ufo:Obligation;
        ufo:content ?content;
        ufo:activeIn ?world.
    ?commitment a ufo:Commitment;
        ufo:content ?content;
        ufo:groundedIn ?obligation;
        ufo:counterpart ?claim.
    ?claim a ufo:Claim;
        ufo:content ?content.
}
=>
{
    ?commitment ufo:activeIn ?world.
    ?claim ufo:activeIn ?world.
}.

# --- Closed validation ---------------------------------------------------

# Explicit negative information may refute a required proposition only when
# the situation declares the applicable validation scope closed.
{
    ?world ufo:closedFor ?scope.
    ?scope a ufo:ValidationScope;
        ufo:requiredProposition ?proposition.
    ?proposition a ufo:Proposition;
        ufo:notHoldsIn ?world.
}
=>
{
    ?proposition ufo:refutedIn ?world.
    ?scope ufo:hasFinding ?proposition.
}.

# --- Accessibility -------------------------------------------------------

# A proposition explicitly marked necessary in a source situation propagates
# across an accessibility edge. The proposition node and target world must
# already occur in the finite input.
{
    ?proposition a ufo:Proposition;
        ufo:holdsIn ?source;
        ufo:necessaryIn ?source.
    ?source ufo:accessible ?target.
}
=>
{
    ?proposition ufo:holdsIn ?target.
}.

=== FILE: crates/sparq-conformance/tests/ufo_sn3/cases/rigidity-kind-vs-role/input.n3 ===
@prefix ufo: <urn:ufo-sn3:> .
@prefix ex:  <urn:ufo-sn3:case:rigidity:> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .

ex:Person a ufo:Kind.
ex:Employee a ufo:Role;
    ufo:identityProvider ex:Person.

ex:w1 a ufo:World;
    ufo:accessible ex:w2.
ex:w2 a ufo:World.

ex:alice ufo:existsIn ex:w1, ex:w2.

ex:alicePerson a ufo:Proposition;
    ufo:subj ex:alice;
    ufo:pred rdf:type;
    ufo:obj ex:Person;
    ufo:holdsIn ex:w1.

ex:aliceEmployee a ufo:Proposition;
    ufo:subj ex:alice;
    ufo:pred rdf:type;
    ufo:obj ex:Employee;
    ufo:holdsIn ex:w1;
    ufo:notHoldsIn ex:w2.

=== FILE: crates/sparq-conformance/tests/ufo_sn3/cases/rigidity-kind-vs-role/answer.n3 ===
@prefix ufo: <urn:ufo-sn3:> .
@prefix ex:  <urn:ufo-sn3:case:rigidity:> .

ex:Person ufo:rigidity ufo:Rigid.
ex:Employee ufo:rigidity ufo:AntiRigid.
ex:alicePerson ufo:holdsIn ex:w2.
ex:Employee ufo:contingentFor ex:alice.

=== FILE: crates/sparq-conformance/tests/ufo_sn3/cases/identity/input.n3 ===
@prefix ufo: <urn:ufo-sn3:> .
@prefix ex:  <urn:ufo-sn3:case:identity:> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .

ex:Person a ufo:Kind;
    ufo:identityCriterion ex:personIdentity.

ex:Employee a ufo:Role;
    ufo:identityProvider ex:Person.

ex:personIdentity a ufo:IdentityCriterion;
    ufo:keyProperty ex:employeeNumber.

ex:w a ufo:World.

ex:aliceEmployee a ufo:Proposition;
    ufo:subj ex:alice;
    ufo:pred rdf:type;
    ufo:obj ex:Employee;
    ufo:holdsIn ex:w.

ex:aliceNumber a ufo:Proposition;
    ufo:subj ex:alice;
    ufo:pred ex:employeeNumber;
    ufo:obj "E-7";
    ufo:holdsIn ex:w.

ex:aliceRecordEmployee a ufo:Proposition;
    ufo:subj ex:aliceRecord;
    ufo:pred rdf:type;
    ufo:obj ex:Employee;
    ufo:holdsIn ex:w.

ex:aliceRecordNumber a ufo:Proposition;
    ufo:subj ex:aliceRecord;
    ufo:pred ex:employeeNumber;
    ufo:obj "E-7";
    ufo:holdsIn ex:w.

=== FILE: crates/sparq-conformance/tests/ufo_sn3/cases/identity/answer.n3 ===
@prefix ufo: <urn:ufo-sn3:> .
@prefix ex:  <urn:ufo-sn3:case:identity:> .

ex:Employee ufo:identityKey ex:employeeNumber.
ex:alice ufo:sameContinuant ex:aliceRecord.

=== FILE: crates/sparq-conformance/tests/ufo_sn3/cases/relator/input.n3 ===
@prefix ufo: <urn:ufo-sn3:> .
@prefix ex:  <urn:ufo-sn3:case:relator:> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

ex:w a ufo:World.

ex:employment a ufo:Relator;
    ufo:mediates ex:alice, ex:acme;
    ufo:existsIn ex:w.

ex:alice owl:differentFrom ex:acme.

ex:employmentStatement a ufo:Proposition;
    ufo:truthmaker ex:employment;
    ufo:subj ex:alice;
    ufo:pred ex:employedBy;
    ufo:obj ex:acme.

=== FILE: crates/sparq-conformance/tests/ufo_sn3/cases/relator/answer.n3 ===
@prefix ufo: <urn:ufo-sn3:> .
@prefix ex:  <urn:ufo-sn3:case:relator:> .

ex:employment ufo:existentiallyDependsOn ex:alice, ex:acme.
ex:alice ufo:existsIn ex:w.
ex:acme ufo:existsIn ex:w.
ex:employmentStatement ufo:holdsIn ex:w.

=== FILE: crates/sparq-conformance/tests/ufo_sn3/cases/event-participation/input.n3 ===
@prefix ufo: <urn:ufo-sn3:> .
@prefix ex:  <urn:ufo-sn3:case:event:> .

ex:w a ufo:World.
ex:work a ufo:Event.
ex:alice a ufo:Agent.

ex:aliceAtWork a ufo:Participation;
    ufo:event ex:work;
    ufo:participant ex:alice;
    ufo:participantRole ex:Worker;
    ufo:occursIn ex:w.

=== FILE: crates/sparq-conformance/tests/ufo_sn3/cases/event-participation/answer.n3 ===
@prefix ufo: <urn:ufo-sn3:> .
@prefix ex:  <urn:ufo-sn3:case:event:> .

ex:work ufo:hasParticipant ex:alice;
    ufo:existsIn ex:w.

ex:alice ufo:participatesIn ex:work;
    ufo:existsIn ex:w.

ex:aliceAtWork ufo:existsIn ex:w.

=== FILE: crates/sparq-conformance/tests/ufo_sn3/cases/disposition/input.n3 ===
@prefix ufo: <urn:ufo-sn3:> .
@prefix ex:  <urn:ufo-sn3:case:disposition:> .

ex:w a ufo:World.

ex:impactStatement a ufo:Proposition;
    ufo:subj ex:glass;
    ufo:pred ex:struckBy;
    ufo:obj ex:hammer;
    ufo:holdsIn ex:w.

ex:fragility a ufo:Disposition;
    ufo:inheresIn ex:glass;
    ufo:triggerCondition ex:impactStatement;
    ufo:manifestsIn ex:breaking;
    ufo:existsIn ex:w.

ex:breaking a ufo:Manifestation.

=== FILE: crates/sparq-conformance/tests/ufo_sn3/cases/disposition/answer.n3 ===
@prefix ufo: <urn:ufo-sn3:> .
@prefix ex:  <urn:ufo-sn3:case:disposition:> .

ex:fragility ufo:existentiallyDependsOn ex:glass;
    ufo:activatedIn ex:w.

ex:glass ufo:existsIn ex:w.

ex:breaking ufo:manifestationOf ex:fragility;
    ufo:occursIn ex:w.

