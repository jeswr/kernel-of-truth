{"architecture":{"frozen_components":["LLM parameters"],"mechanism_tags":["knowledge-encoding","retrieval-augmentation","modular-memory","plug-and-play"],"seam_cell":"text","summary":"MeMo encodes new domain-specific knowledge into a dedicated memory model while keeping the host LLM frozen. The memory model learns to represent cross-document relationships and is queried at inference time to retrieve relevant information, which is then passed to the frozen LLM as context. The system operates without access to LLM weights or logits, enabling integration with both open and proprietary models.","trained_components":["memory model"]},"biblio":{"authors":["Ryan Wei Heng Quek","Sanghyuk Lee","Alfred Wei Lun Leong","Arun Verma","Alok Prakash","Nancy F. Chen","Bryan Kian Hsiang Low","Daniela Rus","Armando Solar-Lezama"],"citation_count":{"as_of":"2026-07-09","source":"openalex","value":0},"title":"MeMo: Memory as a Model","venue":"arXiv (Cornell University)","year":2026},"claims":[{"baseline":null,"claim_id":"c1","compute_reported":false,"dataset":null,"evidence":"claimed","evidence_ref":null,"metric":null,"scale":null,"statement":"MeMo captures complex cross-document relationships","type":"qualitative","unit":null,"value":null},{"baseline":null,"claim_id":"c2","compute_reported":false,"dataset":null,"evidence":"claimed","evidence_ref":null,"metric":null,"scale":null,"statement":"MeMo is robust to retrieval noise","type":"qualitative","unit":null,"value":null},{"baseline":null,"claim_id":"c3","compute_reported":false,"dataset":null,"evidence":"claimed","evidence_ref":null,"metric":null,"scale":null,"statement":"MeMo avoids catastrophic forgetting in the LLM","type":"qualitative","unit":null,"value":null},{"baseline":null,"claim_id":"c4","compute_reported":false,"dataset":null,"evidence":"claimed","evidence_ref":null,"metric":null,"scale":null,"statement":"MeMo does not require access to the LLM's weights or output logits, enabling plug-and-play integration with both open and