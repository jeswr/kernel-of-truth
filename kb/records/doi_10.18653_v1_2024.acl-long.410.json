{"architecture":{"frozen_components":[],"mechanism_tags":["sft-warmup","ppo-rl","chain-of-thought","reasoning","math-problem-solving"],"seam_cell":"text","summary":"ReFT is a two-stage fine-tuning approach for reasoning in LLMs. Stage 1: Supervised Fine-Tuning (SFT) with Chain-of-Thought annotations warms up the model. Stage 2: on-line reinforcement learning via PPO samples multiple reasoning paths for each question and derives rewards from ground-truth answers, enabling the model to learn from diverse solution trajectories rather than single annotated paths.","trained_components":["language model parameters via SFT","language model parameters via PPO fine-tuning"]},"biblio":{"authors":["Luong Trung","Xinbo Zhang","Zhanming Jie","Peng Sun","Xiaoran Jin","Hang Li"],"citation_count":{"as_of":"2026-07-09","source":"openalex","value":26},"title":"ReFT: Reasoning with Reinforced Fine-Tuning","venue":null,"year":2024},"claims":[{"baseline":{"name":"SFT","value":null},"claim_id":"c1","compute_reported":false,"dataset":"GSM8K, MathQA, and SVAMP","evidence":"claimed","evidence_ref":null,"metric":null,"scale":null,"statement":"ReFT significantly outperforms SFT","type":"qualitative","unit":null,"value":null},{"baseline":{"name":"SFT","value":null},"claim_id":"c2","compute_reported":false,"dataset":null,"evidence":"claimed","evidence_ref":null,"metric":null,"scale":null,"statement":"ReFT obtains improvement by learning from the same training questions as SFT, without relying on extra or augmented training questions","type":"qualitative","unit":null,"value":null},{"baseline":null,"claim_id":"c3","compute_reported":false,"dataset":null,"evidence":"claimed","evidence_ref":null,"metric":null,"scale":null,"statement":"Performance can be potentially further boosted by combining inference-time strategies such as majority voting and re-ranking","type":"qualitative","unit":null,"value":null}],"id":"doi:10.18653/v1/2024.acl-long.410","identity":{"arxiv":null,"doi":"10.18653/v1/2024.acl-